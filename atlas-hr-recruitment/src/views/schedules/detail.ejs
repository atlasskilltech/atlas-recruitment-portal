<%
  const schedule = typeof locals.schedule !== 'undefined' ? locals.schedule : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const candidateName = schedule.candidate_name || (candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : (candidate.name || 'Unknown Candidate'));
  const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
  const candidateEmail = candidate.email || candidate.appln_email || '';
  const jobTitle = schedule.job_title || job.title || 'N/A';

  const mode = schedule.mode || 'offline';
  const modeBadge = mode === 'online' ? 'badge-info' : 'badge-muted';

  const schStatus = schedule.status || 'scheduled';
  const schStatusBadge = schStatus === 'scheduled' ? 'badge-scheduled'
    : schStatus === 'completed' ? 'badge-success'
    : schStatus === 'cancelled' ? 'badge-danger'
    : schStatus === 'rescheduled' ? 'badge-warning'
    : 'badge-muted';

  const panelMembers = schedule.panel_members || schedule.panelMembers || [];
  const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);

  const notes = schedule.notes || '';
%>

<!-- Back Button -->
<div class="mb-6">
  <a href="/schedules" class="btn-outline btn-sm inline-flex items-center gap-2">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Back to Schedules
  </a>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Schedule Details</h1>
    <p class="text-sm text-muted-foreground mt-1">View interview schedule information</p>
  </div>
  <span class="<%= schStatusBadge %> text-sm self-start sm:self-auto">
    <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
  </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Main Content (2/3) -->
  <div class="lg:col-span-2 space-y-6">

    <!-- Schedule Details Card -->
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center gap-2">
        <i data-lucide="calendar" class="w-5 h-5 text-primary-800 dark:text-primary-200"></i>
        Schedule Information
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Date -->
        <div>
          <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Date</p>
          <p class="text-sm font-medium text-foreground flex items-center gap-2">
            <i data-lucide="calendar" class="w-4 h-4 text-muted-foreground"></i>
            <% if (schedule.scheduled_date || schedule.date) { %>
              <%= new Date(schedule.scheduled_date || schedule.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
            <% } else { %>
              Not set
            <% } %>
          </p>
        </div>

        <!-- Time -->
        <div>
          <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Time</p>
          <p class="text-sm font-medium text-foreground flex items-center gap-2">
            <i data-lucide="clock" class="w-4 h-4 text-muted-foreground"></i>
            <%= schedule.scheduled_time || schedule.time || 'Not set' %>
          </p>
        </div>

        <!-- Mode -->
        <div>
          <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Interview Mode</p>
          <span class="<%= modeBadge %>">
            <% if (mode === 'online') { %>
              <i data-lucide="video" class="w-3 h-3"></i>
            <% } else { %>
              <i data-lucide="map-pin" class="w-3 h-3"></i>
            <% } %>
            <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
          </span>
        </div>

        <!-- Location / Meeting Link -->
        <div>
          <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">
            <%= mode === 'online' ? 'Meeting Link' : 'Location' %>
          </p>
          <% if (mode === 'online' && (schedule.meeting_link || schedule.meetingLink)) { %>
            <a href="<%= schedule.meeting_link || schedule.meetingLink %>" target="_blank"
               class="text-sm text-primary-400 hover:text-primary-300 hover:underline flex items-center gap-2">
              <i data-lucide="external-link" class="w-4 h-4"></i>
              Join Meeting
            </a>
          <% } else if (schedule.location) { %>
            <p class="text-sm font-medium text-foreground flex items-center gap-2">
              <i data-lucide="map-pin" class="w-4 h-4 text-muted-foreground"></i>
              <%= schedule.location %>
            </p>
          <% } else { %>
            <p class="text-sm text-muted-foreground">Not specified</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Panel Members Card -->
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
        <i data-lucide="users" class="w-5 h-5 text-purple-500"></i>
        Panel Members
      </h2>
      <% if (panelList.length > 0) { %>
        <div class="space-y-3">
          <% panelList.forEach(function(member, idx) { %>
            <div class="flex items-center gap-3 p-3 rounded-xl bg-muted/30">
              <div class="w-8 h-8 rounded-full bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center flex-shrink-0">
                <span class="text-xs font-semibold text-purple-700 dark:text-purple-300"><%= idx + 1 %></span>
              </div>
              <span class="text-sm font-medium text-foreground">
                <%= typeof member === 'string' ? member : (member.name || member) %>
              </span>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-muted-foreground">No panel members assigned.</p>
      <% } %>
    </div>

    <!-- Notes Card -->
    <% if (notes) { %>
      <div class="card p-6">
        <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
          <i data-lucide="file-text" class="w-5 h-5 text-muted-foreground"></i>
          Notes
        </h2>
        <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line bg-muted/30 rounded-xl p-4">
          <%= notes %>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Sidebar (1/3) -->
  <div class="space-y-6">

    <!-- Candidate Info Card -->
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
        <i data-lucide="user" class="w-5 h-5 text-muted-foreground"></i>
        Candidate
      </h2>
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
          <span class="text-lg font-bold text-primary-800 dark:text-primary-200"><%= initials %></span>
        </div>
        <div class="min-w-0">
          <p class="font-medium text-foreground truncate"><%= candidateName %></p>
          <% if (candidateEmail) { %>
            <p class="text-xs text-muted-foreground truncate"><%= candidateEmail %></p>
          <% } %>
        </div>
      </div>
      <div class="pt-3 border-t border-border">
        <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Applied For</p>
        <p class="text-sm font-medium text-foreground">
          <i data-lucide="briefcase" class="w-3.5 h-3.5 inline-block mr-1 text-muted-foreground"></i>
          <%= jobTitle %>
        </p>
      </div>
    </div>

    <!-- Status Card -->
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
        <i data-lucide="activity" class="w-5 h-5 text-muted-foreground"></i>
        Status
      </h2>
      <div class="flex items-center gap-2 mb-4">
        <span class="<%= schStatusBadge %> text-sm">
          <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
        </span>
      </div>
      <% if (schedule.created_at) { %>
        <div class="text-xs text-muted-foreground">
          <p>Created: <%= new Date(schedule.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
        </div>
      <% } %>
      <% if (schedule.updated_at) { %>
        <div class="text-xs text-muted-foreground mt-1">
          <p>Updated: <%= new Date(schedule.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
        </div>
      <% } %>
    </div>

    <!-- Action Buttons -->
    <div class="card p-6">
      <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
        <i data-lucide="settings" class="w-5 h-5 text-muted-foreground"></i>
        Actions
      </h2>
      <div class="space-y-2">
        <% if (schStatus === 'scheduled') { %>
          <a href="/schedules/<%= schedule.id %>/edit" class="btn-outline w-full justify-center">
            <i data-lucide="calendar-clock" class="w-4 h-4"></i>
            Reschedule
          </a>
          <form action="/schedules/<%= schedule.id %>/complete" method="POST">
            <button type="submit" class="btn-primary w-full justify-center">
              <i data-lucide="check-circle" class="w-4 h-4"></i>
              Mark Complete
            </button>
          </form>
          <form action="/schedules/<%= schedule.id %>/cancel" method="POST"
                onsubmit="return confirm('Are you sure you want to cancel this interview?')">
            <button type="submit" class="btn-outline w-full justify-center text-destructive border-destructive hover:bg-destructive hover:text-white">
              <i data-lucide="x-circle" class="w-4 h-4"></i>
              Cancel Interview
            </button>
          </form>
        <% } else { %>
          <p class="text-sm text-muted-foreground text-center py-2">
            No actions available for this status.
          </p>
        <% } %>
      </div>
    </div>
  </div>
</div>
