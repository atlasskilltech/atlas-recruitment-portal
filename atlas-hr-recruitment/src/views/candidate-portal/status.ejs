<%
  /* Layout override: use auth layout instead of main (no sidebar) */
  layout = 'layouts/auth';

  const application = typeof locals.application !== 'undefined' ? locals.application : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};

  const candidateName = candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : (candidate.name || application.appln_full_name || 'Candidate');
  const appStatus = (application.status || application.appln_status_new || 'applied').toLowerCase();

  /* Stepper stages matching the spec */
  const stages = [
    { key: 'applied',      label: 'Applied',       icon: 'file-text',    desc: 'Your application has been received' },
    { key: 'under_review', label: 'Under Review',   icon: 'search',       desc: 'Our team is reviewing your application' },
    { key: 'ai_screening', label: 'AI Screening',   icon: 'brain',        desc: 'AI-powered skills and qualifications analysis' },
    { key: 'interview',    label: 'Interview',      icon: 'monitor',      desc: 'Interview stage of the recruitment process' },
    { key: 'decision',     label: 'Decision',       icon: 'check-circle', desc: 'Final hiring decision' },
  ];

  /* Map various status values to stage index */
  const statusMap = {
    'new': 0, 'applied': 0,
    'under_review': 1, 'review': 1, 'reviewing': 1,
    'screening': 2, 'ai_screening': 2, 'eligible': 2, 'ai_eligible': 2,
    'interview': 3, 'interview_pending': 3, 'interview_passed': 3, 'interviewed': 3,
    'decision': 4, 'shortlisted': 4, 'selected': 4, 'hired': 4, 'offer_released': 4,
  };
  const currentStageIdx = statusMap[appStatus] != null ? statusMap[appStatus] : 0;
  const isRejected = appStatus === 'rejected' || appStatus === 'failed';
%>

<!-- Override: wider container for candidate portal -->
<style>
  .card { max-width: 100%; }
</style>

<!-- ═══════════════════════════════════════════════════════════════════════
     Application Status Header with Atlas University Branding
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="text-center mb-6">
  <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/30 mb-3">
    <i data-lucide="graduation-cap" class="w-6 h-6 text-primary-800 dark:text-primary-200"></i>
  </div>
  <h2 class="text-xl font-bold text-foreground">Application Status</h2>
  <p class="text-sm text-muted-foreground mt-1">Track your application progress at Atlas University</p>
</div>

<!-- Candidate Info -->
<% if (candidateName !== 'Candidate') { %>
  <div class="mb-6 p-4 rounded-xl bg-muted/30 border border-border">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
        <span class="text-sm font-bold text-primary-800 dark:text-primary-200">
          <%= candidateName.charAt(0).toUpperCase() %>
        </span>
      </div>
      <div class="min-w-0 flex-1">
        <p class="text-sm font-semibold text-foreground truncate"><%= candidateName %></p>
        <% if (application.job_title || (application.job && application.job.title)) { %>
          <p class="text-xs text-muted-foreground">
            <i data-lucide="briefcase" class="w-3 h-3 inline-block mr-1"></i>
            <%= application.job_title || application.job.title %>
          </p>
        <% } %>
      </div>
    </div>
  </div>
<% } %>

<!-- ═══════════════════════════════════════════════════════════════════════
     Status Stepper: Applied -> Under Review -> AI Screening -> Interview -> Decision
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="mb-6">
  <div class="relative">
    <% stages.forEach(function(stage, idx) { %>
      <%
        const isCompleted = idx < currentStageIdx;
        const isCurrent = idx === currentStageIdx;
        const isFuture = idx > currentStageIdx;

        let stepCircleClass, iconColorClass, labelClass;
        if (isRejected && isCurrent) {
          stepCircleClass = 'bg-red-500 text-white ring-4 ring-red-500/20';
          iconColorClass = 'text-white';
          labelClass = 'text-red-600 dark:text-red-400 font-semibold';
        } else if (isCompleted) {
          stepCircleClass = 'bg-green-500 text-white';
          iconColorClass = 'text-white';
          labelClass = 'text-foreground';
        } else if (isCurrent) {
          stepCircleClass = 'bg-primary-800 dark:bg-primary-600 text-white ring-4 ring-primary-800/20 dark:ring-primary-600/20';
          iconColorClass = 'text-white';
          labelClass = 'text-foreground font-semibold';
        } else {
          stepCircleClass = 'bg-muted text-muted-foreground';
          iconColorClass = 'text-muted-foreground';
          labelClass = 'text-muted-foreground';
        }
      %>
      <div class="flex items-start gap-3 <%= idx < stages.length - 1 ? 'mb-1' : '' %>">
        <div class="flex flex-col items-center">
          <!-- Step Circle -->
          <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300 <%= stepCircleClass %>">
            <% if (isCompleted) { %>
              <i data-lucide="check" class="w-4 h-4 <%= iconColorClass %>"></i>
            <% } else if (isRejected && isCurrent) { %>
              <i data-lucide="x" class="w-4 h-4 <%= iconColorClass %>"></i>
            <% } else { %>
              <i data-lucide="<%= stage.icon %>" class="w-4 h-4 <%= iconColorClass %>"></i>
            <% } %>
          </div>
          <!-- Connector Line -->
          <% if (idx < stages.length - 1) { %>
            <div class="w-0.5 h-6 <%= isCompleted ? 'bg-green-500' : 'bg-border' %>"></div>
          <% } %>
        </div>
        <div class="pt-1">
          <p class="text-sm <%= labelClass %>">
            <%= stage.label %>
            <% if (isCurrent && !isRejected) { %>
              <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xxs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-200">
                Current
              </span>
            <% } %>
            <% if (isRejected && isCurrent) { %>
              <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xxs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">
                Rejected
              </span>
            <% } %>
          </p>
          <p class="text-xs text-muted-foreground mt-0.5"><%= stage.desc %></p>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Coming Soon Message
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="p-4 rounded-xl bg-blue-50/50 dark:bg-blue-950/20 border border-blue-200 dark:border-blue-800/30 mb-6">
  <div class="flex items-start gap-3">
    <div class="w-8 h-8 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center flex-shrink-0">
      <i data-lucide="info" class="w-4 h-4 text-blue-600 dark:text-blue-400"></i>
    </div>
    <div>
      <p class="text-sm font-medium text-blue-800 dark:text-blue-200">More features coming soon</p>
      <p class="text-xs text-blue-700/70 dark:text-blue-300/60 mt-1">
        The full candidate portal with document uploads, interview preparation tools, and real-time messaging is currently under development. Stay tuned for updates.
      </p>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Contact Information
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="p-4 rounded-xl bg-muted/30 border border-border">
  <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
    <i data-lucide="help-circle" class="w-4 h-4 text-muted-foreground"></i>
    Have questions about your application?
  </h3>
  <div class="space-y-2">
    <div class="flex items-center gap-2 text-sm">
      <i data-lucide="mail" class="w-3.5 h-3.5 text-muted-foreground flex-shrink-0"></i>
      <span class="text-foreground">hr@atlasuniversity.edu</span>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <i data-lucide="phone" class="w-3.5 h-3.5 text-muted-foreground flex-shrink-0"></i>
      <span class="text-foreground">+1 (555) 012-3456</span>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <i data-lucide="map-pin" class="w-3.5 h-3.5 text-muted-foreground flex-shrink-0"></i>
      <span class="text-foreground">Atlas University, HR Department, Main Campus</span>
    </div>
  </div>
</div>

<!-- Footer Link -->
<div class="text-center mt-6">
  <a href="/auth/login" class="text-sm text-primary-400 hover:text-primary-300 font-medium transition-colors">
    <i data-lucide="arrow-left" class="w-3.5 h-3.5 inline-block mr-1"></i>
    Back to Login
  </a>
</div>
