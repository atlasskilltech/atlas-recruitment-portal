# atlas-hr-recruitment
# ===========================================
# Atlas HR Recruitment Portal - Environment
# ===========================================

# App Configuration
NODE_ENV=development
PORT=3000
APP_NAME="Atlas HR Recruitment Portal"
APP_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=atlas_recruitment
DB_CONNECTION_LIMIT=10

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-this
SESSION_MAX_AGE=86400000

# JWT Configuration (for interview tokens)
JWT_SECRET=your-jwt-secret-for-interview-tokens
JWT_EXPIRES_IN=72h

# File Upload Base URL (existing server)
UPLOAD_BASE_URL=https://www.atlasuniversity.edu.in/careers/uploads/

# AI Provider Configuration
# Supported: openai, azure, openrouter, mock
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=gpt-4
AI_BASE_URL=

# Azure OpenAI (if AI_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# OpenRouter (if AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-opus

# Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Atlas HR <hr@atlasuniversity.edu.in>"

# SMS / WhatsApp (placeholders)
SMS_PROVIDER=
SMS_API_KEY=
WHATSAPP_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
