<div class="text-center mb-6">
  <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-50 dark:bg-blue-900/20 rounded-full mb-3">
    <i data-lucide="shield-check" class="w-6 h-6 text-blue-600 dark:text-blue-400"></i>
  </div>
  <h2 class="text-xl font-bold text-foreground">Verify OTP</h2>
  <p class="text-sm text-muted-foreground mt-1">Enter the 6-digit code sent to</p>
  <p class="text-sm font-medium text-foreground"><%= typeof email !== 'undefined' ? email : '' %></p>
</div>

<form action="/candidate/verify-otp" method="POST" class="space-y-5">
  <div class="form-group">
    <label for="otp" class="form-label">One-Time Password</label>
    <input type="text" id="otp" name="otp" required maxlength="6" pattern="[0-9]{6}"
      class="form-input text-center text-2xl tracking-[0.5em] font-mono"
      placeholder="000000" autocomplete="one-time-code" inputmode="numeric">
  </div>

  <button type="submit" class="btn-primary w-full py-3 text-base font-semibold">
    <i data-lucide="check" class="w-5 h-5"></i>
    Verify & Login
  </button>
</form>

<div class="mt-5 text-center space-y-2">
  <form action="/candidate/send-otp" method="POST" class="inline">
    <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
    <button type="submit" class="text-sm text-primary-800 dark:text-primary-200 hover:underline">
      Resend OTP
    </button>
  </form>
  <p class="text-xs text-muted-foreground">OTP is valid for 10 minutes</p>
  <a href="/candidate/login" class="text-xs text-muted-foreground hover:text-foreground transition-colors block">
    Use a different email
  </a>
</div>
