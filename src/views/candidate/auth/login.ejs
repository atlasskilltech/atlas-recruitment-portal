<div class="text-center mb-6">
  <h2 class="text-xl font-bold text-foreground">Welcome Back</h2>
  <p class="text-sm text-muted-foreground mt-1">Enter your application email to continue</p>
</div>

<form action="/candidate/send-otp" method="POST" class="space-y-5">
  <div class="form-group">
    <label for="email" class="form-label">Email Address</label>
    <div class="relative">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <i data-lucide="mail" class="w-4 h-4 text-muted-foreground"></i>
      </div>
      <input type="email" id="email" name="email" required autocomplete="email"
        class="form-input pl-11" placeholder="your.email@example.com">
    </div>
  </div>

  <button type="submit" class="btn-primary w-full py-3 text-base font-semibold">
    <i data-lucide="send" class="w-5 h-5"></i>
    Send OTP
  </button>
</form>

<div class="mt-6 pt-5 border-t border-border text-center">
  <p class="text-xs text-muted-foreground">
    Enter the email you used for your job application.
    <br>We'll send a one-time password to verify your identity.
  </p>
</div>
