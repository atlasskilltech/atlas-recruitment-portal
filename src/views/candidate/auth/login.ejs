<style>
  @keyframes cardEntrance {
    0% { opacity: 0; transform: translateY(20px) scale(0.97); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .login-card-animate {
    animation: cardEntrance 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<div class="login-card-animate">
  <!-- Logo & Branding -->
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-brand rounded-2xl mb-4 shadow-brand">
      <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Candidate Portal</h1>
    <p class="text-muted-foreground text-sm mt-1">Sign in with your application email</p>
  </div>

  <!-- Login Form -->
  <form action="/candidate/send-otp" method="POST" class="space-y-5">
    <!-- Email -->
    <div class="form-group">
      <label for="email" class="form-label">Email Address</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
          <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="form-input pl-11" placeholder="your.email@example.com">
      </div>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn-primary w-full py-3 text-base font-semibold">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
      </svg>
      Send OTP
    </button>
  </form>

  <!-- Footer -->
  <div class="mt-8 pt-6 border-t border-border text-center">
    <p class="text-xs text-muted-foreground">
      Enter the email used in your job application.
      <br>We'll send a one-time password to verify your identity.
    </p>
  </div>
</div>
