<style>
  @keyframes cardEntrance {
    0% { opacity: 0; transform: translateY(20px) scale(0.97); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }
  .login-card-animate {
    animation: cardEntrance 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<div class="login-card-animate">
  <!-- Logo & Branding -->
  <div class="login-logo">
    <div class="logo-icon" style="width:56px;height:56px;font-size:1.5rem;margin:0 auto 12px;border-radius:14px;">
      <svg style="width:28px;height:28px;color:white;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
    </div>
    <h2>Candidate Portal</h2>
    <p>Sign in with your application email</p>
  </div>

  <!-- Flash Messages -->
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-error mb-md">
      <span class="text-sm"><%= Array.isArray(error) ? error[0] : error %></span>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success mb-md">
      <span class="text-sm"><%= Array.isArray(success) ? success[0] : success %></span>
    </div>
  <% } %>

  <!-- Login Form -->
  <form action="/candidate/send-otp" method="POST">
    <!-- Email -->
    <div class="form-group">
      <label for="email" class="form-label">Email Address</label>
      <div style="position:relative;">
        <div style="position:absolute;top:50%;left:14px;transform:translateY(-50%);pointer-events:none;">
          <svg style="width:16px;height:16px;color:var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <input type="email" id="email" name="email" required autocomplete="email"
          class="form-input" style="padding-left:40px;" placeholder="your.email@example.com">
      </div>
    </div>

    <!-- Submit Button -->
    <button type="submit" class="btn btn-primary btn-lg w-full font-semibold">
      <svg style="width:18px;height:18px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
      </svg>
      Send OTP
    </button>
  </form>

  <!-- Footer -->
  <div class="border-t" style="margin-top:24px;padding-top:20px;">
    <p class="text-xs text-muted text-center">
      Enter the email used in your job application.
      <br>We'll send a one-time password to verify your identity.
    </p>
  </div>
</div>
