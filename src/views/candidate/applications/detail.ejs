<%
  const a = typeof app !== 'undefined' ? app : {};
  const docs = typeof documents !== 'undefined' ? documents : [];
  const si = typeof statusInfo !== 'undefined' ? statusInfo : { stages: [], currentStageIndex: 0 };
%>

<!-- Back -->
<div class="mb-md">
  <a href="/candidate/applications" class="flex items-center gap-sm text-sm text-secondary" style="text-decoration:none;">
    <i data-lucide="arrow-left" style="width:16px;height:16px;"></i> Back to Applications
  </a>
</div>

<!-- Header -->
<div class="card mb-lg">
  <div class="card-body flex justify-between" style="flex-wrap:wrap;gap:12px;">
    <div>
      <h1 class="text-xl font-bold"><%= a.job_title || 'Applied Position' %></h1>
      <div class="flex items-center gap-md mt-sm text-sm text-secondary" style="flex-wrap:wrap;">
        <% if (a.appln_id) { %><span>Application ID: <strong><%= a.appln_id %></strong></span><% } %>
        <% if (a.job_location) { %><span class="flex items-center gap-sm"><i data-lucide="map-pin" style="width:12px;height:12px;display:inline;"></i> <%= a.job_location %></span><% } %>
        <span>Applied: <%= a.appln_date ? new Date(a.appln_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) : '--' %></span>
      </div>
    </div>
    <span class="badge <%= si.isRejected ? 'badge-danger' : 'badge-info' %>" style="align-self:flex-start;padding:6px 14px;font-size:0.85rem;">
      <%= si.friendlyStatus %>
    </span>
  </div>
</div>

<!-- Status Stepper -->
<div class="card mb-lg">
  <div class="card-body">
    <h2 class="font-semibold mb-md">Application Progress</h2>
    <div class="flex items-center">
      <% si.stages.forEach(function(stage, idx) { %>
        <div style="flex:1;text-align:center;position:relative;">
          <div style="margin:0 auto;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;
            <% if (idx < si.currentStageIndex) { %>background:var(--accent-secondary);color:white;
            <% } else if (idx === si.currentStageIndex) { %>background:<%= si.isRejected ? 'var(--accent-danger)' : 'var(--accent-secondary)' %>;color:white;box-shadow:0 0 0 4px <%= si.isRejected ? 'rgba(239,68,68,0.2)' : 'rgba(59,130,246,0.2)' %>;
            <% } else { %>background:var(--bg-tertiary);color:var(--text-muted);
            <% } %>">
            <% if (idx < si.currentStageIndex) { %>
              <i data-lucide="check" style="width:18px;height:18px;"></i>
            <% } else if (si.isRejected && idx === si.currentStageIndex) { %>
              <i data-lucide="x" style="width:18px;height:18px;"></i>
            <% } else { %>
              <i data-lucide="<%= stage.icon %>" style="width:16px;height:16px;"></i>
            <% } %>
          </div>
          <p class="text-xs" style="margin-top:8px;<%= idx <= si.currentStageIndex ? 'font-weight:500;color:var(--text-primary);' : 'color:var(--text-muted);' %>">
            <%= stage.label %>
          </p>
        </div>
        <% if (idx < si.stages.length - 1) { %>
          <div style="flex:1;height:2px;margin-top:-20px;background:<%= idx < si.currentStageIndex ? 'var(--accent-secondary)' : 'var(--border-color)' %>;"></div>
        <% } %>
      <% }); %>
    </div>
  </div>
</div>

<div class="grid-2">
  <!-- AI Screening -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="brain"></i> AI Screening
      </h2>
    </div>
    <div class="card-body">
      <% if (a.ai_status) { %>
        <div class="flex justify-between items-center mb-md">
          <span class="text-sm text-secondary">Status</span>
          <span class="text-sm font-medium <%= String(a.ai_status).toLowerCase() === 'eligible' ? 'text-success' : String(a.ai_status).toLowerCase() === 'rejected' ? 'text-danger' : 'text-warning' %>">
            <%= String(a.ai_status).charAt(0).toUpperCase() + String(a.ai_status).slice(1) %>
          </span>
        </div>
        <% if (a.ai_match_score) { %>
          <div class="flex justify-between items-center mb-sm">
            <span class="text-sm text-secondary">Match Score</span>
            <span class="text-sm font-bold"><%= a.ai_match_score %>%</span>
          </div>
          <div class="progress-bar mb-md">
            <div class="progress-fill <%= a.ai_match_score >= 75 ? 'green' : a.ai_match_score >= 50 ? 'yellow' : 'red' %>"
                 style="width: <%= Math.min(a.ai_match_score, 100) %>%"></div>
          </div>
        <% } %>
        <% if (a.role_fit_summary) { %>
          <div class="mt-md">
            <p class="text-xs text-muted mb-sm">Summary</p>
            <p class="text-sm"><%= a.role_fit_summary %></p>
          </div>
        <% } %>
      <% } else { %>
        <p class="text-sm text-secondary">AI screening has not been completed yet.</p>
      <% } %>
    </div>
  </div>

  <!-- AI Interview -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="message-square"></i> AI Interview
      </h2>
    </div>
    <div class="card-body">
      <% if (a.interview_status) { %>
        <div class="flex justify-between items-center mb-md">
          <span class="text-sm text-secondary">Status</span>
          <span class="text-sm font-medium"><%= String(a.interview_status).charAt(0).toUpperCase() + String(a.interview_status).slice(1) %></span>
        </div>
        <% if (a.interview_score) { %>
          <div class="flex justify-between items-center mb-md">
            <span class="text-sm text-secondary">Score</span>
            <span class="text-sm font-bold"><%= a.interview_score %>/100</span>
          </div>
        <% } %>
        <% if (['invited', 'pending'].includes(String(a.interview_status).toLowerCase()) && a.invitation_token) { %>
          <a href="/ai/interview/<%= a.invitation_token %>" class="btn btn-primary w-full mt-md">
            <i data-lucide="play" style="width:16px;height:16px;"></i> Start AI Interview
          </a>
        <% } %>
      <% } else { %>
        <p class="text-sm text-secondary">No AI interview scheduled yet.</p>
      <% } %>
    </div>
  </div>

  <!-- Schedule -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="calendar"></i> Interview Schedule
      </h2>
    </div>
    <div class="card-body">
      <% if (a.scheduled_date) { %>
        <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
          <span class="text-secondary">Date</span>
          <span class="font-medium"><%= new Date(a.scheduled_date).toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric', year:'numeric'}) %></span>
        </div>
        <% if (a.scheduled_time) { %>
          <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
            <span class="text-secondary">Time</span><span class="font-medium"><%= a.scheduled_time %></span>
          </div>
        <% } %>
        <% if (a.schedule_mode) { %>
          <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
            <span class="text-secondary">Mode</span><span class="font-medium"><%= a.schedule_mode === 'online' ? 'Online' : 'In-Person' %></span>
          </div>
        <% } %>
        <% if (a.schedule_location) { %>
          <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
            <span class="text-secondary">Location</span><span class="font-medium"><%= a.schedule_location %></span>
          </div>
        <% } %>
        <% if (a.meeting_link) { %>
          <a href="<%= a.meeting_link %>" target="_blank" class="btn btn-primary w-full mt-md">
            <i data-lucide="video" style="width:16px;height:16px;"></i> Join Meeting
          </a>
        <% } %>
      <% } else { %>
        <p class="text-sm text-secondary">No interview scheduled yet.</p>
      <% } %>
    </div>
  </div>

  <!-- Documents -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="folder"></i> Documents
      </h2>
    </div>
    <div class="card-body">
      <% docs.forEach(function(doc) { %>
        <div class="flex items-center justify-between" style="padding:8px 0;border-bottom:1px solid var(--border-light);">
          <div class="flex items-center gap-sm">
            <i data-lucide="<%= doc.available ? 'file-check' : 'file-x' %>"
               style="width:16px;height:16px;color:<%= doc.available ? 'var(--accent-primary)' : 'var(--text-muted)' %>;"></i>
            <span class="text-sm" style="color:<%= doc.available ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%= doc.type %></span>
          </div>
          <% if (doc.available && doc.url) { %>
            <a href="<%= doc.url %>" target="_blank" class="text-xs text-accent">View</a>
          <% } else { %>
            <span class="text-xs text-muted">Not uploaded</span>
          <% } %>
        </div>
      <% }); %>
    </div>
  </div>
</div>
