<%
  const apps = typeof applications !== 'undefined' ? applications : [];
%>

<div class="mb-lg">
  <h1 class="text-2xl font-bold">My Applications</h1>
  <p class="text-sm text-secondary mt-sm"><%= apps.length %> application(s) found</p>
</div>

<% if (apps.length === 0) { %>
  <div class="card">
    <div class="empty-state">
      <i data-lucide="inbox"></i>
      <p class="font-semibold text-lg" style="color:var(--text-primary);margin-bottom:4px;">No Applications</p>
      <p>No applications are linked to your email address.</p>
    </div>
  </div>
<% } else { %>
  <div class="flex flex-col gap-md">
    <% apps.forEach(function(app) { %>
      <a href="/candidate/applications/<%= app.id %>" class="card" style="display:block;padding:20px 24px;text-decoration:none;color:inherit;transition:box-shadow var(--transition-fast);"
         onmouseover="this.style.boxShadow='var(--shadow-md)'" onmouseout="this.style.boxShadow='var(--shadow-sm)'">
        <div class="flex justify-between items-center gap-md" style="flex-wrap:wrap;">
          <div class="min-w-0" style="flex:1;">
            <div class="flex items-center gap-sm mb-sm">
              <h3 class="font-semibold truncate"><%= app.job_title || 'Applied Position' %></h3>
              <% if (app.job_location) { %>
                <span class="text-xs text-muted"><%= app.job_location %></span>
              <% } %>
            </div>
            <div class="flex items-center gap-md text-xs text-muted" style="flex-wrap:wrap;">
              <% if (app.appln_id) { %><span>ID: <%= app.appln_id %></span><% } %>
              <span>Applied: <%= app.appln_date ? new Date(app.appln_date).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '--' %></span>
              <% if (app.ai_match_score) { %><span>AI Score: <%= app.ai_match_score %>%</span><% } %>
            </div>
          </div>
          <div class="flex items-center gap-sm">
            <span class="badge <%= app.statusInfo.isRejected ? 'badge-danger' : 'badge-info' %>">
              <%= app.statusInfo.friendlyStatus %>
            </span>
            <i data-lucide="chevron-right" style="width:16px;height:16px;color:var(--text-muted);"></i>
          </div>
        </div>
        <!-- Progress bar -->
        <div class="flex gap-sm" style="margin-top:14px;">
          <% app.statusInfo.stages.forEach(function(stage, idx) { %>
            <div class="progress-bar" style="flex:1;height:6px;">
              <div class="progress-fill <%= idx <= app.statusInfo.currentStageIndex ? (app.statusInfo.isRejected && idx === app.statusInfo.currentStageIndex ? 'red' : 'green') : '' %>"
                   style="width:<%= idx <= app.statusInfo.currentStageIndex ? '100' : '0' %>%;"></div>
            </div>
          <% }); %>
        </div>
        <div class="flex justify-between" style="margin-top:6px;">
          <% app.statusInfo.stages.forEach(function(stage, idx) { %>
            <span class="text-xs text-muted text-center" style="flex:1;font-size:0.65rem;<%= idx <= app.statusInfo.currentStageIndex ? 'font-weight:500;' : '' %>">
              <%= stage.label.split(' ').slice(0,2).join(' ') %>
            </span>
          <% }); %>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>
