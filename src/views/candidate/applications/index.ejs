<%
  const apps = typeof applications !== 'undefined' ? applications : [];
%>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-foreground">My Applications</h1>
  <p class="text-sm text-muted-foreground mt-1"><%= apps.length %> application(s) found</p>
</div>

<% if (apps.length === 0) { %>
  <div class="card p-12 text-center">
    <i data-lucide="inbox" class="w-12 h-12 text-muted-foreground mx-auto mb-4"></i>
    <h3 class="text-lg font-semibold text-foreground mb-1">No Applications</h3>
    <p class="text-sm text-muted-foreground">No applications are linked to your email address.</p>
  </div>
<% } else { %>
  <div class="space-y-4">
    <% apps.forEach(function(app) { %>
      <a href="/candidate/applications/<%= app.id %>" class="card block p-5 hover:shadow-md transition-shadow">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-semibold text-foreground truncate"><%= app.job_title || 'Applied Position' %></h3>
              <% if (app.job_location) { %>
                <span class="text-xs text-muted-foreground hidden sm:inline"><%= app.job_location %></span>
              <% } %>
            </div>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground">
              <% if (app.appln_id) { %><span>ID: <%= app.appln_id %></span><% } %>
              <span>Applied: <%= app.appln_date ? new Date(app.appln_date).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '--' %></span>
              <% if (app.ai_match_score) { %><span>AI Score: <%= app.ai_match_score %>%</span><% } %>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium
              <%= app.statusInfo.isRejected ? 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300' : 'bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300' %>">
              <%= app.statusInfo.friendlyStatus %>
            </span>
            <i data-lucide="chevron-right" class="w-4 h-4 text-muted-foreground"></i>
          </div>
        </div>
        <!-- Progress bar -->
        <div class="flex gap-1 mt-4">
          <% app.statusInfo.stages.forEach(function(stage, idx) { %>
            <div class="h-1.5 flex-1 rounded-full
              <%= idx <= app.statusInfo.currentStageIndex
                ? (app.statusInfo.isRejected && idx === app.statusInfo.currentStageIndex ? 'bg-red-500' : 'bg-blue-600')
                : 'bg-border' %>"></div>
          <% }); %>
        </div>
        <div class="flex justify-between mt-1.5">
          <% app.statusInfo.stages.forEach(function(stage, idx) { %>
            <span class="text-[10px] text-muted-foreground text-center flex-1 <%= idx <= app.statusInfo.currentStageIndex ? 'font-medium' : '' %>">
              <%= stage.label.split(' ').slice(0,2).join(' ') %>
            </span>
          <% }); %>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>
