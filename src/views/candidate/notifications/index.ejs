<%
  const notifs = typeof notifications !== 'undefined' ? notifications : [];
%>

<div class="mb-lg">
  <h1 class="text-2xl font-bold">Notifications</h1>
  <p class="text-sm text-secondary mt-sm"><%= notifs.length %> notification(s)</p>
</div>

<% if (notifs.length === 0) { %>
  <div class="card">
    <div class="empty-state">
      <i data-lucide="bell-off"></i>
      <p class="font-semibold text-lg" style="color:var(--text-primary);margin-bottom:4px;">No Notifications</p>
      <p>You'll be notified about updates to your applications.</p>
    </div>
  </div>
<% } else { %>
  <div class="flex flex-col gap-md">
    <% notifs.forEach(function(n) { %>
      <div class="card flex gap-md" style="padding:16px 24px;">
        <div class="stat-icon blue shrink-0" style="width:40px;height:40px;border-radius:50%;">
          <i data-lucide="<%= n.type === 'interview' ? 'message-square' : n.type === 'schedule' ? 'calendar' : 'bell' %>"
             style="width:18px;height:18px;"></i>
        </div>
        <div class="min-w-0" style="flex:1;">
          <p class="text-sm font-medium"><%= n.title || 'Notification' %></p>
          <p class="text-sm text-secondary" style="margin-top:4px;"><%= n.message %></p>
          <p class="text-xs text-muted" style="margin-top:6px;"><%= n.created_at ? new Date(n.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '' %></p>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
