<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>ATLAS Skilltech University - Candidate Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <%- style %>
</head>
<body class="min-h-screen">
  <div class="min-h-screen flex items-center justify-center p-4 relative overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-indigo-950">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-blue-500/10 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-indigo-400/10 blur-3xl"></div>
    </div>
    <div class="relative z-10 w-full max-w-md">
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-sm mb-4">
          <i data-lucide="graduation-cap" class="w-8 h-8 text-blue-300"></i>
        </div>
        <h1 class="text-2xl font-bold text-white">Candidate Portal</h1>
        <p class="text-sm text-white/60 mt-1">ATLAS Skilltech University</p>
      </div>

      <% if (typeof error !== 'undefined') { %>
        <% const errs = Array.isArray(error) ? error : [error]; %>
        <% errs.forEach(function(msg) { %>
          <% if (msg && msg.length > 0) { %>
            <div class="mb-3 p-3 rounded-xl bg-red-500/20 border border-red-500/30 text-red-200 text-sm flex items-center gap-2">
              <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i>
              <span><%= msg %></span>
            </div>
          <% } %>
        <% }); %>
      <% } %>
      <% if (typeof success !== 'undefined') { %>
        <% const succs = Array.isArray(success) ? success : [success]; %>
        <% succs.forEach(function(msg) { %>
          <% if (msg && msg.length > 0) { %>
            <div class="mb-3 p-3 rounded-xl bg-green-500/20 border border-green-500/30 text-green-200 text-sm flex items-center gap-2">
              <i data-lucide="check-circle" class="w-4 h-4 flex-shrink-0"></i>
              <span><%= msg %></span>
            </div>
          <% } %>
        <% }); %>
      <% } %>

      <div class="card shadow-2xl">
        <%- body %>
      </div>

      <div class="mt-6 text-center">
        <a href="/login" class="text-xs text-white/40 hover:text-white/60 transition-colors">HR Portal Login</a>
      </div>
      <p class="text-center text-xs text-white/40 mt-4">&copy; <%= new Date().getFullYear() %> ATLAS Skilltech University. All rights reserved.</p>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script>document.addEventListener('DOMContentLoaded', function() { lucide.createIcons(); });</script>
  <%- script %>
</body>
</html>
