<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Candidate Portal - ATLAS SkillTech University</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/atlas-theme.css">
  <%- style %>
</head>
<body>
  <div class="login-page">
    <!-- Auth card container -->
    <div style="position:relative;z-index:10;width:100%;max-width:420px;">

      <!-- Flash messages -->
      <% if (typeof success !== 'undefined' || typeof error !== 'undefined') { %>
        <div style="margin-bottom:16px;">
          <%
            const authAlertTypes = [
              { key: 'success', cls: 'alert-success', icon: 'check-circle' },
              { key: 'error', cls: 'alert-error', icon: 'alert-circle' },
            ];
          %>
          <% authAlertTypes.forEach(function(alert) { %>
            <% const msgs = typeof locals[alert.key] !== 'undefined' ? (Array.isArray(locals[alert.key]) ? locals[alert.key] : [locals[alert.key]]) : []; %>
            <% msgs.forEach(function(msg) { %>
              <% if (msg && msg.length > 0) { %>
                <div class="alert <%= alert.cls %>" data-auto-dismiss>
                  <i data-lucide="<%= alert.icon %>"></i>
                  <span style="flex:1;"><%= msg %></span>
                  <button class="alert-close" onclick="this.parentElement.remove()"><i data-lucide="x" style="width:14px;height:14px;"></i></button>
                </div>
              <% } %>
            <% }); %>
          <% }); %>
        </div>
      <% } %>

      <!-- Page content -->
      <div class="login-card">
        <%- body %>
      </div>

      <!-- Footer links -->
      <div class="login-footer" style="margin-top:20px;">
        <a href="/login" style="color:rgba(255,255,255,0.5);font-size:0.8rem;">HR Portal Login</a>
        <p style="color:rgba(255,255,255,0.5);margin-top:8px;">
          &copy; <%= new Date().getFullYear() %> ATLAS SkillTech University. All rights reserved.
        </p>
      </div>
    </div>
  </div>

  <!-- Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();

      // Auto-dismiss alerts
      document.querySelectorAll('.alert[data-auto-dismiss]').forEach(function(el) {
        setTimeout(function() { el.style.opacity = '0'; el.style.transform = 'translateY(-8px)'; setTimeout(function() { el.remove(); }, 300); }, 5000);
      });
    });
  </script>
  <%- script %>
</body>
</html>
