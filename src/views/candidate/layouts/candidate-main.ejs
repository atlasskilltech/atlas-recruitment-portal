<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Candidate Portal - ATLAS SkillTech University</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/atlas-theme.css">
  <%- style %>
</head>
<body>
  <%
    const candidateNav = [
      { path: '/candidate/dashboard', icon: 'layout-dashboard', label: 'Dashboard' },
      { path: '/candidate/applications', icon: 'file-text', label: 'My Applications' },
      { path: '/candidate/profile', icon: 'user', label: 'My Profile' },
      { path: '/candidate/notifications', icon: 'bell', label: 'Notifications' },
      { path: '/candidate/help', icon: 'help-circle', label: 'Help & Support' },
    ];
    const currentPath = typeof locals.currentPath !== 'undefined' ? locals.currentPath : '';
    const cand = typeof candidate !== 'undefined' ? candidate : (typeof locals.candidate !== 'undefined' ? locals.candidate : null);
  %>

  <div class="app-container">
    <!-- Sidebar overlay -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo-icon">
          <i data-lucide="graduation-cap" style="width:18px;height:18px;"></i>
        </div>
        <div>
          <div class="logo-text">Candidate Portal</div>
          <div class="logo-sub">ATLAS SkillTech</div>
        </div>
        <button class="sidebar-close" id="sidebar-close">
          <i data-lucide="x"></i>
        </button>
      </div>

      <nav class="sidebar-nav">
        <div class="nav-section">
          <% candidateNav.forEach(function(item) { %>
            <a href="<%= item.path %>"
               class="nav-tab <%= currentPath === item.path || (item.path !== '/candidate/dashboard' && currentPath && currentPath.startsWith(item.path)) ? 'active' : '' %>">
              <i data-lucide="<%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }); %>
        </div>
      </nav>

      <div class="sidebar-footer">
        <% if (cand) { %>
          <div class="sidebar-user" style="margin-bottom:12px;">
            <div class="sidebar-user-avatar" style="width:32px;height:32px;font-size:0.75rem;">
              <%= (cand.name || 'C').charAt(0).toUpperCase() %>
            </div>
            <div class="sidebar-user-info">
              <div class="sidebar-user-name" style="font-size:0.85rem;"><%= cand.name || 'Candidate' %></div>
              <div style="font-size:0.7rem;color:rgba(255,255,255,0.5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= cand.email %></div>
            </div>
          </div>
        <% } %>
        <a href="/candidate/logout" class="nav-tab" style="padding:8px 24px;font-size:0.8rem;">
          <i data-lucide="log-out" style="width:14px;height:14px;"></i>
          Sign Out
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <div class="main-content">
      <!-- Top bar -->
      <header class="main-header">
        <div class="header-left" style="display:flex;align-items:center;gap:16px;">
          <button class="hamburger-btn" id="hamburger-btn">
            <i data-lucide="menu"></i>
          </button>
          <h1 style="font-size:1.1rem;"><%= typeof title !== 'undefined' ? title : '' %></h1>
        </div>
        <div class="header-right"></div>
      </header>

      <!-- Flash messages -->
      <% if (typeof success !== 'undefined' || typeof error !== 'undefined') { %>
        <div style="padding:16px 24px 0;">
          <%
            const flashTypes = [
              { key: 'success', cls: 'alert-success', icon: 'check-circle' },
              { key: 'error', cls: 'alert-error', icon: 'alert-circle' }
            ];
          %>
          <% flashTypes.forEach(function(ft) { %>
            <% const msgs = typeof locals[ft.key] !== 'undefined' ? (Array.isArray(locals[ft.key]) ? locals[ft.key] : [locals[ft.key]]) : []; %>
            <% msgs.forEach(function(msg) { %>
              <% if (msg && msg.length > 0) { %>
                <div class="alert <%= ft.cls %>" data-auto-dismiss>
                  <i data-lucide="<%= ft.icon %>"></i>
                  <span style="flex:1;"><%= msg %></span>
                  <button class="alert-close" onclick="this.parentElement.remove()"><i data-lucide="x" style="width:14px;height:14px;"></i></button>
                </div>
              <% } %>
            <% }); %>
          <% }); %>
        </div>
      <% } %>

      <!-- Page content -->
      <main class="page-content">
        <%- body %>
      </main>

      <footer class="main-footer">
        <span>&copy; <%= new Date().getFullYear() %> ATLAS SkillTech University. All rights reserved.</span>
      </footer>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      lucide.createIcons();

      // Sidebar toggle
      var hamburger = document.getElementById('hamburger-btn');
      var sidebar = document.getElementById('sidebar');
      var overlay = document.getElementById('sidebar-overlay');
      var closeBtn = document.getElementById('sidebar-close');

      function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('active'); }
      function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('active'); }

      if (hamburger) hamburger.addEventListener('click', openSidebar);
      if (overlay) overlay.addEventListener('click', closeSidebar);
      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

      // Auto-dismiss alerts
      document.querySelectorAll('.alert[data-auto-dismiss]').forEach(function(el) {
        setTimeout(function() { el.style.opacity = '0'; el.style.transform = 'translateY(-8px)'; setTimeout(function() { el.remove(); }, 300); }, 5000);
      });
    });
  </script>
  <%- script %>
</body>
</html>
