<%
  const c = typeof candidate !== 'undefined' ? candidate : {};
  const s = typeof stats !== 'undefined' ? stats : {};
  const apps = typeof applications !== 'undefined' ? applications : [];
  const notifs = typeof notifications !== 'undefined' ? notifications : [];
  const schedules = typeof upcomingSchedules !== 'undefined' ? upcomingSchedules : [];
%>

<!-- Welcome -->
<div class="mb-lg">
  <h1 class="text-2xl font-bold">Welcome, <%= c.name || 'Candidate' %></h1>
  <p class="text-sm text-secondary mt-sm">Track your applications and stay updated on your recruitment progress.</p>
</div>

<!-- Stats Cards -->
<div class="stats-row">
  <% const statCards = [
    { label: 'Total', value: s.total || 0, icon: 'file-text', color: 'blue' },
    { label: 'Active', value: s.active || 0, icon: 'clock', color: 'orange' },
    { label: 'AI Eligible', value: s.aiEligible || 0, icon: 'brain', color: 'green' },
    { label: 'Interview', value: s.interviewPending || 0, icon: 'message-square', color: 'purple' },
    { label: 'Scheduled', value: s.scheduled || 0, icon: 'calendar', color: 'blue' },
    { label: 'Selected', value: s.selected || 0, icon: 'award', color: 'green' },
  ]; %>
  <% statCards.forEach(function(sc) { %>
    <div class="stat-card">
      <div class="stat-icon <%= sc.color %>">
        <i data-lucide="<%= sc.icon %>"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value"><%= sc.value %></div>
        <div class="stat-label"><%= sc.label %></div>
      </div>
    </div>
  <% }); %>
</div>

<div class="grid-3" style="grid-template-columns:2fr 1fr;">
  <!-- Applications List -->
  <div>
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">My Applications</h3>
        <a href="/candidate/applications" class="btn btn-sm btn-outline">View All</a>
      </div>
      <% if (apps.length === 0) { %>
        <div class="empty-state">
          <i data-lucide="inbox"></i>
          <p>No applications found.</p>
        </div>
      <% } else { %>
        <% apps.slice(0, 5).forEach(function(app) { %>
          <a href="/candidate/applications/<%= app.id %>" style="display:block;padding:16px 24px;border-bottom:1px solid var(--border-light);text-decoration:none;color:inherit;transition:background var(--transition-fast);"
             onmouseover="this.style.background='var(--bg-tertiary)'" onmouseout="this.style.background='transparent'">
            <div class="flex justify-between items-center gap-md">
              <div class="min-w-0" style="flex:1;">
                <p class="font-medium text-sm truncate"><%= app.job_title || 'Applied Position' %></p>
                <p class="text-xs text-muted" style="margin-top:2px;">
                  Applied: <%= app.appln_date ? new Date(app.appln_date).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '--' %>
                </p>
              </div>
              <span class="badge <%= app.statusInfo.isRejected ? 'badge-danger' : 'badge-info' %>">
                <%= app.statusInfo.friendlyStatus %>
              </span>
            </div>
            <!-- Mini progress -->
            <div class="flex gap-sm" style="margin-top:10px;">
              <% app.statusInfo.stages.forEach(function(stage, idx) { %>
                <div class="progress-bar" style="flex:1;height:4px;">
                  <div class="progress-fill <%= idx <= app.statusInfo.currentStageIndex ? (app.statusInfo.isRejected && idx === app.statusInfo.currentStageIndex ? 'red' : 'green') : '' %>"
                       style="width:<%= idx <= app.statusInfo.currentStageIndex ? '100' : '0' %>%;"></div>
                </div>
              <% }); %>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- Right sidebar -->
  <div>
    <!-- Upcoming Schedules -->
    <% if (schedules.length > 0) { %>
      <div class="card mb-lg">
        <div class="card-header">
          <h3 class="card-title" style="font-size:0.9rem;">Upcoming Interviews</h3>
        </div>
        <% schedules.forEach(function(sch) { %>
          <div style="padding:16px 24px;border-bottom:1px solid var(--border-light);">
            <p class="text-sm font-medium"><%= sch.job_title || 'Interview' %></p>
            <div class="flex items-center gap-sm mt-sm text-xs text-muted">
              <i data-lucide="calendar" style="width:14px;height:14px;"></i>
              <span><%= sch.scheduled_date ? new Date(sch.scheduled_date).toLocaleDateString('en-US', {weekday:'short', month:'short', day:'numeric'}) : '--' %></span>
              <% if (sch.scheduled_time) { %><span>at <%= sch.scheduled_time %></span><% } %>
            </div>
            <% if (sch.mode) { %>
              <span class="badge badge-info" style="margin-top:8px;">
                <i data-lucide="<%= sch.mode === 'online' ? 'video' : 'map-pin' %>" style="width:12px;height:12px;"></i>
                <%= sch.mode === 'online' ? 'Online' : 'In-Person' %>
              </span>
            <% } %>
          </div>
        <% }); %>
      </div>
    <% } %>

    <!-- Notifications -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title" style="font-size:0.9rem;">Recent Notifications</h3>
        <a href="/candidate/notifications" class="btn btn-sm btn-outline">View All</a>
      </div>
      <% if (notifs.length === 0) { %>
        <div class="card-body text-center">
          <p class="text-xs text-muted">No notifications yet.</p>
        </div>
      <% } else { %>
        <% notifs.slice(0, 4).forEach(function(n) { %>
          <div style="padding:12px 24px;border-bottom:1px solid var(--border-light);">
            <p class="text-xs font-medium"><%= n.title %></p>
            <p class="text-xs text-muted" style="margin-top:2px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= n.message %></p>
            <p class="text-xs text-muted" style="margin-top:4px;font-size:0.65rem;"><%= n.created_at ? new Date(n.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) : '' %></p>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>
</div>
