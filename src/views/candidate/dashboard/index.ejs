<%
  const c = typeof candidate !== 'undefined' ? candidate : {};
  const s = typeof stats !== 'undefined' ? stats : {};
  const apps = typeof applications !== 'undefined' ? applications : [];
  const notifs = typeof notifications !== 'undefined' ? notifications : [];
  const schedules = typeof upcomingSchedules !== 'undefined' ? upcomingSchedules : [];
%>

<!-- Welcome -->
<div class="mb-6">
  <h1 class="text-2xl font-bold text-foreground">Welcome, <%= c.name || 'Candidate' %></h1>
  <p class="text-sm text-muted-foreground mt-1">Track your applications and stay updated on your recruitment progress.</p>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
  <% const statCards = [
    { label: 'Total', value: s.total || 0, icon: 'file-text', color: 'text-blue-600 bg-blue-50 dark:bg-blue-900/20' },
    { label: 'Active', value: s.active || 0, icon: 'clock', color: 'text-amber-600 bg-amber-50 dark:bg-amber-900/20' },
    { label: 'AI Eligible', value: s.aiEligible || 0, icon: 'brain', color: 'text-green-600 bg-green-50 dark:bg-green-900/20' },
    { label: 'Interview', value: s.interviewPending || 0, icon: 'message-square', color: 'text-purple-600 bg-purple-50 dark:bg-purple-900/20' },
    { label: 'Scheduled', value: s.scheduled || 0, icon: 'calendar', color: 'text-indigo-600 bg-indigo-50 dark:bg-indigo-900/20' },
    { label: 'Selected', value: s.selected || 0, icon: 'award', color: 'text-emerald-600 bg-emerald-50 dark:bg-emerald-900/20' },
  ]; %>
  <% statCards.forEach(function(sc) { %>
    <div class="card p-4">
      <div class="flex items-center gap-2 mb-2">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center <%= sc.color %>">
          <i data-lucide="<%= sc.icon %>" class="w-4 h-4"></i>
        </div>
      </div>
      <p class="text-2xl font-bold text-foreground"><%= sc.value %></p>
      <p class="text-xs text-muted-foreground"><%= sc.label %></p>
    </div>
  <% }); %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Applications List -->
  <div class="lg:col-span-2">
    <div class="card">
      <div class="p-4 border-b border-border flex items-center justify-between">
        <h3 class="font-semibold text-foreground">My Applications</h3>
        <a href="/candidate/applications" class="text-xs text-primary-800 dark:text-primary-200 hover:underline">View All</a>
      </div>
      <% if (apps.length === 0) { %>
        <div class="p-8 text-center">
          <i data-lucide="inbox" class="w-10 h-10 text-muted-foreground mx-auto mb-3"></i>
          <p class="text-sm text-muted-foreground">No applications found.</p>
        </div>
      <% } else { %>
        <div class="divide-y divide-border">
          <% apps.slice(0, 5).forEach(function(app) { %>
            <a href="/candidate/applications/<%= app.id %>" class="block p-4 hover:bg-muted/50 transition-colors">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <p class="font-medium text-foreground text-sm truncate"><%= app.job_title || 'Applied Position' %></p>
                  <p class="text-xs text-muted-foreground mt-0.5">
                    Applied: <%= app.appln_date ? new Date(app.appln_date).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '--' %>
                  </p>
                </div>
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium
                  <%= app.statusInfo.isRejected ? 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300' : 'bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300' %>">
                  <%= app.statusInfo.friendlyStatus %>
                </span>
              </div>
              <!-- Mini progress -->
              <div class="flex gap-1 mt-3">
                <% app.statusInfo.stages.forEach(function(stage, idx) { %>
                  <div class="h-1 flex-1 rounded-full
                    <%= idx <= app.statusInfo.currentStageIndex
                      ? (app.statusInfo.isRejected && idx === app.statusInfo.currentStageIndex ? 'bg-red-500' : 'bg-blue-600')
                      : 'bg-border' %>"></div>
                <% }); %>
              </div>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right sidebar -->
  <div class="space-y-6">
    <!-- Upcoming Schedules -->
    <% if (schedules.length > 0) { %>
      <div class="card">
        <div class="p-4 border-b border-border">
          <h3 class="font-semibold text-foreground text-sm">Upcoming Interviews</h3>
        </div>
        <div class="divide-y divide-border">
          <% schedules.forEach(function(sch) { %>
            <div class="p-4">
              <p class="text-sm font-medium text-foreground"><%= sch.job_title || 'Interview' %></p>
              <div class="flex items-center gap-2 mt-2 text-xs text-muted-foreground">
                <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                <span><%= sch.scheduled_date ? new Date(sch.scheduled_date).toLocaleDateString('en-US', {weekday:'short', month:'short', day:'numeric'}) : '--' %></span>
                <% if (sch.scheduled_time) { %><span>at <%= sch.scheduled_time %></span><% } %>
              </div>
              <% if (sch.mode) { %>
                <span class="inline-flex items-center gap-1 mt-2 text-xs px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300">
                  <i data-lucide="<%= sch.mode === 'online' ? 'video' : 'map-pin' %>" class="w-3 h-3"></i>
                  <%= sch.mode === 'online' ? 'Online' : 'In-Person' %>
                </span>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Notifications -->
    <div class="card">
      <div class="p-4 border-b border-border flex items-center justify-between">
        <h3 class="font-semibold text-foreground text-sm">Recent Notifications</h3>
        <a href="/candidate/notifications" class="text-xs text-primary-800 dark:text-primary-200 hover:underline">View All</a>
      </div>
      <% if (notifs.length === 0) { %>
        <div class="p-6 text-center">
          <p class="text-xs text-muted-foreground">No notifications yet.</p>
        </div>
      <% } else { %>
        <div class="divide-y divide-border">
          <% notifs.slice(0, 4).forEach(function(n) { %>
            <div class="p-3">
              <p class="text-xs font-medium text-foreground"><%= n.title %></p>
              <p class="text-xs text-muted-foreground mt-0.5 line-clamp-2"><%= n.message %></p>
              <p class="text-xxs text-muted-foreground mt-1"><%= n.created_at ? new Date(n.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) : '' %></p>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</div>
