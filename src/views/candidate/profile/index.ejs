<%
  const p = typeof profile !== 'undefined' ? profile : {};
%>

<div class="mb-lg">
  <h1 class="text-2xl font-bold">My Profile</h1>
  <p class="text-sm text-secondary mt-sm">Your application profile information</p>
</div>

<div class="grid-2">
  <!-- Personal Info -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="user"></i> Personal Information
      </h2>
    </div>
    <div class="card-body">
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Full Name</span><span class="font-medium"><%= p.appln_full_name || '--' %></span>
      </div>
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Email</span><span class="font-medium"><%= p.appln_email || '--' %></span>
      </div>
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Mobile</span><span class="font-medium"><%= p.appln_mobile_no || '--' %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary">Application ID</span><span class="font-medium"><%= p.appln_id || '--' %></span>
      </div>
    </div>
  </div>

  <!-- Education -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="graduation-cap"></i> Education
      </h2>
    </div>
    <div class="card-body">
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Qualification</span><span class="font-medium"><%= p.appln_high_qualification || '--' %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary">Specialization</span><span class="font-medium"><%= p.appln_specialization || '--' %></span>
      </div>
    </div>
  </div>

  <!-- Experience -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="briefcase"></i> Experience
      </h2>
    </div>
    <div class="card-body">
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Total Experience</span><span class="font-medium"><%= p.appln_total_experience || '--' %></span>
      </div>
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Current Organisation</span><span class="font-medium"><%= p.appln_current_organisation || '--' %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary">Current Designation</span><span class="font-medium"><%= p.appln_current_designation || '--' %></span>
      </div>
    </div>
  </div>

  <!-- Applied Position -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="target"></i> Applied Position
      </h2>
    </div>
    <div class="card-body">
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Job Title</span><span class="font-medium"><%= p.job_title || '--' %></span>
      </div>
      <div class="flex justify-between text-sm mb-md" style="padding-bottom:12px;border-bottom:1px solid var(--border-light);">
        <span class="text-secondary">Location</span><span class="font-medium"><%= p.job_location || '--' %></span>
      </div>
      <div class="flex justify-between text-sm">
        <span class="text-secondary">Applied Date</span><span class="font-medium"><%= p.appln_date ? new Date(p.appln_date).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) : '--' %></span>
      </div>
    </div>
  </div>
</div>
