<%
  const tix = typeof tickets !== 'undefined' ? tickets : [];
%>

<div class="mb-lg">
  <h1 class="text-2xl font-bold">Help & Support</h1>
  <p class="text-sm text-secondary mt-sm">Get help with your application or contact HR</p>
</div>

<div class="grid-3" style="grid-template-columns:2fr 1fr;">
  <!-- FAQ -->
  <div class="flex flex-col gap-lg">
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Frequently Asked Questions</h2>
      </div>
      <div class="card-body">
        <% const faqs = [
          { q: 'How do I check my application status?', a: 'Go to My Applications from the dashboard and click on any application to see its detailed status.' },
          { q: 'What is AI Screening?', a: 'AI Screening is an automated process that evaluates your resume against the job requirements to determine eligibility.' },
          { q: 'How do I take the AI Interview?', a: 'If you are invited for an AI Interview, you will see a Start Interview button in your application details.' },
          { q: 'When will I know the result?', a: 'Results are typically communicated within 2-3 weeks. You will receive a notification when your status is updated.' },
          { q: 'How can I contact HR?', a: 'Use the contact form on this page to submit a query. Our HR team will respond within 2 business days.' },
        ]; %>
        <div class="flex flex-col gap-sm">
          <% faqs.forEach(function(faq, idx) { %>
            <div style="border:1px solid var(--border-color);border-radius:var(--radius-lg);overflow:hidden;">
              <button class="faq-toggle flex justify-between items-center w-full" style="padding:14px 16px;background:none;border:none;cursor:pointer;text-align:left;font-family:inherit;" data-faq="<%= idx %>">
                <span class="text-sm font-medium"><%= faq.q %></span>
                <i data-lucide="chevron-down" style="width:16px;height:16px;color:var(--text-muted);transition:transform 0.2s;flex-shrink:0;margin-left:8px;"></i>
              </button>
              <div class="faq-answer" id="faq-<%= idx %>" style="display:none;padding:0 16px 14px;">
                <p class="text-sm text-secondary"><%= faq.a %></p>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Past Tickets -->
    <% if (tix.length > 0) { %>
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Your Support Tickets</h2>
        </div>
        <div class="card-body flex flex-col gap-sm">
          <% tix.forEach(function(t) { %>
            <div style="padding:12px 16px;border:1px solid var(--border-color);border-radius:var(--radius-lg);">
              <div class="flex items-center justify-between mb-sm">
                <span class="text-sm font-medium"><%= t.subject %></span>
                <span class="badge <%= t.status === 'open' ? 'badge-warning' : t.status === 'resolved' ? 'badge-success' : 'badge-muted' %>">
                  <%= t.status %>
                </span>
              </div>
              <p class="text-xs text-muted"><%= t.created_at ? new Date(t.created_at).toLocaleDateString() : '' %></p>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Contact Form -->
  <div class="card" style="align-self:flex-start;">
    <div class="card-header">
      <h2 class="card-title">Contact HR</h2>
    </div>
    <div class="card-body">
      <form action="/candidate/help/contact" method="POST">
        <div class="form-group">
          <label for="category" class="form-label">Category</label>
          <select id="category" name="category" class="form-select">
            <option value="general">General Query</option>
            <option value="application">Application Issue</option>
            <option value="interview">Interview Related</option>
            <option value="documents">Documents</option>
            <option value="technical">Technical Issue</option>
          </select>
        </div>
        <div class="form-group">
          <label for="subject" class="form-label">Subject</label>
          <input type="text" id="subject" name="subject" required class="form-input" placeholder="Brief description">
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea id="message" name="message" required rows="4" class="form-textarea" placeholder="Describe your issue..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary w-full">
          <i data-lucide="send" style="width:16px;height:16px;"></i> Submit
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.faq-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = this.getAttribute('data-faq');
        var answer = document.getElementById('faq-' + idx);
        var icon = this.querySelector('[data-lucide]');
        var isOpen = answer.style.display !== 'none';
        // Close all
        document.querySelectorAll('.faq-answer').forEach(function(el) { el.style.display = 'none'; });
        document.querySelectorAll('.faq-toggle [data-lucide]').forEach(function(el) { el.style.transform = 'rotate(0deg)'; });
        // Toggle current
        if (!isOpen) {
          answer.style.display = 'block';
          if (icon) icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>
