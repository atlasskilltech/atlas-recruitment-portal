<div class="login-logo">
  <div class="logo-icon" style="width:48px;height:48px;font-size:1.5rem;margin:0 auto 12px;">A</div>
  <h2>ATLAS SkillTech University</h2>
  <p>HR Recruitment Portal</p>
</div>

<form action="/login" method="POST">
  <div class="form-group">
    <label class="form-label" for="email">Email Address</label>
    <input type="email" id="email" name="email" class="form-input" required autocomplete="email"
           placeholder="you@atlas.edu" value="<%= typeof email !== 'undefined' ? email : '' %>">
  </div>

  <div class="form-group">
    <label class="form-label" for="password">Password</label>
    <input type="password" id="password" name="password" class="form-input" required
           autocomplete="current-password" placeholder="Enter your password">
  </div>

  <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
    <input type="checkbox" name="rememberMe" id="remember" style="width:16px;height:16px;accent-color:var(--accent-primary);">
    <label for="remember" class="text-sm text-secondary" style="cursor:pointer;">Remember me</label>
  </div>

  <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">
    <i data-lucide="log-in" style="width:18px;height:18px;"></i>
    Sign In
  </button>
</form>

<div class="login-footer" style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border-color);">
  Secure access for authorized HR personnel only.
</div>
