<%
  const notifications = typeof locals.notifications !== 'undefined' ? locals.notifications : [];
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};

  const currentChannel = filters.channel || 'all';

  const tabs = [
    { key: 'all',      label: 'All',      icon: 'inbox' },
    { key: 'email',    label: 'Email',    icon: 'mail' },
    { key: 'sms',      label: 'SMS',      icon: 'smartphone' },
    { key: 'whatsapp', label: 'WhatsApp', icon: 'message-circle' },
    { key: 'system',   label: 'System',   icon: 'bell' },
  ];

  function buildQuery(overrides) {
    const params = Object.assign({}, filters, overrides);
    if (params.channel === 'all') delete params.channel;
    if (params.page == 1) delete params.page;
    const qs = Object.keys(params).filter(k => params[k]).map(k => k + '=' + encodeURIComponent(params[k])).join('&');
    return qs ? '?' + qs : '';
  }
%>

<!-- Page Header -->
<div class="flex items-center justify-between flex-wrap gap-md mb-lg">
  <div>
    <h1 class="text-2xl font-bold">Notifications</h1>
    <p class="text-sm text-muted mt-sm">View and manage all sent notifications</p>
  </div>
</div>

<!-- Filter Tabs -->
<div x-data="{ activeTab: '<%= currentChannel %>' }" class="mb-lg">
  <div class="tabs" style="margin-bottom:0">
    <% tabs.forEach(function(tab) { %>
      <a href="/notifications<%= buildQuery({ channel: tab.key, page: 1 }) %>"
         @click="activeTab = '<%= tab.key %>'"
         class="tab"
         :class="activeTab === '<%= tab.key %>' ? 'active' : ''">
        <i data-lucide="<%= tab.icon %>" style="width:16px;height:16px"></i>
        <%= tab.label %>
      </a>
    <% }); %>
  </div>
</div>

<!-- Notifications Table -->
<div class="card overflow-hidden">
  <% if (notifications.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Recipient</th>
            <th>Channel</th>
            <th>Subject</th>
            <th>Message</th>
            <th>Status</th>
            <th>Sent At</th>
          </tr>
        </thead>
        <tbody>
          <% notifications.forEach(function(n) { %>
            <%
              const recipient = n.recipient || n.recipient_email || n.recipient_name || 'Unknown';
              const channel = (n.channel || n.type || 'system').toLowerCase();

              /* Channel badge class */
              const channelBadgeClass = channel === 'email' ? 'badge badge-info'
                : channel === 'sms' ? 'badge badge-warning'
                : channel === 'whatsapp' ? 'badge badge-success'
                : 'badge badge-muted';
              const channelIcon = channel === 'email' ? 'mail'
                : channel === 'sms' ? 'smartphone'
                : channel === 'whatsapp' ? 'message-circle'
                : 'bell';

              /* Status badge class */
              const nStatus = (n.status || 'queued').toLowerCase();
              const statusBadgeClass = nStatus === 'sent' ? 'badge badge-success'
                : nStatus === 'failed' ? 'badge badge-danger'
                : 'badge badge-warning';
              const statusIcon = nStatus === 'sent' ? 'check-circle'
                : nStatus === 'failed' ? 'x-circle'
                : 'clock';

              const subject = n.subject || n.title || 'No Subject';
              const message = n.message || n.body || '';
              const truncatedMsg = message.length > 60 ? message.substring(0, 60) + '...' : message;
            %>
            <tr>
              <!-- Recipient -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="avatar avatar-sm avatar-gradient shrink-0">
                    <span><%= recipient.charAt(0).toUpperCase() %></span>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-medium truncate" style="max-width:200px"><%= recipient %></p>
                    <% if (n.recipient_email && n.recipient_name) { %>
                      <p class="text-xs text-muted truncate" style="max-width:200px"><%= n.recipient_email %></p>
                    <% } %>
                  </div>
                </div>
              </td>

              <!-- Channel -->
              <td>
                <span class="<%= channelBadgeClass %>">
                  <i data-lucide="<%= channelIcon %>" style="width:12px;height:12px"></i>
                  <%= channel.charAt(0).toUpperCase() + channel.slice(1) %>
                </span>
              </td>

              <!-- Subject -->
              <td>
                <p class="text-sm truncate" style="max-width:250px"><%= subject %></p>
              </td>

              <!-- Message (truncated) -->
              <td>
                <p class="text-sm text-muted truncate" style="max-width:280px" title="<%= message %>">
                  <%= truncatedMsg || '&mdash;' %>
                </p>
              </td>

              <!-- Status -->
              <td>
                <span class="<%= statusBadgeClass %>">
                  <i data-lucide="<%= statusIcon %>" style="width:12px;height:12px"></i>
                  <%= nStatus.charAt(0).toUpperCase() + nStatus.slice(1) %>
                </span>
              </td>

              <!-- Sent At -->
              <td class="text-muted text-sm" style="white-space:nowrap">
                <% if (n.sent_at || n.created_at) { %>
                  <%= new Date(n.sent_at || n.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between p-md border-t">
        <p class="text-sm text-muted">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="pagination" style="margin-top:0">
          <% if (pagination.page > 1) { %>
            <a href="/notifications<%= buildQuery({ page: pagination.page - 1 }) %>">
              <i data-lucide="chevron-left" style="width:16px;height:16px"></i> Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="active"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="/notifications<%= buildQuery({ page: i }) %>"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="text-muted">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="/notifications<%= buildQuery({ page: pagination.page + 1 }) %>">
              Next <i data-lucide="chevron-right" style="width:16px;height:16px"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state" style="padding:80px 24px">
      <i data-lucide="bell-off"></i>
      <h3 class="text-lg font-semibold mb-sm">No Notifications</h3>
      <p class="text-sm text-muted mb-lg" style="max-width:24rem;margin-left:auto;margin-right:auto">
        No notifications found. Notifications will appear here as emails, SMS, WhatsApp messages, and system alerts are sent.
      </p>
    </div>
  <% } %>
</div>
