<%
  const interviews = typeof locals.interviews !== 'undefined' ? locals.interviews : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};
%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-lg">
  <div>
    <h1 class="text-2xl font-bold">AI Interviews</h1>
    <p class="text-sm text-secondary mt-sm">Manage and review AI-powered candidate interviews</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="stats-row">
  <!-- Total -->
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="monitor"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.total || 0 %></p>
      <p class="stat-label">Total</p>
    </div>
  </div>

  <!-- Pending -->
  <div class="stat-card">
    <div class="stat-icon orange">
      <i data-lucide="clock"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-warning)"><%= stats.pending || 0 %></p>
      <p class="stat-label">Pending</p>
    </div>
  </div>

  <!-- In Progress -->
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="loader"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-secondary)"><%= stats.in_progress || 0 %></p>
      <p class="stat-label">In Progress</p>
    </div>
  </div>

  <!-- Completed -->
  <div class="stat-card">
    <div class="stat-icon purple">
      <i data-lucide="check-square"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.completed || 0 %></p>
      <p class="stat-label">Completed</p>
    </div>
  </div>

  <!-- Passed -->
  <div class="stat-card">
    <div class="stat-icon green">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-primary)"><%= stats.passed || 0 %></p>
      <p class="stat-label">Passed</p>
    </div>
  </div>

  <!-- Failed -->
  <div class="stat-card">
    <div class="stat-icon red">
      <i data-lucide="x-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-danger)"><%= stats.failed || 0 %></p>
      <p class="stat-label">Failed</p>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filters-bar">
  <form method="GET" action="/ai-interviews" style="display: contents;">
    <!-- Status -->
    <div class="filter-item">
      <label>Status</label>
      <select name="interview_status">
        <option value="">All Statuses</option>
        <option value="invited" <%= filters.interview_status === 'invited' ? 'selected' : '' %>>Invited</option>
        <option value="in_progress" <%= filters.interview_status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
        <option value="evaluated" <%= filters.interview_status === 'evaluated' ? 'selected' : '' %>>Evaluated</option>
        <option value="passed" <%= filters.interview_status === 'passed' ? 'selected' : '' %>>Passed</option>
        <option value="failed" <%= filters.interview_status === 'failed' ? 'selected' : '' %>>Failed</option>
        <option value="expired" <%= filters.interview_status === 'expired' ? 'selected' : '' %>>Expired</option>
      </select>
    </div>

    <!-- Min Score -->
    <div class="filter-item">
      <label>Min Score</label>
      <input type="number" name="score_min" min="0" max="100" placeholder="0" value="<%= filters.score_min || '' %>">
    </div>

    <!-- Max Score -->
    <div class="filter-item">
      <label>Max Score</label>
      <input type="number" name="score_max" min="0" max="100" placeholder="100" value="<%= filters.score_max || '' %>">
    </div>

    <!-- Actions -->
    <div class="filter-item" style="flex-direction: row; align-items: flex-end; gap: 8px;">
      <button type="submit" class="btn btn-primary btn-sm flex-1">
        <i data-lucide="search"></i>
        Filter
      </button>
      <a href="/ai-interviews" class="btn btn-outline btn-sm">
        <i data-lucide="x"></i>
        Clear
      </a>
    </div>
  </form>
</div>

<!-- Interviews Table -->
<div class="card overflow-hidden">
  <% if (interviews.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate Name</th>
            <th>Job Role</th>
            <th>Interview Type</th>
            <th>Status</th>
            <th>Total Score</th>
            <th>Communication</th>
            <th>Domain</th>
            <th>Problem Solving</th>
            <th>Started At</th>
            <th>Completed At</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% interviews.forEach(function(iv) { %>
            <%
              const candidateName = iv.candidate_name || (iv.candidate ? (iv.candidate.first_name + ' ' + (iv.candidate.last_name || '')) : 'Unknown');
              const jobTitle = iv.job_title || (iv.job ? iv.job.title : 'N/A');

              const ivType = iv.interview_type || iv.type || 'hr';
              const typeBadgeClass = 'badge badge-muted';

              const ivStatus = iv.interview_status || iv.status || 'invited';
              const ivStatusBadge = ivStatus === 'evaluated' ? 'badge badge-success'
                : ivStatus === 'passed' ? 'badge badge-success'
                : ivStatus === 'failed' ? 'badge badge-danger'
                : ivStatus === 'in_progress' ? 'badge badge-info'
                : ivStatus === 'invited' ? 'badge badge-warning'
                : 'badge badge-muted';

              const totalScore = iv.total_score || iv.overall_score || 0;
              const commScore = iv.communication_score || 0;
              const domainScore = iv.domain_score || 0;
              const problemScore = iv.problem_solving_score || 0;

              const totalScoreColor = totalScore >= 75 ? 'text-success' : totalScore >= 50 ? 'text-warning' : 'text-danger';
            %>
            <tr>
              <!-- Candidate Name -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="avatar avatar-sm avatar-gradient">
                    <%= candidateName.charAt(0).toUpperCase() %>
                  </div>
                  <span class="font-medium"><%= candidateName %></span>
                </div>
              </td>

              <!-- Job Role -->
              <td class="text-secondary"><%= jobTitle %></td>

              <!-- Interview Type -->
              <td>
                <span class="<%= typeBadgeClass %>">
                  <%= ivType.charAt(0).toUpperCase() + ivType.slice(1) %>
                </span>
              </td>

              <!-- Status -->
              <td>
                <span class="<%= ivStatusBadge %>">
                  <% if (ivStatus === 'evaluated' || ivStatus === 'passed') { %>
                    <i data-lucide="check" style="width:12px;height:12px;"></i>
                  <% } else if (ivStatus === 'in_progress') { %>
                    <i data-lucide="loader" style="width:12px;height:12px;"></i>
                  <% } else if (ivStatus === 'failed') { %>
                    <i data-lucide="x" style="width:12px;height:12px;"></i>
                  <% } else if (ivStatus === 'invited') { %>
                    <i data-lucide="mail" style="width:12px;height:12px;"></i>
                  <% } else { %>
                    <i data-lucide="clock" style="width:12px;height:12px;"></i>
                  <% } %>
                  <%= ivStatus.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- Total Score -->
              <td>
                <span class="text-sm font-bold <%= totalScoreColor %>"><%= totalScore %>%</span>
              </td>

              <!-- Communication -->
              <td class="text-sm text-secondary"><%= commScore %>%</td>

              <!-- Domain -->
              <td class="text-sm text-secondary"><%= domainScore %>%</td>

              <!-- Problem Solving -->
              <td class="text-sm text-secondary"><%= problemScore %>%</td>

              <!-- Started At -->
              <td class="text-secondary text-sm">
                <% if (iv.started_at) { %>
                  <%= new Date(iv.started_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Completed At -->
              <td class="text-secondary text-sm">
                <% if (iv.completed_at) { %>
                  <%= new Date(iv.completed_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Actions -->
              <td>
                <a href="/ai-interviews/<%= iv.id %>" class="btn btn-ghost btn-sm" title="View Details">
                  <i data-lucide="eye"></i>
                </a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between border-t" style="padding: 12px 16px;">
        <p class="text-sm text-secondary">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="pagination">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.maxScore ? '&maxScore=' + filters.maxScore : '' %>">
              <i data-lucide="chevron-left" style="width:16px;height:16px;"></i>
              Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="active"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="?page=<%= i %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.maxScore ? '&maxScore=' + filters.maxScore : '' %>"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="disabled">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="?page=<%= pagination.page + 1 %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.type ? '&type=' + filters.type : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.maxScore ? '&maxScore=' + filters.maxScore : '' %>">
              Next
              <i data-lucide="chevron-right" style="width:16px;height:16px;"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state" style="padding: 80px 24px;">
      <i data-lucide="monitor"></i>
      <h3 class="text-lg font-semibold mb-sm">No AI Interviews</h3>
      <p class="text-sm text-secondary" style="max-width: 360px; margin: 0 auto 24px;">
        No AI interviews found. Interviews will appear here once candidates are invited.
      </p>
      <a href="/ai-screening" class="btn btn-primary">
        <i data-lucide="brain"></i>
        View Screenings
      </a>
    </div>
  <% } %>
</div>
