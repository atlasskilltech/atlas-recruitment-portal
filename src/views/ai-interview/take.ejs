<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Video Interview | ATLAS SkillTech University</title>
  <link rel="stylesheet" href="/css/atlas-theme.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: 'Inter', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; }
    .video-container { position: relative; background: #000; border-radius: 12px; overflow: hidden; }
    .video-container video { width: 100%; height: 100%; object-fit: cover; }
    .video-overlay { position: absolute; top: 0; left: 0; right: 0; padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; background: linear-gradient(to bottom, rgba(0,0,0,0.6), transparent); z-index: 2; }
    .caption-bar { position: absolute; bottom: 0; left: 0; right: 0; padding: 12px 16px; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); z-index: 2; font-size: 14px; color: #fff; min-height: 40px; }
    .rec-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(239,68,68,0.9); color: #fff; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 700; }
    .rec-badge::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #fff; animation: blink 1s infinite; }
    @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
    .mic-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; }
    .mic-on { background: rgba(34,197,94,0.2); color: #22c55e; }
    .mic-off { background: rgba(239,68,68,0.2); color: #ef4444; }
    .live-dot { display: inline-flex; align-items: center; gap: 4px; color: #ef4444; font-size: 12px; font-weight: 700; }
    .live-dot::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #ef4444; animation: blink 1.5s infinite; }
    .ai-avatar { width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .btn-action { padding: 10px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; border: none; transition: all 0.2s; display: inline-flex; align-items: center; gap: 8px; }
    .btn-submit { background: #2563eb; color: #fff; }
    .btn-submit:hover { background: #1d4ed8; }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-skip { background: #334155; color: #94a3b8; }
    .btn-skip:hover { background: #475569; }
    .btn-save { background: #334155; color: #94a3b8; }
    .btn-save:hover { background: #475569; }
    .btn-end { background: rgba(239,68,68,0.15); color: #ef4444; border: 1px solid rgba(239,68,68,0.3); }
    .btn-end:hover { background: rgba(239,68,68,0.25); }
    .transcript-box { background: #1e293b; border: 1px solid #334155; border-radius: 10px; padding: 12px; min-height: 60px; font-size: 14px; color: #cbd5e1; flex-shrink: 1; }
    .answer-box { background: #1e293b; border: 1px solid #334155; border-radius: 10px; padding: 12px; min-height: 50px; font-size: 14px; color: #cbd5e1; flex-shrink: 1; }
    .setup-card { background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 32px; max-width: 700px; margin: 0 auto; }
    .pulse-speaking { animation: pulse-speak 1.5s infinite; }
    .no-select { -webkit-user-select: none; -moz-user-select: none; -ms-user-select: none; user-select: none; }
    @keyframes pulse-speak { 0%,100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.4); } 50% { box-shadow: 0 0 0 8px rgba(99,102,241,0); } }
  </style>
</head>
<body>
<%
  const _interview = typeof interview !== 'undefined' ? interview : {};
  const _questions = _interview.questions || (typeof questions !== 'undefined' ? questions : []);
  const _token = typeof token !== 'undefined' ? token : (_interview.invitation_token || '');
  const candidateName = _interview.candidate_name || _interview.appln_full_name || 'Candidate';
  const jobTitle = _interview.job_title || 'Position';
  const ivStatus = (_interview.status || _interview.interview_status || 'invited').toLowerCase();
  const isAlreadyCompleted = ['evaluated', 'submitted', 'passed', 'failed'].includes(ivStatus);
%>

<% if (isAlreadyCompleted) { %>
<!-- Already Completed — server rendered, no Alpine needed -->
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;" style="background: #0f172a; color: #e2e8f0;">
  <div class="setup-card" style="background: #1e293b; border: 1px solid #334155; border-radius: 16px; padding: 32px; max-width: 700px; text-align: center;">
    <div style="width:80px;height:80px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
      <svg style="width:40px;height:40px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
    </div>
    <h2 style="font-size:24px;font-weight:bold;margin-bottom:8px;">Interview Already Completed</h2>
    <p style="color:#94a3b8;margin-bottom:16px;">Thank you, <strong style="color:#fff;"><%= candidateName %></strong>, for successfully completing your 1st Round of interview.</p>
    <p style="color:#94a3b8;font-size:14px;margin-bottom:16px;">Our HR team will connect with you shortly regarding the next steps.</p>
    <p style="color:#64748b;font-size:14px;">You may now close this window.</p>
  </div>
</div>

<% } else { %>

<div id="app" x-data="videoInterview()" x-cloak>

  <!-- ═══ SETUP SCREEN ═══ -->
  <template x-if="phase === 'setup'">
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;">
      <div class="setup-card" style="text-align:center;">
        <h1 style="font-size:1.5rem;font-weight:700;margin-bottom:4px;">AI Video Interview</h1>
        <p style="color:#94a3b8;font-size:0.85rem;">ATLAS SkillTech University</p>
        <p style="color:#cbd5e1;margin-top:12px;"><strong><%= candidateName %></strong> &middot; <%= jobTitle %></p>

        <!-- Camera Preview -->
        <div style="margin:24px 0;">
          <div class="video-container" style="max-height:280px;">
            <video x-ref="setupVideo" autoplay muted playsinline style="transform:scaleX(-1);"></video>
            <div class="video-overlay" x-show="cameraReady">
              <span style="font-size:0.75rem;color:#22c55e;font-weight:500;">Camera & microphone ready</span>
            </div>
          </div>
        </div>

        <div style="margin-bottom:12px;">
          <p style="font-size:0.75rem;color:#64748b;margin-bottom:12px;"><%= _questions.length %> questions</p>

          <!-- Permission denied message -->
          <div x-show="permissionError === 'blocked'" style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:16px;margin-bottom:16px;text-align:left;">
            <p style="color:#fca5a5;font-weight:600;font-size:0.9rem;margin-bottom:8px;">Camera & Microphone Blocked</p>
            <p style="color:#94a3b8;font-size:0.8rem;line-height:1.5;margin-bottom:8px;">Your browser has blocked camera access. To enable:</p>
            <ol style="color:#94a3b8;font-size:0.8rem;line-height:1.8;padding-left:16px;margin:0;">
              <li>Tap the <strong style="color:#e2e8f0;">lock icon</strong> (or <strong style="color:#e2e8f0;">ⓘ</strong>) in the address bar</li>
              <li>Find <strong style="color:#e2e8f0;">Camera</strong> and <strong style="color:#e2e8f0;">Microphone</strong></li>
              <li>Change both to <strong style="color:#22c55e;">Allow</strong></li>
              <li>Reload this page</li>
            </ol>
          </div>

          <div x-show="permissionError === 'error'" style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);border-radius:10px;padding:12px;margin-bottom:16px;">
            <p style="color:#fbbf24;font-size:0.8rem;">Camera not available on this device. Please try from a device with a camera.</p>
          </div>

          <!-- Allow button (before permission granted) -->
          <button x-show="!cameraReady" @click="checkCamera()"
                  style="width:100%;padding:14px 24px;border-radius:10px;font-weight:700;font-size:1rem;cursor:pointer;border:none;background:#10b981;color:#fff;display:inline-flex;align-items:center;justify-content:center;gap:8px;">
            <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
            <span x-text="permissionError ? 'Try Again' : 'Allow Camera & Microphone'"></span>
          </button>

          <!-- Start button (after permission granted) -->
          <button x-show="cameraReady" @click="startVideoInterview()"
                  style="width:100%;padding:14px 24px;border-radius:10px;font-weight:700;font-size:1rem;cursor:pointer;border:none;background:#2563eb;color:#fff;display:inline-flex;align-items:center;justify-content:center;gap:8px;">
            <svg style="width:20px;height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg>
            Start Interview
          </button>
        </div>
      </div>
    </div>
  </template>

  <!-- ═══ INTERVIEW SESSION ═══ -->
  <div x-show="phase === 'session'" x-transition style="position:fixed;inset:0;display:flex;flex-direction:column;overflow:hidden;background:#0f172a;z-index:50;">
      <!-- Top Bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 24px;border-bottom:1px solid #334155;background:rgba(15,23,42,0.9);backdrop-filter:blur(8px);flex-shrink:0;">
        <div>
          <span style="font-weight:700;color:#fff;">HR Interview</span>
          <span style="font-size:12px;color:#94a3b8;margin-left:8px;"><%= jobTitle %></span>
        </div>
        <div style="display:flex;align-items:center;gap:16px;">
          <span style="font-size:14px;font-family:monospace;font-weight:700;color:#fff;" x-text="formatTime(timerSeconds)"></span>
          <span class="live-dot">Live</span>
          <span style="font-size:12px;color:#94a3b8;" x-text="answeredCount + '/' + questions.length"></span>
        </div>
      </div>

      <!-- Main Content -->
      <div style="flex:1;display:flex;gap:0;min-height:0;overflow:hidden;">
        <!-- LEFT: Video -->
        <div style="width:40%;min-width:280px;padding:12px;display:flex;flex-direction:column;overflow:hidden;">
          <div class="video-container" style="flex:1;aspect-ratio:auto;width:100%;height:100%;">
            <video x-ref="sessionVideo" autoplay muted playsinline style="transform:scaleX(-1);"></video>
            <div class="video-overlay">
              <span style="font-size:12px;color:#fff;font-weight:500;">YOU</span>
              <template x-if="isRecording">
                <span class="rec-badge">Rec <span x-text="formatTime(timerSeconds)"></span></span>
              </template>
              <template x-if="!isRecording">
                <span class="mic-badge mic-off">Mic Off</span>
              </template>
            </div>
            <div class="caption-bar" x-text="liveCaption || ''"></div>
          </div>
        </div>

        <!-- RIGHT: Question + Transcript + Answer -->
        <div style="width:60%;padding:10px 16px;display:flex;flex-direction:column;gap:8px;overflow-y:auto;">
          <!-- AI Interviewer -->
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:12px;">
              <div class="ai-avatar" :class="aiSpeaking ? 'pulse-speaking' : ''">
                <svg style="width:20px;height:20px;color:#fff;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
              </div>
              <div>
                <span style="font-weight:600;font-size:14px;color:#e2e8f0;">AI Interviewer</span>
                <span style="font-size:12px;color:#94a3b8;margin-left:8px;" x-text="aiSpeaking ? '🔊 Speaking' : '👂 Listening'"></span>
              </div>
            </div>
            <button @click="repeatQuestion()" style="font-size:12px;color:#60a5fa;background:none;border:none;cursor:pointer;">↻ Repeat Question</button>
          </div>

          <!-- Question -->
          <div style="padding:16px;border-radius:12px;background:#1e293b;border:1px solid #334155;">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
              <span style="width:24px;height:24px;border-radius:50%;background:#2563eb;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;" x-text="currentIndex + 1"></span>
              <span style="font-size:11px;color:#94a3b8;text-transform:uppercase;font-weight:600;letter-spacing:0.05em;">Question</span>
            </div>
            <p class="no-select" style="font-size:15px;color:#fff;line-height:1.6;margin:0;" x-text="questions[currentIndex]?.text"></p>
          </div>

          <!-- Transcript -->
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
              <span style="font-size:11px;color:#94a3b8;text-transform:uppercase;font-weight:600;letter-spacing:0.05em;">Transcript</span>
            </div>
            <div class="transcript-box">
              <template x-for="(line, i) in transcriptLines" :key="i">
                <div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:8px;">
                  <span style="width:16px;height:16px;border-radius:50%;background:#16a34a;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:3px;">
                    <svg style="width:10px;height:10px;color:#fff;" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/></svg>
                  </span>
                  <span style="font-size:14px;color:#cbd5e1;" x-text="line"></span>
                </div>
              </template>
              <span style="color:#475569;font-style:italic;font-size:14px;" x-show="transcriptLines.length === 0">Speak to see your transcript here...</span>
            </div>
          </div>

          <!-- Your Answer (read-only) -->
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
              <span style="font-size:11px;color:#94a3b8;text-transform:uppercase;font-weight:600;letter-spacing:0.05em;">Your Answer</span>
              <span style="font-size:12px;color:#475569;" x-text="wordCount + ' words | ' + answerDuration + 's'"></span>
            </div>
            <div class="answer-box">
              <div x-text="answers[currentIndex] || ''" style="min-height:80px;font-size:14px;color:#e2e8f0;white-space:pre-wrap;word-wrap:break-word;"></div>
              <span style="color:#475569;font-style:italic;font-size:14px;" x-show="!(answers[currentIndex] || '').trim()">Your speech will be auto-transcribed here...</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom Action Bar -->
      <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-top:1px solid #334155;background:rgba(15,23,42,0.9);backdrop-filter:blur(8px);flex-shrink:0;">
        <div style="display:flex;align-items:center;gap:12px;">
          <template x-if="currentIndex < questions.length - 1">
            <button @click="submitAnswer()" class="btn-action btn-submit" :disabled="saving || !(answers[currentIndex] || '').trim()">
              ✈ Save &amp; Next
            </button>
          </template>
          <template x-if="currentIndex >= questions.length - 1">
            <button @click="submitAndEnd()" class="btn-action btn-submit" style="background:#16a34a;" :disabled="saving || !(answers[currentIndex] || '').trim()">
              ✈ Submit &amp; Finish
            </button>
          </template>
          <button @click="if(confirm('Are you sure you want to end the interview? All answered questions will be submitted.')) endInterview()" class="btn-action btn-end" style="background:rgba(239,68,68,0.15);color:#ef4444;border:1px solid rgba(239,68,68,0.3);">
            ✕ End Interview
          </button>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:12px;color:#475569;" x-text="answeredCount + ' of ' + questions.length + ' answered'"></span>
        </div>
      </div>
    </div>

  <!-- Tab Switch Warning Overlay -->
  <div x-show="showTabWarning" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.9);display:flex;align-items:center;justify-content:center;" x-cloak>
    <div style="background:#1e293b;border:2px solid #ef4444;border-radius:16px;padding:32px;max-width:500px;text-align:center;">
      <div style="width:60px;height:60px;border-radius:50%;background:rgba(239,68,68,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
        <svg style="width:30px;height:30px;color:#ef4444;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>
      </div>
      <h2 style="font-size:1.2rem;font-weight:700;color:#ef4444;margin-bottom:8px;">Tab Switch Detected!</h2>
      <p style="color:#94a3b8;font-size:0.9rem;margin-bottom:8px;">Switching tabs during the interview is not allowed. This activity is being recorded.</p>
      <p style="color:#64748b;font-size:0.8rem;margin-bottom:20px;">Violations: <strong style="color:#ef4444;" x-text="tabSwitchCount"></strong></p>
      <button @click="showTabWarning = false" style="padding:10px 32px;border-radius:8px;font-weight:600;font-size:14px;cursor:pointer;border:none;background:#2563eb;color:#fff;">Return to Interview</button>
    </div>
  </div>

  <!-- ═══ COMPLETED ═══ -->
  <template x-if="phase === 'completed'">
    <div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;">
      <div style="background:#1e293b;border:1px solid #334155;border-radius:16px;padding:32px;max-width:700px;text-align:center;">
        <div style="width:80px;height:80px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
          <svg style="width:40px;height:40px;color:#22c55e;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
        </div>
        <h2 style="font-size:24px;font-weight:bold;margin-bottom:8px;color:#e2e8f0;">Interview Completed Successfully!</h2>
        <p style="color:#94a3b8;margin-bottom:16px;">Thank you, <strong style="color:#fff;"><%= candidateName %></strong>, for successfully completing your 1st Round of interview.</p>
        <p style="color:#94a3b8;font-size:14px;margin-bottom:24px;">Our HR team will connect with you shortly regarding the next steps.</p>
        <p style="color:#64748b;font-size:14px;">You may now close this window.</p>
      </div>
    </div>
  </template>

</div>
<% } %>

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script>
// Preload voices early (browsers load them asynchronously)
if (window.speechSynthesis) {
  speechSynthesis.getVoices();
  speechSynthesis.onvoiceschanged = function() { speechSynthesis.getVoices(); };
}
function videoInterview() {
  var questionsData = <%- JSON.stringify((_questions || []).map(function(q) {
    return { id: q.id, text: q.question_text || q.question || q.text || '' };
  })) %>;
  var interviewToken = '<%= _token %>';

  return {
    phase: 'setup',
    cameraReady: false,
    permissionError: '',
    stream: null,
    recognition: null,
    isRecording: false,
    aiSpeaking: false,
    liveCaption: '',
    saving: false,

    _candidateName: '<%= candidateName.replace(/'/g, "\\'") %>',
    _jobTitle: '<%= jobTitle.replace(/'/g, "\\'") %>',
    _greetingDone: false,
    _selectedVoice: null,
    questions: questionsData,
    currentIndex: 0,
    answers: {},
    answeredCount: 0,
    transcriptLines: [],
    interviewId: null,

    timerSeconds: 0,
    timerInterval: null,
    answerStartTime: null,

    get wordCount() {
      return ((this.answers[this.currentIndex] || '').match(/\S+/g) || []).length;
    },
    get answerDuration() {
      if (!this.answerStartTime) return 0;
      return Math.round((Date.now() - this.answerStartTime) / 1000);
    },

    _pickVoice() {
      var voices = speechSynthesis.getVoices();
      if (!voices.length) return null;
      // Prefer high-quality English voices (Google, Microsoft, Samantha for Mac)
      var preferred = ['Google US English', 'Google UK English Female', 'Microsoft Zira', 'Samantha', 'Karen', 'Daniel', 'Moira', 'Tessa'];
      for (var i = 0; i < preferred.length; i++) {
        var found = voices.find(function(v) { return v.name.indexOf(preferred[i]) !== -1; });
        if (found) return found;
      }
      // Fallback: any English voice
      var english = voices.find(function(v) { return v.lang && v.lang.startsWith('en'); });
      return english || voices[0];
    },

    _applyVoice(utterance) {
      if (!this._selectedVoice) this._selectedVoice = this._pickVoice();
      if (this._selectedVoice) utterance.voice = this._selectedVoice;
      utterance.lang = 'en-US';
      utterance.rate = 0.92;
      utterance.pitch = 1.0;
      utterance.volume = 1.0;
      return utterance;
    },

    async checkCamera() {
      this.permissionError = '';
      try {
        this.stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: true });
        if (this.$refs.setupVideo) this.$refs.setupVideo.srcObject = this.stream;
        this.cameraReady = true;
      } catch (e) {
        this.cameraReady = false;
        if (e.name === 'NotAllowedError' || e.name === 'PermissionDeniedError') {
          this.permissionError = 'blocked';
        } else {
          this.permissionError = 'error';
        }
      }
    },

    async startVideoInterview() {
      // Preload voices (some browsers load asynchronously)
      speechSynthesis.getVoices();
      this._selectedVoice = this._pickVoice();

      // Request fullscreen
      try {
        var el = document.documentElement;
        if (el.requestFullscreen) await el.requestFullscreen();
        else if (el.webkitRequestFullscreen) await el.webkitRequestFullscreen();
        else if (el.msRequestFullscreen) await el.msRequestFullscreen();
      } catch(e) { console.warn('Fullscreen not available:', e); }

      // Call API to start
      try {
        var res = await fetch('/ai/interview/' + interviewToken + '/start', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }
        });
        var data = await res.json();
        if (data.success) {
          this.interviewId = data.interview_id;
          if (data.questions && data.questions.length > 0) {
            this.questions = data.questions.map(function(q) {
              return { id: q.id, text: q.question_text || q.question || q.text || '' };
            });
          }
        }
      } catch (e) { console.error('Start failed:', e); }

      this.phase = 'session';
      this._startProctoring();
      var self = this;
      // Attach stream to session video — use short delay for DOM to update with x-show
      setTimeout(function() {
        var video = document.querySelector('[x-ref="sessionVideo"]') || self.$refs.sessionVideo;
        if (video && self.stream) {
          video.srcObject = self.stream;
          video.play().catch(function(){});
        }
        self.startQuestion();
      }, 300);
    },

    startQuestion() {
      this.transcriptLines = [];
      this.answerStartTime = Date.now();
      this.timerSeconds = 0;
      this.liveCaption = '';

      // Re-attach video stream (fixes video disappearing on question change)
      var self = this;
      setTimeout(function() {
        var video = document.querySelector('[x-ref="sessionVideo"]');
        if (video && self.stream && !video.srcObject) {
          video.srcObject = self.stream;
          video.play().catch(function(){});
        }
      }, 100);

      // Start timer counting up
      if (this.timerInterval) clearInterval(this.timerInterval);
      this.timerInterval = setInterval(function() { self.timerSeconds++; }, 1000);

      // AI reads the question aloud (with greeting for first question)
      if (this.currentIndex === 0 && !this._greetingDone) {
        this._greetingDone = true;
        this.aiSpeaking = true;
        var greeting = 'Hello ' + this._candidateName + ', welcome to this AI interview for the position of ' + this._jobTitle + ' at ATLAS SkillTech University. I will ask you a series of questions. Please take your time and answer clearly. Let us begin with the first question.';
        var greetUtterance = this._applyVoice(new SpeechSynthesisUtterance(greeting));
        var self2 = this;
        greetUtterance.onend = function() {
          self2.speakQuestion();
        };
        speechSynthesis.cancel();
        speechSynthesis.speak(greetUtterance);
      } else {
        this.speakQuestion();
      }
    },

    speakQuestion() {
      var text = this.questions[this.currentIndex]?.text;
      if (!text) return;

      this.aiSpeaking = true;
      var utterance = this._applyVoice(new SpeechSynthesisUtterance(text));
      var self = this;
      utterance.onend = function() {
        self.aiSpeaking = false;
        self.startListening();
      };
      speechSynthesis.cancel();
      speechSynthesis.speak(utterance);
    },

    repeatQuestion() {
      this.stopListening();
      this.speakQuestion();
    },

    startListening() {
      var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) {
        console.warn('Speech recognition not supported');
        return;
      }

      this.isRecording = true;
      this._recognitionRetries = 0;
      this._initRecognition();

      // Keepalive: check every 5s if recognition is still active, restart if not
      var self = this;
      if (this._keepAliveInterval) clearInterval(this._keepAliveInterval);
      this._keepAliveInterval = setInterval(function() {
        if (self.phase !== 'session' || !self.isRecording) {
          clearInterval(self._keepAliveInterval);
          return;
        }
        // If recognition object is gone or not active, reinitialize
        if (!self.recognition) {
          console.log('[MIC] Keepalive: recognition lost, reinitializing');
          self._initRecognition();
        }
      }, 5000);
    },

    _initRecognition() {
      var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (this.recognition) {
        try { this.recognition.abort(); } catch(e) {}
        this.recognition = null;
      }

      var rec = new SpeechRecognition();
      this.recognition = rec;

      // Safari doesn't support continuous well — use it anyway but handle restarts
      rec.continuous = true;
      rec.interimResults = true;
      rec.lang = 'en-US';
      rec.maxAlternatives = 1;

      var self = this;
      var lastResultTime = Date.now();

      rec.onresult = function(event) {
        lastResultTime = Date.now();
        var interim = '';
        var currentAnswer = self.answers[self.currentIndex] || '';
        for (var i = event.resultIndex; i < event.results.length; i++) {
          var t = event.results[i][0].transcript;
          if (event.results[i].isFinal) {
            currentAnswer += (currentAnswer ? ' ' : '') + t;
            self.transcriptLines.push(t);
          } else {
            interim = t;
          }
        }
        self.answers[self.currentIndex] = currentAnswer;
        self.liveCaption = interim || '';
      };

      rec.onerror = function(e) {
        console.warn('[MIC] Error:', e.error);
        // All errors: try to restart if still in session
        if (self.phase === 'session' && self.isRecording) {
          var delay = e.error === 'not-allowed' ? 3000 : 800;
          if (e.error === 'not-allowed') {
            console.error('[MIC] Microphone permission denied');
            return; // Don't retry if permission denied
          }
          self._recognitionRetries = (self._recognitionRetries || 0) + 1;
          if (self._recognitionRetries > 20) {
            console.error('[MIC] Too many retries, stopping');
            return;
          }
          setTimeout(function() { self._initRecognition(); }, delay);
        }
      };

      rec.onend = function() {
        console.log('[MIC] Recognition ended, isRecording:', self.isRecording);
        // Always restart if we should still be recording
        if (self.phase === 'session' && self.isRecording) {
          self._recognitionRetries = (self._recognitionRetries || 0) + 1;
          if (self._recognitionRetries > 50) {
            console.error('[MIC] Too many restarts, giving up');
            return;
          }
          // Short delay then create fresh instance
          setTimeout(function() {
            if (self.phase === 'session' && self.isRecording) {
              self._initRecognition();
            }
          }, 300);
        }
      };

      rec.onaudiostart = function() {
        self._recognitionRetries = 0; // Reset retries on successful audio
      };

      try {
        rec.start();
        console.log('[MIC] Recognition started');
      } catch(e) {
        console.warn('[MIC] Start failed:', e.message);
        setTimeout(function() {
          if (self.phase === 'session' && self.isRecording) {
            self._initRecognition();
          }
        }, 1000);
      }
    },

    stopListening() {
      this.isRecording = false;
      if (this._keepAliveInterval) {
        clearInterval(this._keepAliveInterval);
        this._keepAliveInterval = null;
      }
      if (this.recognition) {
        try { this.recognition.stop(); } catch(e) {}
        this.recognition = null;
      }
      this.liveCaption = '';
    },

    formatTime(s) {
      var m = Math.floor(s / 60);
      var sec = s % 60;
      return m.toString().padStart(2,'0') + ':' + sec.toString().padStart(2,'0');
    },

    async submitAnswer() {
      this.stopListening();
      speechSynthesis.cancel();
      var answer = (this.answers[this.currentIndex] || '').trim();
      if (!answer) { alert('Please provide an answer before submitting.'); return; }

      this.saving = true;
      try {
        var res = await fetch('/ai/interview/' + interviewToken + '/answer', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question_id: this.questions[this.currentIndex].id, answer_text: answer })
        });
        var data = await res.json();
        if (!data.success) { console.error('Save failed:', data.message); }
      } catch(e) { console.error('Save error:', e); }
      this.saving = false;

      this.answeredCount++;

      // Move to next question or auto-end if last
      if (this.currentIndex < this.questions.length - 1) {
        this.currentIndex++;
        this.startQuestion();
      } else {
        // Last question answered — auto-end
        this.endInterview();
      }
    },

    skipQuestion() {
      this.stopListening();
      speechSynthesis.cancel();
      if (this.currentIndex < this.questions.length - 1) {
        this.currentIndex++;
        this.startQuestion();
      } else {
        this.endInterview();
      }
    },

    async submitAndEnd() {
      // Save the last answer then immediately end
      this.stopListening();
      speechSynthesis.cancel();
      var answer = (this.answers[this.currentIndex] || '').trim();
      if (!answer) { alert('Please provide an answer before submitting.'); return; }
      if (answer) {
        this.saving = true;
        try {
          await fetch('/ai/interview/' + interviewToken + '/answer', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ question_id: this.questions[this.currentIndex].id, answer_text: answer })
          });
        } catch(e) { console.error('Save error:', e); }
        this.saving = false;
      }
      this.endInterview();
    },

    async saveProgress() {
      // Save current answer without advancing
      var answer = (this.answers[this.currentIndex] || '').trim();
      if (!answer) return;
      this.saving = true;
      try {
        await fetch('/ai/interview/' + interviewToken + '/answer', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ question_id: this.questions[this.currentIndex].id, answer_text: answer })
        });
      } catch(e) {}
      this.saving = false;
      alert('Progress saved.');
    },

    async endInterview() {
      this.stopListening();
      speechSynthesis.cancel();
      if (this.timerInterval) clearInterval(this.timerInterval);
      if (this.stream) { this.stream.getTracks().forEach(function(t) { t.stop(); }); }

      // Submit for evaluation
      this.saving = true;
      try {
        var res = await fetch('/ai/interview/' + interviewToken + '/submit', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }
        });
        var data = await res.json();
        console.log('Submit result:', data);
      } catch(e) { console.error('Submit error:', e); }
      this.saving = false;

      this.phase = 'completed';
      // Exit fullscreen on completion
      try { if (document.exitFullscreen) document.exitFullscreen(); } catch(e) {}
    },

    // --- Proctoring: tab switch detection ---
    tabSwitchCount: 0,
    showTabWarning: false,

    _startProctoring() {
      var self = this;

      // Detect tab switch / window blur
      document.addEventListener('visibilitychange', function() {
        if (self.phase !== 'session') return;
        if (document.hidden) {
          self.tabSwitchCount++;
          self.showTabWarning = true;
        }
      });

      // Also detect window blur (alt-tab etc)
      window.addEventListener('blur', function() {
        if (self.phase !== 'session') return;
        self.tabSwitchCount++;
        self.showTabWarning = true;
      });

      // Re-request fullscreen if exited
      document.addEventListener('fullscreenchange', function() {
        if (self.phase === 'session' && !document.fullscreenElement) {
          setTimeout(function() {
            if (self.phase === 'session') {
              try { document.documentElement.requestFullscreen(); } catch(e) {}
            }
          }, 500);
        }
      });

      // Prevent copy/paste/cut and right-click
      document.addEventListener('copy', function(e) { if (self.phase === 'session') e.preventDefault(); });
      document.addEventListener('cut', function(e) { if (self.phase === 'session') e.preventDefault(); });
      document.addEventListener('paste', function(e) { if (self.phase === 'session') e.preventDefault(); });
      document.addEventListener('contextmenu', function(e) { if (self.phase === 'session') e.preventDefault(); });

      // Prevent keyboard shortcuts and problematic keys
      document.addEventListener('keydown', function(e) {
        if (self.phase !== 'session') return;

        // Block Escape (exits fullscreen)
        if (e.key === 'Escape') {
          e.preventDefault();
          e.stopPropagation();
          return false;
        }

        // Block Backspace when not in an input (triggers browser back)
        if (e.key === 'Backspace') {
          e.preventDefault();
          return false;
        }

        // Block Ctrl/Cmd shortcuts
        if ((e.ctrlKey || e.metaKey) && ['c','v','a','x','p','s','u'].includes(e.key.toLowerCase())) {
          e.preventDefault();
        }
        if (e.key === 'PrintScreen' || e.key === 'F12') {
          e.preventDefault();
        }
      }, true); // Use capture phase to intercept before browser handles it
    }
  };
}
</script>
</body>
</html>
