<%- contentFor('style') %>
<style>
  .interview-container { max-width: 800px; margin: 0 auto; }
  .question-timer { font-variant-numeric: tabular-nums; }
  @keyframes pulse-ring { 0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); } 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); } }
  .timer-pulse { animation: pulse-ring 2s infinite; }
  .timer-warning { color: #f59e0b; }
  .timer-danger { color: #ef4444; animation: pulse-ring 1s infinite; }
</style>
<% layout('layouts/auth') %>

<%
  const interview = typeof locals.interview !== 'undefined' ? locals.interview : {};
  const questions = typeof locals.questions !== 'undefined' ? locals.questions : [];
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const candidateName = candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : 'Candidate';
  const jobTitle = job.title || 'N/A';
  const token = interview.token || interview.access_token || '';
  const timeLimit = interview.time_limit_per_question || 300;
%>

<div class="interview-container w-full" x-data="interviewApp()" x-cloak>

  <!-- Header Branding -->
  <div class="text-center mb-6">
    <h2 class="text-xl font-bold text-foreground"><%= candidateName %></h2>
    <p class="text-sm text-muted-foreground">
      <i data-lucide="briefcase" class="w-3.5 h-3.5 inline-block mr-1"></i>
      <%= jobTitle %>
    </p>
  </div>

  <!-- Interview Instructions (collapsible) -->
  <template x-if="!started && !submitted">
    <div class="mb-6">
      <div class="bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-800 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
          <i data-lucide="info" class="w-5 h-5 text-blue-500"></i>
          Interview Instructions
        </h3>
        <ul class="space-y-3 text-sm text-muted-foreground">
          <li class="flex items-start gap-2">
            <i data-lucide="hash" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
            <span>This interview has <strong class="text-foreground"><%= questions.length %> questions</strong>.</span>
          </li>
          <li class="flex items-start gap-2">
            <i data-lucide="timer" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
            <span>You have <strong class="text-foreground"><%= Math.floor(timeLimit / 60) %> minutes</strong> per question.</span>
          </li>
          <li class="flex items-start gap-2">
            <i data-lucide="type" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
            <span>A <strong class="text-foreground">text response</strong> is required for each question.</span>
          </li>
          <li class="flex items-start gap-2">
            <i data-lucide="alert-circle" class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5"></i>
            <span>You <strong class="text-foreground">cannot go back</strong> to previous questions once submitted.</span>
          </li>
          <li class="flex items-start gap-2">
            <i data-lucide="layers" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5"></i>
            <span>Questions are presented <strong class="text-foreground">one at a time</strong>.</span>
          </li>
        </ul>

        <div class="mt-6 text-center">
          <button @click="startInterview()" class="btn-primary px-8 py-3 text-base">
            <i data-lucide="play" class="w-5 h-5"></i>
            Start Interview
          </button>
        </div>
      </div>
    </div>
  </template>

  <!-- Interview In Progress -->
  <template x-if="started && !submitted">
    <div>
      <!-- Progress Bar -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-medium text-foreground">
            Question <span x-text="currentIndex + 1"></span> of <span x-text="questions.length"></span>
          </span>
          <span class="text-sm text-muted-foreground" x-text="Math.round(((currentIndex) / questions.length) * 100) + '% complete'"></span>
        </div>
        <div class="w-full h-2.5 bg-muted rounded-full overflow-hidden">
          <div class="h-full rounded-full bg-primary-800 transition-all duration-500"
               :style="'width: ' + ((currentIndex / questions.length) * 100) + '%'"></div>
        </div>
      </div>

      <!-- Question Card -->
      <div class="card p-6 mb-4">
        <!-- Timer -->
        <div class="flex items-center justify-between mb-6">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-muted text-sm font-medium text-foreground">
            <i data-lucide="hash" class="w-4 h-4"></i>
            Question <span x-text="currentIndex + 1"></span>
          </span>
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-bold question-timer"
                :class="timerSeconds <= 30 ? 'bg-red-100 dark:bg-red-950 timer-danger' : timerSeconds <= 60 ? 'bg-amber-100 dark:bg-amber-950 timer-warning' : 'bg-blue-100 dark:bg-blue-950 text-blue-700 dark:text-blue-300 timer-pulse'">
            <i data-lucide="clock" class="w-4 h-4"></i>
            <span x-text="formatTime(timerSeconds)"></span>
          </span>
        </div>

        <!-- Question Text -->
        <div class="mb-6">
          <p class="text-lg font-semibold text-foreground leading-relaxed" x-text="questions[currentIndex]?.text"></p>
        </div>

        <!-- Answer Text Area -->
        <div class="mb-4">
          <label class="form-label">Your Answer</label>
          <textarea
            x-model="answers[currentIndex]"
            rows="10"
            class="form-input w-full resize-y min-h-[200px]"
            placeholder="Type your answer here..."
            :disabled="saving"
          ></textarea>
          <div class="flex items-center justify-between mt-2">
            <span class="text-xs text-muted-foreground">
              <span x-text="(answers[currentIndex] || '').length"></span> characters
            </span>
            <span class="text-xs text-muted-foreground" x-show="saving">
              <i data-lucide="loader" class="w-3 h-3 inline-block animate-spin"></i> Saving...
            </span>
          </div>
        </div>

        <!-- Navigation Button -->
        <div class="flex items-center justify-end gap-3">
          <template x-if="currentIndex < questions.length - 1">
            <button @click="nextQuestion()" class="btn-primary px-6"
                    :disabled="!answers[currentIndex] || answers[currentIndex].trim() === '' || saving">
              Next Question
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
          </template>
          <template x-if="currentIndex === questions.length - 1">
            <button @click="submitInterview()" class="btn-primary px-6 bg-success hover:bg-green-700"
                    :disabled="!answers[currentIndex] || answers[currentIndex].trim() === '' || saving">
              <i data-lucide="send" class="w-4 h-4"></i>
              Submit Interview
            </button>
          </template>
        </div>
      </div>
    </div>
  </template>

  <!-- Interview Submitted / Thank You -->
  <template x-if="submitted">
    <div class="text-center py-12">
      <div class="w-20 h-20 rounded-full bg-success/20 flex items-center justify-center mx-auto mb-6">
        <i data-lucide="check-circle" class="w-10 h-10 text-success"></i>
      </div>
      <h2 class="text-2xl font-bold text-foreground mb-2">Interview Submitted!</h2>
      <p class="text-muted-foreground max-w-md mx-auto mb-6">
        Thank you, <strong><%= candidateName %></strong>. Your interview responses have been submitted successfully.
        Our team will review your answers and get back to you soon.
      </p>
      <p class="text-sm text-muted-foreground">You may now close this window.</p>
    </div>
  </template>

</div>

<%- contentFor('script') %>
<script>
function interviewApp() {
  const questionsData = <%- JSON.stringify(questions.map(function(q) {
    return { id: q.id, text: q.question_text || q.question || q.text || '' };
  })) %>;
  const token = '<%= token %>';
  const timeLimitSec = <%= timeLimit %>;

  return {
    started: false,
    submitted: false,
    saving: false,
    questions: questionsData,
    currentIndex: 0,
    answers: {},
    timerSeconds: timeLimitSec,
    timerInterval: null,

    startInterview() {
      this.started = true;
      this.startTimer();
      this.$nextTick(() => { lucide.createIcons(); });
    },

    startTimer() {
      this.timerSeconds = timeLimitSec;
      if (this.timerInterval) clearInterval(this.timerInterval);
      this.timerInterval = setInterval(() => {
        this.timerSeconds--;
        if (this.timerSeconds <= 0) {
          this.timerSeconds = 0;
          this.autoAdvance();
        }
      }, 1000);
    },

    formatTime(seconds) {
      const m = Math.floor(seconds / 60);
      const s = seconds % 60;
      return m.toString().padStart(2, '0') + ':' + s.toString().padStart(2, '0');
    },

    async saveAnswer() {
      const questionId = this.questions[this.currentIndex].id;
      const answerText = this.answers[this.currentIndex] || '';
      if (!answerText.trim()) return;

      this.saving = true;
      try {
        await fetch('/ai/interview/' + token + '/answer', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            question_id: questionId,
            answer_text: answerText
          })
        });
      } catch (e) {
        console.error('Failed to save answer:', e);
      }
      this.saving = false;
    },

    async nextQuestion() {
      await this.saveAnswer();
      if (this.currentIndex < this.questions.length - 1) {
        this.currentIndex++;
        this.startTimer();
        this.$nextTick(() => { lucide.createIcons(); });
      }
    },

    autoAdvance() {
      if (this.currentIndex < this.questions.length - 1) {
        this.nextQuestion();
      } else {
        this.submitInterview();
      }
    },

    async submitInterview() {
      await this.saveAnswer();
      if (this.timerInterval) clearInterval(this.timerInterval);

      this.saving = true;
      try {
        await fetch('/ai/interview/' + token + '/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ answers: this.answers })
        });
        this.submitted = true;
      } catch (e) {
        console.error('Failed to submit interview:', e);
        alert('There was an error submitting your interview. Please try again.');
      }
      this.saving = false;
      this.$nextTick(() => { lucide.createIcons(); });
    }
  };
}
</script>
