<%
  const interview = typeof locals.interview !== 'undefined' ? locals.interview : {};
  const questions = typeof locals.questions !== 'undefined' ? locals.questions : [];
  const answers = typeof locals.answers !== 'undefined' ? locals.answers : [];
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const candidateName = interview.candidate_name || interview.appln_full_name
    || (candidate.first_name ? candidate.first_name + ' ' + (candidate.last_name || '') : 'Candidate');
  const jobTitle = interview.job_title || job.title || 'N/A';

  const ivStatus = interview.interview_status || interview.status || 'invited';
  const ivStatusBadge = ivStatus === 'evaluated' ? 'badge-success'
    : ivStatus === 'submitted' ? 'badge-info'
    : ivStatus === 'passed' ? 'badge-success'
    : ivStatus === 'failed' ? 'badge-danger'
    : ivStatus === 'in_progress' ? 'badge-info'
    : ivStatus === 'invited' ? 'badge-warning'
    : 'badge-muted';

  const ivType = interview.interview_type || interview.type || 'hr';
  const typeBadgeClass = 'badge-muted';

  const totalScore = parseFloat(interview.total_score) || parseFloat(interview.overall_score) || 0;
  const commScore = parseFloat(interview.communication_score) || 0;
  const domainScore = parseFloat(interview.domain_knowledge_score) || parseFloat(interview.domain_score) || 0;
  const problemScore = parseFloat(interview.problem_solving_score) || 0;
  const confidenceScore = parseFloat(interview.confidence_score) || 0;

  // Parse JSON feedback safely
  function safeParse(val) {
    if (!val) return null;
    if (typeof val === 'object') return val;
    try { return JSON.parse(val); } catch(e) { return null; }
  }

  const feedbackRaw = interview.ai_feedback || '';
  const summaryRaw = interview.ai_summary || '';
  const feedbackObj = safeParse(feedbackRaw);
  const summaryObj = safeParse(summaryRaw);

  // Extract readable fields from JSON
  const performanceSummary = feedbackObj?.performanceSummary || summaryObj?.performanceSummary || '';
  const recommendation = feedbackObj?.recommendation || summaryObj?.recommendation || '';
  const recommendationJustification = feedbackObj?.recommendationJustification || summaryObj?.recommendationJustification || '';
  const strengthAreas = feedbackObj?.strengthAreas || summaryObj?.strengthAreas || [];
  const improvementAreas = feedbackObj?.improvementAreas || summaryObj?.improvementAreas || [];
  const competencyRatings = feedbackObj?.competencyRatings || summaryObj?.competencyRatings || {};
  const redFlags = feedbackObj?.redFlags || summaryObj?.redFlags || [];
  const culturalFit = feedbackObj?.culturalFitAssessment || summaryObj?.culturalFitAssessment || '';
  const plainFeedback = typeof feedbackRaw === 'string' && !feedbackObj ? feedbackRaw : '';
  const plainSummary = typeof summaryRaw === 'string' && !summaryObj ? summaryRaw : '';

  function scoreColor(s) {
    return s >= 75 ? 'text-success' : s >= 50 ? 'text-warning' : 'text-destructive';
  }
  function strokeColor(s) {
    return s >= 75 ? 'stroke-success' : s >= 50 ? 'stroke-warning' : 'stroke-destructive';
  }
  function bgColor(s) {
    return s >= 75 ? 'bg-success' : s >= 50 ? 'bg-warning' : 'bg-destructive';
  }

  const circumference = 2 * Math.PI * 40;
  function ringOffset(s) {
    return circumference - (s / 100) * circumference;
  }
%>

<!-- Back Button -->
<div class="mb-6">
  <a href="/ai-interview" class="btn-outline btn-sm inline-flex items-center gap-2">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Back to Interviews
  </a>
</div>

<!-- Candidate Info Header -->
<div class="card p-6 mb-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
        <span class="text-xl font-bold text-primary-800 dark:text-primary-200">
          <%= candidateName.charAt(0).toUpperCase() %>
        </span>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-foreground tracking-tight"><%= candidateName %></h1>
        <p class="text-sm text-muted-foreground mt-0.5">
          <i data-lucide="briefcase" class="w-3.5 h-3.5 inline-block mr-1"></i>
          <%= jobTitle %>
        </p>
        <div class="flex items-center gap-2 mt-2">
          <span class="<%= ivStatusBadge %>">
            <%= ivStatus.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
          </span>
          <span class="<%= typeBadgeClass %>">
            <%= ivType.charAt(0).toUpperCase() + ivType.slice(1) %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Score Rings Row -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
  <%
    const scoreRings = [
      { label: 'Total Score', value: totalScore },
      { label: 'Communication', value: commScore },
      { label: 'Domain Knowledge', value: domainScore },
      { label: 'Problem Solving', value: problemScore },
      { label: 'Confidence', value: confidenceScore },
    ];
  %>
  <% scoreRings.forEach(function(ring) { %>
    <div class="card p-4 flex flex-col items-center">
      <div class="relative w-24 h-24 mb-2">
        <svg class="w-24 h-24 -rotate-90" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" class="stroke-muted" opacity="0.2"></circle>
          <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" class="<%= strokeColor(ring.value) %>"
                  stroke-linecap="round"
                  stroke-dasharray="<%= circumference %>"
                  stroke-dashoffset="<%= ringOffset(ring.value) %>"></circle>
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-xl font-bold <%= scoreColor(ring.value) %>"><%= ring.value %>%</span>
        </div>
      </div>
      <p class="text-xs text-muted-foreground text-center font-medium"><%= ring.label %></p>
    </div>
  <% }); %>
</div>

<!-- Score Breakdown Progress Bars -->
<div class="card p-6 mb-6">
  <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
    <i data-lucide="bar-chart-3" class="w-5 h-5 text-primary-800 dark:text-primary-200"></i>
    Score Breakdown
  </h2>
  <div class="space-y-4">
    <%
      const breakdowns = [
        { label: 'Communication', value: commScore },
        { label: 'Domain Knowledge', value: domainScore },
        { label: 'Problem Solving', value: problemScore },
        { label: 'Confidence', value: confidenceScore },
      ];
    %>
    <% breakdowns.forEach(function(b) { %>
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm font-medium text-foreground"><%= b.label %></span>
          <span class="text-sm font-semibold <%= scoreColor(b.value) %>"><%= b.value %>%</span>
        </div>
        <div class="w-full h-2.5 bg-muted rounded-full overflow-hidden">
          <div class="h-full rounded-full <%= bgColor(b.value) %> transition-all duration-500" style="width: <%= b.value %>%"></div>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<!-- AI Analysis Dashboard -->
<% if (recommendation || performanceSummary || plainFeedback) { %>

<!-- Recommendation Banner -->
<div class="card p-5 mb-6 flex items-center justify-between" style="border-left: 4px solid <%= recommendation === 'Strong Hire' || recommendation === 'Hire' ? '#10b981' : recommendation === 'No Hire' ? '#ef4444' : '#f59e0b' %>;">
  <div>
    <h3 class="text-lg font-bold text-foreground">AI Recommendation</h3>
    <p class="text-sm text-muted-foreground mt-1"><%= recommendationJustification || performanceSummary || plainFeedback %></p>
  </div>
  <span class="px-4 py-2 rounded-lg text-sm font-bold
    <%= recommendation === 'Strong Hire' || recommendation === 'Hire' ? 'bg-green-100 text-green-700' :
       recommendation === 'No Hire' ? 'bg-red-100 text-red-700' :
       'bg-yellow-100 text-yellow-700' %>">
    <%= recommendation || 'Pending' %>
  </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Competency Ratings -->
  <% if (Object.keys(competencyRatings).length > 0) { %>
  <div class="card p-6">
    <h2 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="bar-chart-3" class="w-5 h-5 text-info"></i>
      Competency Ratings
    </h2>
    <div class="space-y-3">
      <% const compLabels = { technicalKnowledge: 'Technical Knowledge', problemSolving: 'Problem Solving', communication: 'Communication', teamwork: 'Teamwork', leadership: 'Leadership', adaptability: 'Adaptability', domainExpertise: 'Domain Expertise' }; %>
      <% Object.entries(competencyRatings).forEach(function([key, val]) { %>
        <% const pct = Math.round((parseFloat(val) / 5) * 100); %>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-foreground font-medium"><%= compLabels[key] || key %></span>
            <span class="font-bold <%= pct >= 60 ? 'text-green-600' : pct >= 40 ? 'text-yellow-600' : 'text-red-600' %>"><%= val %>/5</span>
          </div>
          <div class="w-full h-2 bg-muted rounded-full overflow-hidden">
            <div class="h-full rounded-full <%= pct >= 60 ? 'bg-green-500' : pct >= 40 ? 'bg-yellow-500' : 'bg-red-500' %>" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Strengths & Improvements -->
  <div class="card p-6">
    <% if (strengthAreas.length > 0) { %>
    <div class="mb-5">
      <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
        <span class="w-5 h-5 rounded-full bg-green-100 flex items-center justify-center"><i data-lucide="trending-up" class="w-3 h-3 text-green-600"></i></span>
        Strengths
      </h3>
      <div class="space-y-2">
        <% strengthAreas.forEach(function(s) { %>
          <div class="flex items-start gap-2 text-sm p-2 rounded-lg bg-green-50 dark:bg-green-900/10">
            <span class="text-green-500 mt-0.5">✓</span>
            <div>
              <span class="font-medium text-foreground"><%= typeof s === 'string' ? s : s.area || '' %></span>
              <% if (s.evidence) { %><p class="text-xs text-muted-foreground mt-0.5"><%= s.evidence %></p><% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (improvementAreas.length > 0) { %>
    <div>
      <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
        <span class="w-5 h-5 rounded-full bg-amber-100 flex items-center justify-center"><i data-lucide="alert-triangle" class="w-3 h-3 text-amber-600"></i></span>
        Areas for Improvement
      </h3>
      <div class="space-y-2">
        <% improvementAreas.forEach(function(a) { %>
          <div class="flex items-start gap-2 text-sm p-2 rounded-lg bg-amber-50 dark:bg-amber-900/10">
            <span class="text-amber-500 mt-0.5">!</span>
            <div>
              <span class="font-medium text-foreground"><%= typeof a === 'string' ? a : a.area || '' %></span>
              <% if (a.severity) { %><span class="ml-2 text-xs px-2 py-0.5 rounded bg-amber-100 text-amber-700"><%= a.severity %></span><% } %>
              <% if (a.evidence) { %><p class="text-xs text-muted-foreground mt-0.5"><%= a.evidence %></p><% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (strengthAreas.length === 0 && improvementAreas.length === 0 && plainFeedback) { %>
      <h3 class="text-sm font-semibold text-foreground mb-3">AI Analysis</h3>
      <p class="text-sm text-muted-foreground leading-relaxed"><%= plainFeedback.substring(0, 500) %></p>
    <% } %>
  </div>

  <% if (redFlags.length > 0) { %>
  <div class="card p-6 lg:col-span-2">
    <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
      <span class="w-5 h-5 rounded-full bg-red-100 flex items-center justify-center"><i data-lucide="flag" class="w-3 h-3 text-red-600"></i></span>
      Red Flags
    </h3>
    <div class="flex flex-wrap gap-2">
      <% redFlags.forEach(function(f) { %>
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-red-50 text-red-600 border border-red-200"><%= f %></span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if (culturalFit) { %>
  <div class="card p-6 lg:col-span-2">
    <h3 class="text-sm font-semibold text-foreground mb-2 flex items-center gap-2">
      <i data-lucide="users" class="w-4 h-4 text-muted-foreground"></i> Cultural Fit Assessment
    </h3>
    <p class="text-sm text-muted-foreground"><%= culturalFit %></p>
  </div>
  <% } %>

</div>
<% } else { %>
<div class="card p-6 mb-6 text-center text-sm text-muted-foreground">
  <p>AI evaluation is in progress or not yet available.</p>
</div>
<% } %>

<!-- Questions & Answers -->
<div class="card p-6 mb-6">
  <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center gap-2">
    <i data-lucide="help-circle" class="w-5 h-5 text-primary-800 dark:text-primary-200"></i>
    Questions & Answers
  </h2>

  <% if (questions.length > 0) { %>
    <div class="space-y-6">
      <% questions.forEach(function(q, idx) { %>
        <%
          const answer = answers.find(function(a) {
            return a.question_id === q.id || a.questionId === q.id;
          }) || {};
          const answerText = answer.answer_text || answer.answer || '';
          const answerScore = answer.score || answer.answer_score || 0;
          const answerFeedback = answer.ai_feedback || answer.feedback || '';
          const keywordRelevance = answer.keyword_relevance || answer.keyword_relevance_score || 0;
        %>
        <div class="border border-border rounded-xl overflow-hidden">
          <!-- Question Header -->
          <div class="bg-muted/30 px-5 py-4 border-b border-border">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 dark:bg-primary-900 text-xs font-bold text-primary-800 dark:text-primary-200">
                  <%= idx + 1 %>
                </span>
                <h3 class="text-sm font-semibold text-foreground"><%= q.question_text || q.question || q.text || '' %></h3>
              </div>
              <% if (answerScore > 0) { %>
                <span class="text-sm font-bold <%= scoreColor(answerScore) %>"><%= answerScore %>%</span>
              <% } %>
            </div>
          </div>

          <!-- Answer -->
          <div class="px-5 py-4">
            <% if (answerText) { %>
              <div class="mb-4">
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-2 font-medium">Candidate's Answer</p>
                <div class="text-sm text-foreground leading-relaxed bg-muted/20 rounded-lg p-4 whitespace-pre-line"><%= answerText %></div>
              </div>
            <% } else { %>
              <p class="text-sm text-muted-foreground italic mb-4">No answer provided.</p>
            <% } %>

            <!-- Score & Keyword Relevance -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1.5 font-medium">Answer Score</p>
                <div class="flex items-center gap-2">
                  <div class="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= bgColor(answerScore) %>" style="width: <%= answerScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreColor(answerScore) %>"><%= answerScore %>%</span>
                </div>
              </div>
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1.5 font-medium">Keyword Relevance</p>
                <div class="flex items-center gap-2">
                  <div class="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= bgColor(keywordRelevance) %>" style="width: <%= keywordRelevance %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreColor(keywordRelevance) %>"><%= keywordRelevance %>%</span>
                </div>
              </div>
            </div>

            <!-- AI Feedback for Answer -->
            <% if (answerFeedback) { %>
              <div>
                <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1.5 font-medium">AI Feedback</p>
                <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line"><%= answerFeedback %></div>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <p class="text-sm text-muted-foreground text-center py-8">No questions available for this interview.</p>
  <% } %>
</div>

<!-- Action Buttons -->
<div class="flex flex-wrap items-center gap-3">
  <form action="/ai-interview/<%= interview.id %>/shortlist" method="POST" class="inline">
    <button type="submit" class="btn-primary">
      <i data-lucide="star" class="w-4 h-4"></i>
      Shortlist
    </button>
  </form>
  <form action="/ai-interview/<%= interview.id %>/schedule" method="POST" class="inline">
    <button type="submit" class="btn-outline">
      <i data-lucide="calendar" class="w-4 h-4"></i>
      Schedule Interview
    </button>
  </form>
  <form action="/ai-interview/<%= interview.id %>/reject" method="POST" class="inline"
        onsubmit="return confirm('Are you sure you want to reject this candidate?')">
    <button type="submit" class="btn-outline text-destructive border-destructive hover:bg-destructive hover:text-white">
      <i data-lucide="x-circle" class="w-4 h-4"></i>
      Reject
    </button>
  </form>
  <form action="/ai-interview/<%= interview.id %>/pool" method="POST" class="inline">
    <button type="submit" class="btn-outline">
      <i data-lucide="archive" class="w-4 h-4"></i>
      Keep in Pool
    </button>
  </form>
</div>
