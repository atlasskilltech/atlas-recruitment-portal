<%
  const interview = typeof locals.interview !== 'undefined' ? locals.interview : {};
  const questions = typeof locals.questions !== 'undefined' ? locals.questions : [];
  const answers = typeof locals.answers !== 'undefined' ? locals.answers : [];
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const candidateName = interview.candidate_name || interview.appln_full_name
    || (candidate.first_name ? candidate.first_name + ' ' + (candidate.last_name || '') : 'Candidate');
  const jobTitle = interview.job_title || job.title || 'N/A';

  const ivStatus = interview.interview_status || interview.status || 'invited';
  const ivStatusBadge = ivStatus === 'evaluated' ? 'badge badge-success'
    : ivStatus === 'submitted' ? 'badge badge-info'
    : ivStatus === 'passed' ? 'badge badge-success'
    : ivStatus === 'failed' ? 'badge badge-danger'
    : ivStatus === 'in_progress' ? 'badge badge-info'
    : ivStatus === 'invited' ? 'badge badge-warning'
    : 'badge badge-muted';

  const ivType = interview.interview_type || interview.type || 'hr';
  const typeBadgeClass = 'badge badge-muted';

  // Parse JSON feedback safely, handling nested { raw: "..." } structures
  function safeParse(val) {
    if (!val) return null;
    if (typeof val === 'object' && val !== null) {
      if (val.raw && typeof val.raw === 'string') {
        try { return JSON.parse(val.raw); } catch(e) { return val; }
      }
      return val;
    }
    try {
      const parsed = JSON.parse(val);
      if (parsed && parsed.raw && typeof parsed.raw === 'string') {
        try { return JSON.parse(parsed.raw); } catch(e) { return parsed; }
      }
      return parsed;
    } catch(e) { return null; }
  }

  const feedbackRaw = interview.ai_feedback || '';
  const summaryRaw = interview.ai_summary || '';
  const feedbackObj = safeParse(feedbackRaw);
  const summaryObj = safeParse(summaryRaw);

  // Try DB columns first, then fall back to parsed feedback scores
  const fbScores = feedbackObj?.competencyRatings || summaryObj?.competencyRatings || {};
  const fbOverall = parseFloat(feedbackObj?.overallScore || feedbackObj?.averageScore || summaryObj?.overallScore || summaryObj?.averageScore) || 0;

  const totalScore = parseFloat(interview.total_score) || parseFloat(interview.overall_score) || fbOverall || 0;
  const commScore = parseFloat(interview.communication_score) || (parseFloat(fbScores.communication) / 5 * 100) || 0;
  const domainScore = parseFloat(interview.domain_knowledge_score) || parseFloat(interview.domain_score) || (parseFloat(fbScores.domainExpertise || fbScores.technicalKnowledge) / 5 * 100) || 0;
  const problemScore = parseFloat(interview.problem_solving_score) || (parseFloat(fbScores.problemSolving) / 5 * 100) || 0;
  const confidenceScore = parseFloat(interview.confidence_score) || (parseFloat(fbScores.leadership || fbScores.adaptability) / 5 * 100) || 0;

  // Extract readable fields from JSON
  const performanceSummary = feedbackObj?.performanceSummary || summaryObj?.performanceSummary || '';
  const recommendation = feedbackObj?.recommendation || summaryObj?.recommendation || '';
  const recommendationJustification = feedbackObj?.recommendationJustification || summaryObj?.recommendationJustification || '';
  const strengthAreas = feedbackObj?.strengthAreas || summaryObj?.strengthAreas || [];
  const improvementAreas = feedbackObj?.improvementAreas || summaryObj?.improvementAreas || [];
  const competencyRatings = feedbackObj?.competencyRatings || summaryObj?.competencyRatings || {};
  const redFlags = feedbackObj?.redFlags || summaryObj?.redFlags || [];
  const culturalFit = feedbackObj?.culturalFitAssessment || summaryObj?.culturalFitAssessment || '';
  const plainFeedback = typeof feedbackRaw === 'string' && !feedbackObj ? feedbackRaw : '';
  const plainSummary = typeof summaryRaw === 'string' && !summaryObj ? summaryRaw : '';

  function scoreColor(s) {
    return s >= 75 ? 'text-success' : s >= 50 ? 'text-warning' : 'text-danger';
  }
  function strokeColorHex(s) {
    return s >= 75 ? 'var(--accent-primary)' : s >= 50 ? 'var(--accent-warning)' : 'var(--accent-danger)';
  }
  function barColorClass(s) {
    return s >= 75 ? 'green' : s >= 50 ? 'yellow' : 'red';
  }

  const circumference = 2 * Math.PI * 40;
  function ringOffset(s) {
    return circumference - (s / 100) * circumference;
  }
%>

<!-- Back Button -->
<div class="mb-lg">
  <a href="/ai-interview" class="btn btn-outline btn-sm">
    <i data-lucide="arrow-left"></i>
    Back to Interviews
  </a>
</div>

<!-- Candidate Info Header -->
<div class="card p-lg mb-lg">
  <div class="flex items-center justify-between gap-md" style="flex-wrap: wrap;">
    <div class="flex items-center gap-md">
      <div class="avatar avatar-lg avatar-gradient">
        <%= candidateName.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h1 class="text-2xl font-bold"><%= candidateName %></h1>
        <p class="text-sm text-secondary mt-sm">
          <i data-lucide="briefcase" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:4px;"></i>
          <%= jobTitle %>
        </p>
        <div class="flex items-center gap-sm mt-sm">
          <span class="<%= ivStatusBadge %>">
            <%= ivStatus.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
          </span>
          <span class="<%= typeBadgeClass %>">
            <%= ivType.charAt(0).toUpperCase() + ivType.slice(1) %>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Score Rings Row -->
<div class="stats-row mb-lg">
  <%
    const scoreRings = [
      { label: 'Total Score', value: totalScore },
      { label: 'Communication', value: commScore },
      { label: 'Domain Knowledge', value: domainScore },
      { label: 'Problem Solving', value: problemScore },
      { label: 'Confidence', value: confidenceScore },
    ];
  %>
  <% scoreRings.forEach(function(ring) { %>
    <div class="card p-md flex flex-col items-center" style="justify-content: center;">
      <div class="score-ring" style="width:96px;height:96px;margin-bottom:8px;">
        <svg width="96" height="96" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" stroke="var(--border-color)" opacity="0.2"></circle>
          <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" stroke="<%= strokeColorHex(ring.value) %>"
                  stroke-linecap="round"
                  stroke-dasharray="<%= circumference %>"
                  stroke-dashoffset="<%= ringOffset(ring.value) %>"></circle>
        </svg>
        <div class="score-value">
          <span class="text-xl font-bold <%= scoreColor(ring.value) %>"><%= ring.value %>%</span>
        </div>
      </div>
      <p class="text-xs text-secondary text-center font-medium"><%= ring.label %></p>
    </div>
  <% }); %>
</div>

<!-- Score Breakdown Progress Bars -->
<div class="card p-lg mb-lg">
  <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
    <i data-lucide="bar-chart-3" style="width:20px;height:20px;color:var(--accent-secondary);"></i>
    Score Breakdown
  </h2>
  <div style="display:flex;flex-direction:column;gap:16px;">
    <%
      const breakdowns = [
        { label: 'Communication', value: commScore },
        { label: 'Domain Knowledge', value: domainScore },
        { label: 'Problem Solving', value: problemScore },
        { label: 'Confidence', value: confidenceScore },
      ];
    %>
    <% breakdowns.forEach(function(b) { %>
      <div>
        <div class="flex items-center justify-between mb-sm">
          <span class="text-sm font-medium"><%= b.label %></span>
          <span class="text-sm font-semibold <%= scoreColor(b.value) %>"><%= b.value %>%</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill <%= barColorClass(b.value) %>" style="width: <%= b.value %>%"></div>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<!-- AI Analysis Dashboard -->
<% if (recommendation || performanceSummary || plainFeedback) { %>

<!-- Recommendation Banner -->
<div class="card p-lg mb-lg flex items-center justify-between" style="border-left: 4px solid <%= recommendation === 'Strong Hire' || recommendation === 'Hire' ? 'var(--accent-primary)' : recommendation === 'No Hire' ? 'var(--accent-danger)' : 'var(--accent-warning)' %>;">
  <div>
    <h3 class="text-lg font-bold">AI Recommendation</h3>
    <p class="text-sm text-secondary mt-sm"><%= recommendationJustification || performanceSummary || plainFeedback %></p>
  </div>
  <span class="badge <%= recommendation === 'Strong Hire' || recommendation === 'Hire' ? 'badge-success' :
     recommendation === 'No Hire' ? 'badge-danger' :
     'badge-warning' %>" style="padding: 8px 16px; font-size: 0.85rem;">
    <%= recommendation || 'Pending' %>
  </span>
</div>

<div class="grid-2 mb-lg" style="gap:24px;">

  <!-- Competency Ratings -->
  <% if (Object.keys(competencyRatings).length > 0) { %>
  <div class="card p-lg">
    <h2 class="text-sm font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="bar-chart-3" style="width:20px;height:20px;color:var(--accent-secondary);"></i>
      Competency Ratings
    </h2>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <% const compLabels = { technicalKnowledge: 'Technical Knowledge', problemSolving: 'Problem Solving', communication: 'Communication', teamwork: 'Teamwork', leadership: 'Leadership', adaptability: 'Adaptability', domainExpertise: 'Domain Expertise' }; %>
      <% Object.entries(competencyRatings).forEach(function([key, val]) { %>
        <% const pct = Math.round((parseFloat(val) / 5) * 100); %>
        <div>
          <div class="flex justify-between text-sm mb-sm">
            <span class="font-medium"><%= compLabels[key] || key %></span>
            <span class="font-bold <%= scoreColor(pct) %>"><%= val %>/5</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill <%= barColorClass(pct) %>" style="width: <%= pct %>%"></div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <% } %>

  <!-- Strengths & Improvements -->
  <div class="card p-lg">
    <% if (strengthAreas.length > 0) { %>
    <div class="mb-md">
      <h3 class="text-sm font-semibold mb-sm flex items-center gap-sm">
        <span style="width:20px;height:20px;border-radius:50%;background:rgba(16,185,129,0.1);display:inline-flex;align-items:center;justify-content:center;">
          <i data-lucide="trending-up" style="width:12px;height:12px;color:var(--accent-primary);"></i>
        </span>
        Strengths
      </h3>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% strengthAreas.forEach(function(s) { %>
          <div class="flex items-start gap-sm text-sm" style="padding:8px;border-radius:var(--radius-md);background:rgba(16,185,129,0.05);">
            <span style="color:var(--accent-primary);margin-top:2px;">&#10003;</span>
            <div>
              <span class="font-medium"><%= typeof s === 'string' ? s : s.area || '' %></span>
              <% if (s.evidence) { %><p class="text-xs text-muted mt-sm"><%= s.evidence %></p><% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (improvementAreas.length > 0) { %>
    <div>
      <h3 class="text-sm font-semibold mb-sm flex items-center gap-sm">
        <span style="width:20px;height:20px;border-radius:50%;background:rgba(245,158,11,0.1);display:inline-flex;align-items:center;justify-content:center;">
          <i data-lucide="alert-triangle" style="width:12px;height:12px;color:var(--accent-warning);"></i>
        </span>
        Areas for Improvement
      </h3>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <% improvementAreas.forEach(function(a) { %>
          <div class="flex items-start gap-sm text-sm" style="padding:8px;border-radius:var(--radius-md);background:rgba(245,158,11,0.05);">
            <span style="color:var(--accent-warning);margin-top:2px;">!</span>
            <div>
              <span class="font-medium"><%= typeof a === 'string' ? a : a.area || '' %></span>
              <% if (a.severity) { %><span class="badge badge-warning" style="margin-left:8px;"><%= a.severity %></span><% } %>
              <% if (a.evidence) { %><p class="text-xs text-muted mt-sm"><%= a.evidence %></p><% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <% if (strengthAreas.length === 0 && improvementAreas.length === 0 && plainFeedback) { %>
      <h3 class="text-sm font-semibold mb-sm">AI Analysis</h3>
      <p class="text-sm text-secondary" style="line-height:1.6;"><%= plainFeedback.substring(0, 500) %></p>
    <% } %>
  </div>

  <% if (redFlags.length > 0) { %>
  <div class="card p-lg" style="grid-column: 1 / -1;">
    <h3 class="text-sm font-semibold mb-sm flex items-center gap-sm">
      <span style="width:20px;height:20px;border-radius:50%;background:rgba(239,68,68,0.1);display:inline-flex;align-items:center;justify-content:center;">
        <i data-lucide="flag" style="width:12px;height:12px;color:var(--accent-danger);"></i>
      </span>
      Red Flags
    </h3>
    <div class="flex flex-wrap gap-sm">
      <% redFlags.forEach(function(f) { %>
        <span class="badge badge-danger"><%= f %></span>
      <% }); %>
    </div>
  </div>
  <% } %>

  <% if (culturalFit) { %>
  <div class="card p-lg" style="grid-column: 1 / -1;">
    <h3 class="text-sm font-semibold mb-sm flex items-center gap-sm">
      <i data-lucide="users" style="width:16px;height:16px;color:var(--text-muted);"></i> Cultural Fit Assessment
    </h3>
    <p class="text-sm text-secondary"><%= culturalFit %></p>
  </div>
  <% } %>

</div>
<% } else { %>
<div class="card p-lg mb-lg text-center text-sm text-secondary">
  <p>AI evaluation is in progress or not yet available.</p>
</div>
<% } %>

<!-- Questions & Answers -->
<div class="card p-lg mb-lg">
  <h2 class="text-lg font-semibold mb-lg flex items-center gap-sm">
    <i data-lucide="help-circle" style="width:20px;height:20px;color:var(--accent-secondary);"></i>
    Questions & Answers
  </h2>

  <% if (questions.length > 0) { %>
    <div style="display:flex;flex-direction:column;gap:24px;">
      <% questions.forEach(function(q, idx) { %>
        <%
          const answer = q.answer || answers.find(function(a) {
            return a.question_id === q.id || a.questionId === q.id;
          }) || {};
          const answerText = answer.answer_text || answer.answer || '';
          const answerScore = parseFloat(answer.score) || parseFloat(answer.answer_score) || parseFloat(answer.ai_score) || 0;
          const answerFeedback = answer.ai_feedback || answer.feedback || '';
          const keywordRelevance = parseFloat(answer.keyword_relevance) || parseFloat(answer.keyword_relevance_score) || 0;
        %>
        <div style="border:1px solid var(--border-color);border-radius:var(--radius-lg);overflow:hidden;">
          <!-- Question Header -->
          <div style="background:var(--bg-tertiary);padding:16px 20px;border-bottom:1px solid var(--border-color);">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-sm">
                <span class="avatar avatar-sm avatar-gradient" style="width:28px;height:28px;font-size:0.7rem;">
                  <%= idx + 1 %>
                </span>
                <h3 class="text-sm font-semibold"><%= q.question_text || q.question || q.text || '' %></h3>
              </div>
              <% if (answerScore > 0) { %>
                <span class="text-sm font-bold <%= scoreColor(answerScore) %>"><%= answerScore %>%</span>
              <% } %>
            </div>
          </div>

          <!-- Answer -->
          <div style="padding:16px 20px;">
            <% if (answerText) { %>
              <div class="mb-md">
                <p class="text-xs text-muted uppercase tracking-wide mb-sm font-medium">Candidate's Answer</p>
                <div class="text-sm" style="line-height:1.6;background:var(--bg-tertiary);border-radius:var(--radius-md);padding:16px;white-space:pre-line;"><%= answerText %></div>
              </div>
            <% } else { %>
              <p class="text-sm text-secondary mb-md" style="font-style:italic;">No answer provided.</p>
            <% } %>

            <!-- Score & Keyword Relevance -->
            <div class="grid-2 mb-md" style="gap:16px;">
              <div>
                <p class="text-xs text-muted uppercase tracking-wide mb-sm font-medium">Answer Score</p>
                <div class="flex items-center gap-sm">
                  <div class="progress-bar flex-1">
                    <div class="progress-fill <%= barColorClass(answerScore) %>" style="width: <%= answerScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreColor(answerScore) %>"><%= answerScore %>%</span>
                </div>
              </div>
              <div>
                <p class="text-xs text-muted uppercase tracking-wide mb-sm font-medium">Keyword Relevance</p>
                <div class="flex items-center gap-sm">
                  <div class="progress-bar flex-1">
                    <div class="progress-fill <%= barColorClass(keywordRelevance) %>" style="width: <%= keywordRelevance %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreColor(keywordRelevance) %>"><%= keywordRelevance %>%</span>
                </div>
              </div>
            </div>

            <!-- AI Feedback for Answer -->
            <% if (answerFeedback) { %>
              <div>
                <p class="text-xs text-muted uppercase tracking-wide mb-sm font-medium">AI Feedback</p>
                <div class="text-sm text-secondary" style="white-space:pre-line;line-height:1.6;"><%= answerFeedback %></div>
              </div>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <p class="text-sm text-secondary text-center" style="padding:32px 0;">No questions available for this interview.</p>
  <% } %>
</div>

<!-- Action Buttons -->
<div class="flex flex-wrap items-center gap-sm">
  <form action="/ai-interview/<%= interview.id %>/shortlist" method="POST" class="inline">
    <button type="submit" class="btn btn-primary">
      <i data-lucide="star"></i>
      Shortlist
    </button>
  </form>
  <a href="/schedules/create/<%= interview.candidate_id %>" class="btn btn-outline">
    <i data-lucide="calendar"></i>
    Schedule Interview
  </a>
  <form action="/ai-interview/<%= interview.id %>/reject" method="POST" class="inline"
        onsubmit="return confirm('Are you sure you want to reject this candidate?')">
    <button type="submit" class="btn btn-danger">
      <i data-lucide="x-circle"></i>
      Reject
    </button>
  </form>
  <form action="/ai-interview/<%= interview.id %>/pool" method="POST" class="inline">
    <button type="submit" class="btn btn-outline">
      <i data-lucide="archive"></i>
      Keep in Pool
    </button>
  </form>
</div>
