<%
  const _jobs = typeof jobs !== 'undefined' ? jobs : [];
  const _totalJobs = typeof totalJobs !== 'undefined' ? totalJobs : 0;
  const _academicJobs = typeof academicJobs !== 'undefined' ? academicJobs : 0;
  const _adminJobs = typeof adminJobs !== 'undefined' ? adminJobs : 0;
  const _totalApplicants = typeof totalApplicants !== 'undefined' ? totalApplicants : 0;
  const _jobRoles = typeof jobRoles !== 'undefined' ? jobRoles : [];
  const _filters = typeof filters !== 'undefined' ? filters : {};
%>

<!-- Page Header — tight spacing like reference -->
<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
  <div>
    <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin:0;">Job Openings</h1>
    <p style="font-size:0.8rem;color:var(--text-secondary);margin-top:2px;">Manage and view all recruitment positions</p>
  </div>
  <div style="display:flex;align-items:center;gap:24px;">
    <div style="text-align:center;">
      <div style="font-size:1.4rem;font-weight:700;color:var(--accent-primary);line-height:1;"><%= _totalApplicants.toLocaleString() %></div>
      <div style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-top:2px;">Total Applicants</div>
    </div>
    <div style="text-align:center;">
      <div style="font-size:1.4rem;font-weight:700;color:var(--accent-secondary);line-height:1;"><%= _totalJobs %></div>
      <div style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-top:2px;">Positions</div>
    </div>
  </div>
</div>

<!-- Filter Bar — compact single row -->
<div style="display:flex;gap:8px;padding:10px 16px;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-lg);margin-bottom:12px;flex-wrap:wrap;align-items:flex-end;">
  <div style="flex:2;min-width:180px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="search" style="width:11px;height:11px;"></i> Search
    </label>
    <input type="text" id="filter-search" placeholder="Search by post name..."
           value="<%= _filters.search || '' %>"
           style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);"
           onkeyup="if(event.key==='Enter') applyFilters()">
  </div>
  <div style="flex:1;min-width:140px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="layers" style="width:11px;height:11px;"></i> Scope
    </label>
    <select id="filter-scope" onchange="applyFilters()" style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
      <option value="">All Scopes</option>
      <option value="1" <%= _filters.scope === '1' ? 'selected' : '' %>>Academics / Teaching</option>
      <option value="2" <%= _filters.scope === '2' ? 'selected' : '' %>>Administration / Non-Teaching</option>
    </select>
  </div>
  <div style="flex:1;min-width:140px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="user-check" style="width:11px;height:11px;"></i> Job Role
    </label>
    <select id="filter-role" onchange="applyFilters()" style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
      <option value="">All Roles</option>
      <% _jobRoles.forEach(function(role) { %>
        <option value="<%= role %>" <%= _filters.role === role ? 'selected' : '' %>><%= role %></option>
      <% }); %>
    </select>
  </div>
  <button class="btn btn-outline btn-sm" onclick="clearFilters()" style="padding:6px 12px;white-space:nowrap;">
    <i data-lucide="x" style="width:13px;height:13px;"></i> Clear
  </button>
</div>

<!-- Status Info Bar — compact dark bar -->
<div style="display:flex;background:var(--bg-sidebar);border-radius:var(--radius-lg);padding:10px 20px;margin-bottom:16px;gap:32px;align-items:center;flex-wrap:wrap;">
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Total Positions</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _totalJobs %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Academics</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _academicJobs %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Administration</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _adminJobs %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Total Applicants</div>
    <div style="display:inline-block;padding:1px 8px;border-radius:var(--radius-sm);font-size:0.8rem;font-weight:600;background:rgba(16,185,129,0.2);color:#34d399;"><%= _totalApplicants.toLocaleString() %></div>
  </div>
  <div style="margin-left:auto;">
    <span style="font-size:0.75rem;color:var(--text-sidebar-muted);">Showing <strong style="color:white;"><%= _jobs.length %></strong> positions</span>
  </div>
</div>

<!-- Job Cards Grid — compact cards matching reference -->
<% if (_jobs.length > 0) { %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));gap:12px;">
    <% _jobs.forEach(function(job) { %>
      <div style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:12px 14px;cursor:pointer;transition:all 0.15s ease;border-left:3px solid <%= job.scope_id === 1 ? 'var(--accent-primary)' : job.scope_id === 2 ? 'var(--accent-secondary)' : 'var(--accent-warning)' %>;"
           onmouseover="this.style.boxShadow='var(--shadow-md)';this.style.transform='translateY(-1px)';"
           onmouseout="this.style.boxShadow='none';this.style.transform='none';"
           onclick="window.location.href='/candidates?job_id=<%= job.id %>'">

        <!-- Row 1: Scope badge + count -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid var(--border-light);">
          <div style="display:inline-flex;align-items:center;gap:4px;font-size:0.7rem;font-weight:700;color:<%= job.scope_id === 1 ? 'var(--accent-primary)' : 'var(--accent-secondary)' %>;background:<%= job.scope_id === 1 ? 'rgba(16,185,129,0.1)' : 'rgba(59,130,246,0.1)' %>;padding:2px 7px;border-radius:var(--radius-sm);text-transform:uppercase;letter-spacing:0.02em;">
            <i data-lucide="<%= job.scope_id === 1 ? 'graduation-cap' : 'building-2' %>" style="width:11px;height:11px;"></i>
            <%= job.scope_id === 1 ? 'ACADEMICS' : 'ADMIN' %>
          </div>
          <div style="font-size:0.75rem;font-weight:600;background:var(--bg-tertiary);padding:2px 8px;border-radius:var(--radius-sm);color:var(--text-primary);border:1px solid var(--border-color);">
            #<%= job.applicant_count %>
          </div>
        </div>

        <!-- Row 2: Post Name -->
        <div style="font-size:0.88rem;font-weight:600;color:var(--text-primary);line-height:1.35;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
          <%= job.post_name || job.short_desc || 'Untitled Position' %>
        </div>

        <!-- Row 3: Details — compact -->
        <div style="display:flex;flex-direction:column;gap:4px;font-size:0.75rem;color:var(--text-secondary);padding-top:8px;border-top:1px solid var(--border-light);">
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="layers" style="width:13px;height:13px;color:var(--text-muted);flex-shrink:0;"></i>
            <span><%= job.scope %></span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="users" style="width:13px;height:13px;color:var(--text-muted);flex-shrink:0;"></i>
            <span><%= job.applicant_count %> Applicants</span>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="empty-state">
    <i data-lucide="briefcase"></i>
    <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:4px;">No Job Openings Found</h3>
    <p>No positions match your current filters.</p>
    <button class="btn btn-primary" style="margin-top:16px;" onclick="clearFilters()">Clear Filters</button>
  </div>
<% } %>

<script>
function applyFilters() {
  var search = document.getElementById('filter-search').value;
  var scope = document.getElementById('filter-scope').value;
  var role = document.getElementById('filter-role').value;
  var params = [];
  if (search) params.push('search=' + encodeURIComponent(search));
  if (scope) params.push('scope=' + scope);
  if (role) params.push('role=' + encodeURIComponent(role));
  window.location.href = '/admin/jobs' + (params.length ? '?' + params.join('&') : '');
}
function clearFilters() {
  window.location.href = '/admin/jobs';
}
</script>
