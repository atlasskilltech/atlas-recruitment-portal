<%
  const _jobs = typeof jobs !== 'undefined' ? jobs : [];
  const _totalJobs = typeof totalJobs !== 'undefined' ? totalJobs : 0;
  const _academicJobs = typeof academicJobs !== 'undefined' ? academicJobs : 0;
  const _adminJobs = typeof adminJobs !== 'undefined' ? adminJobs : 0;
  const _totalApplicants = typeof totalApplicants !== 'undefined' ? totalApplicants : 0;
  const _jobRoles = typeof jobRoles !== 'undefined' ? jobRoles : [];
  const _filters = typeof filters !== 'undefined' ? filters : {};
%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-lg" style="flex-wrap:wrap;gap:16px;">
  <div>
    <h1 class="text-2xl font-bold">Job Openings</h1>
    <p class="text-sm text-secondary" style="margin-top:4px;">Manage and view all recruitment positions</p>
  </div>
  <div class="flex items-center gap-md">
    <div class="flex items-center gap-lg" style="padding-right:16px;border-right:1px solid var(--border-color);">
      <div style="text-align:center;">
        <div style="font-size:1.25rem;font-weight:700;color:var(--accent-primary);"><%= _totalApplicants.toLocaleString() %></div>
        <div style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Total Applicants</div>
      </div>
      <div style="text-align:center;">
        <div style="font-size:1.25rem;font-weight:700;color:var(--accent-secondary);"><%= _totalJobs %></div>
        <div style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Positions</div>
      </div>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filters-bar mb-md">
  <div class="filter-item">
    <label><i data-lucide="search" style="width:12px;height:12px;"></i> Search</label>
    <input type="text" id="filter-search" placeholder="Search by post name..."
           value="<%= _filters.search || '' %>"
           onkeyup="if(event.key==='Enter') applyFilters()">
  </div>
  <div class="filter-item">
    <label><i data-lucide="layers" style="width:12px;height:12px;"></i> Scope</label>
    <select id="filter-scope" onchange="applyFilters()">
      <option value="">All Scopes</option>
      <option value="1" <%= _filters.scope === '1' ? 'selected' : '' %>>Academics / Teaching</option>
      <option value="2" <%= _filters.scope === '2' ? 'selected' : '' %>>Administration / Non-Teaching</option>
    </select>
  </div>
  <div class="filter-item">
    <label><i data-lucide="user-check" style="width:12px;height:12px;"></i> Job Role</label>
    <select id="filter-role" onchange="applyFilters()">
      <option value="">All Roles</option>
      <% _jobRoles.forEach(function(role) { %>
        <option value="<%= role %>" <%= _filters.role === role ? 'selected' : '' %>><%= role %></option>
      <% }); %>
    </select>
  </div>
  <div style="align-self:flex-end;">
    <button class="btn btn-outline btn-sm" onclick="clearFilters()">
      <i data-lucide="x" style="width:14px;height:14px;"></i> Clear
    </button>
  </div>
</div>

<!-- Status Info Bar -->
<div style="display:flex;background:var(--bg-sidebar);border-radius:var(--radius-lg);padding:14px 24px;margin-bottom:24px;gap:40px;align-items:center;flex-wrap:wrap;">
  <div>
    <div style="font-size:0.7rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.05em;">Total Positions</div>
    <div style="font-size:1rem;font-weight:600;color:white;"><%= _totalJobs %></div>
  </div>
  <div>
    <div style="font-size:0.7rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.05em;">Academics</div>
    <div style="font-size:1rem;font-weight:600;color:white;"><%= _academicJobs %></div>
  </div>
  <div>
    <div style="font-size:0.7rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.05em;">Administration</div>
    <div style="font-size:1rem;font-weight:600;color:white;"><%= _adminJobs %></div>
  </div>
  <div>
    <div style="font-size:0.7rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.05em;">Total Applicants</div>
    <div style="display:inline-block;padding:2px 10px;border-radius:var(--radius-sm);font-size:0.85rem;font-weight:600;background:rgba(16,185,129,0.2);color:#34d399;"><%= _totalApplicants.toLocaleString() %></div>
  </div>
  <div style="margin-left:auto;display:flex;gap:8px;">
    <span style="font-size:0.8rem;color:var(--text-sidebar-muted);">Showing <strong style="color:white;"><%= _jobs.length %></strong> positions</span>
  </div>
</div>

<!-- Job Cards Grid -->
<% if (_jobs.length > 0) { %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));gap:16px;">
    <% _jobs.forEach(function(job) { %>
      <div class="card" style="padding:16px;cursor:pointer;transition:all 0.15s ease;border-left:3px solid <%= job.scope_id === 1 ? 'var(--accent-primary)' : job.scope_id === 2 ? 'var(--accent-secondary)' : 'var(--accent-warning)' %>;"
           onmouseover="this.style.boxShadow='var(--shadow-md)';this.style.transform='translateY(-2px)';"
           onmouseout="this.style.boxShadow='var(--shadow-sm)';this.style.transform='translateY(0)';"
           onclick="window.location.href='/candidates?job_id=<%= job.id %>'">

        <!-- Header: Post Name + Applicant Count -->
        <div class="flex items-center justify-between" style="margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid var(--border-light);">
          <div style="flex:1;min-width:0;">
            <% if (job.post_name) { %>
              <div style="display:inline-flex;align-items:center;gap:4px;font-size:0.75rem;font-weight:700;color:<%= job.scope_id === 1 ? 'var(--accent-primary)' : 'var(--accent-secondary)' %>;background:<%= job.scope_id === 1 ? 'rgba(16,185,129,0.1)' : 'rgba(59,130,246,0.1)' %>;padding:3px 8px;border-radius:var(--radius-sm);text-transform:uppercase;letter-spacing:0.02em;">
                <i data-lucide="<%= job.scope_id === 1 ? 'graduation-cap' : 'building-2' %>" style="width:12px;height:12px;"></i>
                <%= job.scope_id === 1 ? 'ACADEMICS' : 'ADMIN' %>
              </div>
            <% } %>
          </div>
          <div style="font-size:0.8rem;font-weight:600;background:var(--bg-tertiary);padding:4px 10px;border-radius:var(--radius-sm);color:var(--text-primary);border:1px solid var(--border-color);">
            #<%= job.applicant_count %>
          </div>
        </div>

        <!-- Post Name -->
        <div style="margin-bottom:10px;">
          <div class="font-semibold" style="font-size:0.9rem;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
            <%= job.post_name || job.short_desc || 'Untitled Position' %>
          </div>
          <% if (job.short_desc && job.post_name && job.short_desc !== job.post_name) { %>
            <div class="text-xs text-secondary" style="margin-top:4px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;">
              <%= job.short_desc %>
            </div>
          <% } %>
        </div>

        <!-- Details -->
        <div style="display:flex;flex-direction:column;gap:6px;font-size:0.8rem;color:var(--text-secondary);padding-top:10px;border-top:1px solid var(--border-light);">
          <!-- Scope -->
          <div class="flex items-center gap-sm">
            <i data-lucide="layers" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span><%= job.scope %></span>
          </div>

          <!-- Experience -->
          <div class="flex items-center gap-sm">
            <i data-lucide="clock" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span><%= job.applicant_count %> Applicants</span>
          </div>

          <% if (job.location) { %>
            <div class="flex items-center gap-sm">
              <i data-lucide="map-pin" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
              <span><%= job.location %></span>
            </div>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="empty-state">
    <i data-lucide="briefcase"></i>
    <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:4px;">No Job Openings Found</h3>
    <p>No positions match your current filters.</p>
    <button class="btn btn-primary" style="margin-top:16px;" onclick="clearFilters()">Clear Filters</button>
  </div>
<% } %>

<script>
function applyFilters() {
  var search = document.getElementById('filter-search').value;
  var scope = document.getElementById('filter-scope').value;
  var role = document.getElementById('filter-role').value;
  var params = [];
  if (search) params.push('search=' + encodeURIComponent(search));
  if (scope) params.push('scope=' + scope);
  if (role) params.push('role=' + encodeURIComponent(role));
  window.location.href = '/admin/jobs' + (params.length ? '?' + params.join('&') : '');
}

function clearFilters() {
  window.location.href = '/admin/jobs';
}
</script>
