<%
  const _job = typeof job !== 'undefined' ? job : {};
  const _stats = typeof stats !== 'undefined' ? stats : {};
  const _matches = typeof topMatches !== 'undefined' ? topMatches : [];
  const _applied = typeof appliedCandidates !== 'undefined' ? appliedCandidates : [];
  const _funnel = typeof funnel !== 'undefined' ? funnel : {};
  const _applicantCount = typeof applicantCount !== 'undefined' ? applicantCount : 0;
  const _view = typeof view !== 'undefined' ? view : 'applied';
  const _stage = typeof stage !== 'undefined' && stage ? stage : null;

  // Filter candidates based on selected funnel stage
  // NOTE: AI Resume Match thresholds: 50% for applied candidates, 90% for non-applied
  function filterByStage(candidates, stg) {
    if (!stg) return candidates;
    switch (stg) {
      case 'applied':
        return candidates; // All applied candidates
      case 'cvMatch':
        if (_view === 'matches') {
          return candidates.filter(c => (parseFloat(c.match_score) || 0) >= 90);
        }
        return candidates.filter(c => (parseFloat(c.match_score) || 0) >= 50);
      case 'interviewTaken':
        return candidates.filter(c => c.interview_status && ['evaluated', 'submitted', 'passed', 'failed'].includes(c.interview_status));
      case 'interviewPass':
        return candidates.filter(c => (parseFloat(c.interview_score) || 0) >= 75);
      default:
        return candidates;
    }
  }

  const _candidates = filterByStage(_view === 'matches' ? _matches : _applied, _stage);

  const fmt = (n) => (n != null ? Number(n).toLocaleString() : '0');
  const qualMap = { '1': 'PhD', '2': 'Masters', '3': 'Bachelors', '4': 'Diploma', '5': 'Any others' };
  function getQual(val) { return val ? (qualMap[String(val)] || val) : '--'; }

  const lastScanned = _stats.last_scanned
    ? new Date(_stats.last_scanned).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit', hour12: true })
    : null;

  function scoreColor(s) { return s >= 75 ? 'color:var(--accent-primary)' : s >= 50 ? 'color:var(--accent-warning)' : 'color:var(--accent-danger)'; }
  function statusBadge(s) {
    if (!s) return '';
    const map = { 'eligible': 'badge-success', 'strong_fit': 'badge-success', 'moderate_fit': 'badge-warning', 'weak_fit': 'badge-danger', 'rejected': 'badge-danger', 'hold': 'badge-warning' };
    return map[s] || 'badge-muted';
  }
  function statusLabel(s) { return s ? s.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) : '--'; }
%>

<!-- Header -->
<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:12px;">
  <div>
    <a href="/admin/jobs" style="display:inline-flex;align-items:center;gap:6px;font-size:0.8rem;color:var(--text-muted);margin-bottom:8px;text-decoration:none;">
      <i data-lucide="arrow-left" style="width:14px;height:14px;"></i> Back
    </a>
    <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin:0;"><%= _job.post_name %></h1>
    <div style="display:flex;align-items:center;gap:12px;margin-top:4px;flex-wrap:wrap;">
      <span style="font-size:0.85rem;color:var(--text-secondary);"><%= _job.scope %></span>
      <% if (_job.jd_file_path || _job.jd_file) { %>
        <a href="<%= _job.jd_file_path || _job.jd_file %>" target="_blank" style="display:inline-flex;align-items:center;gap:4px;font-size:0.75rem;font-weight:500;color:var(--accent-primary);background:rgba(16,185,129,0.1);padding:3px 10px;border-radius:var(--radius-sm);text-decoration:none;">
          <i data-lucide="file-text" style="width:13px;height:13px;"></i> JD Attached
        </a>
      <% } else { %>
        <span style="display:inline-flex;align-items:center;gap:4px;font-size:0.75rem;color:var(--text-muted);">
          <i data-lucide="file-x" style="width:13px;height:13px;"></i> No JD File
        </span>
      <% } %>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
    <% if (lastScanned) { %>
      <span style="font-size:0.75rem;color:var(--text-muted);">Last scanned: <%= lastScanned %></span>
    <% } %>
    <a href="/admin/jobs/<%= _job.id %>?refresh=1" class="btn btn-primary btn-sm">
      <i data-lucide="refresh-cw" style="width:14px;height:14px;"></i> Refresh Scan
    </a>
  </div>
</div>

<!-- View Selector Dropdown (after header, before funnel) -->
<div style="margin-bottom:16px;display:flex;align-items:center;gap:12px;">
  <label style="font-size:0.8rem;font-weight:600;color:var(--text-secondary);white-space:nowrap;">Show Candidates:</label>
  <select id="view-selector" style="padding:8px 14px;border:1px solid var(--border-color);border-radius:var(--radius-md);font-size:0.85rem;font-family:inherit;background:var(--bg-secondary);color:var(--text-primary);min-width:280px;cursor:pointer;">
    <option value="applied" <%= _view === 'applied' ? 'selected' : '' %>>Applied for Position (<%= _applied.length %>)</option>
    <option value="matches" <%= _view === 'matches' ? 'selected' : '' %>>AI Matches from Entire Database (<%= _matches.length %>)</option>
  </select>
</div>

<!-- Funnel Stats -->
<div style="display:flex;align-items:stretch;gap:0;margin-bottom:24px;">
  <a href="/admin/jobs/<%= _job.id %>?view=<%= _view %>&stage=applied" class="funnel-card" data-stage="applied" style="flex:1;background:var(--bg-secondary);border:2px solid <%= _stage === 'applied' ? '#3b82f6' : 'var(--border-color)' %>;border-radius:var(--radius-lg);padding:16px 12px;text-align:center;text-decoration:none;cursor:pointer;transition:all 0.15s ease;<%= _stage === 'applied' ? 'box-shadow:0 0 0 3px rgba(59,130,246,0.15);' : '' %>">
    <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;"><%= _view === 'matches' ? 'Total Matches' : 'Applied' %></div>
    <div style="font-size:1.6rem;font-weight:700;color:#3b82f6;"><%= fmt(_funnel.applied) %></div>
  </a>
  <div style="display:flex;align-items:center;padding:0 4px;color:var(--border-color);font-size:1.2rem;">&rsaquo;</div>
  <a href="/admin/jobs/<%= _job.id %>?view=<%= _view %>&stage=cvMatch" class="funnel-card" data-stage="cvMatch" style="flex:1;background:var(--bg-secondary);border:2px solid <%= _stage === 'cvMatch' ? '#10b981' : 'var(--border-color)' %>;border-radius:var(--radius-lg);padding:16px 12px;text-align:center;text-decoration:none;cursor:pointer;transition:all 0.15s ease;<%= _stage === 'cvMatch' ? 'box-shadow:0 0 0 3px rgba(16,185,129,0.15);' : '' %>">
    <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">CV Match</div>
    <div style="font-size:1.6rem;font-weight:700;color:#10b981;"><%= fmt(_funnel.cvMatch) %></div>
  </a>
  <div style="display:flex;align-items:center;padding:0 4px;color:var(--border-color);font-size:1.2rem;">&rsaquo;</div>
  <a href="/admin/jobs/<%= _job.id %>?view=<%= _view %>&stage=interviewTaken" class="funnel-card" data-stage="interviewTaken" style="flex:1;background:var(--bg-secondary);border:2px solid <%= _stage === 'interviewTaken' ? '#f59e0b' : 'var(--border-color)' %>;border-radius:var(--radius-lg);padding:16px 12px;text-align:center;text-decoration:none;cursor:pointer;transition:all 0.15s ease;<%= _stage === 'interviewTaken' ? 'box-shadow:0 0 0 3px rgba(245,158,11,0.15);' : '' %>">
    <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">AI Interview Taken</div>
    <div style="font-size:1.6rem;font-weight:700;color:#f59e0b;"><%= fmt(_funnel.interviewTaken) %></div>
  </a>
  <div style="display:flex;align-items:center;padding:0 4px;color:var(--border-color);font-size:1.2rem;">&rsaquo;</div>
  <a href="/admin/jobs/<%= _job.id %>?view=<%= _view %>&stage=interviewPass" class="funnel-card" data-stage="interviewPass" style="flex:1;background:var(--bg-secondary);border:2px solid <%= _stage === 'interviewPass' ? '#ef4444' : 'var(--border-color)' %>;border-radius:var(--radius-lg);padding:16px 12px;text-align:center;text-decoration:none;cursor:pointer;transition:all 0.15s ease;<%= _stage === 'interviewPass' ? 'box-shadow:0 0 0 3px rgba(239,68,68,0.15);' : '' %>">
    <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px;">AI Interview Result 75%+</div>
    <div style="font-size:1.6rem;font-weight:700;color:#ef4444;"><%= fmt(_funnel.interviewPass) %></div>
  </a>
</div>

<% if (_stage) {
  const stageLabels = { applied: 'Applied', cvMatch: 'CV Match', interviewTaken: 'AI Interview Taken', interviewPass: 'AI Interview Result 75%+' };
%>
<div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;font-size:0.85rem;">
  <span style="color:var(--text-secondary);">Showing:</span>
  <span style="font-weight:600;color:var(--text-primary);"><%= stageLabels[_stage] || _stage %></span>
  <span style="color:var(--text-muted);">(<%= _candidates.length %> candidates)</span>
  <a href="/admin/jobs/<%= _job.id %>?view=<%= _view %>" style="font-size:0.8rem;color:var(--accent-primary);text-decoration:none;margin-left:4px;">
    <i data-lucide="x-circle" style="width:14px;height:14px;vertical-align:middle;"></i> Clear filter
  </a>
</div>
<% } %>

<!-- Selection Action Bar -->
<div id="selection-bar" style="display:none;position:sticky;top:60px;z-index:45;background:linear-gradient(135deg,#1e293b,#334155);border-radius:var(--radius-lg);padding:12px 20px;margin-bottom:16px;box-shadow:var(--shadow-lg);">
  <div style="display:flex;align-items:center;justify-content:space-between;">
    <div style="display:flex;align-items:center;gap:12px;">
      <input type="checkbox" id="select-all" style="width:18px;height:18px;accent-color:var(--accent-primary);cursor:pointer;">
      <span style="color:white;font-size:0.85rem;font-weight:500;"><span id="selected-count">0</span> selected</span>
    </div>
    <button id="send-btn" class="btn btn-primary btn-sm" style="display:flex;align-items:center;gap:6px;">
      <i data-lucide="send" style="width:14px;height:14px;"></i> Send AI Interview to Selected
    </button>
  </div>
</div>

<!-- Candidates -->
<form id="bulk-invite-form" method="POST" action="/admin/jobs/<%= _job.id %>/bulk-invite">
<% if (_candidates.length > 0) { %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));gap:16px;">
    <% _candidates.forEach(function(m) { %>
      <%
        const mScore = parseFloat(m.match_score) || parseFloat(m.screening_score) || 0;
        const iScore = parseFloat(m.interview_score) || 0;
        const aiStatus = m.match_status || m.screening_status || null;
        const parts = (m.appln_full_name || '').trim().split(/\s+/);
        const initials = (parts[0] ? parts[0].charAt(0).toUpperCase() : '?') + (parts.length > 1 ? parts[parts.length-1].charAt(0).toUpperCase() : '');
        const avatarBg = mScore >= 75 ? 'linear-gradient(135deg,#10b981,#059669)' : mScore >= 50 ? 'linear-gradient(135deg,#f59e0b,#d97706)' : 'linear-gradient(135deg,#64748b,#475569)';
      %>
      <div class="candidate-card" style="background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:20px;transition:all 0.15s ease;position:relative;">
        <div style="position:absolute;top:12px;right:12px;">
          <input type="checkbox" name="candidate_ids" value="<%= m.candidate_id %>" class="candidate-checkbox" style="width:18px;height:18px;accent-color:var(--accent-primary);cursor:pointer;">
        </div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;padding-right:30px;">
          <div style="width:36px;height:36px;border-radius:50%;background:<%= avatarBg %>;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:white;flex-shrink:0;"><%= initials %></div>
          <span style="font-size:0.95rem;font-weight:600;color:var(--text-primary);"><%= m.appln_full_name || 'N/A' %></span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;font-size:0.8rem;color:var(--text-secondary);margin-bottom:14px;">
          <% if (mScore > 0) { %>
          <div style="display:flex;align-items:center;gap:8px;">
            <i data-lucide="trophy" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span>AI Match: <strong style="<%= scoreColor(mScore) %>"><%= Number(mScore).toFixed(1) %>%</strong></span>
          </div>
          <% } %>
          <div style="display:flex;align-items:center;gap:8px;">
            <i data-lucide="graduation-cap" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span>Qualification: <strong><%= getQual(m.appln_high_qualification) %></strong></span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <i data-lucide="mail" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= m.appln_email || '--' %></span>
          </div>
          <% if (iScore > 0) { %>
          <div style="display:flex;align-items:center;gap:8px;">
            <i data-lucide="message-square" style="width:14px;height:14px;color:var(--text-muted);flex-shrink:0;"></i>
            <span>Interview: <strong style="<%= scoreColor(iScore) %>"><%= Number(iScore).toFixed(1) %>%</strong></span>
          </div>
          <% } %>
        </div>
        <% if (aiStatus) { %>
          <div style="margin-bottom:14px;"><span class="badge <%= statusBadge(aiStatus) %>"><%= statusLabel(aiStatus) %></span></div>
        <% } %>
        <a href="/candidates/<%= m.candidate_id %>" class="btn btn-primary btn-sm" style="text-decoration:none;">
          <i data-lucide="user" style="width:14px;height:14px;"></i> View Profile
        </a>
      </div>
    <% }); %>
  </div>
<% } else { %>
  <div class="empty-state">
    <i data-lucide="users"></i>
    <h3 style="font-size:1rem;font-weight:600;margin-bottom:4px;">No candidates found</h3>
    <p class="text-sm text-muted"><%= _view === 'matches' ? 'Click "Refresh Scan" to scan candidates.' : 'No candidates have applied for this position.' %></p>
  </div>
<% } %>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // View selector dropdown
  var viewSelector = document.getElementById('view-selector');
  if (viewSelector) {
    viewSelector.addEventListener('change', function() {
      var stage = '<%= _stage || '' %>';
      var url = '/admin/jobs/<%= _job.id %>?view=' + this.value;
      if (stage) url += '&stage=' + stage;
      window.location.href = url;
    });
  }

  // Funnel card hover effects
  document.querySelectorAll('.funnel-card').forEach(function(card) {
    var activeStage = '<%= _stage || '' %>';
    var cardStage = card.getAttribute('data-stage');
    var colors = { applied: 'rgba(59,130,246,0.15)', cvMatch: 'rgba(16,185,129,0.15)', interviewTaken: 'rgba(245,158,11,0.15)', interviewPass: 'rgba(239,68,68,0.15)' };
    var defaultShadow = (cardStage === activeStage) ? '0 0 0 3px ' + (colors[cardStage] || 'none') : 'none';

    card.addEventListener('mouseover', function() {
      this.style.transform = 'translateY(-2px)';
      this.style.boxShadow = 'var(--shadow-md)';
    });
    card.addEventListener('mouseout', function() {
      this.style.transform = 'none';
      this.style.boxShadow = defaultShadow;
    });
  });

  // Candidate card hover effects
  document.querySelectorAll('.candidate-card').forEach(function(card) {
    card.addEventListener('mouseover', function() {
      this.style.boxShadow = 'var(--shadow-md)';
      this.style.transform = 'translateY(-2px)';
    });
    card.addEventListener('mouseout', function() {
      this.style.boxShadow = 'none';
      this.style.transform = 'none';
    });
  });

  // Selection bar
  var bar = document.getElementById('selection-bar');
  var countEl = document.getElementById('selected-count');
  var selectAllEl = document.getElementById('select-all');
  var sendBtn = document.getElementById('send-btn');
  var form = document.getElementById('bulk-invite-form');
  var checkboxes = document.querySelectorAll('.candidate-checkbox');

  function updateBar() {
    var checked = document.querySelectorAll('.candidate-checkbox:checked');
    countEl.textContent = checked.length;
    bar.style.display = checked.length > 0 ? 'block' : 'none';
    selectAllEl.checked = checked.length === checkboxes.length && checkboxes.length > 0;
    selectAllEl.indeterminate = checked.length > 0 && checked.length < checkboxes.length;
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', updateBar);
  });

  selectAllEl.addEventListener('change', function() {
    checkboxes.forEach(function(cb) { cb.checked = selectAllEl.checked; });
    updateBar();
  });

  sendBtn.addEventListener('click', function() {
    var checked = document.querySelectorAll('.candidate-checkbox:checked');
    if (checked.length === 0) { alert('Please select at least one candidate.'); return; }
    if (confirm('Send AI Interview invitation to ' + checked.length + ' candidate(s)?')) {
      form.submit();
    }
  });
});
</script>
