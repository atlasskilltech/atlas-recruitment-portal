<%
  const _interviews = typeof interviews !== 'undefined' ? interviews : [];
  const _totalInterviews = typeof totalInterviews !== 'undefined' ? totalInterviews : 0;
  const _evaluated = typeof evaluated !== 'undefined' ? evaluated : 0;
  const _passed = typeof passed !== 'undefined' ? passed : 0;
  const _avgScore = typeof avgScore !== 'undefined' ? avgScore : 0;
  const _jobRoles = typeof jobRoles !== 'undefined' ? jobRoles : [];
  const _filters = typeof filters !== 'undefined' ? filters : {};

  const qualMap = { '1': 'PhD', '2': 'Masters', '3': 'Bachelors', '4': 'Diploma', '5': 'Others' };
  function getQual(val) { return val ? (qualMap[String(val)] || val) : '--'; }
  function scoreColor(s) { return s >= 75 ? 'color:var(--accent-primary)' : s >= 50 ? 'color:var(--accent-warning)' : 'color:var(--accent-danger)'; }
  function statusBadge(s) {
    const map = { 'evaluated': 'badge-success', 'submitted': 'badge-info', 'passed': 'badge-success', 'failed': 'badge-danger', 'in_progress': 'badge-warning' };
    return map[s] || 'badge-muted';
  }
  function formatDate(d) {
    if (!d) return '--';
    var dt = new Date(d);
    return dt.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) + ', ' +
           dt.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true });
  }
%>

<!-- Page Header -->
<div style="margin-bottom:16px;">
  <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin:0;">AI Interview Taken</h1>
  <p style="font-size:0.8rem;color:var(--text-secondary);margin-top:2px;">View all AI interviews conducted across all positions</p>
</div>

<!-- Filter Bar -->
<form id="filter-form" method="GET" action="/admin/interviews" style="display:flex;gap:8px;padding:10px 16px;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-lg);margin-bottom:12px;flex-wrap:wrap;align-items:flex-end;">
  <div style="flex:2;min-width:160px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="search" style="width:11px;height:11px;"></i> Search
    </label>
    <input type="text" name="search" placeholder="Search by name or email..."
           value="<%= _filters.search || '' %>"
           style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
  </div>
  <div style="flex:1;min-width:140px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="user-check" style="width:11px;height:11px;"></i> Job Role
    </label>
    <select name="role" style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
      <option value="">All Roles</option>
      <% _jobRoles.forEach(function(role) { %>
        <option value="<%= role %>" <%= _filters.role === role ? 'selected' : '' %>><%= role %></option>
      <% }); %>
    </select>
  </div>
  <div style="flex:1;min-width:120px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="activity" style="width:11px;height:11px;"></i> Status
    </label>
    <select name="status" style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
      <option value="">All Statuses</option>
      <option value="evaluated" <%= _filters.status === 'evaluated' ? 'selected' : '' %>>Evaluated</option>
      <option value="submitted" <%= _filters.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
      <option value="in_progress" <%= _filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
      <option value="passed" <%= _filters.status === 'passed' ? 'selected' : '' %>>Passed</option>
      <option value="failed" <%= _filters.status === 'failed' ? 'selected' : '' %>>Failed</option>
    </select>
  </div>
  <div style="flex:1;min-width:130px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="calendar" style="width:11px;height:11px;"></i> From Date
    </label>
    <input type="date" name="date_from" value="<%= _filters.date_from || '' %>"
           style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
  </div>
  <div style="flex:1;min-width:130px;">
    <label style="display:flex;align-items:center;gap:4px;font-size:0.65rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:2px;">
      <i data-lucide="calendar" style="width:11px;height:11px;"></i> To Date
    </label>
    <input type="date" name="date_to" value="<%= _filters.date_to || '' %>"
           style="width:100%;padding:6px 10px;border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:0.8rem;font-family:inherit;background:var(--bg-primary);color:var(--text-primary);">
  </div>
  <div style="display:flex;gap:6px;align-self:flex-end;">
    <button type="submit" class="btn btn-primary btn-sm" style="padding:6px 12px;white-space:nowrap;">
      <i data-lucide="search" style="width:13px;height:13px;"></i> Filter
    </button>
    <a href="/admin/interviews" class="btn btn-outline btn-sm" style="padding:6px 12px;white-space:nowrap;">
      <i data-lucide="x" style="width:13px;height:13px;"></i> Clear
    </a>
  </div>
</form>

<!-- Status Info Bar -->
<div style="display:flex;background:var(--bg-sidebar);border-radius:var(--radius-lg);padding:10px 20px;margin-bottom:16px;gap:32px;align-items:center;flex-wrap:wrap;">
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Total Interviews</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _totalInterviews %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Evaluated</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _evaluated %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Score 75%+</div>
    <div style="display:inline-block;padding:1px 8px;border-radius:var(--radius-sm);font-size:0.8rem;font-weight:600;background:rgba(16,185,129,0.2);color:#34d399;"><%= _passed %></div>
  </div>
  <div>
    <div style="font-size:0.6rem;color:var(--text-sidebar-muted);text-transform:uppercase;letter-spacing:0.06em;">Avg Score</div>
    <div style="font-size:0.95rem;font-weight:600;color:white;"><%= _avgScore %>%</div>
  </div>
  <div style="margin-left:auto;">
    <span style="font-size:0.75rem;color:var(--text-sidebar-muted);">Showing <strong style="color:white;"><%= _interviews.length %></strong> interviews</span>
  </div>
</div>

<!-- Interview Cards Grid -->
<% if (_interviews.length > 0) { %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(300px, 1fr));gap:12px;">
    <% _interviews.forEach(function(iv) {
      const score = parseFloat(iv.total_score) || 0;
      const matchScore = parseFloat(iv.job_match_score) || 0;
      const parts = (iv.appln_full_name || '').trim().split(/\s+/);
      const initials = (parts[0] ? parts[0].charAt(0).toUpperCase() : '?') + (parts.length > 1 ? parts[parts.length-1].charAt(0).toUpperCase() : '');
      const avatarBg = score >= 75 ? 'linear-gradient(135deg,#10b981,#059669)' : score >= 50 ? 'linear-gradient(135deg,#f59e0b,#d97706)' : 'linear-gradient(135deg,#64748b,#475569)';
    %>
      <a href="/admin/interviews/<%= iv.interview_id %>" style="display:block;text-decoration:none;color:inherit;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:16px;cursor:pointer;transition:all 0.15s ease;"
         onmouseover="this.style.borderColor='var(--accent-primary)';this.style.boxShadow='var(--shadow-md)';this.style.transform='translateY(-1px)';"
         onmouseout="this.style.borderColor='var(--border-color)';this.style.boxShadow='none';this.style.transform='none';">

        <!-- Name & Avatar -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
          <div style="width:36px;height:36px;border-radius:50%;background:<%= avatarBg %>;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:white;flex-shrink:0;"><%= initials %></div>
          <div style="flex:1;min-width:0;">
            <div style="font-size:0.9rem;font-weight:600;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= iv.appln_full_name || 'N/A' %></div>
            <div style="font-size:0.7rem;color:var(--text-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= iv.job_role %></div>
          </div>
          <span class="badge <%= statusBadge(iv.interview_status) %>" style="font-size:0.65rem;flex-shrink:0;">
            <%= (iv.interview_status || '').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
          </span>
        </div>

        <!-- Scores Row -->
        <div style="display:flex;gap:8px;margin-bottom:12px;padding-top:10px;border-top:1px solid var(--border-light);">
          <div style="flex:1;text-align:center;">
            <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px;">Score</div>
            <div style="font-size:1rem;font-weight:700;<%= scoreColor(score) %>"><%= score %>%</div>
          </div>
          <div style="flex:1;text-align:center;">
            <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px;">Comm</div>
            <div style="font-size:0.8rem;font-weight:600;<%= scoreColor(parseFloat(iv.communication_score) || 0) %>"><%= parseFloat(iv.communication_score) || 0 %>%</div>
          </div>
          <div style="flex:1;text-align:center;">
            <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px;">Domain</div>
            <div style="font-size:0.8rem;font-weight:600;<%= scoreColor(parseFloat(iv.domain_knowledge_score) || 0) %>"><%= parseFloat(iv.domain_knowledge_score) || 0 %>%</div>
          </div>
          <div style="flex:1;text-align:center;">
            <div style="font-size:0.6rem;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px;">Problem</div>
            <div style="font-size:0.8rem;font-weight:600;<%= scoreColor(parseFloat(iv.problem_solving_score) || 0) %>"><%= parseFloat(iv.problem_solving_score) || 0 %>%</div>
          </div>
        </div>

        <!-- Details -->
        <div style="display:flex;flex-direction:column;gap:5px;font-size:0.75rem;color:var(--text-secondary);">
          <% if (matchScore > 0) { %>
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="trophy" style="width:12px;height:12px;color:var(--text-muted);flex-shrink:0;"></i>
            <span>Job Match: <strong style="<%= scoreColor(matchScore) %>"><%= matchScore %>%</strong></span>
          </div>
          <% } %>
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="graduation-cap" style="width:12px;height:12px;color:var(--text-muted);flex-shrink:0;"></i>
            <span>Qualification: <strong><%= getQual(iv.appln_high_qualification) %></strong></span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="mail" style="width:12px;height:12px;color:var(--text-muted);flex-shrink:0;"></i>
            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= iv.appln_email || '--' %></span>
          </div>
          <div style="display:flex;align-items:center;gap:6px;">
            <i data-lucide="calendar" style="width:12px;height:12px;color:var(--text-muted);flex-shrink:0;"></i>
            <span><%= formatDate(iv.started_at) %></span>
          </div>
        </div>

        <% if (iv.match_status) { %>
          <div style="margin-top:10px;">
            <span class="badge <%= iv.match_status === 'strong_fit' ? 'badge-success' : iv.match_status === 'moderate_fit' ? 'badge-warning' : 'badge-danger' %>" style="font-size:0.65rem;">
              <%= (iv.match_status || '').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
            </span>
          </div>
        <% } %>
      </a>
    <% }); %>
  </div>
<% } else { %>
  <div class="empty-state">
    <i data-lucide="mic-off"></i>
    <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:4px;">No Interviews Found</h3>
    <p>No AI interviews match your current filters.</p>
    <a href="/admin/interviews" class="btn btn-primary" style="margin-top:16px;">Clear Filters</a>
  </div>
<% } %>
