<div class="flex justify-center items-center" style="min-height: 60vh;">
  <div class="card text-center" style="max-width: 480px; width: 100%; padding: 48px 32px;">
    <!-- Error Icon -->
    <div class="flex justify-center mb-md">
      <div style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; <%= statusCode === 404 ? 'background: #fffbeb; color: #f59e0b;' : 'background: #fef2f2; color: #ef4444;' %>">
        <% if (statusCode === 404) { %>
          <svg style="width: 40px; height: 40px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
          </svg>
        <% } else { %>
          <svg style="width: 40px; height: 40px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z" />
          </svg>
        <% } %>
      </div>
    </div>

    <!-- Error Text -->
    <h1 class="text-2xl font-bold mb-md" style="font-size: 4rem; color: var(--accent-primary);"><%= statusCode %></h1>
    <h2 class="text-xl font-bold mb-md"><%= title %></h2>
    <p class="text-muted mb-lg">
      <%= message %>
    </p>

    <!-- Error details in development mode -->
    <% if (stack) { %>
      <div class="mb-lg" style="text-align: left; padding: 16px; border-radius: var(--radius-lg); background: #fef2f2; border: 1px solid #fecaca; overflow: auto; max-height: 192px;">
        <pre style="font-family: var(--font-mono); font-size: 0.7rem; color: #dc2626; white-space: pre-wrap; word-break: break-word;"><%= stack %></pre>
      </div>
    <% } %>

    <!-- Actions -->
    <div class="flex items-center justify-center" style="gap: 12px; flex-wrap: wrap;">
      <a href="/dashboard" class="btn btn-primary">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        Back to Dashboard
      </a>
      <% if (statusCode >= 500) { %>
        <button onclick="window.location.reload()" class="btn btn-outline">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" />
          </svg>
          Try Again
        </button>
      <% } %>
    </div>
  </div>
</div>
