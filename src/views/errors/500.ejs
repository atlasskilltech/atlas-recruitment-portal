<div class="text-center animate-slide-up">
  <!-- 500 Icon -->
  <div class="inline-flex items-center justify-center w-20 h-20 bg-red-50 dark:bg-red-900/20 rounded-full mb-6">
    <svg class="w-10 h-10 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Zm0 13.036h.008v.008H12v-.008Z" />
    </svg>
  </div>

  <!-- Error Text -->
  <h1 class="text-7xl font-bold gradient-text mb-2">500</h1>
  <h2 class="text-xl font-semibold text-foreground mb-2">Something Went Wrong</h2>
  <p class="text-muted-foreground text-sm mb-8">
    An unexpected error occurred. Our team has been notified and is working on a fix.
  </p>

  <!-- Error details in development mode -->
  <% if (typeof error !== 'undefined' && error && (typeof env !== 'undefined' && env === 'development')) { %>
    <div class="mb-8 text-left p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 overflow-auto max-h-48 custom-scrollbar">
      <p class="text-xs font-mono text-red-700 dark:text-red-300 font-semibold mb-2"><%= error.message || error %></p>
      <% if (error.stack) { %>
        <pre class="text-xxs font-mono text-red-600 dark:text-red-400 whitespace-pre-wrap break-words"><%= error.stack %></pre>
      <% } %>
    </div>
  <% } %>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
    <a href="/dashboard" class="btn-primary">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
      </svg>
      Back to Dashboard
    </a>
    <button onclick="window.location.reload()" class="btn-outline">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" />
      </svg>
      Try Again
    </button>
  </div>
</div>
