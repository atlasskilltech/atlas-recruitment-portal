<%
  layout = 'layouts/auth';
  const application = typeof locals.application !== 'undefined' ? locals.application : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const candidateName = candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : (candidate.name || application.appln_full_name || 'Candidate');
  const appStatus = (application.status || application.appln_status_new || 'applied').toLowerCase();
  const stages = [
    { key: 'applied',      label: 'Applied',       icon: 'file-text',    desc: 'Your application has been received' },
    { key: 'under_review', label: 'Under Review',   icon: 'search',       desc: 'Our team is reviewing your application' },
    { key: 'ai_screening', label: 'AI Screening',   icon: 'brain',        desc: 'AI-powered skills and qualifications analysis' },
    { key: 'interview',    label: 'Interview',      icon: 'monitor',      desc: 'Interview stage of the recruitment process' },
    { key: 'decision',     label: 'Decision',       icon: 'check-circle', desc: 'Final hiring decision' },
  ];
  const statusMap = {
    'new': 0, 'applied': 0, 'under_review': 1, 'review': 1, 'reviewing': 1,
    'screening': 2, 'ai_screening': 2, 'eligible': 2, 'ai_eligible': 2,
    'interview': 3, 'interview_pending': 3, 'interview_passed': 3, 'interviewed': 3,
    'decision': 4, 'shortlisted': 4, 'selected': 4, 'hired': 4, 'offer_released': 4,
  };
  const currentStageIdx = statusMap[appStatus] != null ? statusMap[appStatus] : 0;
  const isRejected = appStatus === 'rejected' || appStatus === 'failed';
%>

<div style="text-align:center;margin-bottom:24px;">
  <div style="width:48px;height:48px;background:rgba(16,185,129,0.1);border-radius:12px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;">
    <i data-lucide="graduation-cap" style="width:24px;height:24px;color:var(--accent-primary);"></i>
  </div>
  <h2 style="font-size:1.25rem;font-weight:700;color:var(--text-primary);">Application Status</h2>
  <p class="text-sm text-muted" style="margin-top:4px;">Track your application progress at ATLAS SkillTech University</p>
</div>

<% if (candidateName !== 'Candidate') { %>
  <div class="card" style="padding:16px;margin-bottom:24px;">
    <div class="flex items-center gap-md">
      <div class="avatar avatar-sm avatar-gradient"><%= candidateName.charAt(0).toUpperCase() %></div>
      <div class="min-w-0" style="flex:1;">
        <p class="font-semibold truncate"><%= candidateName %></p>
        <% if (application.job_title || (application.job && application.job.title)) { %>
          <p class="text-xs text-muted"><i data-lucide="briefcase" style="width:12px;height:12px;display:inline;margin-right:4px;"></i><%= application.job_title || application.job.title %></p>
        <% } %>
      </div>
    </div>
  </div>
<% } %>

<!-- Status Stepper -->
<div style="margin-bottom:24px;">
  <% stages.forEach(function(stage, idx) { %>
    <%
      const isCompleted = idx < currentStageIdx;
      const isCurrent = idx === currentStageIdx;
      let circleStyle, labelStyle;
      if (isRejected && isCurrent) {
        circleStyle = 'background:#ef4444;color:white;box-shadow:0 0 0 4px rgba(239,68,68,0.2);';
        labelStyle = 'color:#ef4444;font-weight:600;';
      } else if (isCompleted) {
        circleStyle = 'background:#10b981;color:white;';
        labelStyle = 'color:var(--text-primary);';
      } else if (isCurrent) {
        circleStyle = 'background:#1e293b;color:white;box-shadow:0 0 0 4px rgba(30,41,59,0.2);';
        labelStyle = 'color:var(--text-primary);font-weight:600;';
      } else {
        circleStyle = 'background:var(--bg-tertiary);color:var(--text-muted);';
        labelStyle = 'color:var(--text-muted);';
      }
    %>
    <div class="flex items-start gap-md" style="<%= idx < stages.length - 1 ? 'margin-bottom:4px;' : '' %>">
      <div style="display:flex;flex-direction:column;align-items:center;">
        <div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;<%= circleStyle %>">
          <% if (isCompleted) { %>
            <i data-lucide="check" style="width:16px;height:16px;"></i>
          <% } else if (isRejected && isCurrent) { %>
            <i data-lucide="x" style="width:16px;height:16px;"></i>
          <% } else { %>
            <i data-lucide="<%= stage.icon %>" style="width:16px;height:16px;"></i>
          <% } %>
        </div>
        <% if (idx < stages.length - 1) { %>
          <div style="width:2px;height:24px;<%= isCompleted ? 'background:#10b981;' : 'background:var(--border-color);' %>"></div>
        <% } %>
      </div>
      <div style="padding-top:4px;">
        <p class="text-sm" style="<%= labelStyle %>">
          <%= stage.label %>
          <% if (isCurrent && !isRejected) { %>
            <span class="badge badge-primary" style="margin-left:8px;">Current</span>
          <% } %>
          <% if (isRejected && isCurrent) { %>
            <span class="badge badge-danger" style="margin-left:8px;">Rejected</span>
          <% } %>
        </p>
        <p class="text-xs text-muted" style="margin-top:2px;"><%= stage.desc %></p>
      </div>
    </div>
  <% }); %>
</div>

<!-- Info Box -->
<div class="alert alert-info" style="margin-bottom:24px;">
  <i data-lucide="info"></i>
  <div>
    <p class="font-medium">More features coming soon</p>
    <p class="text-xs" style="margin-top:4px;opacity:0.8;">The full candidate portal with document uploads, interview preparation tools, and real-time messaging is currently under development.</p>
  </div>
</div>

<!-- Contact -->
<div class="card" style="padding:16px;">
  <h3 class="text-sm font-semibold" style="margin-bottom:12px;display:flex;align-items:center;gap:8px;">
    <i data-lucide="help-circle" style="width:16px;height:16px;color:var(--text-muted);"></i>
    Have questions about your application?
  </h3>
  <div style="display:flex;flex-direction:column;gap:8px;">
    <div class="flex items-center gap-sm text-sm">
      <i data-lucide="mail" style="width:14px;height:14px;color:var(--text-muted);"></i>
      <span>hr@atlasuniversity.edu</span>
    </div>
    <div class="flex items-center gap-sm text-sm">
      <i data-lucide="phone" style="width:14px;height:14px;color:var(--text-muted);"></i>
      <span>+1 (555) 012-3456</span>
    </div>
    <div class="flex items-center gap-sm text-sm">
      <i data-lucide="map-pin" style="width:14px;height:14px;color:var(--text-muted);"></i>
      <span>ATLAS SkillTech University, HR Department</span>
    </div>
  </div>
</div>

<div style="text-align:center;margin-top:24px;">
  <a href="/login" class="text-sm" style="color:var(--accent-primary);font-weight:500;">
    <i data-lucide="arrow-left" style="width:14px;height:14px;display:inline;margin-right:4px;"></i>
    Back to Login
  </a>
</div>
