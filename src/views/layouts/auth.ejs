<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/header') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/atlas-theme.css">
  <%- style %>
</head>
<body>
  <div class="login-page">
    <div style="width:100%;max-width:420px;">
      <%
        const authAlertTypes = [
          { key: 'success', cls: 'alert-success', icon: 'check-circle' },
          { key: 'error',   cls: 'alert-error',   icon: 'x-circle' },
          { key: 'warning', cls: 'alert-warning', icon: 'alert-triangle' },
          { key: 'info',    cls: 'alert-info',    icon: 'info' },
        ];
      %>
      <% authAlertTypes.forEach(function(alert) { %>
        <% const msgs = typeof locals[alert.key] !== 'undefined' ? (Array.isArray(locals[alert.key]) ? locals[alert.key] : [locals[alert.key]]) : []; %>
        <% msgs.forEach(function(msg) { %>
          <% if (msg && msg.length > 0) { %>
            <div class="alert <%= alert.cls %>" style="margin-bottom:8px;">
              <i data-lucide="<%= alert.icon %>"></i>
              <span style="flex:1;"><%= msg %></span>
            </div>
          <% } %>
        <% }); %>
      <% }); %>

      <div class="login-card">
        <%- body %>
      </div>

      <p style="text-align:center;font-size:0.75rem;color:rgba(255,255,255,0.4);margin-top:24px;">
        &copy; <%= new Date().getFullYear() %> ATLAS SkillTech University. All rights reserved.
      </p>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>document.addEventListener('DOMContentLoaded', function() { lucide.createIcons(); });</script>
  <%- script %>
</body>
</html>
