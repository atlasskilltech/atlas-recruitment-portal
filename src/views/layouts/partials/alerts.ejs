<%
  const alertTypes = [
    { key: 'success', icon: 'check-circle', cls: 'alert-success' },
    { key: 'error',   icon: 'x-circle',     cls: 'alert-error' },
    { key: 'warning', icon: 'alert-triangle', cls: 'alert-warning' },
    { key: 'info',    icon: 'info',          cls: 'alert-info' },
  ];
%>
<div id="alert-container" style="margin-bottom:16px;">
  <% alertTypes.forEach(function(alert) { %>
    <% const messages = typeof locals[alert.key] !== 'undefined' ? (Array.isArray(locals[alert.key]) ? locals[alert.key] : [locals[alert.key]]) : []; %>
    <% messages.forEach(function(msg) { %>
      <% if (msg && msg.length > 0) { %>
        <div class="alert <%= alert.cls %>" data-auto-dismiss style="transition: opacity 0.3s, transform 0.3s;">
          <i data-lucide="<%= alert.icon %>"></i>
          <span style="flex:1;"><%= msg %></span>
          <button class="alert-close" onclick="this.parentElement.remove()"><i data-lucide="x" style="width:16px;height:16px;"></i></button>
        </div>
      <% } %>
    <% }); %>
  <% }); %>
</div>
