<%
  /* Super Admin menu - only these items shown */
  const navItems = [
    { path: '/admin/jobs', icon: 'briefcase', label: 'Job Openings' },
  ];

  const isActive = (itemPath) => {
    if (!currentPath) return false;
    return currentPath.startsWith(itemPath);
  };
%>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo-icon">A</div>
    <div style="flex:1;overflow:hidden;">
      <div class="logo-text">ATLAS SkillTech Uni...</div>
      <div class="logo-sub">HR Recruitment</div>
    </div>
    <button class="sidebar-close" id="sidebar-close">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section">
      <div class="nav-section-title">Super Admin</div>
      <% navItems.forEach(function(item) { %>
        <a href="<%= item.path %>" class="nav-tab<%= isActive(item.path) ? ' active' : '' %>">
          <i data-lucide="<%= item.icon %>"></i>
          <span><%= item.label %></span>
        </a>
      <% }); %>
    </div>
  </nav>

  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="sidebar-user-avatar">
          <%= currentUser.first_name ? currentUser.first_name.charAt(0).toUpperCase() : 'U' %><%= currentUser.last_name ? currentUser.last_name.charAt(0).toUpperCase() : '' %>
        </div>
        <div class="sidebar-user-info">
          <div class="sidebar-user-name"><%= currentUser.first_name %> <%= currentUser.last_name %></div>
          <div class="sidebar-user-role"><%= currentUser.role ? currentUser.role.replace('_', ' ').replace(/\b\w/g, c => c.toUpperCase()) : 'User' %></div>
        </div>
      </div>
    </div>
  <% } %>
</aside>
