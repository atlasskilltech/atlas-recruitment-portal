<%
  const esIcon = typeof icon !== 'undefined' ? icon : 'inbox';
  const esTitle = typeof title !== 'undefined' ? title : 'No data found';
  const esDescription = typeof description !== 'undefined' ? description : 'There are no items to display at this time.';
  const esActionUrl = typeof actionUrl !== 'undefined' ? actionUrl : '';
  const esActionLabel = typeof actionLabel !== 'undefined' ? actionLabel : '';
%>
<div class="empty-state">
  <i data-lucide="<%= esIcon %>"></i>
  <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:4px;color:var(--text-primary);"><%= esTitle %></h3>
  <p><%= esDescription %></p>
  <% if (esActionUrl && esActionLabel) { %>
    <a href="<%= esActionUrl %>" class="btn btn-primary" style="margin-top:16px;">
      <i data-lucide="plus" style="width:16px;height:16px;"></i>
      <%= esActionLabel %>
    </a>
  <% } %>
</div>
