<!DOCTYPE html>
<html lang="en" class="">
<head>
  <%- include('./partials/header') %>

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Tailwind CSS -->
  <link rel="stylesheet" href="/css/output.css">

  <!-- Page-specific styles -->
  <%- style %>
</head>
<body x-data="{ sidebarOpen: false, darkMode: localStorage.getItem('darkMode') === 'true' }"
      x-init="if (darkMode) document.documentElement.classList.add('dark')"
      class="min-h-screen flex flex-col">

  <!-- Sidebar -->
  <%- include('./partials/sidebar') %>

  <!-- Main wrapper -->
  <div class="lg:ml-64 flex flex-col min-h-screen transition-all duration-300">

    <!-- Top bar -->
    <%- include('./partials/topbar') %>

    <!-- Page content -->
    <main class="flex-1 p-4 sm:p-6">
      <%- include('./partials/alerts') %>
      <%- body %>
    </main>

    <!-- Footer -->
    <%- include('./partials/footer') %>
  </div>

  <!-- ApexCharts -->
  <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

  <!-- Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"></script>

  <!-- Alpine.js -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

  <!-- Initialize Lucide icons -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      lucide.createIcons();
    });
  </script>

  <!-- Dark mode initialization (runs before Alpine to prevent flash) -->
  <script>
    (function () {
      var darkMode = localStorage.getItem('darkMode') === 'true';
      if (darkMode) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>

  <!-- Page-specific scripts -->
  <%- script %>
</body>
</html>
