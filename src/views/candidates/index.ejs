<%
  /* ── Helpers ────────────────────────────────────────────────────────────── */
  const _candidates = typeof candidates !== 'undefined' ? candidates : [];
  const _pagination  = typeof pagination  !== 'undefined' ? pagination  : { page:1, limit:20, total:0, totalPages:1, hasNext:false, hasPrev:false };
  const _filters     = typeof filters     !== 'undefined' ? filters     : {};
  const _jobs        = typeof jobs        !== 'undefined' ? jobs        : [];
  const _hrStatuses  = typeof hrStatuses  !== 'undefined' ? hrStatuses  : [];
  const _aiStatuses  = typeof aiStatuses  !== 'undefined' ? aiStatuses  : [];

  /* Status counts derived from candidate list for mini-cards (fallback) */
  const _stats = typeof stats !== 'undefined' ? stats : {
    total:        _pagination.total || _candidates.length,
    new:          _candidates.filter(c => c.appln_status_new === 'new').length,
    ai_eligible:  _candidates.filter(c => c.screening_status === 'eligible').length,
    interviewed:  _candidates.filter(c => c.interview_id).length,
    shortlisted:  _candidates.filter(c => c.appln_status_new === 'shortlisted').length,
    hired:        _candidates.filter(c => c.appln_status_new === 'hired').length,
  };

  /* Formatting helpers */
  function fmtDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    if (isNaN(dt)) return '-';
    return dt.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
  }
  function fmtScore(s) { const n = parseFloat(s); return isNaN(n) ? '-' : n.toFixed(1); }
  function scoreColor(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'text-green-600 dark:text-green-400';
    if (n >= 50) return 'text-yellow-600 dark:text-yellow-400';
    return 'text-red-600 dark:text-red-400';
  }
  function scoreBg(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'stroke-green-500';
    if (n >= 50) return 'stroke-yellow-500';
    return 'stroke-red-500';
  }
  function initials(name) {
    if (!name) return '?';
    return name.trim().split(/\s+/).filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
  }
  function badgeClass(status) {
    const s = String(status||'').toLowerCase().replace(/\s+/g,'_');
    const map = {
      new:'badge-new', shortlisted:'badge-shortlisted', rejected:'badge-rejected',
      hold:'badge-hold', scheduled:'badge-scheduled', selected:'badge-selected',
      offer_released:'badge-info', hired:'badge-hired',
      eligible:'badge-eligible', strong_fit:'badge-strong-fit',
      moderate_fit:'badge-moderate-fit', weak_fit:'badge-weak-fit',
    };
    return map[s] || 'badge-muted';
  }
  function labelise(s) {
    if (!s) return '-';
    return String(s).replace(/_/g,' ').replace(/\b\w/g, c=>c.toUpperCase());
  }

  /* Pagination page array */
  function pageArray(cur, total) {
    if (total <= 7) return Array.from({length:total},(_,i)=>i+1);
    const p = [1];
    if (cur > 3) p.push('...');
    for (let i = Math.max(2,cur-1); i <= Math.min(total-1,cur+1); i++) p.push(i);
    if (cur < total-2) p.push('...');
    p.push(total);
    return p;
  }

  /* Build query string preserving current filters */
  function qs(overrides) {
    const params = new URLSearchParams();
    const merged = Object.assign({}, _filters, overrides);
    Object.entries(merged).forEach(([k,v]) => { if (v !== '' && v != null) params.set(k,v); });
    return params.toString();
  }
%>

<!-- ═══════════════════════════════════════════════════════════════════════
     Candidates List – ATS-style view
     ═══════════════════════════════════════════════════════════════════════ -->

<div x-data="{
  showFilters: false,
  selectedIds: [],
  selectAll: false,
  quickView: null,
  toggleAll(checked) {
    this.selectAll = checked;
    if (checked) {
      this.selectedIds = [<% _candidates.forEach((c,i) => { %>'<%= c.id %>'<%= i < _candidates.length-1 ? ',' : '' %><% }); %>];
    } else {
      this.selectedIds = [];
    }
  },
  toggleOne(id) {
    const idx = this.selectedIds.indexOf(id);
    if (idx > -1) { this.selectedIds.splice(idx,1); } else { this.selectedIds.push(id); }
    this.selectAll = this.selectedIds.length === <%= _candidates.length %>;
  }
}">

  <!-- ── Page Header ──────────────────────────────────────────────────── -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-foreground tracking-tight">Candidates</h1>
      <p class="text-sm text-muted-foreground mt-1">Manage and review all applicants</p>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      <a href="/candidates/export?format=csv&<%= qs({}) %>" class="btn-outline btn-sm">
        <i data-lucide="file-text" class="w-4 h-4"></i> CSV
      </a>
      <a href="/candidates/export?format=json&<%= qs({}) %>" class="btn-outline btn-sm">
        <i data-lucide="file-json" class="w-4 h-4"></i> Excel
      </a>
      <a href="/candidates/export?format=pdf&<%= qs({}) %>" class="btn-outline btn-sm">
        <i data-lucide="file-down" class="w-4 h-4"></i> PDF
      </a>
    </div>
  </div>

  <!-- ── Summary Mini-Cards ───────────────────────────────────────────── -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
    <% const miniCards = [
      { label:'Total',       value: _stats.total,       icon:'users',        bg:'bg-primary-100 dark:bg-primary-900', ic:'text-primary-800 dark:text-primary-200' },
      { label:'New',         value: _stats.new,         icon:'user-plus',    bg:'bg-blue-100 dark:bg-blue-900',       ic:'text-blue-700 dark:text-blue-300' },
      { label:'AI Eligible', value: _stats.ai_eligible, icon:'brain',        bg:'bg-green-100 dark:bg-green-900',     ic:'text-green-700 dark:text-green-300' },
      { label:'Interviewed', value: _stats.interviewed, icon:'message-square', bg:'bg-cyan-100 dark:bg-cyan-900',    ic:'text-cyan-700 dark:text-cyan-300' },
      { label:'Shortlisted', value: _stats.shortlisted, icon:'check-circle', bg:'bg-purple-100 dark:bg-purple-900',  ic:'text-purple-700 dark:text-purple-300' },
      { label:'Hired',       value: _stats.hired,       icon:'award',        bg:'bg-accent-100 dark:bg-accent-700',   ic:'text-accent-700 dark:text-accent-100' },
    ]; %>
    <% miniCards.forEach(function(mc) { %>
      <div class="card p-4 flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 <%= mc.bg %>">
          <i data-lucide="<%= mc.icon %>" class="w-5 h-5 <%= mc.ic %>"></i>
        </div>
        <div>
          <p class="text-xl font-bold text-foreground leading-none"><%= mc.value || 0 %></p>
          <p class="text-xs text-muted-foreground mt-0.5"><%= mc.label %></p>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- ── Search Bar ───────────────────────────────────────────────────── -->
  <form method="GET" action="/candidates" class="mb-4">
    <!-- preserve existing filters in hidden inputs -->
    <% Object.entries(_filters).forEach(function([k,v]) { if (k !== 'search' && k !== 'page' && v) { %>
      <input type="hidden" name="<%= k %>" value="<%= v %>">
    <% } }); %>
    <div class="relative">
      <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-muted-foreground pointer-events-none"></i>
      <input type="text" name="search" value="<%= _filters.search || '' %>"
             placeholder="Search candidates by name, email, or phone..."
             class="form-input pl-12 pr-4">
    </div>
  </form>

  <!-- ── Advanced Filters Toggle ──────────────────────────────────────── -->
  <div class="mb-6">
    <button @click="showFilters = !showFilters" class="btn-outline btn-sm mb-3">
      <i data-lucide="sliders-horizontal" class="w-4 h-4"></i>
      <span x-text="showFilters ? 'Hide Filters' : 'Advanced Filters'">Advanced Filters</span>
      <i data-lucide="chevron-down" class="w-4 h-4 transition-transform" :class="showFilters && 'rotate-180'"></i>
    </button>

    <div x-show="showFilters" x-collapse x-cloak class="filter-panel">
      <form method="GET" action="/candidates" id="filterForm">
        <% if (_filters.search) { %><input type="hidden" name="search" value="<%= _filters.search %>"><% } %>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <!-- Job Applied -->
          <div class="form-group">
            <label class="form-label">Job Applied</label>
            <select name="job_id" class="form-select">
              <option value="">All Jobs</option>
              <% _jobs.forEach(function(j) { %>
                <option value="<%= j.id %>" <%= _filters.job_id == j.id ? 'selected' : '' %>><%= j.title %></option>
              <% }); %>
            </select>
          </div>

          <!-- Department/Post -->
          <div class="form-group">
            <label class="form-label">Department / Post</label>
            <input type="text" name="department" value="<%= _filters.department || '' %>" class="form-input" placeholder="e.g. Computer Science">
          </div>

          <!-- AI Status -->
          <div class="form-group">
            <label class="form-label">AI Status</label>
            <select name="ai_status" class="form-select">
              <option value="">All</option>
              <% _aiStatuses.forEach(function(s) { %>
                <option value="<%= s %>" <%= _filters.ai_status === s ? 'selected' : '' %>><%= labelise(s) %></option>
              <% }); %>
            </select>
          </div>

          <!-- HR Status -->
          <div class="form-group">
            <label class="form-label">HR Status</label>
            <select name="hr_status" class="form-select">
              <option value="">All</option>
              <% _hrStatuses.forEach(function(s) { %>
                <option value="<%= s %>" <%= _filters.hr_status === s ? 'selected' : '' %>><%= labelise(s) %></option>
              <% }); %>
            </select>
          </div>

          <!-- Match Score Range -->
          <div class="form-group">
            <label class="form-label">Match Score</label>
            <div class="flex gap-2">
              <input type="number" name="match_score_min" value="<%= _filters.match_score_min || '' %>" class="form-input" placeholder="Min" min="0" max="100" step="1">
              <input type="number" name="match_score_max" value="<%= _filters.match_score_max || '' %>" class="form-input" placeholder="Max" min="0" max="100" step="1">
            </div>
          </div>

          <!-- Interview Score Range -->
          <div class="form-group">
            <label class="form-label">Interview Score</label>
            <div class="flex gap-2">
              <input type="number" name="interview_score_min" value="<%= _filters.interview_score_min || '' %>" class="form-input" placeholder="Min" min="0" max="100" step="1">
              <input type="number" name="interview_score_max" value="<%= _filters.interview_score_max || '' %>" class="form-input" placeholder="Max" min="0" max="100" step="1">
            </div>
          </div>

          <!-- Qualification -->
          <div class="form-group">
            <label class="form-label">Qualification</label>
            <select name="qualification" class="form-select">
              <option value="">All</option>
              <% ['PhD', 'M.Tech', 'M.Sc', 'MCA', 'MBA', 'M.E', 'B.Tech', 'B.E', 'B.Sc', 'BCA'].forEach(function(q) { %>
                <option value="<%= q %>" <%= _filters.qualification === q ? 'selected' : '' %>><%= q %></option>
              <% }); %>
            </select>
          </div>

          <!-- Experience Range -->
          <div class="form-group">
            <label class="form-label">Experience (years)</label>
            <div class="flex gap-2">
              <input type="number" name="experience_min" value="<%= _filters.experience_min || '' %>" class="form-input" placeholder="Min" min="0" step="0.5">
              <input type="number" name="experience_max" value="<%= _filters.experience_max || '' %>" class="form-input" placeholder="Max" min="0" step="0.5">
            </div>
          </div>

          <!-- Location -->
          <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" name="location" value="<%= _filters.location || '' %>" class="form-input" placeholder="e.g. Mumbai">
          </div>

          <!-- Date Range -->
          <div class="form-group">
            <label class="form-label">Applied Date</label>
            <div class="flex gap-2">
              <input type="date" name="date_from" value="<%= _filters.date_from || '' %>" class="form-input">
              <input type="date" name="date_to" value="<%= _filters.date_to || '' %>" class="form-input">
            </div>
          </div>
        </div>

        <div class="flex items-center gap-3 mt-4 pt-4 border-t border-border">
          <button type="submit" class="btn-primary btn-sm">
            <i data-lucide="filter" class="w-4 h-4"></i> Apply Filters
          </button>
          <a href="/candidates" class="btn-ghost btn-sm">
            <i data-lucide="x" class="w-4 h-4"></i> Reset
          </a>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Bulk Action Bar ──────────────────────────────────────────────── -->
  <div x-show="selectedIds.length > 0" x-cloak
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       class="card p-3 mb-4 flex flex-wrap items-center gap-3 border-primary-300 bg-primary-50 dark:bg-primary-900/30">
    <span class="text-sm font-semibold text-primary-800 dark:text-primary-200">
      <span x-text="selectedIds.length"></span> selected
    </span>
    <div class="flex items-center gap-2 ml-auto flex-wrap">
      <form method="POST" action="/candidates/bulk/run-ai-match" class="inline">
        <template x-for="id in selectedIds" :key="id">
          <input type="hidden" name="candidate_ids[]" :value="id">
        </template>
        <button type="submit" class="btn-accent btn-sm">
          <i data-lucide="brain" class="w-4 h-4"></i> Run AI Match
        </button>
      </form>
      <button class="btn-success btn-sm" onclick="alert('Bulk shortlist coming soon')">
        <i data-lucide="check-circle" class="w-4 h-4"></i> Shortlist
      </button>
      <button class="btn-danger btn-sm" onclick="alert('Bulk reject coming soon')">
        <i data-lucide="x-circle" class="w-4 h-4"></i> Reject
      </button>
    </div>
  </div>

  <!-- ── Candidates Data Table ────────────────────────────────────────── -->
  <% if (_candidates.length > 0) { %>
    <div class="card overflow-hidden">
      <div class="overflow-x-auto custom-scrollbar">
        <table class="data-table">
          <thead>
            <tr>
              <th class="w-10">
                <input type="checkbox" class="rounded border-border"
                       :checked="selectAll"
                       @change="toggleAll($event.target.checked)">
              </th>
              <th>Candidate</th>
              <th>Applied Role</th>
              <th>Location</th>
              <th>Qualification</th>
              <th>Exp</th>
              <th>Designation</th>
              <th>Organisation</th>
              <th class="text-center">AI Match</th>
              <th class="text-center">AI Interview</th>
              <th>Recommendation</th>
              <th>HR Status</th>
              <th>Applied</th>
              <th class="w-12">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% _candidates.forEach(function(c) { %>
              <tr class="group">
                <!-- Checkbox -->
                <td>
                  <input type="checkbox" class="rounded border-border"
                         value="<%= c.id %>"
                         :checked="selectedIds.includes('<%= c.id %>')"
                         @change="toggleOne('<%= c.id %>')">
                </td>

                <!-- Candidate Name + Email -->
                <td class="min-w-[200px]">
                  <a href="/candidates/<%= c.id %>" class="flex items-center gap-3 group/link">
                    <div class="w-9 h-9 rounded-full bg-primary-100 dark:bg-primary-800 flex items-center justify-center flex-shrink-0">
                      <span class="text-xs font-semibold text-primary-800 dark:text-primary-200"><%= initials(c.appln_full_name) %></span>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-foreground truncate group-hover/link:text-primary-800 dark:group-hover/link:text-accent transition-colors">
                        <%= c.appln_full_name || 'Unnamed' %>
                      </p>
                      <p class="text-xs text-muted-foreground truncate"><%= c.appln_email || '' %></p>
                    </div>
                  </a>
                </td>

                <!-- Applied Role -->
                <td class="min-w-[160px]">
                  <span class="text-sm text-foreground"><%= c.applied_job_short_desc_new || '-' %></span>
                </td>

                <!-- Location -->
                <td class="whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= c.applied_location || '-' %></span>
                </td>

                <!-- Qualification -->
                <td>
                  <% if (c.appln_high_qualification) { %>
                    <span class="badge-muted"><%= c.appln_high_qualification %></span>
                  <% } else { %>
                    <span class="text-sm text-muted-foreground">-</span>
                  <% } %>
                </td>

                <!-- Experience -->
                <td class="whitespace-nowrap">
                  <span class="text-sm text-foreground"><%= c.appln_total_experience != null ? c.appln_total_experience + ' yr' : '-' %></span>
                </td>

                <!-- Designation -->
                <td class="min-w-[140px]">
                  <span class="text-sm text-foreground truncate block max-w-[160px]"><%= c.appln_current_designation || '-' %></span>
                </td>

                <!-- Organisation -->
                <td class="min-w-[140px]">
                  <span class="text-sm text-muted-foreground truncate block max-w-[160px]"><%= c.appln_current_organisation || '-' %></span>
                </td>

                <!-- AI Match Score -->
                <td class="text-center">
                  <% if (c.match_score != null) { %>
                    <div class="inline-flex flex-col items-center">
                      <div class="score-ring w-10 h-10">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3" class="stroke-muted/30"></circle>
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3"
                                  class="<%= scoreBg(c.match_score) %>"
                                  stroke-dasharray="<%= (2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-dashoffset="<%= ((1 - (parseFloat(c.match_score)||0)/100) * 2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-linecap="round"></circle>
                        </svg>
                        <span class="score-value text-xs font-bold <%= scoreColor(c.match_score) %>"><%= Math.round(c.match_score) %></span>
                      </div>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted-foreground">-</span>
                  <% } %>
                </td>

                <!-- AI Interview Score -->
                <td class="text-center">
                  <% if (c.overall_score != null) { %>
                    <div class="inline-flex flex-col items-center">
                      <div class="score-ring w-10 h-10">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3" class="stroke-muted/30"></circle>
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3"
                                  class="<%= scoreBg(c.overall_score) %>"
                                  stroke-dasharray="<%= (2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-dashoffset="<%= ((1 - (parseFloat(c.overall_score)||0)/100) * 2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-linecap="round"></circle>
                        </svg>
                        <span class="score-value text-xs font-bold <%= scoreColor(c.overall_score) %>"><%= Math.round(c.overall_score) %></span>
                      </div>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted-foreground">-</span>
                  <% } %>
                </td>

                <!-- Recommendation -->
                <td>
                  <% if (c.screening_status === 'eligible' && c.match_score != null) {
                    const rec = parseFloat(c.match_score) >= 75 ? 'strong_fit' : (parseFloat(c.match_score) >= 50 ? 'moderate_fit' : 'weak_fit');
                  %>
                    <span class="<%= badgeClass(rec) %>"><%= labelise(rec) %></span>
                  <% } else { %>
                    <span class="text-xs text-muted-foreground">-</span>
                  <% } %>
                </td>

                <!-- HR Status -->
                <td>
                  <span class="<%= badgeClass(c.appln_status_new) %>"><%= labelise(c.appln_status_new) %></span>
                </td>

                <!-- Applied Date -->
                <td class="whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= fmtDate(c.appln_date) %></span>
                </td>

                <!-- Actions Dropdown -->
                <td>
                  <div x-data="{ open: false }" class="relative">
                    <button @click="open = !open" @click.outside="open = false" class="btn-icon btn-ghost p-1.5">
                      <i data-lucide="more-vertical" class="w-4 h-4"></i>
                    </button>
                    <div x-show="open" x-cloak
                         x-transition:enter="transition ease-out duration-100"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         x-transition:leave="transition ease-in duration-75"
                         x-transition:leave-start="opacity-100 scale-100"
                         x-transition:leave-end="opacity-0 scale-95"
                         class="absolute right-0 mt-1 w-48 bg-card border border-border rounded-xl shadow-brand-lg z-30 py-1">
                      <a href="/candidates/<%= c.id %>" class="flex items-center gap-2 px-4 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="eye" class="w-4 h-4"></i> View Detail
                      </a>
                      <form method="POST" action="/candidates/<%= c.id %>/run-ai-match">
                        <button type="submit" class="w-full flex items-center gap-2 px-4 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                          <i data-lucide="brain" class="w-4 h-4"></i> Run AI Match
                        </button>
                      </form>
                      <a href="/ai-interviews/invite/<%= c.id %>" class="flex items-center gap-2 px-4 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="video" class="w-4 h-4"></i> Invite Interview
                      </a>
                      <button @click="quickView = '<%= c.id %>'; open = false"
                              class="w-full flex items-center gap-2 px-4 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="message-square-plus" class="w-4 h-4"></i> Add Note
                      </button>
                      <div class="border-t border-border my-1"></div>
                      <a href="/shortlist/add/<%= c.id %>" class="flex items-center gap-2 px-4 py-2 text-sm text-green-700 hover:bg-green-50 dark:hover:bg-green-900/20 transition-colors">
                        <i data-lucide="check-circle" class="w-4 h-4"></i> Shortlist
                      </a>
                      <a href="/schedules/create?candidate=<%= c.id %>" class="flex items-center gap-2 px-4 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="calendar-plus" class="w-4 h-4"></i> Schedule
                      </a>
                      <button class="w-full flex items-center gap-2 px-4 py-2 text-sm text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                              onclick="if(confirm('Reject this candidate?')) { /* reject */ }">
                        <i data-lucide="x-circle" class="w-4 h-4"></i> Reject
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- ── Pagination ──────────────────────────────────────────────── -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 px-4 py-4 border-t border-border">
        <p class="text-sm text-muted-foreground">
          Showing
          <span class="font-medium text-foreground"><%= ((_pagination.page - 1) * _pagination.limit) + 1 %></span>
          to
          <span class="font-medium text-foreground"><%= Math.min(_pagination.page * _pagination.limit, _pagination.total) %></span>
          of
          <span class="font-medium text-foreground"><%= _pagination.total %></span>
          candidates
        </p>

        <div class="flex items-center gap-1">
          <% if (_pagination.hasPrev) { %>
            <a href="/candidates?<%= qs({ page: _pagination.page - 1 }) %>"
               class="btn-ghost btn-sm px-2">
              <i data-lucide="chevron-left" class="w-4 h-4"></i>
            </a>
          <% } else { %>
            <span class="btn-ghost btn-sm px-2 opacity-40 pointer-events-none">
              <i data-lucide="chevron-left" class="w-4 h-4"></i>
            </span>
          <% } %>

          <% pageArray(_pagination.page, _pagination.totalPages).forEach(function(pg) { %>
            <% if (pg === '...') { %>
              <span class="px-2 text-sm text-muted-foreground">...</span>
            <% } else { %>
              <a href="/candidates?<%= qs({ page: pg }) %>"
                 class="btn-sm rounded-lg px-3 py-1.5 text-sm font-medium transition-colors
                        <%= pg === _pagination.page
                          ? 'bg-primary-800 text-white shadow-brand'
                          : 'btn-ghost' %>">
                <%= pg %>
              </a>
            <% } %>
          <% }); %>

          <% if (_pagination.hasNext) { %>
            <a href="/candidates?<%= qs({ page: _pagination.page + 1 }) %>"
               class="btn-ghost btn-sm px-2">
              <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </a>
          <% } else { %>
            <span class="btn-ghost btn-sm px-2 opacity-40 pointer-events-none">
              <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </span>
          <% } %>
        </div>
      </div>
    </div>

  <% } else { %>
    <!-- ── Empty State ─────────────────────────────────────────────── -->
    <div class="card">
      <div class="empty-state py-20">
        <div class="w-20 h-20 rounded-2xl bg-muted/50 flex items-center justify-center mb-5">
          <i data-lucide="users" class="w-10 h-10 text-muted-foreground/30"></i>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-1">No candidates found</h3>
        <p class="text-sm text-muted-foreground max-w-sm mb-6">
          <% if (Object.keys(_filters).length > 0) { %>
            No candidates match your current filters. Try adjusting or clearing them.
          <% } else { %>
            There are no candidate applications to display at this time.
          <% } %>
        </p>
        <% if (Object.keys(_filters).length > 0) { %>
          <a href="/candidates" class="btn-primary">
            <i data-lucide="x" class="w-4 h-4"></i> Clear Filters
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- ── Quick View Drawer ────────────────────────────────────────────── -->
  <%- include('_quick_view') %>

</div>
