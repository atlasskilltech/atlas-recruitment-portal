<%
  /* ── Helpers ────────────────────────────────────────────────────────────── */
  const _candidates = typeof candidates !== 'undefined' ? candidates : [];
  const _pagination  = typeof pagination  !== 'undefined' ? pagination  : { page:1, limit:20, total:0, totalPages:1, hasNext:false, hasPrev:false };
  const _filters     = typeof filters     !== 'undefined' ? filters     : {};
  const _jobs        = typeof jobs        !== 'undefined' ? jobs        : [];
  const _posts       = typeof posts       !== 'undefined' ? posts       : [];
  const _hrStatuses  = typeof hrStatuses  !== 'undefined' ? hrStatuses  : [];
  const _aiStatuses  = typeof aiStatuses  !== 'undefined' ? aiStatuses  : [];
  const _applnAppliedFor    = typeof applnAppliedFor    !== 'undefined' ? applnAppliedFor    : {};
  const _applnCategory      = typeof applnCategory      !== 'undefined' ? applnCategory      : {};
  const _applnQualified     = typeof applnQualified     !== 'undefined' ? applnQualified     : {};
  const _applnHighQual      = typeof applnHighQualification !== 'undefined' ? applnHighQualification : {};

  /* Status counts derived from candidate list for mini-cards (fallback) */
  const _stats = typeof stats !== 'undefined' ? stats : {
    total:        _pagination.total || _candidates.length,
    new:          _candidates.filter(c => c.appln_status_new === 'new').length,
    ai_eligible:  _candidates.filter(c => c.screening_status === 'eligible').length,
    interviewed:  _candidates.filter(c => c.interview_id).length,
    shortlisted:  _candidates.filter(c => c.appln_status_new === 'shortlisted').length,
    hired:        _candidates.filter(c => c.appln_status_new === 'hired').length,
  };

  /* Formatting helpers */
  function fmtDate(d) {
    if (!d) return '-';
    const dt = new Date(d);
    if (isNaN(dt)) return '-';
    return dt.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
  }
  function fmtScore(s) { const n = parseFloat(s); return isNaN(n) ? '-' : n.toFixed(1); }
  function scoreColor(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'text-success';
    if (n >= 50) return 'text-warning';
    return 'text-danger';
  }
  function scoreBg(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'stroke-green-500';
    if (n >= 50) return 'stroke-yellow-500';
    return 'stroke-red-500';
  }
  function initials(name) {
    if (!name) return '?';
    return name.trim().split(/\s+/).filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
  }
  function badgeClass(status) {
    const s = String(status||'').toLowerCase().replace(/\s+/g,'_');
    const map = {
      new:'badge-new', shortlisted:'badge-shortlisted', rejected:'badge-rejected',
      hold:'badge-hold', scheduled:'badge-scheduled', selected:'badge-selected',
      offer_released:'badge-info', hired:'badge-hired',
      eligible:'badge-eligible', strong_fit:'badge-strong-fit',
      moderate_fit:'badge-moderate-fit', weak_fit:'badge-weak-fit',
    };
    return map[s] || 'badge-muted';
  }
  function labelise(s) {
    if (!s) return '-';
    return String(s).replace(/_/g,' ').replace(/\b\w/g, c=>c.toUpperCase());
  }

  /* Pagination page array */
  function pageArray(cur, total) {
    if (total <= 7) return Array.from({length:total},(_,i)=>i+1);
    const p = [1];
    if (cur > 3) p.push('...');
    for (let i = Math.max(2,cur-1); i <= Math.min(total-1,cur+1); i++) p.push(i);
    if (cur < total-2) p.push('...');
    p.push(total);
    return p;
  }

  /* Build query string preserving current filters */
  function qs(overrides) {
    const params = new URLSearchParams();
    const merged = Object.assign({}, _filters, overrides);
    Object.entries(merged).forEach(([k,v]) => { if (v !== '' && v != null) params.set(k,v); });
    return params.toString();
  }
%>

<!-- ═══════════════════════════════════════════════════════════════════════
     Candidates List – ATS-style view
     ═══════════════════════════════════════════════════════════════════════ -->

<div x-data="{
  showFilters: false,
  selectedIds: [],
  selectAll: false,
  quickView: null,
  toggleAll(checked) {
    this.selectAll = checked;
    if (checked) {
      this.selectedIds = [<% _candidates.forEach((c,i) => { %>'<%= c.id %>'<%= i < _candidates.length-1 ? ',' : '' %><% }); %>];
    } else {
      this.selectedIds = [];
    }
  },
  toggleOne(id) {
    const idx = this.selectedIds.indexOf(id);
    if (idx > -1) { this.selectedIds.splice(idx,1); } else { this.selectedIds.push(id); }
    this.selectAll = this.selectedIds.length === <%= _candidates.length %>;
  }
}">

  <!-- ── Page Header ──────────────────────────────────────────────────── -->
  <div class="flex justify-between items-center flex-wrap gap-md mb-lg">
    <div>
      <h1 class="text-2xl font-bold">Candidates</h1>
      <p class="text-sm text-muted" style="margin-top:4px;">Manage and review all applicants</p>
    </div>
    <div class="flex items-center gap-sm flex-wrap">
      <a href="/candidates/export?format=csv&<%= qs({}) %>" class="btn btn-outline btn-sm">
        <i data-lucide="file-text" style="width:16px;height:16px;"></i> CSV
      </a>
      <a href="/candidates/export?format=json&<%= qs({}) %>" class="btn btn-outline btn-sm">
        <i data-lucide="file-json" style="width:16px;height:16px;"></i> Excel
      </a>
      <a href="/candidates/export?format=pdf&<%= qs({}) %>" class="btn btn-outline btn-sm">
        <i data-lucide="file-down" style="width:16px;height:16px;"></i> PDF
      </a>
    </div>
  </div>

  <!-- ── Summary Mini-Cards ───────────────────────────────────────────── -->
  <div class="stats-row mb-lg">
    <% const miniCards = [
      { label:'Total',       value: _stats.total,       icon:'users',          color:'green' },
      { label:'New',         value: _stats.new,         icon:'user-plus',      color:'blue' },
      { label:'AI Eligible', value: _stats.ai_eligible, icon:'brain',          color:'green' },
      { label:'Interviewed', value: _stats.interviewed, icon:'message-square', color:'blue' },
      { label:'Shortlisted', value: _stats.shortlisted, icon:'check-circle',   color:'purple' },
      { label:'Hired',       value: _stats.hired,       icon:'award',          color:'green' },
    ]; %>
    <% miniCards.forEach(function(mc) { %>
      <div class="stat-card">
        <div class="stat-icon <%= mc.color %>">
          <i data-lucide="<%= mc.icon %>"></i>
        </div>
        <div class="stat-info">
          <div class="stat-value"><%= mc.value || 0 %></div>
          <div class="stat-label"><%= mc.label %></div>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- ── Search Bar ───────────────────────────────────────────────────── -->
  <form method="GET" action="/candidates" class="mb-md">
    <!-- preserve existing filters in hidden inputs -->
    <% Object.entries(_filters).forEach(function([k,v]) { if (k !== 'search' && k !== 'page' && v) { %>
      <input type="hidden" name="<%= k %>" value="<%= v %>">
    <% } }); %>
    <div class="relative">
      <i data-lucide="search" class="absolute" style="left:16px;top:50%;transform:translateY(-50%);width:20px;height:20px;color:var(--text-muted);pointer-events:none;"></i>
      <input type="text" name="search" value="<%= _filters.search || '' %>"
             placeholder="Search candidates by name, email, or phone..."
             class="form-input" style="padding-left:48px;">
    </div>
  </form>

  <!-- ── Advanced Filters Toggle ──────────────────────────────────────── -->
  <div class="mb-lg">
    <button @click="showFilters = !showFilters" class="btn btn-outline btn-sm mb-sm">
      <i data-lucide="sliders-horizontal" style="width:16px;height:16px;"></i>
      <span x-text="showFilters ? 'Hide Filters' : 'Advanced Filters'">Advanced Filters</span>
      <i data-lucide="chevron-down" style="width:16px;height:16px;transition:transform 0.2s;" :class="showFilters && 'rotate-180'"></i>
    </button>

    <div x-show="showFilters" x-collapse x-cloak class="card" style="padding:20px;">
      <form method="GET" action="/candidates" id="filterForm">
        <% if (_filters.search) { %><input type="hidden" name="search" value="<%= _filters.search %>"><% } %>

        <div class="form-grid" style="grid-template-columns:repeat(4,1fr);">

          <!-- Department Type (Academic / Non-Academic) -->
          <div class="form-group">
            <label class="form-label">Department Type</label>
            <select name="appln_applied_for" id="filterDeptType" class="form-select">
              <option value="">All</option>
              <% Object.entries(_applnAppliedFor).forEach(function([k,v]) { %>
                <option value="<%= k %>" <%= _filters.appln_applied_for == k ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>

          <!-- Post Category (applied_for_post_id) -->
          <div class="form-group">
            <label class="form-label">Post Category</label>
            <select name="applied_for_post_id" id="filterPostId" class="form-select">
              <option value="">All</option>
              <% Object.entries(_applnAppliedFor).forEach(function([k,v]) { %>
                <option value="<%= k %>" <%= _filters.applied_for_post_id == k ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>

          <!-- Specific Post/Role (cascading from post category) -->
          <div class="form-group">
            <label class="form-label">Post / Role</label>
            <select name="applied_for_post" id="filterPost" class="form-select">
              <option value="">All Posts</option>
              <% _posts.forEach(function(p) { %>
                <option value="<%= p.applied_for_post %>" data-post-id="<%= p.applied_for_post_id %>" <%= _filters.applied_for_post == p.applied_for_post ? 'selected' : '' %>><%= p.applied_for_post %></option>
              <% }); %>
            </select>
          </div>

          <!-- Job Applied (specific job listing) -->
          <div class="form-group">
            <label class="form-label">Job Applied</label>
            <select name="job_id" class="form-select">
              <option value="">All Jobs</option>
              <% _jobs.forEach(function(j) { %>
                <option value="<%= j.id %>" <%= _filters.job_id == j.id ? 'selected' : '' %>><%= j.title %></option>
              <% }); %>
            </select>
          </div>

          <!-- Qualification -->
          <div class="form-group">
            <label class="form-label">Qualification</label>
            <select name="appln_high_qualification" class="form-select">
              <option value="">All</option>
              <% Object.entries(_applnHighQual).forEach(function([k,v]) { %>
                <option value="<%= k %>" <%= _filters.appln_high_qualification == k ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>

          <!-- Category (SC/ST/OBC/General) -->
          <div class="form-group">
            <label class="form-label">Category</label>
            <select name="appln_category" class="form-select">
              <option value="">All</option>
              <% Object.entries(_applnCategory).forEach(function([k,v]) { %>
                <option value="<%= k %>" <%= _filters.appln_category == k ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>

          <!-- NET/SET Qualification -->
          <div class="form-group">
            <label class="form-label">NET / SET / JRF</label>
            <select name="appln_qualified" class="form-select">
              <option value="">All</option>
              <% Object.entries(_applnQualified).forEach(function([k,v]) { %>
                <option value="<%= k %>" <%= _filters.appln_qualified == k ? 'selected' : '' %>><%= v %></option>
              <% }); %>
            </select>
          </div>

          <!-- AI Status -->
          <div class="form-group">
            <label class="form-label">AI Status</label>
            <select name="ai_status" class="form-select">
              <option value="">All</option>
              <% _aiStatuses.forEach(function(s) { %>
                <option value="<%= s %>" <%= _filters.ai_status === s ? 'selected' : '' %>><%= labelise(s) %></option>
              <% }); %>
            </select>
          </div>

          <!-- HR Status -->
          <div class="form-group">
            <label class="form-label">HR Status</label>
            <select name="hr_status" class="form-select">
              <option value="">All</option>
              <% _hrStatuses.forEach(function(s) { %>
                <option value="<%= s %>" <%= _filters.hr_status === s ? 'selected' : '' %>><%= labelise(s) %></option>
              <% }); %>
            </select>
          </div>

          <!-- Match Score Range -->
          <div class="form-group">
            <label class="form-label">Match Score</label>
            <div class="flex gap-sm">
              <input type="number" name="match_score_min" value="<%= _filters.match_score_min || '' %>" class="form-input" placeholder="Min" min="0" max="100" step="1">
              <input type="number" name="match_score_max" value="<%= _filters.match_score_max || '' %>" class="form-input" placeholder="Max" min="0" max="100" step="1">
            </div>
          </div>

          <!-- Experience Range -->
          <div class="form-group">
            <label class="form-label">Experience (years)</label>
            <div class="flex gap-sm">
              <input type="number" name="experience_min" value="<%= _filters.experience_min || '' %>" class="form-input" placeholder="Min" min="0" step="0.5">
              <input type="number" name="experience_max" value="<%= _filters.experience_max || '' %>" class="form-input" placeholder="Max" min="0" step="0.5">
            </div>
          </div>

          <!-- Location -->
          <div class="form-group">
            <label class="form-label">Location</label>
            <input type="text" name="location" value="<%= _filters.location || '' %>" class="form-input" placeholder="e.g. Mumbai">
          </div>

          <!-- Date Range -->
          <div class="form-group">
            <label class="form-label">Applied Date</label>
            <div class="flex gap-sm">
              <input type="date" name="date_from" value="<%= _filters.date_from || '' %>" class="form-input">
              <input type="date" name="date_to" value="<%= _filters.date_to || '' %>" class="form-input">
            </div>
          </div>
        </div>

        <div class="flex items-center gap-sm border-t" style="margin-top:16px;padding-top:16px;">
          <button type="submit" class="btn btn-primary btn-sm">
            <i data-lucide="filter" style="width:16px;height:16px;"></i> Apply Filters
          </button>
          <a href="/candidates" class="btn btn-ghost btn-sm">
            <i data-lucide="x" style="width:16px;height:16px;"></i> Reset
          </a>
        </div>
      </form>

      <!-- Cascading filter JS: Department Type -> Post Category -> Post -->
      <script>
        (function() {
          var deptType = document.getElementById('filterDeptType');
          var postId = document.getElementById('filterPostId');
          var postSelect = document.getElementById('filterPost');
          if (!deptType || !postId || !postSelect) return;

          var allPostOptions = Array.from(postSelect.querySelectorAll('option[data-post-id]'));

          function syncPostCategory() {
            if (deptType.value) postId.value = deptType.value;
          }

          function filterPosts() {
            var selectedPostId = postId.value;
            var currentVal = postSelect.value;
            // Remove all post options except "All Posts"
            allPostOptions.forEach(function(opt) { opt.style.display = 'none'; opt.disabled = true; });
            // Show matching ones
            allPostOptions.forEach(function(opt) {
              if (!selectedPostId || opt.getAttribute('data-post-id') == selectedPostId) {
                opt.style.display = '';
                opt.disabled = false;
              }
            });
            // Reset post selection if current is now hidden
            var currentOpt = postSelect.querySelector('option[value="' + currentVal + '"]:not([disabled])');
            if (!currentOpt && currentVal) postSelect.value = '';
          }

          deptType.addEventListener('change', function() { syncPostCategory(); filterPosts(); });
          postId.addEventListener('change', filterPosts);

          // Initialize on load
          filterPosts();
        })();
      </script>
    </div>
  </div>

  <!-- ── Bulk Action Bar ──────────────────────────────────────────────── -->
  <div x-show="selectedIds.length > 0" x-cloak
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       class="card flex flex-wrap items-center gap-sm mb-md" style="padding:12px;border-color:var(--accent-primary);background:rgba(16,185,129,0.05);">
    <span class="text-sm font-semibold text-accent">
      <span x-text="selectedIds.length"></span> selected
    </span>
    <div class="flex items-center gap-sm flex-wrap" style="margin-left:auto;">
      <form method="POST" action="/candidates/bulk/run-ai-match" class="inline">
        <template x-for="id in selectedIds" :key="id">
          <input type="hidden" name="candidate_ids[]" :value="id">
        </template>
        <button type="submit" class="btn btn-primary btn-sm">
          <i data-lucide="brain" style="width:16px;height:16px;"></i> Run AI Match
        </button>
      </form>
      <button class="btn btn-primary btn-sm" onclick="alert('Bulk shortlist coming soon')">
        <i data-lucide="check-circle" style="width:16px;height:16px;"></i> Shortlist
      </button>
      <button class="btn btn-danger btn-sm" onclick="alert('Bulk reject coming soon')">
        <i data-lucide="x-circle" style="width:16px;height:16px;"></i> Reject
      </button>
    </div>
  </div>

  <!-- ── Candidates Data Table ────────────────────────────────────────── -->
  <% if (_candidates.length > 0) { %>
    <div class="card overflow-hidden">
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th style="width:40px;">
                <input type="checkbox"
                       :checked="selectAll"
                       @change="toggleAll($event.target.checked)">
              </th>
              <th>Candidate</th>
              <th>Applied Role</th>
              <th>Location</th>
              <th>Qualification</th>
              <th>Exp</th>
              <th>Designation</th>
              <th>Organisation</th>
              <th class="text-center">AI Match</th>
              <th class="text-center">AI Interview</th>
              <th>Recommendation</th>
              <th>HR Status</th>
              <th>Applied</th>
              <th style="width:48px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% _candidates.forEach(function(c) { %>
              <tr>
                <!-- Checkbox -->
                <td>
                  <input type="checkbox"
                         value="<%= c.id %>"
                         :checked="selectedIds.includes('<%= c.id %>')"
                         @change="toggleOne('<%= c.id %>')">
                </td>

                <!-- Candidate Name + Email -->
                <td style="min-width:200px;">
                  <a href="/candidates/<%= c.id %>" class="flex items-center gap-sm">
                    <div class="avatar avatar-sm avatar-gradient shrink-0">
                      <span class="text-xs font-semibold"><%= initials(c.appln_full_name) %></span>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-medium truncate"><%= c.appln_full_name || 'Unnamed' %></p>
                      <p class="text-xs text-muted truncate"><%= c.appln_email || '' %></p>
                    </div>
                  </a>
                </td>

                <!-- Applied Role -->
                <td style="min-width:160px;">
                  <span class="text-sm"><%= c.job_role_label || c.applied_for_post || c.applied_job_short_desc_new || '-' %></span>
                </td>

                <!-- Location -->
                <td style="white-space:nowrap;">
                  <span class="text-sm text-muted"><%= c.applied_location || '-' %></span>
                </td>

                <!-- Qualification -->
                <td>
                  <% if (c.qualification_label || c.appln_high_qualification) { %>
                    <span class="badge badge-muted"><%= c.qualification_label || c.appln_high_qualification %></span>
                  <% } else { %>
                    <span class="text-sm text-muted">-</span>
                  <% } %>
                </td>

                <!-- Experience -->
                <td style="white-space:nowrap;">
                  <span class="text-sm"><%= c.appln_total_experience != null ? c.appln_total_experience + ' yr' : '-' %></span>
                </td>

                <!-- Designation -->
                <td style="min-width:140px;">
                  <span class="text-sm truncate" style="display:block;max-width:160px;"><%= c.appln_current_designation || '-' %></span>
                </td>

                <!-- Organisation -->
                <td style="min-width:140px;">
                  <span class="text-sm text-muted truncate" style="display:block;max-width:160px;"><%= c.appln_current_organisation || '-' %></span>
                </td>

                <!-- AI Match Score -->
                <td class="text-center">
                  <% if (c.match_score != null) { %>
                    <div class="inline-flex" style="flex-direction:column;align-items:center;">
                      <div class="score-ring" style="width:40px;height:40px;">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3" style="stroke:var(--border-color);"></circle>
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3"
                                  class="<%= scoreBg(c.match_score) %>"
                                  stroke-dasharray="<%= (2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-dashoffset="<%= ((1 - (parseFloat(c.match_score)||0)/100) * 2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-linecap="round"></circle>
                        </svg>
                        <span class="score-value text-xs font-bold <%= scoreColor(c.match_score) %>"><%= Math.round(c.match_score) %></span>
                      </div>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted">-</span>
                  <% } %>
                </td>

                <!-- AI Interview Score -->
                <td class="text-center">
                  <% if (c.overall_score != null) { %>
                    <div class="inline-flex" style="flex-direction:column;align-items:center;">
                      <div class="score-ring" style="width:40px;height:40px;">
                        <svg width="40" height="40" viewBox="0 0 40 40">
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3" style="stroke:var(--border-color);"></circle>
                          <circle cx="20" cy="20" r="16" fill="none" stroke-width="3"
                                  class="<%= scoreBg(c.overall_score) %>"
                                  stroke-dasharray="<%= (2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-dashoffset="<%= ((1 - (parseFloat(c.overall_score)||0)/100) * 2 * Math.PI * 16).toFixed(1) %>"
                                  stroke-linecap="round"></circle>
                        </svg>
                        <span class="score-value text-xs font-bold <%= scoreColor(c.overall_score) %>"><%= Math.round(c.overall_score) %></span>
                      </div>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted">-</span>
                  <% } %>
                </td>

                <!-- Recommendation -->
                <td>
                  <% if (c.screening_status === 'eligible' && c.match_score != null) {
                    const rec = parseFloat(c.match_score) >= 75 ? 'strong_fit' : (parseFloat(c.match_score) >= 50 ? 'moderate_fit' : 'weak_fit');
                  %>
                    <span class="badge <%= badgeClass(rec) %>"><%= labelise(rec) %></span>
                  <% } else { %>
                    <span class="text-xs text-muted">-</span>
                  <% } %>
                </td>

                <!-- HR Status -->
                <td>
                  <span class="badge <%= badgeClass(c.appln_status_new) %>"><%= labelise(c.appln_status_new) %></span>
                </td>

                <!-- Applied Date -->
                <td style="white-space:nowrap;">
                  <span class="text-sm text-muted"><%= fmtDate(c.appln_date) %></span>
                </td>

                <!-- Actions Dropdown -->
                <td>
                  <div x-data="{ open: false }" class="relative">
                    <button @click="open = !open" @click.outside="open = false" class="btn btn-ghost" style="padding:6px;">
                      <i data-lucide="more-vertical" style="width:16px;height:16px;"></i>
                    </button>
                    <div x-show="open" x-cloak
                         x-transition:enter="transition ease-out duration-100"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         x-transition:leave="transition ease-in duration-75"
                         x-transition:leave-start="opacity-100 scale-100"
                         x-transition:leave-end="opacity-0 scale-95"
                         class="card absolute" style="right:0;margin-top:4px;width:192px;z-index:30;padding:4px 0;">
                      <a href="/candidates/<%= c.id %>" class="flex items-center gap-sm text-sm" style="padding:8px 16px;">
                        <i data-lucide="eye" style="width:16px;height:16px;"></i> View Detail
                      </a>
                      <form method="POST" action="/candidates/<%= c.id %>/run-ai-match">
                        <button type="submit" class="w-full flex items-center gap-sm text-sm" style="padding:8px 16px;background:none;border:none;cursor:pointer;font-family:inherit;text-align:left;">
                          <i data-lucide="brain" style="width:16px;height:16px;"></i> Run AI Match
                        </button>
                      </form>
                      <a href="/ai-interviews/invite/<%= c.id %>" class="flex items-center gap-sm text-sm" style="padding:8px 16px;">
                        <i data-lucide="video" style="width:16px;height:16px;"></i> Invite Interview
                      </a>
                      <button @click="quickView = '<%= c.id %>'; open = false"
                              class="w-full flex items-center gap-sm text-sm" style="padding:8px 16px;background:none;border:none;cursor:pointer;font-family:inherit;text-align:left;">
                        <i data-lucide="message-square-plus" style="width:16px;height:16px;"></i> Add Note
                      </button>
                      <div class="border-t" style="margin:4px 0;"></div>
                      <a href="/shortlist/add/<%= c.id %>" class="flex items-center gap-sm text-sm text-success" style="padding:8px 16px;">
                        <i data-lucide="check-circle" style="width:16px;height:16px;"></i> Shortlist
                      </a>
                      <a href="/schedules/create?candidate=<%= c.id %>" class="flex items-center gap-sm text-sm" style="padding:8px 16px;">
                        <i data-lucide="calendar-plus" style="width:16px;height:16px;"></i> Schedule
                      </a>
                      <button class="w-full flex items-center gap-sm text-sm text-danger" style="padding:8px 16px;background:none;border:none;cursor:pointer;font-family:inherit;text-align:left;"
                              onclick="if(confirm('Reject this candidate?')) { /* reject */ }">
                        <i data-lucide="x-circle" style="width:16px;height:16px;"></i> Reject
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- ── Pagination ──────────────────────────────────────────────── -->
      <div class="flex items-center justify-between flex-wrap gap-md border-t" style="padding:16px;">
        <p class="text-sm text-muted">
          Showing
          <span class="font-medium text-primary"><%= ((_pagination.page - 1) * _pagination.limit) + 1 %></span>
          to
          <span class="font-medium text-primary"><%= Math.min(_pagination.page * _pagination.limit, _pagination.total) %></span>
          of
          <span class="font-medium text-primary"><%= _pagination.total %></span>
          candidates
        </p>

        <div class="pagination">
          <% if (_pagination.hasPrev) { %>
            <a href="/candidates?<%= qs({ page: _pagination.page - 1 }) %>">
              <i data-lucide="chevron-left" style="width:16px;height:16px;"></i>
            </a>
          <% } else { %>
            <span class="disabled">
              <i data-lucide="chevron-left" style="width:16px;height:16px;"></i>
            </span>
          <% } %>

          <% pageArray(_pagination.page, _pagination.totalPages).forEach(function(pg) { %>
            <% if (pg === '...') { %>
              <span style="border:none;">...</span>
            <% } else { %>
              <a href="/candidates?<%= qs({ page: pg }) %>"
                 class="<%= pg === _pagination.page ? 'active' : '' %>">
                <%= pg %>
              </a>
            <% } %>
          <% }); %>

          <% if (_pagination.hasNext) { %>
            <a href="/candidates?<%= qs({ page: _pagination.page + 1 }) %>">
              <i data-lucide="chevron-right" style="width:16px;height:16px;"></i>
            </a>
          <% } else { %>
            <span class="disabled">
              <i data-lucide="chevron-right" style="width:16px;height:16px;"></i>
            </span>
          <% } %>
        </div>
      </div>
    </div>

  <% } else { %>
    <!-- ── Empty State ─────────────────────────────────────────────── -->
    <div class="card">
      <div class="empty-state" style="padding:80px 24px;">
        <div style="width:80px;height:80px;border-radius:var(--radius-lg);background:var(--bg-tertiary);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
          <i data-lucide="users" style="width:40px;height:40px;color:var(--text-muted);opacity:0.3;"></i>
        </div>
        <h3 class="text-lg font-semibold mb-sm">No candidates found</h3>
        <p class="text-sm text-muted" style="max-width:24rem;margin:0 auto 24px;">
          <% if (Object.keys(_filters).length > 0) { %>
            No candidates match your current filters. Try adjusting or clearing them.
          <% } else { %>
            There are no candidate applications to display at this time.
          <% } %>
        </p>
        <% if (Object.keys(_filters).length > 0) { %>
          <a href="/candidates" class="btn btn-primary">
            <i data-lucide="x" style="width:16px;height:16px;"></i> Clear Filters
          </a>
        <% } %>
      </div>
    </div>
  <% } %>

  <!-- ── Quick View Drawer ────────────────────────────────────────────── -->
  <%- include('_quick_view') %>

</div>
