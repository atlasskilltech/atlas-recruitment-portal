<%
  /* ── Quick View Drawer Partial ───────────────────────────────────────
     Used inside the candidates/index.ejs page.
     Requires Alpine.js `quickView` property on the parent x-data scope
     and the `_candidates` array to be available.
     ─────────────────────────────────────────────────────────────────── */
  const _qvCandidates = typeof candidates !== 'undefined' ? candidates : (typeof _candidates !== 'undefined' ? _candidates : []);

  function qvInitials(name) {
    if (!name) return '?';
    return name.trim().split(/\s+/).filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
  }
  function qvScoreColor(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'text-success';
    if (n >= 50) return 'text-warning';
    return 'text-danger';
  }
  function qvScoreBg(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'stroke-green-500';
    if (n >= 50) return 'stroke-yellow-500';
    return 'stroke-red-500';
  }
  function qvBadgeClass(status) {
    const s = String(status||'').toLowerCase().replace(/\s+/g,'_');
    const map = {
      new:'badge-new', shortlisted:'badge-shortlisted', rejected:'badge-rejected',
      hold:'badge-hold', scheduled:'badge-scheduled', selected:'badge-selected',
      offer_released:'badge-info', hired:'badge-hired',
      eligible:'badge-eligible',
    };
    return map[s] || 'badge-muted';
  }
  function qvLabel(s) {
    if (!s) return '-';
    return String(s).replace(/_/g,' ').replace(/\b\w/g, c=>c.toUpperCase());
  }
%>

<!-- Overlay -->
<div x-show="quickView" x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @click="quickView = null"
     style="position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:50;">
</div>

<!-- Drawer Panel -->
<div x-show="quickView" x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     style="position:fixed;top:0;right:0;height:100%;width:100%;max-width:28rem;z-index:50;overflow-y:auto;background:var(--bg-secondary);box-shadow:var(--shadow-lg);">

  <% _qvCandidates.forEach(function(c) { %>
    <template x-if="quickView === '<%= c.id %>'">
      <div class="flex flex-col" style="height:100%;">
        <!-- Drawer Header -->
        <div class="gradient-header flex items-center justify-between" style="border-radius:0;margin-bottom:0;padding:20px;">
          <div class="flex items-center gap-sm min-w-0">
            <div class="avatar avatar-md" style="background:rgba(255,255,255,0.15);">
              <span class="text-sm font-bold" style="color:white;"><%= qvInitials(c.appln_full_name) %></span>
            </div>
            <div class="min-w-0">
              <h3 class="font-semibold truncate" style="font-size:1rem;"><%= c.appln_full_name || 'Unnamed' %></h3>
              <p class="text-xs truncate" style="color:rgba(255,255,255,0.7);"><%= c.appln_email || '' %></p>
            </div>
          </div>
          <button @click="quickView = null" class="shrink-0" style="padding:6px;border-radius:var(--radius-md);background:none;border:none;color:white;cursor:pointer;">
            <i data-lucide="x" style="width:20px;height:20px;"></i>
          </button>
        </div>

        <!-- Drawer Body -->
        <div class="flex-1" style="padding:20px;">

          <!-- Status & Role -->
          <div class="mb-md">
            <div class="flex items-center justify-between mb-sm">
              <span class="text-xs text-muted uppercase tracking-wide">HR Status</span>
              <span class="badge <%= qvBadgeClass(c.appln_status_new) %>"><%= qvLabel(c.appln_status_new) %></span>
            </div>
            <div class="flex items-center justify-between mb-sm">
              <span class="text-xs text-muted uppercase tracking-wide">Applied Role</span>
              <span class="text-sm font-medium"><%= c.applied_job_short_desc_new || '-' %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-muted uppercase tracking-wide">Location</span>
              <span class="text-sm"><%= c.applied_location || '-' %></span>
            </div>
          </div>

          <div class="border-t mb-md"></div>

          <!-- Key Details -->
          <div class="grid-2 mb-md">
            <div>
              <p class="text-xs text-muted">Qualification</p>
              <p class="text-sm font-medium" style="margin-top:2px;"><%= c.appln_high_qualification || '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted">Experience</p>
              <p class="text-sm font-medium" style="margin-top:2px;"><%= c.appln_total_experience != null ? c.appln_total_experience + ' years' : '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted">Designation</p>
              <p class="text-sm font-medium" style="margin-top:2px;"><%= c.appln_current_designation || '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted">Organisation</p>
              <p class="text-sm font-medium" style="margin-top:2px;"><%= c.appln_current_organisation || '-' %></p>
            </div>
          </div>

          <div class="border-t mb-md"></div>

          <!-- Scores -->
          <div class="mb-md">
            <h4 class="text-xs text-muted uppercase tracking-wide mb-sm">AI Scores</h4>
            <div class="flex items-center justify-center gap-lg">
              <!-- Match Score Ring -->
              <div class="text-center">
                <div class="score-ring" style="width:64px;height:64px;margin:0 auto;">
                  <svg width="64" height="64" viewBox="0 0 64 64">
                    <circle cx="32" cy="32" r="26" fill="none" stroke-width="4" style="stroke:var(--border-color);"></circle>
                    <% if (c.match_score != null) { %>
                      <circle cx="32" cy="32" r="26" fill="none" stroke-width="4"
                              class="<%= qvScoreBg(c.match_score) %>"
                              stroke-dasharray="<%= (2 * Math.PI * 26).toFixed(1) %>"
                              stroke-dashoffset="<%= ((1 - (parseFloat(c.match_score)||0)/100) * 2 * Math.PI * 26).toFixed(1) %>"
                              stroke-linecap="round"></circle>
                    <% } %>
                  </svg>
                  <span class="score-value text-sm font-bold <%= c.match_score != null ? qvScoreColor(c.match_score) : 'text-muted' %>">
                    <%= c.match_score != null ? Math.round(c.match_score) : '-' %>
                  </span>
                </div>
                <p class="text-xs text-muted" style="margin-top:4px;">Match</p>
              </div>

              <!-- Interview Score Ring -->
              <div class="text-center">
                <div class="score-ring" style="width:64px;height:64px;margin:0 auto;">
                  <svg width="64" height="64" viewBox="0 0 64 64">
                    <circle cx="32" cy="32" r="26" fill="none" stroke-width="4" style="stroke:var(--border-color);"></circle>
                    <% if (c.overall_score != null) { %>
                      <circle cx="32" cy="32" r="26" fill="none" stroke-width="4"
                              class="<%= qvScoreBg(c.overall_score) %>"
                              stroke-dasharray="<%= (2 * Math.PI * 26).toFixed(1) %>"
                              stroke-dashoffset="<%= ((1 - (parseFloat(c.overall_score)||0)/100) * 2 * Math.PI * 26).toFixed(1) %>"
                              stroke-linecap="round"></circle>
                    <% } %>
                  </svg>
                  <span class="score-value text-sm font-bold <%= c.overall_score != null ? qvScoreColor(c.overall_score) : 'text-muted' %>">
                    <%= c.overall_score != null ? Math.round(c.overall_score) : '-' %>
                  </span>
                </div>
                <p class="text-xs text-muted" style="margin-top:4px;">Interview</p>
              </div>
            </div>
          </div>

          <div class="border-t mb-md"></div>

          <!-- Contact -->
          <div>
            <h4 class="text-xs text-muted uppercase tracking-wide mb-sm">Contact</h4>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <% if (c.appln_email) { %>
                <div class="flex items-center gap-sm">
                  <i data-lucide="mail" style="width:16px;height:16px;color:var(--text-muted);"></i>
                  <a href="mailto:<%= c.appln_email %>" class="text-sm truncate"><%= c.appln_email %></a>
                </div>
              <% } %>
              <% if (c.appln_mobile_no) { %>
                <div class="flex items-center gap-sm">
                  <i data-lucide="phone" style="width:16px;height:16px;color:var(--text-muted);"></i>
                  <a href="tel:<%= c.appln_mobile_no %>" class="text-sm"><%= c.appln_mobile_no %></a>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Drawer Footer – Quick Actions -->
        <div class="border-t" style="padding:16px;background:var(--bg-tertiary);">
          <div class="grid-2" style="gap:8px;">
            <a href="/candidates/<%= c.id %>" class="btn btn-primary btn-sm justify-center">
              <i data-lucide="eye" style="width:16px;height:16px;"></i> Full Profile
            </a>
            <form method="POST" action="/candidates/<%= c.id %>/run-ai-match">
              <button type="submit" class="btn btn-primary btn-sm w-full justify-center">
                <i data-lucide="brain" style="width:16px;height:16px;"></i> AI Match
              </button>
            </form>
            <a href="/shortlist/add/<%= c.id %>" class="btn btn-primary btn-sm justify-center" style="background:var(--accent-primary);">
              <i data-lucide="check-circle" style="width:16px;height:16px;"></i> Shortlist
            </a>
            <a href="/ai-interviews/invite/<%= c.id %>" class="btn btn-outline btn-sm justify-center">
              <i data-lucide="video" style="width:16px;height:16px;"></i> Interview
            </a>
          </div>
        </div>
      </div>
    </template>
  <% }); %>
</div>
