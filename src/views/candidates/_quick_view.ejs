<%
  /* ── Quick View Drawer Partial ───────────────────────────────────────
     Used inside the candidates/index.ejs page.
     Requires Alpine.js `quickView` property on the parent x-data scope
     and the `_candidates` array to be available.
     ─────────────────────────────────────────────────────────────────── */
  const _qvCandidates = typeof candidates !== 'undefined' ? candidates : (typeof _candidates !== 'undefined' ? _candidates : []);

  function qvInitials(name) {
    if (!name) return '?';
    return name.trim().split(/\s+/).filter(Boolean).slice(0,2).map(w=>w[0].toUpperCase()).join('');
  }
  function qvScoreColor(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'text-green-600 dark:text-green-400';
    if (n >= 50) return 'text-yellow-600 dark:text-yellow-400';
    return 'text-red-600 dark:text-red-400';
  }
  function qvScoreBg(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'stroke-green-500';
    if (n >= 50) return 'stroke-yellow-500';
    return 'stroke-red-500';
  }
  function qvBadgeClass(status) {
    const s = String(status||'').toLowerCase().replace(/\s+/g,'_');
    const map = {
      new:'badge-new', shortlisted:'badge-shortlisted', rejected:'badge-rejected',
      hold:'badge-hold', scheduled:'badge-scheduled', selected:'badge-selected',
      offer_released:'badge-info', hired:'badge-hired',
      eligible:'badge-eligible',
    };
    return map[s] || 'badge-muted';
  }
  function qvLabel(s) {
    if (!s) return '-';
    return String(s).replace(/_/g,' ').replace(/\b\w/g, c=>c.toUpperCase());
  }
%>

<!-- Overlay -->
<div x-show="quickView" x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @click="quickView = null"
     class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50">
</div>

<!-- Drawer Panel -->
<div x-show="quickView" x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="translate-x-full"
     x-transition:enter-end="translate-x-0"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="translate-x-0"
     x-transition:leave-end="translate-x-full"
     class="fixed top-0 right-0 h-full w-full max-w-md bg-card shadow-brand-lg z-50 overflow-y-auto custom-scrollbar">

  <% _qvCandidates.forEach(function(c) { %>
    <template x-if="quickView === '<%= c.id %>'">
      <div class="flex flex-col h-full">
        <!-- Drawer Header -->
        <div class="flex items-center justify-between p-5 border-b border-border bg-gradient-brand text-white">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center flex-shrink-0">
              <span class="text-sm font-bold text-white"><%= qvInitials(c.appln_full_name) %></span>
            </div>
            <div class="min-w-0">
              <h3 class="text-base font-semibold truncate"><%= c.appln_full_name || 'Unnamed' %></h3>
              <p class="text-xs text-white/70 truncate"><%= c.appln_email || '' %></p>
            </div>
          </div>
          <button @click="quickView = null" class="flex-shrink-0 p-1.5 rounded-lg hover:bg-white/10 transition-colors">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>

        <!-- Drawer Body -->
        <div class="flex-1 p-5 space-y-5">

          <!-- Status & Role -->
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-xs text-muted-foreground uppercase tracking-wider">HR Status</span>
              <span class="<%= qvBadgeClass(c.appln_status_new) %>"><%= qvLabel(c.appln_status_new) %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-muted-foreground uppercase tracking-wider">Applied Role</span>
              <span class="text-sm font-medium text-foreground"><%= c.applied_job_short_desc_new || '-' %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-muted-foreground uppercase tracking-wider">Location</span>
              <span class="text-sm text-foreground"><%= c.applied_location || '-' %></span>
            </div>
          </div>

          <div class="border-t border-border"></div>

          <!-- Key Details -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-xs text-muted-foreground">Qualification</p>
              <p class="text-sm font-medium text-foreground mt-0.5"><%= c.appln_high_qualification || '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted-foreground">Experience</p>
              <p class="text-sm font-medium text-foreground mt-0.5"><%= c.appln_total_experience != null ? c.appln_total_experience + ' years' : '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted-foreground">Designation</p>
              <p class="text-sm font-medium text-foreground mt-0.5"><%= c.appln_current_designation || '-' %></p>
            </div>
            <div>
              <p class="text-xs text-muted-foreground">Organisation</p>
              <p class="text-sm font-medium text-foreground mt-0.5"><%= c.appln_current_organisation || '-' %></p>
            </div>
          </div>

          <div class="border-t border-border"></div>

          <!-- Scores -->
          <div>
            <h4 class="text-xs text-muted-foreground uppercase tracking-wider mb-3">AI Scores</h4>
            <div class="flex items-center justify-center gap-8">
              <!-- Match Score Ring -->
              <div class="text-center">
                <div class="score-ring w-16 h-16 mx-auto">
                  <svg width="64" height="64" viewBox="0 0 64 64">
                    <circle cx="32" cy="32" r="26" fill="none" stroke-width="4" class="stroke-muted/30"></circle>
                    <% if (c.match_score != null) { %>
                      <circle cx="32" cy="32" r="26" fill="none" stroke-width="4"
                              class="<%= qvScoreBg(c.match_score) %>"
                              stroke-dasharray="<%= (2 * Math.PI * 26).toFixed(1) %>"
                              stroke-dashoffset="<%= ((1 - (parseFloat(c.match_score)||0)/100) * 2 * Math.PI * 26).toFixed(1) %>"
                              stroke-linecap="round"></circle>
                    <% } %>
                  </svg>
                  <span class="score-value text-sm font-bold <%= c.match_score != null ? qvScoreColor(c.match_score) : 'text-muted-foreground' %>">
                    <%= c.match_score != null ? Math.round(c.match_score) : '-' %>
                  </span>
                </div>
                <p class="text-xs text-muted-foreground mt-1">Match</p>
              </div>

              <!-- Interview Score Ring -->
              <div class="text-center">
                <div class="score-ring w-16 h-16 mx-auto">
                  <svg width="64" height="64" viewBox="0 0 64 64">
                    <circle cx="32" cy="32" r="26" fill="none" stroke-width="4" class="stroke-muted/30"></circle>
                    <% if (c.overall_score != null) { %>
                      <circle cx="32" cy="32" r="26" fill="none" stroke-width="4"
                              class="<%= qvScoreBg(c.overall_score) %>"
                              stroke-dasharray="<%= (2 * Math.PI * 26).toFixed(1) %>"
                              stroke-dashoffset="<%= ((1 - (parseFloat(c.overall_score)||0)/100) * 2 * Math.PI * 26).toFixed(1) %>"
                              stroke-linecap="round"></circle>
                    <% } %>
                  </svg>
                  <span class="score-value text-sm font-bold <%= c.overall_score != null ? qvScoreColor(c.overall_score) : 'text-muted-foreground' %>">
                    <%= c.overall_score != null ? Math.round(c.overall_score) : '-' %>
                  </span>
                </div>
                <p class="text-xs text-muted-foreground mt-1">Interview</p>
              </div>
            </div>
          </div>

          <div class="border-t border-border"></div>

          <!-- Contact -->
          <div>
            <h4 class="text-xs text-muted-foreground uppercase tracking-wider mb-3">Contact</h4>
            <div class="space-y-2">
              <% if (c.appln_email) { %>
                <div class="flex items-center gap-2">
                  <i data-lucide="mail" class="w-4 h-4 text-muted-foreground"></i>
                  <a href="mailto:<%= c.appln_email %>" class="text-sm text-primary-800 dark:text-accent hover:underline truncate"><%= c.appln_email %></a>
                </div>
              <% } %>
              <% if (c.appln_mobile_no) { %>
                <div class="flex items-center gap-2">
                  <i data-lucide="phone" class="w-4 h-4 text-muted-foreground"></i>
                  <a href="tel:<%= c.appln_mobile_no %>" class="text-sm text-foreground"><%= c.appln_mobile_no %></a>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Drawer Footer – Quick Actions -->
        <div class="border-t border-border p-4 space-y-2 bg-muted/30">
          <div class="grid grid-cols-2 gap-2">
            <a href="/candidates/<%= c.id %>" class="btn-primary btn-sm justify-center">
              <i data-lucide="eye" class="w-4 h-4"></i> Full Profile
            </a>
            <form method="POST" action="/candidates/<%= c.id %>/run-ai-match">
              <button type="submit" class="btn-accent btn-sm w-full justify-center">
                <i data-lucide="brain" class="w-4 h-4"></i> AI Match
              </button>
            </form>
            <a href="/shortlist/add/<%= c.id %>" class="btn-success btn-sm justify-center">
              <i data-lucide="check-circle" class="w-4 h-4"></i> Shortlist
            </a>
            <a href="/ai-interviews/invite/<%= c.id %>" class="btn-outline btn-sm justify-center">
              <i data-lucide="video" class="w-4 h-4"></i> Interview
            </a>
          </div>
        </div>
      </div>
    </template>
  <% }); %>
</div>
