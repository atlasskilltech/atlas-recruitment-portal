<% locals.title = 'Candidate - ' + ((candidate && candidate.appln_full_name) || 'Detail') %>

<!-- Header Card -->
<div class="gradient-header">
  <div class="flex items-center gap-sm mb-md">
    <a href="javascript:history.back()" style="display:inline-flex;align-items:center;gap:6px;text-decoration:none;color:rgba(255,255,255,0.6);">
      <i data-lucide="arrow-left" style="width:16px;height:16px;"></i>
      <span class="text-sm">Back</span>
    </a>
  </div>

  <div class="flex items-start justify-between flex-wrap gap-lg">
    <!-- Left: Name & Info -->
    <div class="flex-1">
      <div class="flex items-center gap-md mb-sm">
        <% const profilePhotoUrl = candidate.appln_profile ? fileUrlService.buildFileUrl(candidate.appln_profile) : null; %>
        <% if (profilePhotoUrl) { %>
          <div style="width:56px;height:56px;border-radius:var(--radius-lg);overflow:hidden;flex-shrink:0;border:2px solid rgba(255,255,255,0.2);">
            <img src="<%= profilePhotoUrl %>" alt="<%= candidate.appln_full_name %>" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
            <div class="avatar avatar-lg" style="display:none;border-radius:0;background:rgba(255,255,255,0.1);width:100%;height:100%;align-items:center;justify-content:center;">
              <%= helpers.getInitials(candidate.appln_full_name || 'NA') %>
            </div>
          </div>
        <% } else { %>
          <div class="avatar avatar-lg" style="border-radius:var(--radius-lg);background:rgba(255,255,255,0.1);">
            <%= helpers.getInitials(candidate.appln_full_name || 'NA') %>
          </div>
        <% } %>
        <div>
          <h1 class="text-2xl font-bold"><%= candidate.appln_full_name || 'N/A' %></h1>
          <p style="color:rgba(255,255,255,0.7);"><%= candidate.applied_job_short_desc_new || 'Position not specified' %></p>
        </div>
      </div>

      <div class="flex flex-wrap gap-sm mt-md">
        <% if (candidate.applied_location) { %>
          <span class="pill">
            <i data-lucide="map-pin" style="width:12px;height:12px;"></i> <%= candidate.applied_location %>
          </span>
        <% } %>
        <% if (candidate.appln_total_experience) { %>
          <span class="pill">
            <i data-lucide="briefcase" style="width:12px;height:12px;"></i> <%= candidate.appln_total_experience %> yrs exp
          </span>
        <% } %>
        <% if (candidate.appln_high_qualification) { %>
          <span class="pill">
            <i data-lucide="graduation-cap" style="width:12px;height:12px;"></i> <%= candidate.appln_high_qualification %>
          </span>
        <% } %>
        <% if (candidate.appln_category) { %>
          <span class="pill">
            <%= candidate.appln_category %>
          </span>
        <% } %>
        <% if (candidate.appln_net_set) { %>
          <span class="pill" style="background:rgba(16,185,129,0.3);">
            NET/SET: <%= candidate.appln_net_set %>
          </span>
        <% } %>
      </div>
    </div>

    <!-- Right: Scores & Actions -->
    <div class="flex flex-col items-start" style="align-items:flex-end;gap:16px;">
      <div class="flex items-center gap-lg">
        <% if (candidate.ai_match_score != null) { %>
          <div class="text-center">
            <div style="width:64px;height:64px;" data-score="<%= candidate.ai_match_score %>" data-size="64" data-stroke="4"></div>
            <p class="text-xs" style="color:rgba(255,255,255,0.7);margin-top:4px;">AI Match</p>
          </div>
        <% } %>
        <% if (candidate.total_score != null) { %>
          <div class="text-center">
            <div style="width:64px;height:64px;" data-score="<%= candidate.total_score %>" data-size="64" data-stroke="4"></div>
            <p class="text-xs" style="color:rgba(255,255,255,0.7);margin-top:4px;">Interview</p>
          </div>
        <% } %>
        <% if (candidate.ai_recommendation_tag) { %>
          <span class="badge badge-<%= candidate.ai_recommendation_tag %>" style="padding:6px 16px;">
            <%= candidate.ai_recommendation_tag.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %>
          </span>
        <% } %>
      </div>

      <div class="flex flex-wrap gap-sm">
        <form method="POST" action="/candidates/<%= candidate.id %>/run-ai-match" class="inline">
          <button type="submit" class="btn btn-sm" style="background:var(--accent-primary);color:white;">
            <i data-lucide="brain" style="width:12px;height:12px;"></i> Run AI Match
          </button>
        </form>
        <form method="POST" action="/ai/interviews/<%= candidate.id %>/invite" class="inline">
          <input type="hidden" name="candidate_id" value="<%= candidate.id %>">
          <input type="hidden" name="interview_type" value="hr">
          <button type="submit" class="btn btn-sm" style="background:rgba(255,255,255,0.2);color:white;">
            <i data-lucide="message-square" style="width:12px;height:12px;"></i> Invite Interview
          </button>
        </form>
        <form method="POST" action="/shortlist/<%= candidate.id %>/shortlist" class="inline">
          <button type="submit" class="btn btn-sm" style="background:rgba(255,255,255,0.2);color:white;">
            <i data-lucide="check-circle" style="width:12px;height:12px;"></i> Shortlist
          </button>
        </form>
        <a href="/schedules/create/<%= candidate.id %>" class="btn btn-sm" style="background:rgba(255,255,255,0.2);color:white;">
          <i data-lucide="calendar" style="width:12px;height:12px;"></i> Schedule
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Tabs -->
<div x-data="{ activeTab: 'overview' }">
  <!-- Tab Navigation -->
  <div class="tabs mb-lg">
    <% const tabs = [
      { key: 'overview', label: 'Overview', icon: 'user' },
      { key: 'education', label: 'Education', icon: 'graduation-cap' },
      { key: 'experience', label: 'Experience', icon: 'briefcase' },
      { key: 'research', label: 'Research', icon: 'book-open' },
      { key: 'references', label: 'References', icon: 'users' },
      { key: 'documents', label: 'Documents', icon: 'file-text' },
      { key: 'screening', label: 'AI Screening', icon: 'brain' },
      { key: 'interview', label: 'AI Interview', icon: 'message-square' },
      { key: 'notes', label: 'HR Notes', icon: 'sticky-note' },
      { key: 'timeline', label: 'Timeline', icon: 'clock' },
    ]; %>
    <% tabs.forEach(t => { %>
      <button class="tab" :class="{ 'active': activeTab === '<%= t.key %>' }"
              @click="activeTab = '<%= t.key %>'">
        <i data-lucide="<%= t.icon %>" style="width:16px;height:16px;display:inline;margin-right:4px;"></i> <%= t.label %>
      </button>
    <% }) %>
  </div>

  <!-- Tab: Overview -->
  <div x-show="activeTab === 'overview'" x-transition>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:100%;overflow:hidden;">
      <!-- Personal Info -->
      <div class="card" style="min-width:0;overflow:hidden;">
        <div class="card-body">
          <h3 class="text-lg font-semibold mb-md">Personal Information</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Full Name</span><span class="font-medium" style="text-align:right;overflow:hidden;text-overflow:ellipsis;"><%= candidate.appln_full_name || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Email</span><span class="font-medium" style="text-align:right;overflow:hidden;text-overflow:ellipsis;"><%= candidate.appln_email || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Mobile</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_mobile_no || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Date of Birth</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_dob ? dateUtils.formatDate(candidate.appln_dob) : '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Age</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_age || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Marital Status</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_marital_status || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Category</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_category || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Specialization</span><span class="font-medium" style="text-align:right;overflow:hidden;text-overflow:ellipsis;"><%= candidate.appln_specialization || '-' %></span></div>
          </div>
        </div>
      </div>

      <!-- Current Employment -->
      <div class="card" style="min-width:0;overflow:hidden;">
        <div class="card-body">
          <h3 class="text-lg font-semibold mb-md">Current Employment</h3>
          <div style="display:flex;flex-direction:column;gap:12px;">
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Organization</span><span class="font-medium" style="text-align:right;overflow:hidden;text-overflow:ellipsis;"><%= candidate.appln_current_organisation || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Designation</span><span class="font-medium" style="text-align:right;overflow:hidden;text-overflow:ellipsis;"><%= candidate.appln_current_designation || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Current Salary</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_current_salary || '-' %></span></div>
            <div style="display:flex;justify-content:space-between;gap:8px;"><span class="text-secondary" style="white-space:nowrap;">Notice Period</span><span class="font-medium" style="text-align:right;"><%= candidate.appln_current_notice_period || '-' %></span></div>
          </div>

          <h3 class="text-lg font-semibold mt-lg mb-md">Experience Summary</h3>
          <div class="grid-2" style="gap:12px;">
            <div class="card text-center" style="padding:12px;background:var(--bg-tertiary);border:none;">
              <p class="text-2xl font-bold text-accent"><%= candidate.appln_total_experience || '0' %></p>
              <p class="text-xs text-muted">Total Years</p>
            </div>
            <div class="card text-center" style="padding:12px;background:var(--bg-tertiary);border:none;">
              <p class="text-2xl font-bold"><%= candidate.appln_total_ug_experience || '0' %></p>
              <p class="text-xs text-muted">UG Teaching</p>
            </div>
            <div class="card text-center" style="padding:12px;background:var(--bg-tertiary);border:none;">
              <p class="text-2xl font-bold"><%= candidate.appln_total_pg_experience || '0' %></p>
              <p class="text-xs text-muted">PG Teaching</p>
            </div>
            <div class="card text-center" style="padding:12px;background:var(--bg-tertiary);border:none;">
              <p class="text-2xl font-bold"><%= candidate.appln_total_research_experience || '0' %></p>
              <p class="text-xs text-muted">Research</p>
            </div>
            <div class="card text-center" style="padding:12px;background:var(--bg-tertiary);border:none;">
              <p class="text-2xl font-bold"><%= candidate.appln_total_industry_experience || '0' %></p>
              <p class="text-xs text-muted">Industry</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Education -->
  <div x-show="activeTab === 'education'" x-transition>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <% const eduLevels = [
        { title: 'PhD / Doctorate', degree: candidate.appln_phd, college: candidate.appln_phd_collage, grade: candidate.appln_phd_grade, spec: candidate.appln_phd_specilzation, year: candidate.appln_phd_passing_year, extra: candidate.appln_phd_title, color: 'var(--accent-purple)' },
        { title: 'Post Graduate (PG)', degree: candidate.appln_pg, college: candidate.appln_pg_collage, grade: candidate.appln_pg_grade, spec: candidate.appln_pg_specilzation, year: candidate.appln_pg_passing_year, color: 'var(--accent-secondary)' },
        { title: 'Under Graduate (UG)', degree: candidate.appln_ug, college: candidate.appln_ug_collage, grade: candidate.appln_ug_grade, spec: candidate.appln_ug_specilzation, year: candidate.appln_ug_passing_year, color: 'var(--accent-primary)' },
        { title: 'HSC / 12th', degree: candidate.appln_hsc, college: candidate.appln_hsc_collage, grade: candidate.appln_hsc_grade, spec: candidate.appln_hsc_specilzation, year: candidate.appln_hsc_passing_year, color: 'var(--accent-warning)' },
        { title: 'SSC / 10th', degree: candidate.appln_ssc, college: candidate.appln_ssc_collage, grade: candidate.appln_ssc_grade, spec: candidate.appln_ssc_specilzation, year: candidate.appln_ssc_passing_year, color: 'var(--accent-warning)' },
      ]; %>

      <% eduLevels.forEach(edu => { if (edu.degree) { %>
        <div class="card" style="padding:20px;border-left:4px solid <%= edu.color %>;">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="font-semibold text-lg"><%= edu.title %></h4>
              <p class="text-secondary"><%= edu.degree %></p>
            </div>
            <% if (edu.year) { %>
              <span class="badge badge-info"><%= edu.year %></span>
            <% } %>
          </div>
          <div class="grid-3 mt-sm">
            <div><span class="text-xs text-muted">College/University</span><p class="text-sm font-medium"><%= edu.college || '-' %></p></div>
            <div><span class="text-xs text-muted">Grade/Percentage</span><p class="text-sm font-medium"><%= edu.grade || '-' %></p></div>
            <div><span class="text-xs text-muted">Specialization</span><p class="text-sm font-medium"><%= edu.spec || '-' %></p></div>
          </div>
          <% if (edu.extra) { %>
            <div class="mt-sm"><span class="text-xs text-muted">PhD Title</span><p class="text-sm font-medium"><%= edu.extra %></p></div>
          <% } %>
        </div>
      <% }}) %>

      <% if (candidate.appln_qualified || candidate.appln_net_set) { %>
        <div class="card" style="padding:20px;border-left:4px solid var(--accent-primary);">
          <h4 class="font-semibold">Qualifying Exams</h4>
          <div class="flex gap-md mt-sm">
            <% if (candidate.appln_net_set) { %><span class="badge badge-success">NET/SET: <%= candidate.appln_net_set %></span><% } %>
            <% if (candidate.appln_qualified) { %><span class="badge badge-success">Qualified: <%= candidate.appln_qualified %></span><% } %>
          </div>
        </div>
      <% } %>

      <% if (!eduLevels.some(e => e.degree)) { %>
        <div class="empty-state"><i data-lucide="graduation-cap"></i><p class="text-muted">No education data available</p></div>
      <% } %>
    </div>
  </div>

  <!-- Tab: Experience -->
  <div x-show="activeTab === 'experience'" x-transition>
    <div style="display:flex;flex-direction:column;gap:16px;">
      <% const exps = [
        { designation: candidate.appln_prev_designation, company: candidate.appln_prev_company, experience: candidate.appln_prev_experience, from: candidate.appln_prev_from_date, to: candidate.appln_prev_to_date },
        { designation: candidate.appln_prev_designation_second, company: candidate.appln_prev_company_second, experience: candidate.appln_prev_experience_second, from: candidate.appln_prev_from_date_second, to: candidate.appln_prev_to_date_second },
        { designation: candidate.appln_prev_designation_third, company: candidate.appln_prev_company_third, experience: candidate.appln_prev_experience_third, from: candidate.appln_prev_from_date_third, to: candidate.appln_prev_to_date_third },
      ]; %>

      <% let hasExp = false; exps.forEach((exp, idx) => { if (exp.company) { hasExp = true; %>
        <div class="card" style="padding:20px;border-left:4px solid var(--accent-secondary);">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="font-semibold"><%= exp.designation || 'Position' %></h4>
              <p class="text-secondary"><%= exp.company %></p>
            </div>
            <% if (exp.experience) { %><span class="badge badge-info"><%= exp.experience %> yrs</span><% } %>
          </div>
          <% if (exp.from || exp.to) { %>
            <p class="text-sm text-muted mt-sm">
              <%= exp.from ? dateUtils.formatDate(exp.from) : 'N/A' %> - <%= exp.to ? dateUtils.formatDate(exp.to) : 'Present' %>
            </p>
          <% } %>
        </div>
      <% }}) %>

      <% if (!hasExp) { %>
        <div class="empty-state"><i data-lucide="briefcase"></i><p class="text-muted">No previous experience data available</p></div>
      <% } %>
    </div>
  </div>

  <!-- Tab: Research -->
  <div x-show="activeTab === 'research'" x-transition>
    <div class="stats-row mb-lg">
      <div class="stat-card" style="flex-direction:column;align-items:center;text-align:center;">
        <div class="stat-value text-accent"><%= candidate.appln_total_journal || '0' %></div>
        <div class="stat-label">Journal Papers</div>
      </div>
      <div class="stat-card" style="flex-direction:column;align-items:center;text-align:center;">
        <div class="stat-value"><%= candidate.appln_total_book || '0' %></div>
        <div class="stat-label">Books</div>
      </div>
      <div class="stat-card" style="flex-direction:column;align-items:center;text-align:center;">
        <div class="stat-value"><%= candidate.appln_impact || '0' %></div>
        <div class="stat-label">Impact Factor</div>
      </div>
      <div class="stat-card" style="flex-direction:column;align-items:center;text-align:center;">
        <div class="stat-value"><%= candidate.appln_patents || '0' %></div>
        <div class="stat-label">Patents</div>
      </div>
    </div>
    <% if (candidate.appln_guide_phd_students) { %>
      <div class="card mb-md">
        <div class="card-body">
          <h4 class="font-semibold">PhD Students Guided</h4>
          <p style="margin-top:4px;"><%= candidate.appln_guide_phd_students %></p>
        </div>
      </div>
    <% } %>
    <% if (candidate.appln_phd_title) { %>
      <div class="card">
        <div class="card-body">
          <h4 class="font-semibold">PhD Thesis Title</h4>
          <p class="text-muted" style="margin-top:4px;"><%= candidate.appln_phd_title %></p>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Tab: References -->
  <div x-show="activeTab === 'references'" x-transition>
    <div class="grid-2 gap-lg">
      <% const refs = [
        { name: candidate.appln_ref_name, org: candidate.appln_ref_org, designation: candidate.appln_ref_designation, phone: candidate.appln_ref_phone, email: candidate.appln_ref_email },
        { name: candidate.appln_ref_name1, org: candidate.appln_ref_org1, designation: candidate.appln_ref_designation1, phone: candidate.appln_ref_phone1, email: candidate.appln_ref_email1 },
      ]; %>
      <% refs.forEach((ref, idx) => { if (ref.name) { %>
        <div class="card">
          <div class="card-body">
            <h4 class="font-semibold mb-sm">Reference <%= idx + 1 %></h4>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <div><span class="text-xs text-muted">Name</span><p class="font-medium"><%= ref.name %></p></div>
              <div><span class="text-xs text-muted">Organization</span><p><%= ref.org || '-' %></p></div>
              <div><span class="text-xs text-muted">Designation</span><p><%= ref.designation || '-' %></p></div>
              <div><span class="text-xs text-muted">Phone</span><p><%= ref.phone || '-' %></p></div>
              <div><span class="text-xs text-muted">Email</span><p><%= ref.email || '-' %></p></div>
            </div>
          </div>
        </div>
      <% }}) %>
      <% if (!refs.some(r => r.name)) { %>
        <div style="grid-column:1/-1;" class="empty-state"><i data-lucide="users"></i><p class="text-muted">No references provided</p></div>
      <% } %>
    </div>
  </div>

  <!-- Tab: Documents -->
  <div x-show="activeTab === 'documents'" x-transition>
    <% const docs = fileUrlService.getCandidateFiles(candidate); %>
    <% if (docs.length > 0) { %>
      <div class="grid-3">
        <% docs.forEach(doc => { %>
          <div class="card flex items-center gap-sm" style="padding:16px;">
            <% if (doc.columnName === 'appln_profile') { %>
              <div style="width:40px;height:40px;border-radius:var(--radius-md);overflow:hidden;flex-shrink:0;">
                <img src="<%= doc.url %>" alt="Profile Photo" style="width:100%;height:100%;object-fit:cover;" onerror="this.parentElement.innerHTML='<div class=\'stat-icon blue\' style=\'width:40px;height:40px;\'><i data-lucide=\'user\' style=\'width:18px;height:18px;\'></i></div>';">
              </div>
            <% } else { %>
              <div class="stat-icon blue shrink-0">
                <i data-lucide="file-text"></i>
              </div>
            <% } %>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-sm truncate"><%= doc.label %></p>
              <p class="text-xs text-muted truncate"><%= doc.fileName %></p>
            </div>
            <div class="flex items-center gap-sm">
              <a href="<%= doc.url %>" target="_blank" class="btn btn-ghost btn-sm" style="padding:4px;" title="View">
                <i data-lucide="external-link" style="width:16px;height:16px;"></i>
              </a>
              <a href="<%= doc.url %>" download class="btn btn-ghost btn-sm" style="padding:4px;" title="Download">
                <i data-lucide="download" style="width:16px;height:16px;"></i>
              </a>
              <button onclick="copyToClipboard('<%= doc.url %>')" class="btn btn-ghost btn-sm" style="padding:4px;" title="Copy URL">
                <i data-lucide="copy" style="width:16px;height:16px;"></i>
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state"><i data-lucide="file-x"></i><h3 class="text-lg font-medium text-muted">No documents uploaded</h3></div>
    <% } %>
  </div>

  <!-- Tab: AI Screening -->
  <div x-show="activeTab === 'screening'" x-transition>
    <% if (candidate.screening_id) { %>
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
        <div class="card text-center" style="padding:24px;">
          <% const aiScore = parseFloat(candidate.ai_match_score) || 0;
             const ringCirc = 2 * Math.PI * 40;
             const ringOff = ringCirc - (aiScore / 100) * ringCirc;
             const ringColor = aiScore >= 75 ? '#10b981' : aiScore >= 50 ? '#f59e0b' : '#ef4444';
          %>
          <div style="position:relative;width:96px;height:96px;margin:0 auto;">
            <svg width="96" height="96" viewBox="0 0 100 100" style="transform:rotate(-90deg);">
              <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" stroke="var(--border-color)" opacity="0.2"></circle>
              <circle cx="50" cy="50" r="40" fill="none" stroke-width="6" stroke="<%= ringColor %>"
                      stroke-linecap="round" stroke-dasharray="<%= ringCirc %>" stroke-dashoffset="<%= ringOff %>"></circle>
            </svg>
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
              <span style="font-size:1.3rem;font-weight:800;color:<%= ringColor %>;"><%= aiScore %>%</span>
            </div>
          </div>
          <p class="text-sm text-muted mt-sm">AI Match Score</p>
          <% if (candidate.ai_recommendation_tag) { %>
            <span class="badge badge-<%= candidate.ai_recommendation_tag %> mt-sm"><%= candidate.ai_recommendation_tag.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></span>
          <% } %>
          <% if (candidate.ai_status) { %>
            <span class="badge badge-<%= candidate.ai_status %>" style="margin-top:4px;"><%= candidate.ai_status.replace(/\b\w/g, l => l.toUpperCase()) %></span>
          <% } %>
        </div>
        <div style="display:flex;flex-direction:column;gap:16px;">
          <% if (candidate.extracted_skills) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Extracted Skills</h4>
                <div class="flex flex-wrap gap-sm">
                  <% const skills = typeof candidate.extracted_skills === 'string' ? JSON.parse(candidate.extracted_skills || '[]') : (candidate.extracted_skills || []); %>
                  <% skills.forEach(s => { %><span class="badge badge-info"><%= s %></span><% }) %>
                  <% if (skills.length === 0) { %><span class="text-muted text-sm">None extracted</span><% } %>
                </div>
              </div>
            </div>
          <% } %>
          <% if (candidate.extracted_keywords) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Keywords</h4>
                <div class="flex flex-wrap gap-sm">
                  <% const keywords = typeof candidate.extracted_keywords === 'string' ? JSON.parse(candidate.extracted_keywords || '[]') : (candidate.extracted_keywords || []); %>
                  <% keywords.forEach(k => { %><span class="badge badge-muted"><%= k %></span><% }) %>
                </div>
              </div>
            </div>
          <% } %>
          <% if (candidate.extracted_education_summary) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Education Summary</h4>
                <p class="text-sm text-muted"><%= candidate.extracted_education_summary %></p>
              </div>
            </div>
          <% } %>
          <% if (candidate.extracted_experience_summary) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Experience Summary</h4>
                <p class="text-sm text-muted"><%= candidate.extracted_experience_summary %></p>
              </div>
            </div>
          <% } %>
          <% if (candidate.skill_gap_analysis) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Skill Gap Analysis</h4>
                <%
                  let sgaParsed = null;
                  try { sgaParsed = typeof candidate.skill_gap_analysis === 'string' ? JSON.parse(candidate.skill_gap_analysis) : candidate.skill_gap_analysis; } catch(e) { sgaParsed = null; }
                %>
                <% if (sgaParsed && typeof sgaParsed === 'object') { %>
                  <div style="display:flex;flex-direction:column;gap:12px;">
                    <% if (sgaParsed.matched && sgaParsed.matched.length > 0) { %>
                      <div>
                        <p class="text-xs font-semibold mb-sm" style="color:#10b981;">Matched Skills</p>
                        <div class="flex flex-wrap gap-sm">
                          <% sgaParsed.matched.forEach(function(s) { %><span class="badge badge-success"><%= s %></span><% }); %>
                        </div>
                      </div>
                    <% } %>
                    <% if (sgaParsed.missing && sgaParsed.missing.length > 0) { %>
                      <div>
                        <p class="text-xs font-semibold mb-sm" style="color:#ef4444;">Missing Skills</p>
                        <div class="flex flex-wrap gap-sm">
                          <% sgaParsed.missing.forEach(function(s) { %><span class="badge badge-danger"><%= s %></span><% }); %>
                        </div>
                      </div>
                    <% } %>
                    <% if (sgaParsed.additional && sgaParsed.additional.length > 0) { %>
                      <div>
                        <p class="text-xs font-semibold mb-sm" style="color:#3b82f6;">Additional Skills</p>
                        <div class="flex flex-wrap gap-sm">
                          <% sgaParsed.additional.forEach(function(s) { %><span class="badge badge-info"><%= s %></span><% }); %>
                        </div>
                      </div>
                    <% } %>
                  </div>
                <% } else { %>
                  <p class="text-sm text-muted"><%= candidate.skill_gap_analysis %></p>
                <% } %>
              </div>
            </div>
          <% } %>
          <% if (candidate.role_fit_summary) { %>
            <div class="card">
              <div class="card-body">
                <h4 class="font-semibold mb-sm">Role Fit Summary</h4>
                <p class="text-sm text-muted"><%= candidate.role_fit_summary %></p>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="brain"></i>
        <h3 class="text-lg font-medium text-muted">No AI screening results yet</h3>
        <p class="text-sm text-muted" style="margin-top:4px;">Run AI Match to analyze this candidate against the job description.</p>
        <form method="POST" action="/candidates/<%= candidate.id %>/run-ai-match" class="mt-md">
          <button type="submit" class="btn btn-primary">
            <i data-lucide="brain" style="width:16px;height:16px;"></i> Run AI Match
          </button>
        </form>
      </div>
    <% } %>
  </div>

  <!-- Tab: AI Interview -->
  <div x-show="activeTab === 'interview'" x-transition>
    <% if (candidate.interviews && candidate.interviews.length > 0) { %>
      <% candidate.interviews.forEach(interview => { %>
        <div class="card mb-md" style="padding:24px;">
          <div class="flex items-center justify-between mb-md">
            <div class="flex items-center gap-sm">
              <span class="badge badge-info"><%= (interview.interview_type || 'HR').toUpperCase() %></span>
              <span class="badge badge-<%= interview.status || 'pending' %>"><%= (interview.status || 'pending').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></span>
            </div>
            <span class="text-sm text-muted"><%= interview.started_at ? dateUtils.formatDateTime(interview.started_at) : '-' %></span>
          </div>

          <% if (interview.total_score != null) { %>
            <%
              const ivScores = [
                { label: 'Total', val: parseFloat(interview.total_score) || 0 },
                { label: 'Communication', val: parseFloat(interview.communication_score) || 0 },
                { label: 'Domain', val: parseFloat(interview.domain_knowledge_score) || 0 },
                { label: 'Problem Solving', val: parseFloat(interview.problem_solving_score) || 0 },
                { label: 'Confidence', val: parseFloat(interview.confidence_score) || 0 },
              ];
              const ivCirc = 2 * Math.PI * 22;
            %>
            <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px;">
              <% ivScores.forEach(function(sc) {
                const ivOff = ivCirc - (sc.val / 100) * ivCirc;
                const ivCol = sc.val >= 75 ? '#10b981' : sc.val >= 50 ? '#f59e0b' : '#ef4444';
              %>
                <div style="text-align:center;">
                  <div style="position:relative;width:56px;height:56px;margin:0 auto;">
                    <svg width="56" height="56" viewBox="0 0 56 56" style="transform:rotate(-90deg);">
                      <circle cx="28" cy="28" r="22" fill="none" stroke-width="4" stroke="var(--border-color)" opacity="0.2"></circle>
                      <circle cx="28" cy="28" r="22" fill="none" stroke-width="4" stroke="<%= ivCol %>"
                              stroke-linecap="round" stroke-dasharray="<%= ivCirc %>" stroke-dashoffset="<%= ivOff %>"></circle>
                    </svg>
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                      <span style="font-size:0.7rem;font-weight:700;color:<%= ivCol %>;"><%= sc.val %>%</span>
                    </div>
                  </div>
                  <p class="text-xs text-muted" style="margin-top:4px;"><%= sc.label %></p>
                </div>
              <% }); %>
            </div>
          <% } %>

          <%
            let feedbackDisplay = '';
            let recDisplay = '';
            let strengthsDisplay = [];
            let improvementsDisplay = [];
            if (interview.ai_feedback) {
              let fbObj = null;
              try {
                fbObj = typeof interview.ai_feedback === 'string' ? JSON.parse(interview.ai_feedback) : interview.ai_feedback;
              } catch(e) { fbObj = null; }
              if (fbObj && typeof fbObj === 'object') {
                // Try to get raw.performanceSummary first
                let inner = fbObj;
                if (fbObj.raw) {
                  try { inner = typeof fbObj.raw === 'string' ? JSON.parse(fbObj.raw) : fbObj.raw; } catch(e2) { inner = fbObj; }
                }
                feedbackDisplay = inner.performanceSummary || fbObj.performanceSummary || '';
                recDisplay = inner.recommendation || fbObj.recommendation || '';
                strengthsDisplay = inner.strengthAreas || fbObj.strengthAreas || [];
                improvementsDisplay = inner.improvementAreas || fbObj.improvementAreas || [];
                if (!feedbackDisplay) feedbackDisplay = inner.recommendationJustification || fbObj.recommendationJustification || '';
              } else {
                feedbackDisplay = String(interview.ai_feedback).substring(0, 500);
              }
            }
          %>
          <% if (feedbackDisplay || recDisplay) { %>
            <div class="card" style="padding:16px;background:var(--bg-tertiary);border:none;display:flex;flex-direction:column;gap:12px;">
              <% if (recDisplay) { %>
                <div class="flex items-center gap-sm">
                  <h5 class="font-semibold text-sm">AI Recommendation:</h5>
                  <span class="badge <%= recDisplay === 'Hire' || recDisplay === 'Strong Hire' ? 'badge-success' :
                     recDisplay === 'No Hire' ? 'badge-danger' : 'badge-warning' %>">
                    <%= recDisplay %>
                  </span>
                </div>
              <% } %>
              <% if (feedbackDisplay) { %>
                <p class="text-sm text-muted" style="line-height:1.7;"><%= feedbackDisplay %></p>
              <% } %>
              <% if (strengthsDisplay.length > 0) { %>
                <div>
                  <p class="text-xs font-semibold mb-sm">Strengths:</p>
                  <div class="flex flex-wrap gap-sm">
                    <% strengthsDisplay.forEach(function(s) { %>
                      <span class="badge badge-success"><%= typeof s === 'string' ? s : s.area || '' %></span>
                    <% }); %>
                  </div>
                </div>
              <% } %>
              <% if (improvementsDisplay.length > 0) { %>
                <div>
                  <p class="text-xs font-semibold mb-sm">Areas for Improvement:</p>
                  <div class="flex flex-wrap gap-sm">
                    <% improvementsDisplay.forEach(function(a) { %>
                      <span class="badge badge-warning"><%= typeof a === 'string' ? a : a.area || '' %></span>
                    <% }); %>
                  </div>
                </div>
              <% } %>
            </div>
          <% } %>

          <a href="/ai/interviews/<%= interview.id %>" class="btn btn-outline btn-sm mt-sm">View Full Details</a>
        </div>
      <% }) %>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="message-square"></i>
        <h3 class="text-lg font-medium text-muted">No AI interviews yet</h3>
        <form method="POST" action="/ai/interviews/<%= candidate.id %>/invite" class="mt-md">
          <input type="hidden" name="candidate_id" value="<%= candidate.id %>">
          <input type="hidden" name="interview_type" value="hr">
          <button type="submit" class="btn btn-primary"><i data-lucide="message-square" style="width:16px;height:16px;"></i> Invite to AI Interview</button>
        </form>
      </div>
    <% } %>
  </div>

  <!-- Tab: HR Notes -->
  <div x-show="activeTab === 'notes'" x-transition>
    <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:24px;">
      <% if (locals.notes && notes.length > 0) { %>
        <% notes.forEach(note => { %>
          <div class="card" style="padding:16px;">
            <div class="flex items-center justify-between mb-sm">
              <span class="badge badge-<%= note.note_type || 'general' %>"><%= (note.note_type || 'general').replace(/\b\w/g, l => l.toUpperCase()) %></span>
              <span class="text-xs text-muted"><%= note.created_at ? dateUtils.formatDateTime(note.created_at) : '' %></span>
            </div>
            <p class="text-sm"><%= note.note_text %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted text-sm">No notes yet.</p>
      <% } %>
    </div>

    <!-- Add Note Form -->
    <div class="card">
      <div class="card-body">
        <h4 class="font-semibold mb-sm">Add Note</h4>
        <form method="POST" action="/candidates/<%= candidate.id %>/add-note">
          <div class="form-group mb-sm">
            <select name="note_type" class="form-select">
              <option value="general">General</option>
              <option value="screening">Screening</option>
              <option value="interview">Interview</option>
              <option value="decision">Decision</option>
            </select>
          </div>
          <div class="form-group mb-sm">
            <textarea name="note_text" class="form-textarea" rows="3" placeholder="Write your note..." required data-max-chars="2000"></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">
            <i data-lucide="plus" style="width:16px;height:16px;"></i> Add Note
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Tab: Timeline -->
  <div x-show="activeTab === 'timeline'" x-transition>
    <% if ((locals.activityLogs && activityLogs.length > 0) || (locals.statusHistory && statusHistory.length > 0)) { %>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <% const allEvents = [
          ...(activityLogs || []).map(l => ({ type: 'activity', date: l.created_at, label: l.action_label || l.action_key, meta: l.metadata })),
          ...(statusHistory || []).map(s => ({ type: 'status', date: s.created_at, label: `Status changed: ${s.old_status || 'none'} → ${s.new_status}`, meta: s.remarks })),
        ].sort((a, b) => new Date(b.date) - new Date(a.date)); %>

        <% allEvents.forEach(event => { %>
          <div class="card" style="padding:12px 16px;">
            <div class="flex items-start justify-between">
              <div>
                <p class="font-medium text-sm"><%= event.label %></p>
                <% if (event.meta) { %><p class="text-xs text-muted" style="margin-top:2px;"><%= typeof event.meta === 'string' ? event.meta : '' %></p><% } %>
              </div>
              <span class="text-xs text-muted shrink-0" style="margin-left:16px;white-space:nowrap;"><%= event.date ? dateUtils.formatDateTime(event.date) : '' %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state"><i data-lucide="clock"></i><p class="text-muted">No activity recorded yet</p></div>
    <% } %>
  </div>
</div>
