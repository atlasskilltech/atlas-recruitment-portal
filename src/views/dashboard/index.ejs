<%
  /* ── Safe defaults ──────────────────────────────────────────────────── */
  const s = typeof stats !== 'undefined' && stats ? stats : {};
  const c = typeof charts !== 'undefined' && charts ? charts : {};
  const recent = typeof recentApplicants !== 'undefined' && recentApplicants ? recentApplicants : [];
  const top5 = typeof topCandidates !== 'undefined' && topCandidates ? topCandidates : [];

  const userName = (typeof currentUser !== 'undefined' && currentUser)
    ? (currentUser.first_name || 'User')
    : 'User';

  const today = new Date();
  const dateStr = today.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

  /* Helper: format numbers with commas */
  const fmt = (n) => (n != null ? Number(n).toLocaleString() : '0');

  /* Stat card definitions */
  const statCards = [
    { key: 'total_applicants',  label: 'Total Applicants',  icon: 'users',        color: 'blue' },
    { key: 'new_applicants',    label: 'New Applicants',     icon: 'user-plus',    color: 'green' },
    { key: 'ai_eligible',       label: 'AI Eligible',        icon: 'check-circle', color: 'green' },
    { key: 'ai_rejected',       label: 'AI Rejected',        icon: 'x-circle',     color: 'red' },
    { key: 'interview_pending', label: 'Interview Pending',  icon: 'clock',        color: 'orange' },
    { key: 'interview_passed',  label: 'Interview Passed',   icon: 'award',        color: 'green' },
    { key: 'shortlisted',       label: 'Shortlisted',        icon: 'list-checks',  color: 'blue' },
    { key: 'scheduled',         label: 'Scheduled',          icon: 'calendar',     color: 'purple' },
    { key: 'hired',             label: 'Hired',              icon: 'trophy',       color: 'green' },
    { key: 'rejected',          label: 'Rejected',           icon: 'ban',          color: 'red' },
  ];

  /* Badge helper */
  const statusBadge = (status) => {
    const map = {
      'new':        'badge-new',
      'eligible':   'badge-eligible',
      'rejected':   'badge-rejected',
      'hold':       'badge-hold',
      'shortlisted':'badge-shortlisted',
      'scheduled':  'badge-scheduled',
      'selected':   'badge-selected',
      'hired':      'badge-hired',
      'pending':    'badge-warning',
      'passed':     'badge-success',
      'failed':     'badge-danger',
    };
    return map[String(status || '').toLowerCase()] || 'badge-muted';
  };
%>

<!-- ═══════════════════════════════════════════════════════════════════════
     Page Header
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="flex items-center justify-between mb-lg">
  <div>
    <h1 class="text-2xl font-bold">Dashboard</h1>
    <p class="text-sm text-secondary" style="margin-top: 4px;">
      Welcome back, <span class="font-medium text-primary"><%= userName %></span>
      <span style="margin: 0 6px; color: var(--border-color);">|</span>
      <%= dateStr %>
    </p>
  </div>
  <a href="/candidates" class="btn btn-primary btn-sm">
    <i data-lucide="plus" style="width: 16px; height: 16px;"></i>
    View All Candidates
  </a>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Stat Cards Grid
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="stats-row">
  <% statCards.forEach(function(card, idx) { %>
    <div class="stat-card" style="animation: fadeIn 0.3s ease <%= idx * 60 %>ms both;">
      <div class="stat-icon <%= card.color %>">
        <i data-lucide="<%= card.icon %>"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value"><%= fmt(s[card.key]) %></div>
        <div class="stat-label"><%= card.label %></div>
      </div>
    </div>
  <% }); %>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Charts Row 1 – Applicants by Role & AI Match Score Distribution
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid-2 mb-lg" style="grid-template-columns: 1fr 1fr;">

  <!-- Applicants by Job Role (Horizontal Bar) -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="bar-chart-3"></i>
        Applicants by Job Role
      </h2>
    </div>
    <div class="card-body">
      <% if (c.applicantsByRole && c.applicantsByRole.length > 0) { %>
        <div id="chart-role" class="chart-container" style="min-height: 320px;"></div>
      <% } else { %>
        <div class="empty-state">
          <i data-lucide="bar-chart-3"></i>
          <p class="text-sm text-muted">No role data available yet.</p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- AI Match Score Distribution (Donut) -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="pie-chart"></i>
        AI Match Score Distribution
      </h2>
    </div>
    <div class="card-body">
      <% if (c.matchScoreDist && c.matchScoreDist.length > 0) { %>
        <div id="chart-score" class="chart-container" style="min-height: 320px;"></div>
      <% } else { %>
        <div class="empty-state">
          <i data-lucide="pie-chart"></i>
          <p class="text-sm text-muted">No screening data available yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Charts Row 2 – Monthly Trend & Hiring Funnel
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid-2 mb-lg" style="grid-template-columns: 1fr 1fr;">

  <!-- Monthly Applications Trend (Area) -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="trending-up"></i>
        Monthly Applications Trend
      </h2>
    </div>
    <div class="card-body">
      <% if (c.monthlyTrend && c.monthlyTrend.length > 0) { %>
        <div id="chart-trend" class="chart-container"></div>
      <% } else { %>
        <div class="empty-state">
          <i data-lucide="trending-up"></i>
          <p class="text-sm text-muted">No trend data available yet.</p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Hiring Funnel (Horizontal Bar) -->
  <div class="card">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="filter"></i>
        Hiring Funnel
      </h2>
    </div>
    <div class="card-body">
      <% if (c.statusFunnel && c.statusFunnel.length > 0) { %>
        <div id="chart-funnel" class="chart-container"></div>
      <% } else { %>
        <div class="empty-state">
          <i data-lucide="filter"></i>
          <p class="text-sm text-muted">No funnel data available yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Recent Applicants Table & Top Matched Candidates
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid-3 mb-lg" style="grid-template-columns: 2fr 1fr;">

  <!-- Recent Applicants Table -->
  <div class="card" style="overflow: hidden;">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="clock"></i>
        Recent Applicants
      </h2>
      <a href="/candidates" class="text-sm text-accent font-medium">
        View all &rarr;
      </a>
    </div>

    <% if (recent.length > 0) { %>
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Role Applied</th>
              <th>AI Score</th>
              <th>Status</th>
              <th>Date</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% recent.forEach(function(a) { %>
              <tr>
                <td>
                  <div class="flex items-center gap-sm">
                    <div class="avatar avatar-sm avatar-gradient"><%
                      if (a.appln_full_name) {
                        const parts = a.appln_full_name.trim().split(/\s+/);
                        %><%= parts[0].charAt(0).toUpperCase() %><%= parts.length > 1 ? parts[parts.length - 1].charAt(0).toUpperCase() : '' %><%
                      } else { %>?<% } %></div>
                    <div style="min-width: 0;">
                      <p class="text-sm font-medium truncate" style="max-width: 160px;"><%= a.appln_full_name || 'N/A' %></p>
                      <p class="text-xs text-muted truncate" style="max-width: 160px;"><%= a.appln_email || '' %></p>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="text-sm"><%= a.job_title || 'N/A' %></span>
                </td>
                <td>
                  <% if (a.match_score != null) { %>
                    <span class="text-sm font-semibold" style="color: <%= a.match_score >= 70 ? 'var(--accent-primary)' : a.match_score >= 40 ? 'var(--accent-warning)' : 'var(--accent-danger)' %>;">
                      <%= a.match_score %>%
                    </span>
                  <% } else { %>
                    <span class="text-xs text-muted">--</span>
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= statusBadge(a.appln_status_new) %>">
                    <%= a.appln_status_new ? String(a.appln_status_new).charAt(0).toUpperCase() + String(a.appln_status_new).slice(1) : 'New' %>
                  </span>
                </td>
                <td>
                  <span class="text-xs text-muted">
                    <%= a.appln_date ? new Date(a.appln_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '--' %>
                  </span>
                </td>
                <td class="text-right">
                  <a href="/candidates/<%= a.id %>" class="btn btn-ghost btn-sm text-accent">
                    View
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="users"></i>
        <p class="text-sm text-muted">No applicants yet</p>
        <p class="text-xs text-muted">Applicants will appear here once they apply.</p>
      </div>
    <% } %>
  </div>

  <!-- Top Matched Candidates Leaderboard -->
  <div class="card" style="overflow: hidden;">
    <div class="card-header">
      <h2 class="card-title">
        <i data-lucide="trophy"></i>
        Top Matched Candidates
      </h2>
    </div>

    <%
      /* Build top 5 from recent applicants if topCandidates not provided */
      let leaderboard = top5;
      if (leaderboard.length === 0 && recent.length > 0) {
        leaderboard = recent
          .filter(r => r.match_score != null)
          .sort((a, b) => b.match_score - a.match_score)
          .slice(0, 5);
      }
    %>

    <% if (leaderboard.length > 0) { %>
      <div>
        <% leaderboard.forEach(function(cand, rank) { %>
          <div class="flex items-center gap-md" style="padding: 16px 20px; border-bottom: 1px solid var(--border-light);">
            <!-- Rank Badge -->
            <div class="shrink-0 flex items-center justify-center font-bold" style="width: 28px; height: 28px; border-radius: 50%; font-size: 0.75rem;
              <% if (rank === 0) { %>background: rgba(245,158,11,0.1); color: #b45309;
              <% } else if (rank === 1) { %>background: var(--bg-tertiary); color: var(--text-secondary);
              <% } else if (rank === 2) { %>background: rgba(234,88,12,0.1); color: #c2410c;
              <% } else { %>background: var(--bg-tertiary); color: var(--text-muted);
              <% } %>">
              <%= rank + 1 %>
            </div>

            <!-- Candidate Info -->
            <div class="flex-1" style="min-width: 0;">
              <p class="text-sm font-medium truncate"><%= cand.appln_full_name || cand.name || 'N/A' %></p>
              <p class="text-xs text-muted truncate"><%= cand.job_title || cand.role || '' %></p>
            </div>

            <!-- Score Ring -->
            <%
              const score = cand.match_score || cand.score || 0;
              const ringRadius = 20;
              const circumference = 2 * Math.PI * ringRadius;
              const offset = circumference - (score / 100) * circumference;
              const ringColor = score >= 70 ? '#10b981' : score >= 40 ? '#f59e0b' : '#ef4444';
              const ringBg = score >= 70 ? 'rgba(16,185,129,0.1)' : score >= 40 ? 'rgba(245,158,11,0.1)' : 'rgba(239,68,68,0.1)';
            %>
            <div class="score-ring shrink-0" title="AI Match Score: <%= score %>%">
              <svg width="52" height="52" viewBox="0 0 52 52">
                <circle cx="26" cy="26" r="<%= ringRadius %>" fill="<%= ringBg %>" stroke="#e2e8f0" stroke-width="3" />
                <circle cx="26" cy="26" r="<%= ringRadius %>" fill="none" stroke="<%= ringColor %>" stroke-width="3"
                  stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= offset %>"
                  stroke-linecap="round" />
              </svg>
              <span class="score-value text-xs font-bold" style="color: <%= ringColor %>;"><%= score %>%</span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <i data-lucide="award"></i>
        <p class="text-sm text-muted">No scored candidates yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     ApexCharts Initialization
     ═══════════════════════════════════════════════════════════════════════ -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Brand palette ──────────────────────────────────────────────────── */
  var brandColors = ['#1a237e', '#283593', '#3949ab', '#5c6bc0', '#7986cb',
                     '#9fa8da', '#c5cae9', '#8bc34a', '#689f38', '#558b2f'];

  var isDark = document.documentElement.classList.contains('dark');
  var textColor = isDark ? '#94a3b8' : '#64748b';
  var gridColor = isDark ? 'rgba(148,163,184,0.08)' : 'rgba(0,0,0,0.06)';

  var baseOptions = {
    chart: { fontFamily: 'Inter, system-ui, sans-serif', toolbar: { show: false }, background: 'transparent' },
    theme: { mode: isDark ? 'dark' : 'light' },
    grid: { borderColor: gridColor, strokeDashArray: 4 },
  };

  /* ── 1. Applicants by Job Role (Horizontal Bar) ─────────────────────── */
  <% if (c.applicantsByRole && c.applicantsByRole.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.applicantsByRole) %>;
    new ApexCharts(document.querySelector('#chart-role'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'bar', height: 320 }),
      series: [{ name: 'Applicants', data: data.map(function(d) { return d.value; }) }],
      plotOptions: { bar: { horizontal: true, barHeight: '60%', borderRadius: 4, distributed: true } },
      colors: brandColors,
      dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 600 } },
      xaxis: { categories: data.map(function(d) { return d.label || 'Unknown'; }), labels: { style: { colors: textColor, fontSize: '12px' } } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' }, maxWidth: 160 } },
      legend: { show: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

  /* ── 2. AI Match Score Distribution (Donut) ──────────────────────────── */
  <% if (c.matchScoreDist && c.matchScoreDist.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.matchScoreDist) %>;
    new ApexCharts(document.querySelector('#chart-score'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'donut', height: 320 }),
      series: data.map(function(d) { return d.value; }),
      labels: data.map(function(d) { return d.label; }),
      colors: ['#ef4444', '#f97316', '#f59e0b', '#eab308', '#84cc16', '#22c55e', '#14b8a6', '#06b6d4', '#3b82f6', '#6366f1'],
      plotOptions: { pie: { donut: { size: '60%', labels: { show: true, total: { show: true, label: 'Total', fontSize: '14px', fontWeight: 600, color: textColor } } } } },
      dataLabels: { enabled: false },
      legend: { position: 'bottom', fontSize: '12px', labels: { colors: textColor } },
      tooltip: { theme: isDark ? 'dark' : 'light' },
      stroke: { width: 2, colors: [isDark ? '#1e293b' : '#ffffff'] },
    })).render();
  })();
  <% } %>

  /* ── 3. Monthly Applications Trend (Area) ────────────────────────────── */
  <% if (c.monthlyTrend && c.monthlyTrend.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.monthlyTrend) %>;
    var labels = data.map(function(d) {
      var parts = d.label.split('-');
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[parseInt(parts[1], 10) - 1] + ' ' + parts[0].slice(2);
    });
    new ApexCharts(document.querySelector('#chart-trend'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'area', height: 300 }),
      series: [{ name: 'Applications', data: data.map(function(d) { return d.value; }) }],
      xaxis: { categories: labels, labels: { style: { colors: textColor, fontSize: '11px' }, rotate: -45 } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' } } },
      colors: ['#3949ab'],
      fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.45, opacityTo: 0.05, stops: [0, 100] } },
      stroke: { curve: 'smooth', width: 2.5 },
      dataLabels: { enabled: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

  /* ── 4. Hiring Funnel (Horizontal Bar) ──────────────────────────────── */
  <% if (c.statusFunnel && c.statusFunnel.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.statusFunnel) %>;
    var funnelColors = ['#3949ab', '#5c6bc0', '#7986cb', '#8bc34a', '#689f38', '#558b2f'];
    new ApexCharts(document.querySelector('#chart-funnel'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'bar', height: 300 }),
      series: [{ name: 'Candidates', data: data.map(function(d) { return d.value; }) }],
      plotOptions: { bar: { horizontal: true, barHeight: '55%', borderRadius: 6, distributed: true } },
      colors: funnelColors.slice(0, data.length),
      xaxis: { categories: data.map(function(d) { return d.label; }), labels: { style: { colors: textColor, fontSize: '12px' } } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' }, maxWidth: 140 } },
      dataLabels: { enabled: true, style: { fontSize: '12px', fontWeight: 700 }, formatter: function(v) { return v.toLocaleString(); } },
      legend: { show: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

});
</script>
