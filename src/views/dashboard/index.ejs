<%
  /* ── Safe defaults ──────────────────────────────────────────────────── */
  const s = typeof stats !== 'undefined' && stats ? stats : {};
  const c = typeof charts !== 'undefined' && charts ? charts : {};
  const recent = typeof recentApplicants !== 'undefined' && recentApplicants ? recentApplicants : [];
  const top5 = typeof topCandidates !== 'undefined' && topCandidates ? topCandidates : [];

  const userName = (typeof currentUser !== 'undefined' && currentUser)
    ? (currentUser.first_name || 'User')
    : 'User';

  const today = new Date();
  const dateStr = today.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

  /* Helper: format numbers with commas */
  const fmt = (n) => (n != null ? Number(n).toLocaleString() : '0');

  /* Stat card definitions */
  const statCards = [
    { key: 'total_applicants',  label: 'Total Applicants',  icon: 'users',        bg: 'bg-blue-500',    light: 'bg-blue-50 dark:bg-blue-950/30',    text: 'text-blue-600 dark:text-blue-400' },
    { key: 'new_applicants',    label: 'New Applicants',     icon: 'user-plus',    bg: 'bg-green-500',   light: 'bg-green-50 dark:bg-green-950/30',  text: 'text-green-600 dark:text-green-400' },
    { key: 'ai_eligible',       label: 'AI Eligible',        icon: 'check-circle', bg: 'bg-emerald-500', light: 'bg-emerald-50 dark:bg-emerald-950/30', text: 'text-emerald-600 dark:text-emerald-400' },
    { key: 'ai_rejected',       label: 'AI Rejected',        icon: 'x-circle',     bg: 'bg-red-500',     light: 'bg-red-50 dark:bg-red-950/30',      text: 'text-red-600 dark:text-red-400' },
    { key: 'interview_pending', label: 'Interview Pending',  icon: 'clock',        bg: 'bg-amber-500',   light: 'bg-amber-50 dark:bg-amber-950/30',  text: 'text-amber-600 dark:text-amber-400' },
    { key: 'interview_passed',  label: 'Interview Passed',   icon: 'award',        bg: 'bg-green-500',   light: 'bg-green-50 dark:bg-green-950/30',  text: 'text-green-600 dark:text-green-400' },
    { key: 'shortlisted',       label: 'Shortlisted',        icon: 'list-checks',  bg: 'bg-blue-500',    light: 'bg-blue-50 dark:bg-blue-950/30',    text: 'text-blue-600 dark:text-blue-400' },
    { key: 'scheduled',         label: 'Scheduled',          icon: 'calendar',     bg: 'bg-purple-500',  light: 'bg-purple-50 dark:bg-purple-950/30',text: 'text-purple-600 dark:text-purple-400' },
    { key: 'hired',             label: 'Hired',              icon: 'trophy',       bg: 'bg-accent',      light: 'bg-accent-50 dark:bg-accent-700/20',text: 'text-accent-600 dark:text-accent-400' },
    { key: 'rejected',          label: 'Rejected',           icon: 'ban',          bg: 'bg-red-500',     light: 'bg-red-50 dark:bg-red-950/30',      text: 'text-red-600 dark:text-red-400' },
  ];

  /* Badge helper */
  const statusBadge = (status) => {
    const map = {
      'new':        'badge-new',
      'eligible':   'badge-eligible',
      'rejected':   'badge-rejected',
      'hold':       'badge-hold',
      'shortlisted':'badge-shortlisted',
      'scheduled':  'badge-scheduled',
      'selected':   'badge-selected',
      'hired':      'badge-hired',
      'pending':    'badge-warning',
      'passed':     'badge-success',
      'failed':     'badge-danger',
    };
    return map[String(status || '').toLowerCase()] || 'badge-muted';
  };
%>

<!-- ═══════════════════════════════════════════════════════════════════════
     Page Header
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Dashboard</h1>
    <p class="text-sm text-muted-foreground mt-1">
      Welcome back, <span class="font-medium text-foreground"><%= userName %></span>
      <span class="mx-1.5 text-border">|</span>
      <%= dateStr %>
    </p>
  </div>
  <a href="/candidates" class="btn-primary btn-sm self-start sm:self-auto">
    <i data-lucide="plus" class="w-4 h-4"></i>
    View All Candidates
  </a>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Stat Cards Grid
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-4 mb-8">
  <% statCards.forEach(function(card, idx) { %>
    <div class="stat-card animate-slide-up" style="animation-delay: <%= idx * 60 %>ms">
      <div class="flex items-start justify-between mb-3">
        <div class="stat-icon <%= card.bg %>">
          <i data-lucide="<%= card.icon %>" class="w-5 h-5"></i>
        </div>
      </div>
      <div class="stat-value text-foreground"><%= fmt(s[card.key]) %></div>
      <div class="stat-label"><%= card.label %></div>
    </div>
  <% }); %>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Charts Row 1 – Applicants by Role & AI Match Score Distribution
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Applicants by Job Role (Horizontal Bar) -->
  <div class="card p-5">
    <h2 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="bar-chart-3" class="w-5 h-5 text-primary-400"></i>
      Applicants by Job Role
    </h2>
    <% if (c.applicantsByRole && c.applicantsByRole.length > 0) { %>
      <div id="chart-role" class="min-h-[320px]"></div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="bar-chart-3" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground">No role data available yet.</p>
      </div>
    <% } %>
  </div>

  <!-- AI Match Score Distribution (Donut) -->
  <div class="card p-5">
    <h2 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="pie-chart" class="w-5 h-5 text-emerald-500"></i>
      AI Match Score Distribution
    </h2>
    <% if (c.matchScoreDist && c.matchScoreDist.length > 0) { %>
      <div id="chart-score" class="min-h-[320px]"></div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="pie-chart" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground">No screening data available yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Charts Row 2 – Monthly Trend & Hiring Funnel
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Monthly Applications Trend (Area) -->
  <div class="card p-5">
    <h2 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="trending-up" class="w-5 h-5 text-blue-500"></i>
      Monthly Applications Trend
    </h2>
    <% if (c.monthlyTrend && c.monthlyTrend.length > 0) { %>
      <div id="chart-trend" class="min-h-[300px]"></div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="trending-up" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground">No trend data available yet.</p>
      </div>
    <% } %>
  </div>

  <!-- Hiring Funnel (Horizontal Bar) -->
  <div class="card p-5">
    <h2 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="filter" class="w-5 h-5 text-purple-500"></i>
      Hiring Funnel
    </h2>
    <% if (c.statusFunnel && c.statusFunnel.length > 0) { %>
      <div id="chart-funnel" class="min-h-[300px]"></div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="filter" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground">No funnel data available yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     Recent Applicants Table & Top Matched Candidates
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="grid grid-cols-1 xl:grid-cols-3 gap-6 mb-6">

  <!-- Recent Applicants Table (2/3 width on xl) -->
  <div class="xl:col-span-2 card overflow-hidden">
    <div class="px-5 py-4 border-b border-border flex items-center justify-between">
      <h2 class="text-base font-semibold text-foreground flex items-center gap-2">
        <i data-lucide="clock" class="w-5 h-5 text-muted-foreground"></i>
        Recent Applicants
      </h2>
      <a href="/candidates" class="text-sm text-primary-400 hover:text-primary-300 font-medium transition-colors">
        View all &rarr;
      </a>
    </div>

    <% if (recent.length > 0) { %>
      <div class="overflow-x-auto custom-scrollbar">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Role Applied</th>
              <th class="hidden md:table-cell">AI Score</th>
              <th>Status</th>
              <th class="hidden sm:table-cell">Date</th>
              <th class="text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% recent.forEach(function(a) { %>
              <tr>
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-brand flex items-center justify-center flex-shrink-0">
                      <span class="text-xs font-semibold text-white">
                        <%= a.appln_full_name ? a.appln_full_name.charAt(0).toUpperCase() : '?' %>
                      </span>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-foreground truncate max-w-[160px]"><%= a.appln_full_name || 'N/A' %></p>
                      <p class="text-xxs text-muted-foreground truncate max-w-[160px]"><%= a.appln_email || '' %></p>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="text-sm text-foreground"><%= a.job_title || 'N/A' %></span>
                </td>
                <td class="hidden md:table-cell">
                  <% if (a.match_score != null) { %>
                    <span class="inline-flex items-center gap-1.5 text-sm font-semibold <%= a.match_score >= 70 ? 'text-green-600 dark:text-green-400' : a.match_score >= 40 ? 'text-amber-600 dark:text-amber-400' : 'text-red-600 dark:text-red-400' %>">
                      <%= a.match_score %>%
                    </span>
                  <% } else { %>
                    <span class="text-xs text-muted-foreground">--</span>
                  <% } %>
                </td>
                <td>
                  <span class="<%= statusBadge(a.appln_status_new) %>">
                    <%= a.appln_status_new ? a.appln_status_new.charAt(0).toUpperCase() + a.appln_status_new.slice(1) : 'New' %>
                  </span>
                </td>
                <td class="hidden sm:table-cell">
                  <span class="text-xs text-muted-foreground">
                    <%= a.appln_date ? new Date(a.appln_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '--' %>
                  </span>
                </td>
                <td class="text-right">
                  <a href="/candidates/<%= a.id %>" class="btn-ghost btn-sm text-primary-400 hover:text-primary-300">
                    View
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="users" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground mb-1">No applicants yet</p>
        <p class="text-xs text-muted-foreground">Applicants will appear here once they apply.</p>
      </div>
    <% } %>
  </div>

  <!-- Top Matched Candidates Leaderboard (1/3 width on xl) -->
  <div class="card overflow-hidden">
    <div class="px-5 py-4 border-b border-border">
      <h2 class="text-base font-semibold text-foreground flex items-center gap-2">
        <i data-lucide="trophy" class="w-5 h-5 text-accent"></i>
        Top Matched Candidates
      </h2>
    </div>

    <%
      /* Build top 5 from recent applicants if topCandidates not provided */
      let leaderboard = top5;
      if (leaderboard.length === 0 && recent.length > 0) {
        leaderboard = recent
          .filter(r => r.match_score != null)
          .sort((a, b) => b.match_score - a.match_score)
          .slice(0, 5);
      }
    %>

    <% if (leaderboard.length > 0) { %>
      <div class="divide-y divide-border">
        <% leaderboard.forEach(function(cand, rank) { %>
          <div class="px-5 py-4 flex items-center gap-4 hover:bg-muted/30 transition-colors">
            <!-- Rank Badge -->
            <div class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold
              <%= rank === 0 ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' :
                   rank === 1 ? 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-300' :
                   rank === 2 ? 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400' :
                   'bg-muted text-muted-foreground' %>">
              <%= rank + 1 %>
            </div>

            <!-- Candidate Info -->
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-foreground truncate"><%= cand.appln_full_name || cand.name || 'N/A' %></p>
              <p class="text-xxs text-muted-foreground truncate"><%= cand.job_title || cand.role || '' %></p>
            </div>

            <!-- Score Ring -->
            <div class="score-ring flex-shrink-0" title="AI Match Score: <%= cand.match_score || cand.score || 0 %>%">
              <%
                const score = cand.match_score || cand.score || 0;
                const circumference = 2 * Math.PI * 18;
                const offset = circumference - (score / 100) * circumference;
                const ringColor = score >= 70 ? '#22c55e' : score >= 40 ? '#f59e0b' : '#ef4444';
              %>
              <svg width="48" height="48" viewBox="0 0 48 48">
                <circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="3" class="text-border" />
                <circle cx="24" cy="24" r="18" fill="none" stroke="<%= ringColor %>" stroke-width="3"
                  stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= offset %>"
                  stroke-linecap="round" />
              </svg>
              <span class="score-value text-xs font-bold text-foreground"><%= score %></span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state py-12">
        <i data-lucide="award" class="empty-state-icon"></i>
        <p class="text-sm text-muted-foreground">No scored candidates yet.</p>
      </div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     ApexCharts Initialization
     ═══════════════════════════════════════════════════════════════════════ -->
<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ── Brand palette ──────────────────────────────────────────────────── */
  var brandColors = ['#1a237e', '#283593', '#3949ab', '#5c6bc0', '#7986cb',
                     '#9fa8da', '#c5cae9', '#8bc34a', '#689f38', '#558b2f'];

  var isDark = document.documentElement.classList.contains('dark');
  var textColor = isDark ? '#94a3b8' : '#64748b';
  var gridColor = isDark ? 'rgba(148,163,184,0.08)' : 'rgba(0,0,0,0.06)';

  var baseOptions = {
    chart: { fontFamily: 'Inter, system-ui, sans-serif', toolbar: { show: false }, background: 'transparent' },
    theme: { mode: isDark ? 'dark' : 'light' },
    grid: { borderColor: gridColor, strokeDashArray: 4 },
  };

  /* ── 1. Applicants by Job Role (Horizontal Bar) ─────────────────────── */
  <% if (c.applicantsByRole && c.applicantsByRole.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.applicantsByRole) %>;
    new ApexCharts(document.querySelector('#chart-role'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'bar', height: 320 }),
      series: [{ name: 'Applicants', data: data.map(function(d) { return d.value; }) }],
      plotOptions: { bar: { horizontal: true, barHeight: '60%', borderRadius: 4, distributed: true } },
      colors: brandColors,
      dataLabels: { enabled: true, style: { fontSize: '11px', fontWeight: 600 } },
      xaxis: { categories: data.map(function(d) { return d.label || 'Unknown'; }), labels: { style: { colors: textColor, fontSize: '12px' } } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' }, maxWidth: 160 } },
      legend: { show: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

  /* ── 2. AI Match Score Distribution (Donut) ──────────────────────────── */
  <% if (c.matchScoreDist && c.matchScoreDist.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.matchScoreDist) %>;
    new ApexCharts(document.querySelector('#chart-score'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'donut', height: 320 }),
      series: data.map(function(d) { return d.value; }),
      labels: data.map(function(d) { return d.label; }),
      colors: ['#ef4444', '#f97316', '#f59e0b', '#eab308', '#84cc16', '#22c55e', '#14b8a6', '#06b6d4', '#3b82f6', '#6366f1'],
      plotOptions: { pie: { donut: { size: '60%', labels: { show: true, total: { show: true, label: 'Total', fontSize: '14px', fontWeight: 600, color: textColor } } } } },
      dataLabels: { enabled: false },
      legend: { position: 'bottom', fontSize: '12px', labels: { colors: textColor } },
      tooltip: { theme: isDark ? 'dark' : 'light' },
      stroke: { width: 2, colors: [isDark ? '#1e293b' : '#ffffff'] },
    })).render();
  })();
  <% } %>

  /* ── 3. Monthly Applications Trend (Area) ────────────────────────────── */
  <% if (c.monthlyTrend && c.monthlyTrend.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.monthlyTrend) %>;
    var labels = data.map(function(d) {
      var parts = d.label.split('-');
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return months[parseInt(parts[1], 10) - 1] + ' ' + parts[0].slice(2);
    });
    new ApexCharts(document.querySelector('#chart-trend'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'area', height: 300 }),
      series: [{ name: 'Applications', data: data.map(function(d) { return d.value; }) }],
      xaxis: { categories: labels, labels: { style: { colors: textColor, fontSize: '11px' }, rotate: -45 } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' } } },
      colors: ['#3949ab'],
      fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.45, opacityTo: 0.05, stops: [0, 100] } },
      stroke: { curve: 'smooth', width: 2.5 },
      dataLabels: { enabled: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

  /* ── 4. Hiring Funnel (Horizontal Bar) ──────────────────────────────── */
  <% if (c.statusFunnel && c.statusFunnel.length > 0) { %>
  (function () {
    var data = <%- JSON.stringify(c.statusFunnel) %>;
    var funnelColors = ['#3949ab', '#5c6bc0', '#7986cb', '#8bc34a', '#689f38', '#558b2f'];
    new ApexCharts(document.querySelector('#chart-funnel'), Object.assign({}, baseOptions, {
      chart: Object.assign({}, baseOptions.chart, { type: 'bar', height: 300 }),
      series: [{ name: 'Candidates', data: data.map(function(d) { return d.value; }) }],
      plotOptions: { bar: { horizontal: true, barHeight: '55%', borderRadius: 6, distributed: true } },
      colors: funnelColors.slice(0, data.length),
      xaxis: { categories: data.map(function(d) { return d.label; }), labels: { style: { colors: textColor, fontSize: '12px' } } },
      yaxis: { labels: { style: { colors: textColor, fontSize: '12px' }, maxWidth: 140 } },
      dataLabels: { enabled: true, style: { fontSize: '12px', fontWeight: 700 }, formatter: function(v) { return v.toLocaleString(); } },
      legend: { show: false },
      tooltip: { theme: isDark ? 'dark' : 'light' },
    })).render();
  })();
  <% } %>

});
</script>
