<%
  const shortlists = typeof locals.shortlists !== 'undefined' ? locals.shortlists : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};

  const currentStatus = filters.status || 'all';

  const tabs = [
    { key: 'all', label: 'All' },
    { key: 'shortlisted', label: 'Shortlisted' },
    { key: 'scheduled', label: 'Scheduled' },
    { key: 'selected', label: 'Selected' },
    { key: 'offer_released', label: 'Offer Released' },
    { key: 'hired', label: 'Hired' },
  ];

  function buildQuery(overrides) {
    const params = Object.assign({}, filters, overrides);
    if (params.status === 'all') delete params.status;
    if (params.page == 1) delete params.page;
    const qs = Object.keys(params).filter(k => params[k]).map(k => k + '=' + encodeURIComponent(params[k])).join('&');
    return qs ? '?' + qs : '';
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Shortlisted Candidates</h1>
    <p class="text-sm text-muted-foreground mt-1">Manage shortlisted candidates through the hiring pipeline</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
  <!-- Total Shortlisted -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-foreground"><%= stats.total || 0 %></p>
        <p class="stat-label">Total Shortlisted</p>
      </div>
      <div class="stat-icon bg-primary-800">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Scheduled -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-purple-600 dark:text-purple-400"><%= stats.scheduled || 0 %></p>
        <p class="stat-label">Scheduled</p>
      </div>
      <div class="stat-icon bg-purple-600">
        <i data-lucide="calendar" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Selected -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-indigo-600 dark:text-indigo-400"><%= stats.selected || 0 %></p>
        <p class="stat-label">Selected</p>
      </div>
      <div class="stat-icon bg-indigo-600">
        <i data-lucide="user-check" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Offer Released -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-warning"><%= stats.offerReleased || 0 %></p>
        <p class="stat-label">Offer Released</p>
      </div>
      <div class="stat-icon bg-warning">
        <i data-lucide="file-text" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Hired -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-success"><%= stats.hired || 0 %></p>
        <p class="stat-label">Hired</p>
      </div>
      <div class="stat-icon bg-success">
        <i data-lucide="award" class="w-5 h-5"></i>
      </div>
    </div>
  </div>
</div>

<!-- Filter Tabs -->
<div class="tabs mb-6">
  <% tabs.forEach(function(tab) { %>
    <a href="/shortlist<%= buildQuery({ status: tab.key, page: 1 }) %>"
       class="tab <%= currentStatus === tab.key ? 'active' : '' %>">
      <%= tab.label %>
    </a>
  <% }); %>
</div>

<!-- Shortlist Table -->
<div class="card overflow-hidden" x-data="{ openDropdown: null, activeModal: null, selectedId: null }">
  <% if (shortlists.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate Name</th>
            <th>Job Role</th>
            <th>AI Match Score</th>
            <th>Interview Score</th>
            <th>Recommendation</th>
            <th>HR Status</th>
            <th>Updated Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% shortlists.forEach(function(s, idx) { %>
            <%
              const candidateName = s.candidate_name || (s.candidate ? (s.candidate.first_name + ' ' + s.candidate.last_name) : 'Unknown');
              const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
              const jobTitle = s.job_title || (s.job ? s.job.title : 'N/A');

              const aiScore = s.ai_score || s.match_score || 0;
              const aiScoreColor = aiScore >= 75 ? 'bg-success' : aiScore >= 50 ? 'bg-warning' : 'bg-destructive';
              const aiScoreTextColor = aiScore >= 75 ? 'text-success' : aiScore >= 50 ? 'text-warning' : 'text-destructive';

              const interviewScore = s.interview_score || 0;
              const intScoreColor = interviewScore >= 75 ? 'bg-success' : interviewScore >= 50 ? 'bg-warning' : 'bg-destructive';
              const intScoreTextColor = interviewScore >= 75 ? 'text-success' : interviewScore >= 50 ? 'text-warning' : 'text-destructive';

              const rec = s.recommendation || 'N/A';
              const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
                ? 'badge-strong-fit'
                : rec === 'moderate_fit' || rec === 'Moderate Fit'
                  ? 'badge-moderate-fit'
                  : rec === 'weak_fit' || rec === 'Weak Fit'
                    ? 'badge-weak-fit'
                    : 'badge-muted';

              const hrStatus = s.hr_status || s.status || 'shortlisted';
              const hrStatusBadge = hrStatus === 'shortlisted' ? 'badge-shortlisted'
                : hrStatus === 'scheduled' ? 'badge-scheduled'
                : hrStatus === 'selected' ? 'badge-selected'
                : hrStatus === 'offer_released' ? 'badge-warning'
                : hrStatus === 'hired' ? 'badge-hired'
                : hrStatus === 'rejected' ? 'badge-danger'
                : 'badge-muted';
            %>
            <tr>
              <!-- Candidate Name -->
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-semibold text-primary-800 dark:text-primary-200"><%= initials %></span>
                  </div>
                  <span class="font-medium text-foreground"><%= candidateName %></span>
                </div>
              </td>

              <!-- Job Role -->
              <td class="text-muted-foreground"><%= jobTitle %></td>

              <!-- AI Match Score -->
              <td>
                <div class="flex items-center gap-2">
                  <div class="w-20 h-2 bg-muted rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= aiScoreColor %>" style="width: <%= aiScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= aiScoreTextColor %>"><%= aiScore %>%</span>
                </div>
              </td>

              <!-- Interview Score -->
              <td>
                <div class="flex items-center gap-2">
                  <div class="w-20 h-2 bg-muted rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= intScoreColor %>" style="width: <%= interviewScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= intScoreTextColor %>"><%= interviewScore %>%</span>
                </div>
              </td>

              <!-- Recommendation -->
              <td>
                <span class="<%= recBadge %>">
                  <%= rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- HR Status -->
              <td>
                <span class="<%= hrStatusBadge %>">
                  <%= hrStatus.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- Updated Date -->
              <td class="text-muted-foreground text-sm">
                <% if (s.updated_at) { %>
                  <%= new Date(s.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Actions Dropdown -->
              <td>
                <div class="relative" @click.away="if (openDropdown === <%= idx %>) openDropdown = null">
                  <button @click="openDropdown = openDropdown === <%= idx %> ? null : <%= idx %>"
                          class="btn-ghost btn-sm text-muted-foreground">
                    <i data-lucide="more-vertical" class="w-4 h-4"></i>
                  </button>
                  <div x-show="openDropdown === <%= idx %>" x-transition
                       class="absolute right-0 mt-1 w-48 bg-card border border-border rounded-xl shadow-lg z-20 py-1">
                    <a href="/schedules/create?candidateId=<%= s.candidate_id || (s.candidate ? s.candidate.id : '') %>&jobId=<%= s.job_id || (s.job ? s.job.id : '') %>"
                       class="flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                      <i data-lucide="calendar-plus" class="w-4 h-4 text-muted-foreground"></i>
                      Schedule Interview
                    </a>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="selected">
                      <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="user-check" class="w-4 h-4 text-muted-foreground"></i>
                        Mark Selected
                      </button>
                    </form>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="offer_released">
                      <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="file-text" class="w-4 h-4 text-muted-foreground"></i>
                        Release Offer
                      </button>
                    </form>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="hired">
                      <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                        <i data-lucide="award" class="w-4 h-4 text-muted-foreground"></i>
                        Mark Hired
                      </button>
                    </form>
                    <div class="border-t border-border my-1"></div>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="rejected">
                      <button type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-destructive hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                        <i data-lucide="x-circle" class="w-4 h-4"></i>
                        Reject
                      </button>
                    </form>
                    <button @click="openDropdown = null; activeModal = 'note'; selectedId = '<%= s.id %>'"
                            class="w-full flex items-center gap-2 px-3 py-2 text-sm text-foreground hover:bg-muted transition-colors">
                      <i data-lucide="message-square-plus" class="w-4 h-4 text-muted-foreground"></i>
                      Add Note
                    </button>
                  </div>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between px-4 py-3 border-t border-border">
        <p class="text-sm text-muted-foreground">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="flex items-center gap-1">
          <% if (pagination.page > 1) { %>
            <a href="/shortlist<%= buildQuery({ page: pagination.page - 1 }) %>" class="btn-outline btn-sm">
              <i data-lucide="chevron-left" class="w-4 h-4"></i> Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="btn-primary btn-sm"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="/shortlist<%= buildQuery({ page: i }) %>" class="btn-outline btn-sm"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="px-1 text-muted-foreground">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="/shortlist<%= buildQuery({ page: pagination.page + 1 }) %>" class="btn-outline btn-sm">
              Next <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state py-20">
      <div class="w-20 h-20 rounded-2xl bg-muted/50 flex items-center justify-center mb-5">
        <i data-lucide="check-circle" class="w-10 h-10 text-muted-foreground/30"></i>
      </div>
      <h3 class="text-lg font-semibold text-foreground mb-1">No Shortlisted Candidates</h3>
      <p class="text-sm text-muted-foreground max-w-sm mb-6">
        No shortlisted candidates found. Candidates will appear here once they are shortlisted from AI screening.
      </p>
      <a href="/ai-screening" class="btn-primary">
        <i data-lucide="brain" class="w-4 h-4"></i>
        View AI Screening
      </a>
    </div>
  <% } %>

  <!-- Add Note Modal -->
  <div x-show="activeModal === 'note'" x-transition
       class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4"
       @click.self="activeModal = null" x-cloak>
    <div class="bg-card rounded-2xl shadow-brand-lg w-full max-w-md" @click.stop>
      <div class="modal-header">
        <h3 class="text-lg font-semibold text-foreground">Add Note</h3>
        <button @click="activeModal = null" class="btn-ghost btn-sm text-muted-foreground">
          <i data-lucide="x" class="w-4 h-4"></i>
        </button>
      </div>
      <form :action="'/shortlist/' + selectedId + '/note'" method="POST">
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Note</label>
            <textarea name="note" rows="4" class="form-input" placeholder="Enter your note here..." required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" @click="activeModal = null" class="btn-outline">Cancel</button>
          <button type="submit" class="btn-primary">
            <i data-lucide="save" class="w-4 h-4"></i>
            Save Note
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
