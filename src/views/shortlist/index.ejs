<%
  const shortlists = typeof locals.shortlists !== 'undefined' ? locals.shortlists : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};

  const currentStatus = filters.status || 'all';

  const tabs = [
    { key: 'all', label: 'All' },
    { key: 'shortlisted', label: 'Shortlisted' },
    { key: 'scheduled', label: 'Scheduled' },
    { key: 'selected', label: 'Selected' },
    { key: 'offer_released', label: 'Offer Released' },
    { key: 'hired', label: 'Hired' },
  ];

  function buildQuery(overrides) {
    const params = Object.assign({}, filters, overrides);
    if (params.status === 'all') delete params.status;
    if (params.page == 1) delete params.page;
    const qs = Object.keys(params).filter(k => params[k]).map(k => k + '=' + encodeURIComponent(params[k])).join('&');
    return qs ? '?' + qs : '';
  }
%>

<!-- Page Header -->
<div class="flex flex-wrap items-center justify-between gap-md mb-lg">
  <div>
    <h1 class="text-2xl font-bold text-primary">Shortlisted Candidates</h1>
    <p class="text-sm text-secondary mt-sm">Manage shortlisted candidates through the hiring pipeline</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="stats-row mb-lg">
  <!-- Total Shortlisted -->
  <div class="stat-card">
    <div class="flex items-center justify-between w-full">
      <div>
        <p class="stat-value"><%= stats.total || 0 %></p>
        <p class="stat-label">Total Shortlisted</p>
      </div>
      <div class="stat-icon blue">
        <i data-lucide="check-circle" style="width:22px;height:22px;"></i>
      </div>
    </div>
  </div>

  <!-- Scheduled -->
  <div class="stat-card">
    <div class="flex items-center justify-between w-full">
      <div>
        <p class="stat-value" style="color:var(--accent-purple);"><%= stats.scheduled || 0 %></p>
        <p class="stat-label">Scheduled</p>
      </div>
      <div class="stat-icon purple">
        <i data-lucide="calendar" style="width:22px;height:22px;"></i>
      </div>
    </div>
  </div>

  <!-- Selected -->
  <div class="stat-card">
    <div class="flex items-center justify-between w-full">
      <div>
        <p class="stat-value" style="color:var(--accent-secondary);"><%= stats.selected || 0 %></p>
        <p class="stat-label">Selected</p>
      </div>
      <div class="stat-icon blue">
        <i data-lucide="user-check" style="width:22px;height:22px;"></i>
      </div>
    </div>
  </div>

  <!-- Offer Released -->
  <div class="stat-card">
    <div class="flex items-center justify-between w-full">
      <div>
        <p class="stat-value text-warning"><%= stats.offerReleased || 0 %></p>
        <p class="stat-label">Offer Released</p>
      </div>
      <div class="stat-icon orange">
        <i data-lucide="file-text" style="width:22px;height:22px;"></i>
      </div>
    </div>
  </div>

  <!-- Hired -->
  <div class="stat-card">
    <div class="flex items-center justify-between w-full">
      <div>
        <p class="stat-value text-success"><%= stats.hired || 0 %></p>
        <p class="stat-label">Hired</p>
      </div>
      <div class="stat-icon green">
        <i data-lucide="award" style="width:22px;height:22px;"></i>
      </div>
    </div>
  </div>
</div>

<!-- Filter Tabs -->
<div class="tabs mb-lg">
  <% tabs.forEach(function(tab) { %>
    <a href="/shortlist<%= buildQuery({ status: tab.key, page: 1 }) %>"
       class="tab <%= currentStatus === tab.key ? 'active' : '' %>">
      <%= tab.label %>
    </a>
  <% }); %>
</div>

<!-- Shortlist Table -->
<div class="card overflow-hidden" x-data="{ openDropdown: null, activeModal: null, selectedId: null }">
  <% if (shortlists.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate Name</th>
            <th>Job Role</th>
            <th>AI Match Score</th>
            <th>Interview Score</th>
            <th>Recommendation</th>
            <th>HR Status</th>
            <th>Updated Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% shortlists.forEach(function(s, idx) { %>
            <%
              const candidateName = s.candidate_name || (s.candidate ? (s.candidate.first_name + ' ' + s.candidate.last_name) : 'Unknown');
              const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
              const jobTitle = s.job_title || (s.job ? s.job.title : 'N/A');

              const aiScore = s.ai_score || s.match_score || 0;
              const aiScoreBarClass = aiScore >= 75 ? 'green' : aiScore >= 50 ? 'yellow' : 'red';
              const aiScoreTextClass = aiScore >= 75 ? 'text-success' : aiScore >= 50 ? 'text-warning' : 'text-danger';

              const interviewScore = s.interview_score || 0;
              const intScoreBarClass = interviewScore >= 75 ? 'green' : interviewScore >= 50 ? 'yellow' : 'red';
              const intScoreTextClass = interviewScore >= 75 ? 'text-success' : interviewScore >= 50 ? 'text-warning' : 'text-danger';

              const rec = s.recommendation || 'N/A';
              const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
                ? 'badge badge-success'
                : rec === 'moderate_fit' || rec === 'Moderate Fit'
                  ? 'badge badge-warning'
                  : rec === 'weak_fit' || rec === 'Weak Fit'
                    ? 'badge badge-danger'
                    : 'badge badge-muted';

              const hrStatus = s.hr_status || s.status || 'shortlisted';
              const hrStatusBadge = hrStatus === 'shortlisted' ? 'badge badge-shortlisted'
                : hrStatus === 'scheduled' ? 'badge badge-scheduled'
                : hrStatus === 'selected' ? 'badge badge-selected'
                : hrStatus === 'offer_released' ? 'badge badge-warning'
                : hrStatus === 'hired' ? 'badge badge-hired'
                : hrStatus === 'rejected' ? 'badge badge-danger'
                : 'badge badge-muted';
            %>
            <tr>
              <!-- Candidate Name -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="avatar avatar-sm avatar-gradient shrink-0">
                    <span><%= initials %></span>
                  </div>
                  <span class="font-medium text-primary"><%= candidateName %></span>
                </div>
              </td>

              <!-- Job Role -->
              <td class="text-secondary"><%= jobTitle %></td>

              <!-- AI Match Score -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="progress-bar" style="width:80px;height:8px;">
                    <div class="progress-fill <%= aiScoreBarClass %>" style="width: <%= aiScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= aiScoreTextClass %>"><%= aiScore %>%</span>
                </div>
              </td>

              <!-- Interview Score -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="progress-bar" style="width:80px;height:8px;">
                    <div class="progress-fill <%= intScoreBarClass %>" style="width: <%= interviewScore %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= intScoreTextClass %>"><%= interviewScore %>%</span>
                </div>
              </td>

              <!-- Recommendation -->
              <td>
                <span class="<%= recBadge %>">
                  <%= rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- HR Status -->
              <td>
                <span class="<%= hrStatusBadge %>">
                  <%= hrStatus.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- Updated Date -->
              <td class="text-secondary text-sm">
                <% if (s.updated_at) { %>
                  <%= new Date(s.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Actions Dropdown -->
              <td>
                <div class="relative" @click.away="if (openDropdown === <%= idx %>) openDropdown = null">
                  <button @click="openDropdown = openDropdown === <%= idx %> ? null : <%= idx %>"
                          class="btn btn-ghost btn-sm text-muted">
                    <i data-lucide="more-vertical" style="width:16px;height:16px;"></i>
                  </button>
                  <div x-show="openDropdown === <%= idx %>" x-transition
                       class="absolute" style="right:0;margin-top:4px;width:192px;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);z-index:20;padding:4px 0;">
                    <a href="/schedules/create?candidateId=<%= s.candidate_id || (s.candidate ? s.candidate.id : '') %>&jobId=<%= s.job_id || (s.job ? s.job.id : '') %>"
                       class="flex items-center gap-sm text-sm text-primary" style="padding:8px 12px;text-decoration:none;">
                      <i data-lucide="calendar-plus" style="width:16px;height:16px;color:var(--text-muted);"></i>
                      Schedule Interview
                    </a>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="selected">
                      <button type="submit" class="w-full flex items-center gap-sm text-sm text-primary" style="padding:8px 12px;background:none;border:none;cursor:pointer;font-family:inherit;">
                        <i data-lucide="user-check" style="width:16px;height:16px;color:var(--text-muted);"></i>
                        Mark Selected
                      </button>
                    </form>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="offer_released">
                      <button type="submit" class="w-full flex items-center gap-sm text-sm text-primary" style="padding:8px 12px;background:none;border:none;cursor:pointer;font-family:inherit;">
                        <i data-lucide="file-text" style="width:16px;height:16px;color:var(--text-muted);"></i>
                        Release Offer
                      </button>
                    </form>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="hired">
                      <button type="submit" class="w-full flex items-center gap-sm text-sm text-primary" style="padding:8px 12px;background:none;border:none;cursor:pointer;font-family:inherit;">
                        <i data-lucide="award" style="width:16px;height:16px;color:var(--text-muted);"></i>
                        Mark Hired
                      </button>
                    </form>
                    <div class="border-t" style="margin:4px 0;"></div>
                    <form action="/shortlist/<%= s.id %>/status" method="POST">
                      <input type="hidden" name="status" value="rejected">
                      <button type="submit" class="w-full flex items-center gap-sm text-sm text-danger" style="padding:8px 12px;background:none;border:none;cursor:pointer;font-family:inherit;">
                        <i data-lucide="x-circle" style="width:16px;height:16px;"></i>
                        Reject
                      </button>
                    </form>
                    <button @click="openDropdown = null; activeModal = 'note'; selectedId = '<%= s.id %>'"
                            class="w-full flex items-center gap-sm text-sm text-primary" style="padding:8px 12px;background:none;border:none;cursor:pointer;font-family:inherit;">
                      <i data-lucide="message-square-plus" style="width:16px;height:16px;color:var(--text-muted);"></i>
                      Add Note
                    </button>
                  </div>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between border-t p-md">
        <p class="text-sm text-secondary">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="flex items-center gap-sm">
          <% if (pagination.page > 1) { %>
            <a href="/shortlist<%= buildQuery({ page: pagination.page - 1 }) %>" class="btn btn-outline btn-sm">
              <i data-lucide="chevron-left" style="width:16px;height:16px;"></i> Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="btn btn-primary btn-sm"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="/shortlist<%= buildQuery({ page: i }) %>" class="btn btn-outline btn-sm"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="text-muted" style="padding:0 4px;">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="/shortlist<%= buildQuery({ page: pagination.page + 1 }) %>" class="btn btn-outline btn-sm">
              Next <i data-lucide="chevron-right" style="width:16px;height:16px;"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state" style="padding:80px 24px;">
      <div class="flex items-center justify-center mb-md" style="width:80px;height:80px;border-radius:16px;background:var(--bg-tertiary);margin:0 auto 20px;">
        <i data-lucide="check-circle" style="width:40px;height:40px;color:var(--text-muted);opacity:0.3;"></i>
      </div>
      <h3 class="text-lg font-semibold text-primary mb-sm">No Shortlisted Candidates</h3>
      <p class="text-sm text-secondary" style="max-width:24rem;margin:0 auto 24px;">
        No shortlisted candidates found. Candidates will appear here once they are shortlisted from AI screening.
      </p>
      <a href="/ai-screening" class="btn btn-primary">
        <i data-lucide="brain" style="width:16px;height:16px;"></i>
        View AI Screening
      </a>
    </div>
  <% } %>

  <!-- Add Note Modal -->
  <div x-show="activeModal === 'note'" x-transition
       class="modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);backdrop-filter:blur(4px);z-index:50;align-items:center;justify-content:center;padding:16px;"
       x-bind:style="activeModal === 'note' ? 'display:flex' : 'display:none'"
       @click.self="activeModal = null" x-cloak>
    <div class="modal" style="max-width:28rem;" @click.stop>
      <div class="modal-header">
        <h3 class="modal-title">Add Note</h3>
        <button @click="activeModal = null" class="modal-close">
          <i data-lucide="x" style="width:16px;height:16px;"></i>
        </button>
      </div>
      <form :action="'/shortlist/' + selectedId + '/note'" method="POST">
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">Note</label>
            <textarea name="note" rows="4" class="form-textarea" placeholder="Enter your note here..." required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" @click="activeModal = null" class="btn btn-outline">Cancel</button>
          <button type="submit" class="btn btn-primary">
            <i data-lucide="save" style="width:16px;height:16px;"></i>
            Save Note
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
