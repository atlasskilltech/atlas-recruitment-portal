<%
  const _job = typeof job !== 'undefined' ? job : {};
  const _candidates = typeof topCandidates !== 'undefined' ? topCandidates : [];
  const _stats = typeof stats !== 'undefined' ? stats : {};
  const QUAL_MAP = { '1': 'PhD', '2': 'Masters', '3': 'Bachelors', '4': 'Diploma', '5': 'Others' };

  function fmtScore(s) { return s != null ? parseFloat(s).toFixed(1) : '0.0'; }
  function scoreColor(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'text-green-600';
    if (n >= 50) return 'text-yellow-600';
    return 'text-red-600';
  }
  function scoreBg(s) {
    const n = parseFloat(s) || 0;
    if (n >= 75) return 'bg-green-100 text-green-700 border-green-200';
    if (n >= 50) return 'bg-yellow-100 text-yellow-700 border-yellow-200';
    return 'bg-red-100 text-red-700 border-red-200';
  }
  function recBadge(tag) {
    if (tag === 'strong_fit') return 'badge-strong-fit';
    if (tag === 'moderate_fit') return 'badge-moderate-fit';
    return 'badge-weak-fit';
  }
  function initials(name) {
    if (!name) return '?';
    return name.trim().split(/\s+/).slice(0,2).map(w=>w[0].toUpperCase()).join('');
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-4">
    <a href="/jobs" class="btn-outline btn-sm">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Back
    </a>
    <div>
      <h1 class="text-2xl font-bold text-foreground tracking-tight">Top Matching Candidates</h1>
    <p class="text-sm text-muted-foreground mt-1">
      <strong><%= _job.applied_for_post %></strong> — <%= _job.scope_name || 'Academics' %> — <%= _job.applied_location || 'Mumbai' %>
      <% if (_job.applied_experience_min || _job.applied_experience_max) { %>
        — <%= _job.applied_experience_min || 0 %>-<%= _job.applied_experience_max || '∞' %> yrs
      <% } %>
    </p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if (_stats.last_scanned) { %>
      <span class="text-xs text-muted-foreground">Last scanned: <%= new Date(_stats.last_scanned).toLocaleString('en-IN', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) %></span>
    <% } %>
    <form method="POST" action="/jobs/<%= _job.id %>/refresh-matches" class="inline">
      <button type="submit" class="btn-primary btn-sm">
        <i data-lucide="refresh-cw" class="w-4 h-4"></i> Refresh Scan
      </button>
    </form>
  </div>
</div>

<!-- Stats Overview -->
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-6">
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-foreground"><%= _stats.total_applicants || 0 %></p>
    <p class="text-xs text-muted-foreground">Applied for this Job</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-foreground"><%= _stats.total_scanned || 0 %></p>
    <p class="text-xs text-muted-foreground">Candidates Scanned</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-green-600"><%= _stats.strong_fit || 0 %></p>
    <p class="text-xs text-muted-foreground">Strong Fit (≥75)</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-yellow-600"><%= _stats.moderate_fit || 0 %></p>
    <p class="text-xs text-muted-foreground">Moderate (50-74)</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-red-600"><%= _stats.weak_fit || 0 %></p>
    <p class="text-xs text-muted-foreground">Weak (&lt;50)</p>
  </div>
  <div class="card p-4 text-center">
    <p class="text-2xl font-bold text-foreground"><%= _stats.avg_score || 0 %>%</p>
    <p class="text-xs text-muted-foreground">Avg Match Score</p>
  </div>
</div>

<!-- Top 20 Candidates -->
<% if (_candidates.length > 0) { %>
<div x-data="{
  selected: [],
  selectAll: false,
  toggleAll(checked) {
    this.selectAll = checked;
    this.selected = checked ? [<% _candidates.forEach((c,i) => { %>'<%= c.candidate_id %>'<%= i < _candidates.length-1 ? ',' : '' %><% }); %>] : [];
  },
  toggleOne(id) {
    const idx = this.selected.indexOf(id);
    if (idx > -1) this.selected.splice(idx,1); else this.selected.push(id);
    this.selectAll = this.selected.length === <%= _candidates.length %>;
  }
}">

  <!-- Bulk Action Bar -->
  <div x-show="selected.length > 0" x-cloak
       class="card p-3 mb-4 flex flex-wrap items-center gap-3 border-primary-300 bg-primary-50 dark:bg-primary-900/30"
       x-transition>
    <span class="text-sm font-semibold text-primary-800 dark:text-primary-200">
      <span x-text="selected.length"></span> selected
    </span>
    <div class="flex items-center gap-2 ml-auto">
      <form method="POST" action="/jobs/<%= _job.id %>/bulk-invite" class="inline">
        <template x-for="id in selected" :key="id">
          <input type="hidden" name="candidate_ids[]" :value="id">
        </template>
        <button type="submit" class="btn-primary btn-sm">
          <i data-lucide="video" class="w-4 h-4"></i> Send Interview to Selected
        </button>
      </form>
    </div>
  </div>

<div class="card overflow-hidden">
  <div class="px-5 py-4 border-b border-border flex items-center justify-between">
    <h2 class="text-base font-semibold text-foreground flex items-center gap-2">
      <i data-lucide="trophy" class="w-5 h-5 text-yellow-500"></i>
      Top <%= _candidates.length %> Matching Candidates
    </h2>
    <span class="text-xs text-muted-foreground">Ranked by AI Match Score</span>
  </div>
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th class="w-10">
            <input type="checkbox" class="rounded border-border" :checked="selectAll" @change="toggleAll($event.target.checked)">
          </th>
          <th class="w-10">#</th>
          <th>Candidate</th>
          <th>Qualification</th>
          <th>Experience</th>
          <th>Current Role</th>
          <th class="text-center">AI Match</th>
          <th>Recommendation</th>
          <th>Interview</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% _candidates.forEach(function(c, idx) { %>
          <tr>
            <!-- Checkbox -->
            <td>
              <input type="checkbox" class="rounded border-border"
                     value="<%= c.candidate_id %>"
                     :checked="selected.includes('<%= c.candidate_id %>')"
                     @change="toggleOne('<%= c.candidate_id %>')">
            </td>
            <!-- Rank -->
            <td>
              <% if (idx < 3) { %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-xs font-bold
                  <%= idx === 0 ? 'bg-yellow-100 text-yellow-700' : idx === 1 ? 'bg-gray-100 text-gray-600' : 'bg-orange-100 text-orange-700' %>">
                  <%= idx + 1 %>
                </span>
              <% } else { %>
                <span class="text-sm text-muted-foreground font-medium"><%= idx + 1 %></span>
              <% } %>
            </td>

            <!-- Candidate -->
            <td>
              <a href="/candidates/<%= c.id %>" class="flex items-center gap-3 group">
                <div class="w-9 h-9 rounded-full bg-primary-100 dark:bg-primary-800 flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-semibold text-primary-800 dark:text-primary-200"><%= initials(c.appln_full_name) %></span>
                </div>
                <div>
                  <p class="text-sm font-medium text-foreground group-hover:text-primary-800 transition-colors"><%= c.appln_full_name || 'Unknown' %></p>
                  <p class="text-xs text-muted-foreground"><%= c.appln_email || '' %></p>
                </div>
              </a>
            </td>

            <!-- Qualification -->
            <td>
              <span class="badge-muted"><%= QUAL_MAP[String(c.appln_high_qualification)] || c.appln_high_qualification || '-' %></span>
            </td>

            <!-- Experience -->
            <td class="text-sm text-foreground"><%= c.appln_total_experience || 0 %> yr</td>

            <!-- Current Role -->
            <td class="min-w-[140px]">
              <p class="text-sm text-foreground truncate max-w-[160px]"><%= c.appln_current_designation || '-' %></p>
              <p class="text-xs text-muted-foreground truncate max-w-[160px]"><%= c.appln_current_organisation || '' %></p>
            </td>

            <!-- Match Score -->
            <td class="text-center">
              <div class="inline-flex flex-col items-center">
                <span class="text-lg font-bold <%= scoreColor(c.match_score) %>"><%= fmtScore(c.match_score) %>%</span>
                <div class="w-16 h-1.5 bg-muted rounded-full overflow-hidden mt-1">
                  <div class="h-full rounded-full <%= parseFloat(c.match_score) >= 75 ? 'bg-green-500' : parseFloat(c.match_score) >= 50 ? 'bg-yellow-500' : 'bg-red-500' %>"
                       style="width: <%= Math.min(100, parseFloat(c.match_score) || 0) %>%"></div>
                </div>
              </div>
            </td>

            <!-- Match Status -->
            <td>
              <span class="<%= recBadge(c.match_status) %>">
                <%= (c.match_status || 'weak_fit').replace(/_/g, ' ').replace(/\b\w/g, function(x){return x.toUpperCase();}) %>
              </span>
            </td>

            <!-- Interview Status -->
            <td>
              <% if (c.interview_score) { %>
                <span class="text-sm font-semibold <%= scoreColor(c.interview_score) %>"><%= fmtScore(c.interview_score) %>%</span>
              <% } else if (c.interview_status) { %>
                <span class="badge-muted"><%= c.interview_status %></span>
              <% } else { %>
                <span class="text-xs text-muted-foreground">—</span>
              <% } %>
            </td>

            <!-- Actions -->
            <td>
              <div class="flex items-center gap-1">
                <a href="/candidates/<%= c.id %>" class="btn-ghost btn-sm" title="View Profile">
                  <i data-lucide="eye" class="w-4 h-4"></i>
                </a>
                <a href="/ai-interviews/invite/<%= c.id %>" class="btn-ghost btn-sm text-primary-800" title="Invite Interview">
                  <i data-lucide="video" class="w-4 h-4"></i>
                </a>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
</div>
<% } else { %>
<div class="card">
  <div class="empty-state py-16">
    <div class="w-16 h-16 rounded-2xl bg-muted/50 flex items-center justify-center mb-4">
      <i data-lucide="search-x" class="w-8 h-8 text-muted-foreground/30"></i>
    </div>
    <h3 class="text-lg font-semibold text-foreground mb-1">No Matching Candidates</h3>
    <p class="text-sm text-muted-foreground max-w-sm">
      No candidates have been screened for this job yet. Run AI screening from the Candidates page first.
    </p>
  </div>
</div>
<% } %>

<!-- JD Summary -->
<% if (_job.applied_job_desc) { %>
<div class="card p-6 mt-6">
  <h3 class="text-base font-semibold text-foreground mb-3 flex items-center gap-2">
    <i data-lucide="file-text" class="w-5 h-5 text-muted-foreground"></i>
    Job Description
  </h3>
  <div class="text-sm text-muted-foreground leading-relaxed prose max-w-none">
    <%- _job.applied_job_desc %>
  </div>
</div>
<% } %>
