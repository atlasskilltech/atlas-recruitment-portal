<%
  const screenings = typeof locals.screenings !== 'undefined' ? locals.screenings : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const jobs = typeof locals.jobs !== 'undefined' ? locals.jobs : [];
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};
%>

<!-- Page Header -->
<div class="flex items-center justify-between mb-lg">
  <div>
    <h1 class="text-2xl font-bold">AI Screening Results</h1>
    <p class="text-sm text-secondary mt-sm">Review AI-powered candidate screening analysis and recommendations</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="stats-row">
  <!-- Total Screened -->
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="brain"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.total || 0 %></p>
      <p class="stat-label">Total Screened</p>
    </div>
  </div>

  <!-- Eligible -->
  <div class="stat-card">
    <div class="stat-icon green">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-primary)"><%= stats.eligible || 0 %></p>
      <p class="stat-label">Eligible</p>
    </div>
  </div>

  <!-- Hold -->
  <div class="stat-card">
    <div class="stat-icon orange">
      <i data-lucide="pause-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-warning)"><%= stats.hold || 0 %></p>
      <p class="stat-label">Hold</p>
    </div>
  </div>

  <!-- Rejected -->
  <div class="stat-card">
    <div class="stat-icon red">
      <i data-lucide="x-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value" style="color: var(--accent-danger)"><%= stats.rejected || 0 %></p>
      <p class="stat-label">Rejected</p>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filters-bar">
  <form method="GET" action="/ai-screening" style="display: contents;">
    <!-- Job Role -->
    <div class="filter-item">
      <label>Job Role</label>
      <select name="jobId">
        <option value="">All Roles</option>
        <% jobs.forEach(function(job) { %>
          <option value="<%= job.id %>" <%= filters.jobId == job.id ? 'selected' : '' %>><%= job.title %></option>
        <% }); %>
      </select>
    </div>

    <!-- AI Status -->
    <div class="filter-item">
      <label>AI Status</label>
      <select name="status">
        <option value="">All Statuses</option>
        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="failed" <%= filters.status === 'failed' ? 'selected' : '' %>>Failed</option>
        <option value="processing" <%= filters.status === 'processing' ? 'selected' : '' %>>Processing</option>
      </select>
    </div>

    <!-- Score Range -->
    <div class="filter-item">
      <label>Min Score</label>
      <input type="number" name="minScore" min="0" max="100" placeholder="0" value="<%= filters.minScore || '' %>">
    </div>

    <!-- Date Range -->
    <div class="filter-item">
      <label>From Date</label>
      <input type="date" name="fromDate" value="<%= filters.fromDate || '' %>">
    </div>

    <!-- Actions -->
    <div class="filter-item" style="flex-direction: row; align-items: flex-end; gap: 8px;">
      <button type="submit" class="btn btn-primary btn-sm flex-1">
        <i data-lucide="search"></i>
        Filter
      </button>
      <a href="/ai-screening" class="btn btn-outline btn-sm">
        <i data-lucide="x"></i>
        Clear
      </a>
    </div>
  </form>
</div>

<!-- Screenings Table -->
<div class="card overflow-hidden">
  <% if (screenings.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate Name</th>
            <th>Job Role</th>
            <th>AI Match Score</th>
            <th>Recommendation</th>
            <th>AI Status</th>
            <th>Skills Found</th>
            <th>Processed Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% screenings.forEach(function(s) { %>
            <%
              const score = parseFloat(s.ai_match_score) || parseFloat(s.ai_score) || parseFloat(s.match_score) || 0;
              const scoreColor = score >= 75 ? 'green' : score >= 50 ? 'yellow' : 'red';
              const scoreTextColor = score >= 75 ? 'text-success' : score >= 50 ? 'text-warning' : 'text-danger';

              const rec = s.ai_recommendation_tag || s.recommendation || 'N/A';
              const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
                ? 'badge badge-success'
                : rec === 'moderate_fit' || rec === 'Moderate Fit'
                  ? 'badge badge-warning'
                  : rec === 'weak_fit' || rec === 'Weak Fit'
                    ? 'badge badge-danger'
                    : 'badge badge-muted';

              const status = s.ai_status || s.status || 'eligible';
              const statusBadge = status === 'completed'
                ? 'badge badge-success'
                : status === 'pending'
                  ? 'badge badge-warning'
                  : status === 'processing'
                    ? 'badge badge-info'
                    : 'badge badge-danger';

              let skillsCount = 0;
              if (s.extracted_skills) {
                try {
                  const parsed = typeof s.extracted_skills === 'string' ? JSON.parse(s.extracted_skills) : s.extracted_skills;
                  skillsCount = Array.isArray(parsed) ? parsed.length : 0;
                } catch(e) { skillsCount = 0; }
              }
              const candidateName = s.candidate_name || (s.candidate ? (s.candidate.first_name + ' ' + s.candidate.last_name) : 'Unknown');
              const jobTitle = s.job_title || (s.job ? s.job.title : 'N/A');
            %>
            <tr>
              <!-- Candidate Name -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="avatar avatar-sm avatar-gradient">
                    <%= candidateName.charAt(0).toUpperCase() %>
                  </div>
                  <span class="font-medium"><%= candidateName %></span>
                </div>
              </td>

              <!-- Job Role -->
              <td class="text-secondary"><%= jobTitle %></td>

              <!-- AI Match Score -->
              <td>
                <div class="flex items-center gap-sm">
                  <div class="progress-bar" style="width: 96px;">
                    <div class="progress-fill <%= scoreColor %>" style="width: <%= score %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreTextColor %>"><%= score %>%</span>
                </div>
              </td>

              <!-- Recommendation -->
              <td>
                <span class="<%= recBadge %>">
                  <%= rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- AI Status -->
              <td>
                <span class="<%= statusBadge %>">
                  <% if (status === 'completed') { %>
                    <i data-lucide="check" style="width:12px;height:12px;"></i>
                  <% } else if (status === 'processing') { %>
                    <i data-lucide="loader" style="width:12px;height:12px;"></i>
                  <% } else if (status === 'failed') { %>
                    <i data-lucide="alert-triangle" style="width:12px;height:12px;"></i>
                  <% } else { %>
                    <i data-lucide="clock" style="width:12px;height:12px;"></i>
                  <% } %>
                  <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                </span>
              </td>

              <!-- Skills Found -->
              <td>
                <span class="badge badge-muted">
                  <i data-lucide="tag" style="width:12px;height:12px;"></i>
                  <%= skillsCount %>
                </span>
              </td>

              <!-- Processed Date -->
              <td class="text-secondary text-sm">
                <% if (s.processed_at || s.created_at) { %>
                  <%= new Date(s.processed_at || s.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Actions -->
              <td>
                <div class="flex items-center gap-sm">
                  <a href="/ai-screening/<%= s.id %>" class="btn btn-ghost btn-sm" title="View Details">
                    <i data-lucide="eye"></i>
                  </a>
                  <% if (status === 'failed') { %>
                    <form action="/ai-screening/<%= s.id %>/retry" method="POST" class="inline">
                      <button type="submit" class="btn btn-ghost btn-sm text-warning" title="Retry Screening">
                        <i data-lucide="refresh-cw"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between border-t" style="padding: 12px 16px;">
        <p class="text-sm text-secondary">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="pagination">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>">
              <i data-lucide="chevron-left" style="width:16px;height:16px;"></i>
              Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="active"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="?page=<%= i %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="disabled">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="?page=<%= pagination.page + 1 %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>">
              Next
              <i data-lucide="chevron-right" style="width:16px;height:16px;"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state" style="padding: 80px 24px;">
      <i data-lucide="brain"></i>
      <h3 class="text-lg font-semibold mb-sm">No Screening Results</h3>
      <p class="text-sm text-secondary" style="max-width: 360px; margin: 0 auto 24px;">
        No AI screening results found. Screenings will appear here once candidates are processed.
      </p>
      <a href="/candidates" class="btn btn-primary">
        <i data-lucide="users"></i>
        View Candidates
      </a>
    </div>
  <% } %>
</div>
