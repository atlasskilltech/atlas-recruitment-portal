<%
  const screenings = typeof locals.screenings !== 'undefined' ? locals.screenings : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const jobs = typeof locals.jobs !== 'undefined' ? locals.jobs : [];
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">AI Screening Results</h1>
    <p class="text-sm text-muted-foreground mt-1">Review AI-powered candidate screening analysis and recommendations</p>
  </div>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <!-- Total Screened -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-foreground"><%= stats.total || 0 %></p>
        <p class="stat-label">Total Screened</p>
      </div>
      <div class="stat-icon bg-primary-800">
        <i data-lucide="brain" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Eligible -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-success"><%= stats.eligible || 0 %></p>
        <p class="stat-label">Eligible</p>
      </div>
      <div class="stat-icon bg-success">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Hold -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-warning"><%= stats.hold || 0 %></p>
        <p class="stat-label">Hold</p>
      </div>
      <div class="stat-icon bg-warning">
        <i data-lucide="pause-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Rejected -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-destructive"><%= stats.rejected || 0 %></p>
        <p class="stat-label">Rejected</p>
      </div>
      <div class="stat-icon bg-destructive">
        <i data-lucide="x-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>
</div>

<!-- Filter Bar -->
<div class="filter-panel">
  <form method="GET" action="/ai-screening" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
    <!-- Job Role -->
    <div class="form-group">
      <label class="form-label">Job Role</label>
      <select name="jobId" class="form-select">
        <option value="">All Roles</option>
        <% jobs.forEach(function(job) { %>
          <option value="<%= job.id %>" <%= filters.jobId == job.id ? 'selected' : '' %>><%= job.title %></option>
        <% }); %>
      </select>
    </div>

    <!-- AI Status -->
    <div class="form-group">
      <label class="form-label">AI Status</label>
      <select name="status" class="form-select">
        <option value="">All Statuses</option>
        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
        <option value="failed" <%= filters.status === 'failed' ? 'selected' : '' %>>Failed</option>
        <option value="processing" <%= filters.status === 'processing' ? 'selected' : '' %>>Processing</option>
      </select>
    </div>

    <!-- Score Range -->
    <div class="form-group">
      <label class="form-label">Min Score</label>
      <input type="number" name="minScore" min="0" max="100" placeholder="0"
             class="form-input" value="<%= filters.minScore || '' %>">
    </div>

    <!-- Date Range -->
    <div class="form-group">
      <label class="form-label">From Date</label>
      <input type="date" name="fromDate" class="form-input" value="<%= filters.fromDate || '' %>">
    </div>

    <!-- Actions -->
    <div class="form-group flex items-end gap-2">
      <button type="submit" class="btn-primary btn-sm flex-1">
        <i data-lucide="search" class="w-4 h-4"></i>
        Filter
      </button>
      <a href="/ai-screening" class="btn-outline btn-sm">
        <i data-lucide="x" class="w-4 h-4"></i>
        Clear
      </a>
    </div>
  </form>
</div>

<!-- Screenings Table -->
<div class="card overflow-hidden">
  <% if (screenings.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate Name</th>
            <th>Job Role</th>
            <th>AI Match Score</th>
            <th>Recommendation</th>
            <th>AI Status</th>
            <th>Skills Found</th>
            <th>Processed Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% screenings.forEach(function(s) { %>
            <%
              const score = parseFloat(s.ai_match_score) || parseFloat(s.ai_score) || parseFloat(s.match_score) || 0;
              const scoreColor = score >= 75 ? 'bg-success' : score >= 50 ? 'bg-warning' : 'bg-destructive';
              const scoreTextColor = score >= 75 ? 'text-success' : score >= 50 ? 'text-warning' : 'text-destructive';

              const rec = s.ai_recommendation_tag || s.recommendation || 'N/A';
              const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
                ? 'badge-strong-fit'
                : rec === 'moderate_fit' || rec === 'Moderate Fit'
                  ? 'badge-moderate-fit'
                  : rec === 'weak_fit' || rec === 'Weak Fit'
                    ? 'badge-weak-fit'
                    : 'badge-muted';

              const status = s.ai_status || s.status || 'eligible';
              const statusBadge = status === 'completed'
                ? 'badge-success'
                : status === 'pending'
                  ? 'badge-warning'
                  : status === 'processing'
                    ? 'badge-info'
                    : 'badge-danger';

              let skillsCount = 0;
              if (s.extracted_skills) {
                try {
                  const parsed = typeof s.extracted_skills === 'string' ? JSON.parse(s.extracted_skills) : s.extracted_skills;
                  skillsCount = Array.isArray(parsed) ? parsed.length : 0;
                } catch(e) { skillsCount = 0; }
              }
              const candidateName = s.candidate_name || (s.candidate ? (s.candidate.first_name + ' ' + s.candidate.last_name) : 'Unknown');
              const jobTitle = s.job_title || (s.job ? s.job.title : 'N/A');
            %>
            <tr>
              <!-- Candidate Name -->
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
                    <span class="text-xs font-semibold text-primary-800 dark:text-primary-200">
                      <%= candidateName.charAt(0).toUpperCase() %>
                    </span>
                  </div>
                  <span class="font-medium text-foreground"><%= candidateName %></span>
                </div>
              </td>

              <!-- Job Role -->
              <td class="text-muted-foreground"><%= jobTitle %></td>

              <!-- AI Match Score -->
              <td>
                <div class="flex items-center gap-2">
                  <div class="w-24 h-2 bg-muted rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= scoreColor %>" style="width: <%= score %>%"></div>
                  </div>
                  <span class="text-sm font-semibold <%= scoreTextColor %>"><%= score %>%</span>
                </div>
              </td>

              <!-- Recommendation -->
              <td>
                <span class="<%= recBadge %>">
                  <%= rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); }) %>
                </span>
              </td>

              <!-- AI Status -->
              <td>
                <span class="<%= statusBadge %>">
                  <% if (status === 'completed') { %>
                    <i data-lucide="check" class="w-3 h-3"></i>
                  <% } else if (status === 'processing') { %>
                    <i data-lucide="loader" class="w-3 h-3 animate-spin-slow"></i>
                  <% } else if (status === 'failed') { %>
                    <i data-lucide="alert-triangle" class="w-3 h-3"></i>
                  <% } else { %>
                    <i data-lucide="clock" class="w-3 h-3"></i>
                  <% } %>
                  <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                </span>
              </td>

              <!-- Skills Found -->
              <td>
                <span class="badge-muted">
                  <i data-lucide="tag" class="w-3 h-3"></i>
                  <%= skillsCount %>
                </span>
              </td>

              <!-- Processed Date -->
              <td class="text-muted-foreground text-sm">
                <% if (s.processed_at || s.created_at) { %>
                  <%= new Date(s.processed_at || s.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>

              <!-- Actions -->
              <td>
                <div class="flex items-center gap-1">
                  <a href="/ai-screening/<%= s.id %>" class="btn-ghost btn-sm text-primary-800 dark:text-primary-200" title="View Details">
                    <i data-lucide="eye" class="w-4 h-4"></i>
                  </a>
                  <% if (status === 'failed') { %>
                    <form action="/ai-screening/<%= s.id %>/retry" method="POST" class="inline">
                      <button type="submit" class="btn-ghost btn-sm text-warning" title="Retry Screening">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="flex items-center justify-between px-4 py-3 border-t border-border">
        <p class="text-sm text-muted-foreground">
          Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
          to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
          of <span class="font-medium"><%= pagination.total %></span> results
        </p>
        <div class="flex items-center gap-1">
          <% if (pagination.page > 1) { %>
            <a href="?page=<%= pagination.page - 1 %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>"
               class="btn-outline btn-sm">
              <i data-lucide="chevron-left" class="w-4 h-4"></i>
              Prev
            </a>
          <% } %>

          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% if (i === pagination.page) { %>
              <span class="btn-primary btn-sm"><%= i %></span>
            <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
              <a href="?page=<%= i %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>"
                 class="btn-outline btn-sm"><%= i %></a>
            <% } else if (Math.abs(i - pagination.page) === 3) { %>
              <span class="px-1 text-muted-foreground">&hellip;</span>
            <% } %>
          <% } %>

          <% if (pagination.page < pagination.totalPages) { %>
            <a href="?page=<%= pagination.page + 1 %><%= filters.jobId ? '&jobId=' + filters.jobId : '' %><%= filters.status ? '&status=' + filters.status : '' %><%= filters.minScore ? '&minScore=' + filters.minScore : '' %><%= filters.fromDate ? '&fromDate=' + filters.fromDate : '' %>"
               class="btn-outline btn-sm">
              Next
              <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </a>
          <% } %>
        </div>
      </div>
    <% } %>

  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state py-20">
      <div class="w-20 h-20 rounded-2xl bg-muted/50 flex items-center justify-center mb-5">
        <i data-lucide="brain" class="w-10 h-10 text-muted-foreground/30"></i>
      </div>
      <h3 class="text-lg font-semibold text-foreground mb-1">No Screening Results</h3>
      <p class="text-sm text-muted-foreground max-w-sm mb-6">
        No AI screening results found. Screenings will appear here once candidates are processed.
      </p>
      <a href="/candidates" class="btn-primary">
        <i data-lucide="users" class="w-4 h-4"></i>
        View Candidates
      </a>
    </div>
  <% } %>
</div>
