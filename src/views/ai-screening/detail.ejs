<%
  const screening = typeof locals.screening !== 'undefined' ? locals.screening : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const score = parseFloat(screening.ai_match_score) || parseFloat(screening.match_score) || 0;
  const scoreColor = score >= 75 ? 'text-success' : score >= 50 ? 'text-warning' : 'text-danger';
  const scoreStroke = score >= 75 ? 'var(--accent-primary)' : score >= 50 ? 'var(--accent-warning)' : 'var(--accent-danger)';

  const rec = screening.ai_recommendation_tag || screening.recommendation || 'N/A';
  const recLabel = rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
    ? 'badge badge-success'
    : rec === 'moderate_fit' || rec === 'Moderate Fit'
      ? 'badge badge-warning'
      : rec === 'weak_fit' || rec === 'Weak Fit'
        ? 'badge badge-danger'
        : 'badge badge-muted';

  const status = screening.ai_status || screening.status || 'eligible';
  const statusBadge = status === 'eligible' ? 'badge badge-eligible'
    : status === 'hold' ? 'badge badge-hold'
    : status === 'rejected' ? 'badge badge-rejected'
    : 'badge badge-info';

  /* Parse JSON fields safely */
  function safeParse(val) {
    if (!val) return val;
    if (typeof val !== 'string') return val;
    try { return JSON.parse(val); } catch(e) { return val; }
  }

  const skills = safeParse(screening.extracted_skills) || [];
  const keywords = safeParse(screening.extracted_keywords) || [];
  const educationSummary = screening.extracted_education_summary || screening.education_summary || '';
  const experienceSummary = screening.extracted_experience_summary || screening.experience_summary || '';
  const skillGapRaw = safeParse(screening.skill_gap_analysis) || '';
  const skillGapAnalysis = typeof skillGapRaw === 'object' ? JSON.stringify(skillGapRaw, null, 2) : skillGapRaw;
  const roleFitSummary = screening.role_fit_summary || '';

  const candidateName = screening.candidate_name || (candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : screening.appln_full_name || 'Unknown Candidate');
  const jobTitle = screening.job_title || job.title || 'N/A';

  const circumference = 2 * Math.PI * 54;
  const offset = circumference - (score / 100) * circumference;
%>

<!-- Back Button -->
<div class="mb-lg">
  <a href="/ai-screening" class="btn btn-outline btn-sm">
    <i data-lucide="arrow-left"></i>
    Back to Screening List
  </a>
</div>

<!-- Candidate Info Header -->
<div class="card p-lg mb-lg">
  <div class="flex items-center justify-between gap-md" style="flex-wrap: wrap;">
    <!-- Left: Candidate Info -->
    <div class="flex items-center gap-md">
      <div class="avatar avatar-lg avatar-gradient">
        <%= candidateName.charAt(0).toUpperCase() %>
      </div>
      <div>
        <h1 class="text-2xl font-bold"><%= candidateName %></h1>
        <p class="text-sm text-secondary mt-sm">
          <i data-lucide="briefcase" style="width:14px;height:14px;display:inline-block;vertical-align:middle;margin-right:4px;"></i>
          <%= jobTitle %>
        </p>
        <div class="flex items-center gap-sm mt-sm">
          <span class="<%= statusBadge %>">
            <%= status.charAt(0).toUpperCase() + status.slice(1) %>
          </span>
          <span class="<%= recBadge %>"><%= recLabel %></span>
        </div>
      </div>
    </div>

    <!-- Right: Score Ring -->
    <div class="score-ring" style="width:128px;height:128px;">
      <svg width="128" height="128" viewBox="0 0 120 120">
        <circle cx="60" cy="60" r="54" fill="none" stroke-width="8" stroke="var(--border-color)" opacity="0.3"></circle>
        <circle cx="60" cy="60" r="54" fill="none" stroke-width="8" stroke="<%= scoreStroke %>"
                stroke-linecap="round"
                stroke-dasharray="<%= circumference %>"
                stroke-dashoffset="<%= offset %>"></circle>
      </svg>
      <div class="score-value flex-col">
        <span class="text-2xl font-bold <%= scoreColor %>"><%= score %>%</span>
        <span class="text-xs text-muted">Match Score</span>
      </div>
    </div>
  </div>
</div>

<!-- Content Grid -->
<div class="grid-2 mb-lg" style="gap:24px;">

  <!-- Extracted Skills -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="tag" style="width:20px;height:20px;color:var(--accent-primary);"></i>
      Extracted Skills
    </h2>
    <% if (skills.length > 0) { %>
      <div class="flex flex-wrap gap-sm">
        <% skills.forEach(function(skill) { %>
          <span class="badge badge-info">
            <%= typeof skill === 'string' ? skill : skill.name || skill %>
          </span>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-sm text-secondary">No skills extracted.</p>
    <% } %>
  </div>

  <!-- Extracted Keywords -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="key" style="width:20px;height:20px;color:var(--accent-primary);"></i>
      Extracted Keywords
    </h2>
    <% if (keywords.length > 0) { %>
      <div class="flex flex-wrap gap-sm">
        <% keywords.forEach(function(kw) { %>
          <span class="badge badge-primary">
            <%= typeof kw === 'string' ? kw : kw.keyword || kw %>
          </span>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-sm text-secondary">No keywords extracted.</p>
    <% } %>
  </div>

  <!-- Education Summary -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="graduation-cap" style="width:20px;height:20px;color:var(--accent-secondary);"></i>
      Education Summary
    </h2>
    <% if (educationSummary) { %>
      <div class="text-sm text-secondary" style="white-space:pre-line;line-height:1.6;"><%= educationSummary %></div>
    <% } else { %>
      <p class="text-sm text-secondary">No education summary available.</p>
    <% } %>
  </div>

  <!-- Experience Summary -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="briefcase" style="width:20px;height:20px;color:var(--accent-warning);"></i>
      Experience Summary
    </h2>
    <% if (experienceSummary) { %>
      <div class="text-sm text-secondary" style="white-space:pre-line;line-height:1.6;"><%= experienceSummary %></div>
    <% } else { %>
      <p class="text-sm text-secondary">No experience summary available.</p>
    <% } %>
  </div>

  <!-- Skill Gap Analysis -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="git-compare" style="width:20px;height:20px;color:var(--accent-danger);"></i>
      Skill Gap Analysis
    </h2>
    <% if (skillGapAnalysis) { %>
      <% if (Array.isArray(skillGapAnalysis)) { %>
        <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px;">
          <% skillGapAnalysis.forEach(function(gap) { %>
            <li class="flex items-start gap-sm text-sm text-secondary">
              <i data-lucide="alert-circle" style="width:16px;height:16px;color:var(--accent-danger);flex-shrink:0;margin-top:2px;"></i>
              <%= typeof gap === 'string' ? gap : gap.skill || gap %>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <div class="text-sm text-secondary" style="white-space:pre-line;line-height:1.6;"><%= skillGapAnalysis %></div>
      <% } %>
    <% } else { %>
      <p class="text-sm text-secondary">No skill gap analysis available.</p>
    <% } %>
  </div>

  <!-- Role Fit Summary -->
  <div class="card p-lg">
    <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
      <i data-lucide="target" style="width:20px;height:20px;color:var(--accent-primary);"></i>
      Role Fit Summary
    </h2>
    <% if (roleFitSummary) { %>
      <div class="text-sm text-secondary" style="white-space:pre-line;line-height:1.6;"><%= roleFitSummary %></div>
    <% } else { %>
      <p class="text-sm text-secondary">No role fit summary available.</p>
    <% } %>
  </div>
</div>

<!-- AI Details -->
<div class="card p-lg mb-lg">
  <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
    <i data-lucide="cpu" style="width:20px;height:20px;color:var(--text-muted);"></i>
    AI Processing Details
  </h2>
  <div class="grid-3" style="gap:16px;">
    <div>
      <p class="text-xs text-muted uppercase tracking-wide mb-sm">Provider</p>
      <p class="text-sm font-medium"><%= screening.ai_provider || 'N/A' %></p>
    </div>
    <div>
      <p class="text-xs text-muted uppercase tracking-wide mb-sm">Model</p>
      <p class="text-sm font-medium"><%= screening.ai_model || 'N/A' %></p>
    </div>
    <div>
      <p class="text-xs text-muted uppercase tracking-wide mb-sm">Processed Date</p>
      <p class="text-sm font-medium">
        <% if (screening.processed_at || screening.created_at) { %>
          <%= new Date(screening.processed_at || screening.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
        <% } else { %>
          N/A
        <% } %>
      </p>
    </div>
  </div>
</div>

<!-- Action Buttons -->
<div class="flex flex-wrap items-center gap-sm">
  <form action="/ai-screening/<%= screening.id %>/invite" method="POST" class="inline">
    <button type="submit" class="btn btn-primary">
      <i data-lucide="mail"></i>
      Invite to Interview
    </button>
  </form>
  <form action="/ai-screening/<%= screening.id %>/shortlist" method="POST" class="inline">
    <button type="submit" class="btn btn-outline">
      <i data-lucide="star"></i>
      Shortlist
    </button>
  </form>
  <form action="/ai-screening/<%= screening.id %>/reject" method="POST" class="inline"
        onsubmit="return confirm('Are you sure you want to reject this candidate?')">
    <button type="submit" class="btn btn-danger">
      <i data-lucide="x-circle"></i>
      Reject
    </button>
  </form>
</div>
