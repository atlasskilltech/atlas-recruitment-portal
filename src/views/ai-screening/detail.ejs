<%
  const screening = typeof locals.screening !== 'undefined' ? locals.screening : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const score = screening.ai_score || screening.match_score || 0;
  const scoreColor = score >= 75 ? 'text-success' : score >= 50 ? 'text-warning' : 'text-destructive';
  const scoreBgColor = score >= 75 ? 'stroke-success' : score >= 50 ? 'stroke-warning' : 'stroke-destructive';
  const scoreTrack = 'stroke-muted';

  const rec = screening.recommendation || 'N/A';
  const recLabel = rec.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  const recBadge = rec === 'strong_fit' || rec === 'Strong Fit'
    ? 'badge-strong-fit'
    : rec === 'moderate_fit' || rec === 'Moderate Fit'
      ? 'badge-moderate-fit'
      : rec === 'weak_fit' || rec === 'Weak Fit'
        ? 'badge-weak-fit'
        : 'badge-muted';

  const status = screening.ai_status || screening.status || 'pending';
  const statusBadge = status === 'completed' ? 'badge-success'
    : status === 'pending' ? 'badge-warning'
    : status === 'processing' ? 'badge-info'
    : 'badge-danger';

  const skills = screening.extracted_skills || [];
  const keywords = screening.extracted_keywords || [];
  const educationSummary = screening.education_summary || '';
  const experienceSummary = screening.experience_summary || '';
  const skillGapAnalysis = screening.skill_gap_analysis || '';
  const roleFitSummary = screening.role_fit_summary || '';

  const candidateName = candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : 'Unknown Candidate';
  const jobTitle = job.title || 'N/A';

  const circumference = 2 * Math.PI * 54;
  const offset = circumference - (score / 100) * circumference;
%>

<!-- Back Button -->
<div class="mb-6">
  <a href="/ai-screening" class="btn-outline btn-sm inline-flex items-center gap-2">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Back to Screening List
  </a>
</div>

<!-- Candidate Info Header -->
<div class="card p-6 mb-6">
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <!-- Left: Candidate Info -->
    <div class="flex items-center gap-4">
      <div class="w-16 h-16 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
        <span class="text-2xl font-bold text-primary-800 dark:text-primary-200">
          <%= candidateName.charAt(0).toUpperCase() %>
        </span>
      </div>
      <div>
        <h1 class="text-2xl font-bold text-foreground tracking-tight"><%= candidateName %></h1>
        <p class="text-sm text-muted-foreground mt-0.5">
          <i data-lucide="briefcase" class="w-3.5 h-3.5 inline-block mr-1"></i>
          <%= jobTitle %>
        </p>
        <div class="flex items-center gap-2 mt-2">
          <span class="<%= statusBadge %>">
            <%= status.charAt(0).toUpperCase() + status.slice(1) %>
          </span>
          <span class="<%= recBadge %>"><%= recLabel %></span>
        </div>
      </div>
    </div>

    <!-- Right: Score Ring -->
    <div class="flex flex-col items-center">
      <div class="relative w-32 h-32">
        <svg class="w-32 h-32 -rotate-90" viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="54" fill="none" stroke-width="8" class="<%= scoreTrack %>" opacity="0.2"></circle>
          <circle cx="60" cy="60" r="54" fill="none" stroke-width="8" class="<%= scoreBgColor %>"
                  stroke-linecap="round"
                  stroke-dasharray="<%= circumference %>"
                  stroke-dashoffset="<%= offset %>"></circle>
        </svg>
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <span class="text-3xl font-bold <%= scoreColor %>"><%= score %>%</span>
          <span class="text-xs text-muted-foreground">Match Score</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Content Grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Extracted Skills -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="tag" class="w-5 h-5 text-primary-800 dark:text-primary-200"></i>
      Extracted Skills
    </h2>
    <% if (skills.length > 0) { %>
      <div class="flex flex-wrap gap-2">
        <% skills.forEach(function(skill) { %>
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200">
            <%= typeof skill === 'string' ? skill : skill.name || skill %>
          </span>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No skills extracted.</p>
    <% } %>
  </div>

  <!-- Extracted Keywords -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="key" class="w-5 h-5 text-accent"></i>
      Extracted Keywords
    </h2>
    <% if (keywords.length > 0) { %>
      <div class="flex flex-wrap gap-2">
        <% keywords.forEach(function(kw) { %>
          <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-accent/10 text-accent dark:bg-accent/20">
            <%= typeof kw === 'string' ? kw : kw.keyword || kw %>
          </span>
        <% }); %>
      </div>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No keywords extracted.</p>
    <% } %>
  </div>

  <!-- Education Summary -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="graduation-cap" class="w-5 h-5 text-info"></i>
      Education Summary
    </h2>
    <% if (educationSummary) { %>
      <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line"><%= educationSummary %></div>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No education summary available.</p>
    <% } %>
  </div>

  <!-- Experience Summary -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="briefcase" class="w-5 h-5 text-warning"></i>
      Experience Summary
    </h2>
    <% if (experienceSummary) { %>
      <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line"><%= experienceSummary %></div>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No experience summary available.</p>
    <% } %>
  </div>

  <!-- Skill Gap Analysis -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="git-compare" class="w-5 h-5 text-destructive"></i>
      Skill Gap Analysis
    </h2>
    <% if (skillGapAnalysis) { %>
      <% if (Array.isArray(skillGapAnalysis)) { %>
        <ul class="space-y-2">
          <% skillGapAnalysis.forEach(function(gap) { %>
            <li class="flex items-start gap-2 text-sm text-muted-foreground">
              <i data-lucide="alert-circle" class="w-4 h-4 text-destructive flex-shrink-0 mt-0.5"></i>
              <%= typeof gap === 'string' ? gap : gap.skill || gap %>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line"><%= skillGapAnalysis %></div>
      <% } %>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No skill gap analysis available.</p>
    <% } %>
  </div>

  <!-- Role Fit Summary -->
  <div class="card p-6">
    <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
      <i data-lucide="target" class="w-5 h-5 text-success"></i>
      Role Fit Summary
    </h2>
    <% if (roleFitSummary) { %>
      <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line"><%= roleFitSummary %></div>
    <% } else { %>
      <p class="text-sm text-muted-foreground">No role fit summary available.</p>
    <% } %>
  </div>
</div>

<!-- AI Details -->
<div class="card p-6 mb-6">
  <h2 class="text-lg font-semibold text-foreground mb-4 flex items-center gap-2">
    <i data-lucide="cpu" class="w-5 h-5 text-muted-foreground"></i>
    AI Processing Details
  </h2>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div>
      <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Provider</p>
      <p class="text-sm font-medium text-foreground"><%= screening.ai_provider || 'N/A' %></p>
    </div>
    <div>
      <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Model</p>
      <p class="text-sm font-medium text-foreground"><%= screening.ai_model || 'N/A' %></p>
    </div>
    <div>
      <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Processed Date</p>
      <p class="text-sm font-medium text-foreground">
        <% if (screening.processed_at || screening.created_at) { %>
          <%= new Date(screening.processed_at || screening.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
        <% } else { %>
          N/A
        <% } %>
      </p>
    </div>
  </div>
</div>

<!-- Action Buttons -->
<div class="flex flex-wrap items-center gap-3">
  <form action="/ai-screening/<%= screening.id %>/invite" method="POST" class="inline">
    <button type="submit" class="btn-primary">
      <i data-lucide="mail" class="w-4 h-4"></i>
      Invite to Interview
    </button>
  </form>
  <form action="/ai-screening/<%= screening.id %>/shortlist" method="POST" class="inline">
    <button type="submit" class="btn-outline">
      <i data-lucide="star" class="w-4 h-4"></i>
      Shortlist
    </button>
  </form>
  <form action="/ai-screening/<%= screening.id %>/reject" method="POST" class="inline"
        onsubmit="return confirm('Are you sure you want to reject this candidate?')">
    <button type="submit" class="btn-outline text-destructive border-destructive hover:bg-destructive hover:text-white">
      <i data-lucide="x-circle" class="w-4 h-4"></i>
      Reject
    </button>
  </form>
</div>
