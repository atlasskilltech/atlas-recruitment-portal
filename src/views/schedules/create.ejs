<%
  const candidate = locals.candidate || null;
  const candidates = locals.candidates || [];
  const job = locals.job || {};

  const hasCandidate = candidate && candidate.id;
  const candidateName = hasCandidate
    ? (candidate.appln_full_name
      || (candidate.first_name ? candidate.first_name + ' ' + (candidate.last_name || '') : '')
      || candidate.name || 'Select a Candidate')
    : 'Select a Candidate';
  const candidateEmail = hasCandidate ? (candidate.appln_email || candidate.email || '') : '';
  const jobTitle = hasCandidate ? (candidate.applied_job_short_desc_new || candidate.job_title || job.title || 'N/A') : 'N/A';
  const aiScore = hasCandidate ? (candidate.ai_match_score || candidate.match_score || candidate.ai_score || 0) : 0;
  const interviewScore = hasCandidate ? (candidate.total_score || candidate.interview_score || candidate.overall_score || 0) : 0;
  const aiScoreColor = aiScore >= 75 ? 'text-success' : aiScore >= 50 ? 'text-warning' : 'text-destructive';
  const intScoreColor = interviewScore >= 75 ? 'text-success' : interviewScore >= 50 ? 'text-warning' : 'text-destructive';
%>

<!-- Back Button -->
<div class="mb-6">
  <a href="/schedules" class="btn-outline btn-sm inline-flex items-center gap-2">
    <i data-lucide="arrow-left" class="w-4 h-4"></i>
    Back to Schedules
  </a>
</div>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Schedule Interview</h1>
    <p class="text-sm text-muted-foreground mt-1">Set up a new interview schedule for a candidate</p>
  </div>
</div>

<% if (hasCandidate) { %>
  <!-- Pre-selected Candidate Info Card -->
  <div class="card p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <% const nameParts = candidateName.trim().split(/\s+/); %>
      <div class="w-14 h-14 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center flex-shrink-0">
        <span class="text-lg font-bold text-white">
          <%= nameParts[0].charAt(0).toUpperCase() %><%= nameParts.length > 1 ? nameParts[nameParts.length - 1].charAt(0).toUpperCase() : '' %>
        </span>
      </div>
      <div class="flex-1 min-w-0">
        <h2 class="text-lg font-semibold text-foreground"><%= candidateName %></h2>
        <% if (candidateEmail) { %>
          <p class="text-sm text-muted-foreground"><%= candidateEmail %></p>
        <% } %>
        <p class="text-sm text-muted-foreground mt-0.5">
          <i data-lucide="briefcase" class="w-3.5 h-3.5 inline-block mr-1"></i>
          <%= jobTitle %>
        </p>
      </div>
      <div class="flex items-center gap-6">
        <% if (aiScore > 0) { %>
          <div class="text-center">
            <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">AI Score</p>
            <p class="text-2xl font-bold <%= aiScoreColor %>"><%= aiScore %>%</p>
          </div>
        <% } %>
        <% if (interviewScore > 0) { %>
          <div class="text-center">
            <p class="text-xs text-muted-foreground uppercase tracking-wider mb-1">Interview</p>
            <p class="text-2xl font-bold <%= intScoreColor %>"><%= interviewScore %>%</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
<% } %>

<!-- Schedule Form -->
<div class="card p-6" x-data="{ mode: 'offline' }">
  <h2 class="text-lg font-semibold text-foreground mb-6 flex items-center gap-2">
    <i data-lucide="calendar-plus" class="w-5 h-5 text-primary-800 dark:text-primary-200"></i>
    Interview Details
  </h2>

  <form action="/schedules" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <% if (hasCandidate) { %>
        <!-- Hidden fields for pre-selected candidate -->
        <input type="hidden" name="candidate_id" value="<%= candidate.id %>">
        <input type="hidden" name="job_id" value="<%= candidate.appln_applied_for_sub || job.id || '' %>">
      <% } else { %>
        <!-- Candidate Selection Dropdown -->
        <div class="form-group md:col-span-2">
          <label class="form-label" for="candidate_id">
            Select Candidate <span class="text-destructive">*</span>
          </label>
          <select id="candidate_id" name="candidate_id" class="form-select" required>
            <option value="">-- Choose a candidate --</option>
            <% candidates.forEach(function(c) { %>
              <option value="<%= c.id %>"><%= c.appln_full_name %> — <%= c.job_title || 'N/A' %> (<%= c.appln_email || '' %>)</option>
            <% }); %>
          </select>
          <p class="text-xs text-muted-foreground mt-1">Only shortlisted, selected, and scheduled candidates are shown</p>
        </div>
      <% } %>

      <!-- Date -->
      <div class="form-group">
        <label class="form-label" for="scheduled_date">
          Date <span class="text-destructive">*</span>
        </label>
        <input type="date" id="scheduled_date" name="scheduled_date" class="form-input" required>
      </div>

      <!-- Time -->
      <div class="form-group">
        <label class="form-label" for="scheduled_time">
          Time <span class="text-destructive">*</span>
        </label>
        <input type="time" id="scheduled_time" name="scheduled_time" class="form-input" required>
      </div>

      <!-- Mode -->
      <div class="form-group">
        <label class="form-label" for="mode">
          Interview Mode <span class="text-destructive">*</span>
        </label>
        <select id="mode" name="mode" class="form-select" x-model="mode" required>
          <option value="offline">Offline (In-person)</option>
          <option value="online">Online (Virtual)</option>
        </select>
      </div>

      <!-- Location (shown when offline) -->
      <div class="form-group" x-show="mode === 'offline'" x-transition>
        <label class="form-label" for="location">
          Location <span class="text-destructive">*</span>
        </label>
        <input type="text" id="location" name="location" class="form-input"
               placeholder="e.g., Room 301, Admin Block, ATLAS SkillTech University"
               :required="mode === 'offline'">
      </div>

      <!-- Meeting Link (shown when online) -->
      <div class="form-group" x-show="mode === 'online'" x-transition>
        <label class="form-label" for="meeting_link">
          Meeting Link <span class="text-destructive">*</span>
        </label>
        <input type="url" id="meeting_link" name="meeting_link" class="form-input"
               placeholder="e.g., https://meet.google.com/abc-defg-hij"
               :required="mode === 'online'">
      </div>

      <!-- Panel Members -->
      <div class="form-group md:col-span-2">
        <label class="form-label" for="panel_members">Panel Members</label>
        <input type="text" id="panel_members" name="panel_members" class="form-input"
               placeholder="Enter panel member names, separated by commas">
        <p class="text-xs text-muted-foreground mt-1">Separate multiple names with commas (e.g., Dr. Smith, Prof. Jones)</p>
      </div>

      <!-- Notes -->
      <div class="form-group md:col-span-2">
        <label class="form-label" for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="4" class="form-input"
                  placeholder="Any additional notes or instructions for the interview..."></textarea>
      </div>

      <!-- Notify Candidate -->
      <div class="form-group md:col-span-2">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="notify_candidate" value="1" checked
                 class="w-4 h-4 rounded border-border text-primary-800 focus:ring-primary-800">
          <span class="text-sm text-foreground">Notify candidate via email about this interview</span>
        </label>
      </div>
    </div>

    <!-- Form Actions -->
    <div class="flex items-center gap-3 mt-8 pt-6 border-t border-border">
      <button type="submit" class="btn-primary">
        <i data-lucide="calendar-check" class="w-4 h-4"></i>
        Schedule Interview
      </button>
      <a href="/schedules" class="btn-outline">
        Cancel
      </a>
    </div>
  </form>
</div>
