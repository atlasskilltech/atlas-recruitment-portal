<%
  const schedule = typeof locals.schedule !== 'undefined' ? locals.schedule : {};
  const candidate = typeof locals.candidate !== 'undefined' ? locals.candidate : {};
  const job = typeof locals.job !== 'undefined' ? locals.job : {};

  const candidateName = schedule.candidate_name || (candidate.first_name
    ? candidate.first_name + ' ' + (candidate.last_name || '')
    : (candidate.name || 'Unknown Candidate'));
  const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
  const candidateEmail = candidate.email || candidate.appln_email || '';
  const jobTitle = schedule.job_title || job.title || 'N/A';

  const mode = schedule.mode || 'offline';
  const modeBadge = mode === 'online' ? 'badge badge-info' : 'badge badge-muted';

  const schStatus = schedule.status || 'scheduled';
  const schStatusBadge = schStatus === 'scheduled' ? 'badge badge-scheduled'
    : schStatus === 'completed' ? 'badge badge-success'
    : schStatus === 'cancelled' ? 'badge badge-danger'
    : schStatus === 'rescheduled' ? 'badge badge-warning'
    : 'badge badge-muted';

  const panelMembers = schedule.panel_members || schedule.panelMembers || [];
  const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);

  const notes = schedule.notes || '';
%>

<!-- Back Button -->
<div class="mb-lg">
  <a href="/schedules" class="btn btn-outline btn-sm inline-flex items-center gap-sm">
    <i data-lucide="arrow-left" style="width:16px;height:16px"></i>
    Back to Schedules
  </a>
</div>

<!-- Page Header -->
<div class="flex items-center justify-between flex-wrap gap-md mb-lg">
  <div>
    <h1 class="text-2xl font-bold">Schedule Details</h1>
    <p class="text-sm text-muted mt-sm">View interview schedule information</p>
  </div>
  <span class="<%= schStatusBadge %> text-sm">
    <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
  </span>
</div>

<div class="grid-3" style="grid-template-columns:2fr 1fr;gap:24px">

  <!-- Main Content (2/3) -->
  <div class="flex flex-col gap-lg">

    <!-- Schedule Details Card -->
    <div class="card p-lg">
      <h2 class="text-lg font-semibold mb-lg flex items-center gap-sm">
        <i data-lucide="calendar" style="width:20px;height:20px;color:var(--accent-primary)"></i>
        Schedule Information
      </h2>

      <div class="form-grid" style="gap:24px">
        <!-- Date -->
        <div>
          <p class="text-xs text-muted uppercase tracking-wide mb-sm">Date</p>
          <p class="text-sm font-medium flex items-center gap-sm">
            <i data-lucide="calendar" style="width:16px;height:16px;color:var(--text-muted)"></i>
            <% if (schedule.scheduled_date || schedule.date) { %>
              <%= new Date(schedule.scheduled_date || schedule.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
            <% } else { %>
              Not set
            <% } %>
          </p>
        </div>

        <!-- Time -->
        <div>
          <p class="text-xs text-muted uppercase tracking-wide mb-sm">Time</p>
          <p class="text-sm font-medium flex items-center gap-sm">
            <i data-lucide="clock" style="width:16px;height:16px;color:var(--text-muted)"></i>
            <%= schedule.scheduled_time || schedule.time || 'Not set' %>
          </p>
        </div>

        <!-- Mode -->
        <div>
          <p class="text-xs text-muted uppercase tracking-wide mb-sm">Interview Mode</p>
          <span class="<%= modeBadge %>">
            <% if (mode === 'online') { %>
              <i data-lucide="video" style="width:12px;height:12px"></i>
            <% } else { %>
              <i data-lucide="map-pin" style="width:12px;height:12px"></i>
            <% } %>
            <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
          </span>
        </div>

        <!-- Location / Meeting Link -->
        <div>
          <p class="text-xs text-muted uppercase tracking-wide mb-sm">
            <%= mode === 'online' ? 'Meeting Link' : 'Location' %>
          </p>
          <% if (mode === 'online' && (schedule.meeting_link || schedule.meetingLink)) { %>
            <a href="<%= schedule.meeting_link || schedule.meetingLink %>" target="_blank"
               class="text-sm text-accent flex items-center gap-sm">
              <i data-lucide="external-link" style="width:16px;height:16px"></i>
              Join Meeting
            </a>
          <% } else if (schedule.location) { %>
            <p class="text-sm font-medium flex items-center gap-sm">
              <i data-lucide="map-pin" style="width:16px;height:16px;color:var(--text-muted)"></i>
              <%= schedule.location %>
            </p>
          <% } else { %>
            <p class="text-sm text-muted">Not specified</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Panel Members Card -->
    <div class="card p-lg">
      <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
        <i data-lucide="users" style="width:20px;height:20px;color:var(--accent-purple)"></i>
        Panel Members
      </h2>
      <% if (panelList.length > 0) { %>
        <div class="flex flex-col gap-sm">
          <% panelList.forEach(function(member, idx) { %>
            <div class="flex items-center gap-sm" style="padding:12px;border-radius:var(--radius-lg);background:var(--bg-tertiary)">
              <div class="avatar avatar-sm" style="background:rgba(139,92,246,0.1);color:var(--accent-purple);font-size:0.7rem">
                <span><%= idx + 1 %></span>
              </div>
              <span class="text-sm font-medium">
                <%= typeof member === 'string' ? member : (member.name || member) %>
              </span>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p class="text-sm text-muted">No panel members assigned.</p>
      <% } %>
    </div>

    <!-- Notes Card -->
    <% if (notes) { %>
      <div class="card p-lg">
        <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
          <i data-lucide="file-text" style="width:20px;height:20px;color:var(--text-muted)"></i>
          Notes
        </h2>
        <div class="text-sm text-muted" style="line-height:1.7;white-space:pre-line;background:var(--bg-tertiary);border-radius:var(--radius-lg);padding:16px">
          <%= notes %>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Sidebar (1/3) -->
  <div class="flex flex-col gap-lg">

    <!-- Candidate Info Card -->
    <div class="card p-lg">
      <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
        <i data-lucide="user" style="width:20px;height:20px;color:var(--text-muted)"></i>
        Candidate
      </h2>
      <div class="flex items-center gap-sm mb-md">
        <div class="avatar avatar-md avatar-gradient shrink-0">
          <span><%= initials %></span>
        </div>
        <div class="min-w-0">
          <p class="font-medium truncate"><%= candidateName %></p>
          <% if (candidateEmail) { %>
            <p class="text-xs text-muted truncate"><%= candidateEmail %></p>
          <% } %>
        </div>
      </div>
      <div class="border-t" style="padding-top:12px">
        <p class="text-xs text-muted uppercase tracking-wide mb-sm">Applied For</p>
        <p class="text-sm font-medium">
          <i data-lucide="briefcase" style="width:14px;height:14px;display:inline-block;margin-right:4px;color:var(--text-muted)"></i>
          <%= jobTitle %>
        </p>
      </div>
    </div>

    <!-- Status Card -->
    <div class="card p-lg">
      <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
        <i data-lucide="activity" style="width:20px;height:20px;color:var(--text-muted)"></i>
        Status
      </h2>
      <div class="flex items-center gap-sm mb-md">
        <span class="<%= schStatusBadge %> text-sm">
          <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
        </span>
      </div>
      <% if (schedule.created_at) { %>
        <div class="text-xs text-muted">
          <p>Created: <%= new Date(schedule.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
        </div>
      <% } %>
      <% if (schedule.updated_at) { %>
        <div class="text-xs text-muted mt-sm">
          <p>Updated: <%= new Date(schedule.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
        </div>
      <% } %>
    </div>

    <!-- Action Buttons -->
    <div class="card p-lg">
      <h2 class="text-lg font-semibold mb-md flex items-center gap-sm">
        <i data-lucide="settings" style="width:20px;height:20px;color:var(--text-muted)"></i>
        Actions
      </h2>
      <div class="flex flex-col gap-sm">
        <% if (schStatus === 'scheduled') { %>
          <a href="/schedules/<%= schedule.id %>/edit" class="btn btn-outline w-full justify-center">
            <i data-lucide="calendar-clock" style="width:16px;height:16px"></i>
            Reschedule
          </a>
          <form action="/schedules/<%= schedule.id %>/complete" method="POST">
            <button type="submit" class="btn btn-primary w-full justify-center">
              <i data-lucide="check-circle" style="width:16px;height:16px"></i>
              Mark Complete
            </button>
          </form>
          <form action="/schedules/<%= schedule.id %>/cancel" method="POST"
                onsubmit="return confirm('Are you sure you want to cancel this interview?')">
            <button type="submit" class="btn btn-danger w-full justify-center">
              <i data-lucide="x-circle" style="width:16px;height:16px"></i>
              Cancel Interview
            </button>
          </form>
        <% } else { %>
          <p class="text-sm text-muted text-center" style="padding:8px 0">
            No actions available for this status.
          </p>
        <% } %>
      </div>
    </div>
  </div>
</div>
