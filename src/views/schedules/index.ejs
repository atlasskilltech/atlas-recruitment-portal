<%
  const schedules = typeof locals.schedules !== 'undefined' ? locals.schedules : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};

  const currentStatus = filters.status || 'all';

  const tabs = [
    { key: 'all', label: 'All' },
    { key: 'scheduled', label: 'Scheduled' },
    { key: 'completed', label: 'Completed' },
    { key: 'cancelled', label: 'Cancelled' },
  ];

  function buildQuery(overrides) {
    const params = Object.assign({}, filters, overrides);
    if (params.status === 'all') delete params.status;
    if (params.page == 1) delete params.page;
    const qs = Object.keys(params).filter(k => params[k]).map(k => k + '=' + encodeURIComponent(params[k])).join('&');
    return qs ? '?' + qs : '';
  }
%>

<!-- Page Header -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-foreground tracking-tight">Interview Schedules</h1>
    <p class="text-sm text-muted-foreground mt-1">Manage and track all interview schedules</p>
  </div>
  <a href="/schedules/create" class="btn-primary btn-sm self-start sm:self-auto">
    <i data-lucide="calendar-plus" class="w-4 h-4"></i>
    Schedule Interview
  </a>
</div>

<!-- Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
  <!-- Total Scheduled -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-foreground"><%= stats.total || 0 %></p>
        <p class="stat-label">Total Scheduled</p>
      </div>
      <div class="stat-icon bg-primary-800">
        <i data-lucide="calendar" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Today's Interviews -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-blue-600 dark:text-blue-400"><%= stats.today || 0 %></p>
        <p class="stat-label">Today's Interviews</p>
      </div>
      <div class="stat-icon bg-blue-600">
        <i data-lucide="clock" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Upcoming -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-purple-600 dark:text-purple-400"><%= stats.upcoming || 0 %></p>
        <p class="stat-label">Upcoming</p>
      </div>
      <div class="stat-icon bg-purple-600">
        <i data-lucide="calendar-clock" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Completed -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-success"><%= stats.completed || 0 %></p>
        <p class="stat-label">Completed</p>
      </div>
      <div class="stat-icon bg-success">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>

  <!-- Cancelled -->
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <div>
        <p class="stat-value text-destructive"><%= stats.cancelled || 0 %></p>
        <p class="stat-label">Cancelled</p>
      </div>
      <div class="stat-icon bg-destructive">
        <i data-lucide="x-circle" class="w-5 h-5"></i>
      </div>
    </div>
  </div>
</div>

<!-- View Toggle & Filter Tabs -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6"
     x-data="{ view: 'list' }">

  <!-- Filter Tabs -->
  <div class="tabs">
    <% tabs.forEach(function(tab) { %>
      <a href="/schedules<%= buildQuery({ status: tab.key, page: 1 }) %>"
         class="tab <%= currentStatus === tab.key ? 'active' : '' %>">
        <%= tab.label %>
      </a>
    <% }); %>
  </div>

  <!-- View Toggle -->
  <div class="flex items-center gap-1 bg-muted rounded-lg p-1">
    <button @click="view = 'list'"
            :class="view === 'list' ? 'bg-card shadow-sm text-foreground' : 'text-muted-foreground'"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium transition-all">
      <i data-lucide="list" class="w-4 h-4"></i>
      List
    </button>
    <button @click="view = 'card'"
            :class="view === 'card' ? 'bg-card shadow-sm text-foreground' : 'text-muted-foreground'"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium transition-all">
      <i data-lucide="layout-grid" class="w-4 h-4"></i>
      Cards
    </button>
  </div>

  <% if (schedules.length > 0) { %>

  <!-- List View -->
  <template x-if="view === 'list'">
    <div class="card overflow-hidden w-full">
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Candidate Name</th>
              <th>Job Role</th>
              <th>Date & Time</th>
              <th>Mode</th>
              <th>Location / Link</th>
              <th>Panel Members</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% schedules.forEach(function(sch) { %>
              <%
                const candidateName = sch.candidate_name || (sch.candidate ? (sch.candidate.first_name + ' ' + (sch.candidate.last_name || '')) : 'Unknown');
                const jobTitle = sch.job_title || (sch.job ? sch.job.title : 'N/A');
                const mode = sch.mode || 'offline';
                const modeBadge = mode === 'online' ? 'badge-info' : 'badge-muted';
                const schStatus = sch.status || 'scheduled';
                const schStatusBadge = schStatus === 'scheduled' ? 'badge-scheduled'
                  : schStatus === 'completed' ? 'badge-success'
                  : schStatus === 'cancelled' ? 'badge-danger'
                  : schStatus === 'rescheduled' ? 'badge-warning'
                  : 'badge-muted';
                const panelMembers = sch.panel_members || sch.panelMembers || [];
                const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);
              %>
              <tr>
                <!-- Candidate Name -->
                <td>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
                      <span class="text-xs font-semibold text-primary-800 dark:text-primary-200">
                        <%= candidateName.charAt(0).toUpperCase() %>
                      </span>
                    </div>
                    <span class="font-medium text-foreground"><%= candidateName %></span>
                  </div>
                </td>

                <!-- Job Role -->
                <td class="text-muted-foreground"><%= jobTitle %></td>

                <!-- Date & Time -->
                <td>
                  <div class="text-sm">
                    <% if (sch.scheduled_date || sch.date) { %>
                      <p class="font-medium text-foreground">
                        <%= new Date(sch.scheduled_date || sch.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                      </p>
                      <p class="text-xs text-muted-foreground">
                        <% if (sch.scheduled_time || sch.time) { %>
                          <%= sch.scheduled_time || sch.time %>
                        <% } %>
                      </p>
                    <% } else { %>
                      &mdash;
                    <% } %>
                  </div>
                </td>

                <!-- Mode -->
                <td>
                  <span class="<%= modeBadge %>">
                    <% if (mode === 'online') { %>
                      <i data-lucide="video" class="w-3 h-3"></i>
                    <% } else { %>
                      <i data-lucide="map-pin" class="w-3 h-3"></i>
                    <% } %>
                    <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
                  </span>
                </td>

                <!-- Location / Link -->
                <td class="text-sm text-muted-foreground max-w-[200px] truncate">
                  <% if (mode === 'online' && (sch.meeting_link || sch.meetingLink)) { %>
                    <a href="<%= sch.meeting_link || sch.meetingLink %>" target="_blank" class="text-primary-400 hover:text-primary-300 hover:underline">
                      <i data-lucide="external-link" class="w-3 h-3 inline-block mr-1"></i>
                      Join Meeting
                    </a>
                  <% } else if (sch.location) { %>
                    <span><i data-lucide="map-pin" class="w-3 h-3 inline-block mr-1"></i><%= sch.location %></span>
                  <% } else { %>
                    &mdash;
                  <% } %>
                </td>

                <!-- Panel Members -->
                <td>
                  <% if (panelList.length > 0) { %>
                    <div class="flex flex-wrap gap-1">
                      <% panelList.slice(0, 2).forEach(function(member) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-muted text-muted-foreground">
                          <%= typeof member === 'string' ? member : (member.name || member) %>
                        </span>
                      <% }); %>
                      <% if (panelList.length > 2) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-muted text-muted-foreground">
                          +<%= panelList.length - 2 %> more
                        </span>
                      <% } %>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted-foreground">&mdash;</span>
                  <% } %>
                </td>

                <!-- Status -->
                <td>
                  <span class="<%= schStatusBadge %>">
                    <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
                  </span>
                </td>

                <!-- Actions -->
                <td>
                  <div class="flex items-center gap-1">
                    <a href="/schedules/<%= sch.id %>" class="btn-ghost btn-sm text-primary-800 dark:text-primary-200" title="View Details">
                      <i data-lucide="eye" class="w-4 h-4"></i>
                    </a>
                    <% if (schStatus === 'scheduled') { %>
                      <a href="/schedules/<%= sch.id %>/edit" class="btn-ghost btn-sm text-warning" title="Reschedule">
                        <i data-lucide="calendar-clock" class="w-4 h-4"></i>
                      </a>
                      <form action="/schedules/<%= sch.id %>/cancel" method="POST" class="inline"
                            onsubmit="return confirm('Cancel this interview?')">
                        <button type="submit" class="btn-ghost btn-sm text-destructive" title="Cancel">
                          <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                      </form>
                      <form action="/schedules/<%= sch.id %>/complete" method="POST" class="inline">
                        <button type="submit" class="btn-ghost btn-sm text-success" title="Mark Complete">
                          <i data-lucide="check-circle" class="w-4 h-4"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <div class="flex items-center justify-between px-4 py-3 border-t border-border">
          <p class="text-sm text-muted-foreground">
            Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
            to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
            of <span class="font-medium"><%= pagination.total %></span> results
          </p>
          <div class="flex items-center gap-1">
            <% if (pagination.page > 1) { %>
              <a href="/schedules<%= buildQuery({ page: pagination.page - 1 }) %>" class="btn-outline btn-sm">
                <i data-lucide="chevron-left" class="w-4 h-4"></i> Prev
              </a>
            <% } %>

            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <% if (i === pagination.page) { %>
                <span class="btn-primary btn-sm"><%= i %></span>
              <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
                <a href="/schedules<%= buildQuery({ page: i }) %>" class="btn-outline btn-sm"><%= i %></a>
              <% } else if (Math.abs(i - pagination.page) === 3) { %>
                <span class="px-1 text-muted-foreground">&hellip;</span>
              <% } %>
            <% } %>

            <% if (pagination.page < pagination.totalPages) { %>
              <a href="/schedules<%= buildQuery({ page: pagination.page + 1 }) %>" class="btn-outline btn-sm">
                Next <i data-lucide="chevron-right" class="w-4 h-4"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </template>

  <!-- Card View -->
  <template x-if="view === 'card'">
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 w-full">
      <% schedules.forEach(function(sch) { %>
        <%
          const candidateName = sch.candidate_name || (sch.candidate ? (sch.candidate.first_name + ' ' + (sch.candidate.last_name || '')) : 'Unknown');
          const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
          const jobTitle = sch.job_title || (sch.job ? sch.job.title : 'N/A');
          const mode = sch.mode || 'offline';
          const modeBadge = mode === 'online' ? 'badge-info' : 'badge-muted';
          const schStatus = sch.status || 'scheduled';
          const schStatusBadge = schStatus === 'scheduled' ? 'badge-scheduled'
            : schStatus === 'completed' ? 'badge-success'
            : schStatus === 'cancelled' ? 'badge-danger'
            : schStatus === 'rescheduled' ? 'badge-warning'
            : 'badge-muted';
          const panelMembers = sch.panel_members || sch.panelMembers || [];
          const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);
        %>
        <div class="card p-5 hover:shadow-brand-md transition-shadow">
          <!-- Card Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-semibold text-primary-800 dark:text-primary-200"><%= initials %></span>
              </div>
              <div>
                <p class="font-medium text-foreground"><%= candidateName %></p>
                <p class="text-xs text-muted-foreground"><%= jobTitle %></p>
              </div>
            </div>
            <span class="<%= schStatusBadge %>">
              <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
            </span>
          </div>

          <!-- Card Details -->
          <div class="space-y-3 mb-4">
            <!-- Date & Time -->
            <div class="flex items-center gap-2 text-sm">
              <i data-lucide="calendar" class="w-4 h-4 text-muted-foreground flex-shrink-0"></i>
              <% if (sch.scheduled_date || sch.date) { %>
                <span class="text-foreground">
                  <%= new Date(sch.scheduled_date || sch.date).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
                </span>
                <% if (sch.scheduled_time || sch.time) { %>
                  <span class="text-muted-foreground">at <%= sch.scheduled_time || sch.time %></span>
                <% } %>
              <% } else { %>
                <span class="text-muted-foreground">Not set</span>
              <% } %>
            </div>

            <!-- Mode -->
            <div class="flex items-center gap-2 text-sm">
              <% if (mode === 'online') { %>
                <i data-lucide="video" class="w-4 h-4 text-muted-foreground flex-shrink-0"></i>
              <% } else { %>
                <i data-lucide="map-pin" class="w-4 h-4 text-muted-foreground flex-shrink-0"></i>
              <% } %>
              <span class="<%= modeBadge %>">
                <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
              </span>
              <% if (mode === 'online' && (sch.meeting_link || sch.meetingLink)) { %>
                <a href="<%= sch.meeting_link || sch.meetingLink %>" target="_blank" class="text-primary-400 hover:underline text-xs">
                  Join Link
                </a>
              <% } else if (sch.location) { %>
                <span class="text-muted-foreground truncate"><%= sch.location %></span>
              <% } %>
            </div>

            <!-- Panel Members -->
            <% if (panelList.length > 0) { %>
              <div class="flex items-start gap-2 text-sm">
                <i data-lucide="users" class="w-4 h-4 text-muted-foreground flex-shrink-0 mt-0.5"></i>
                <div class="flex flex-wrap gap-1">
                  <% panelList.forEach(function(member) { %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-muted text-muted-foreground">
                      <%= typeof member === 'string' ? member : (member.name || member) %>
                    </span>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>

          <!-- Card Actions -->
          <div class="flex items-center gap-2 pt-3 border-t border-border">
            <a href="/schedules/<%= sch.id %>" class="btn-outline btn-sm flex-1 justify-center">
              <i data-lucide="eye" class="w-4 h-4"></i>
              View
            </a>
            <% if (schStatus === 'scheduled') { %>
              <a href="/schedules/<%= sch.id %>/edit" class="btn-outline btn-sm flex-1 justify-center">
                <i data-lucide="calendar-clock" class="w-4 h-4"></i>
                Reschedule
              </a>
              <form action="/schedules/<%= sch.id %>/complete" method="POST" class="flex-1">
                <button type="submit" class="btn-primary btn-sm w-full justify-center">
                  <i data-lucide="check" class="w-4 h-4"></i>
                  Complete
                </button>
              </form>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </template>

  <% } else { %>
    <!-- Empty State -->
    <div class="card w-full">
      <div class="empty-state py-20">
        <div class="w-20 h-20 rounded-2xl bg-muted/50 flex items-center justify-center mb-5">
          <i data-lucide="calendar" class="w-10 h-10 text-muted-foreground/30"></i>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-1">No Interview Schedules</h3>
        <p class="text-sm text-muted-foreground max-w-sm mb-6">
          No interview schedules found. Schedules will appear here once interviews are scheduled.
        </p>
        <a href="/schedules/create" class="btn-primary">
          <i data-lucide="calendar-plus" class="w-4 h-4"></i>
          Schedule Interview
        </a>
      </div>
    </div>
  <% } %>
</div>
