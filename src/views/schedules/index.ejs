<%
  const schedules = typeof locals.schedules !== 'undefined' ? locals.schedules : [];
  const stats = typeof locals.stats !== 'undefined' ? locals.stats : {};
  const pagination = typeof locals.pagination !== 'undefined' ? locals.pagination : {};
  const filters = typeof locals.filters !== 'undefined' ? locals.filters : {};

  const currentStatus = filters.status || 'all';

  const tabs = [
    { key: 'all', label: 'All' },
    { key: 'scheduled', label: 'Scheduled' },
    { key: 'completed', label: 'Completed' },
    { key: 'cancelled', label: 'Cancelled' },
  ];

  function buildQuery(overrides) {
    const params = Object.assign({}, filters, overrides);
    if (params.status === 'all') delete params.status;
    if (params.page == 1) delete params.page;
    const qs = Object.keys(params).filter(k => params[k]).map(k => k + '=' + encodeURIComponent(params[k])).join('&');
    return qs ? '?' + qs : '';
  }
%>

<!-- Page Header -->
<div class="flex items-center justify-between flex-wrap gap-md mb-lg">
  <div>
    <h1 class="text-2xl font-bold">Interview Schedules</h1>
    <p class="text-sm text-secondary mt-sm">Manage and track all interview schedules</p>
  </div>
  <a href="/schedules/create" class="btn btn-primary btn-sm">
    <i data-lucide="calendar-plus" style="width:16px;height:16px"></i>
    Schedule Interview
  </a>
</div>

<!-- Summary Cards -->
<div class="stats-row">
  <!-- Total Scheduled -->
  <div class="stat-card">
    <div class="stat-icon purple">
      <i data-lucide="calendar"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.total || 0 %></p>
      <p class="stat-label">Total Scheduled</p>
    </div>
  </div>

  <!-- Today's Interviews -->
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="clock"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.today || 0 %></p>
      <p class="stat-label">Today's Interviews</p>
    </div>
  </div>

  <!-- Upcoming -->
  <div class="stat-card">
    <div class="stat-icon orange">
      <i data-lucide="calendar-clock"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.upcoming || 0 %></p>
      <p class="stat-label">Upcoming</p>
    </div>
  </div>

  <!-- Completed -->
  <div class="stat-card">
    <div class="stat-icon green">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.completed || 0 %></p>
      <p class="stat-label">Completed</p>
    </div>
  </div>

  <!-- Cancelled -->
  <div class="stat-card">
    <div class="stat-icon red">
      <i data-lucide="x-circle"></i>
    </div>
    <div class="stat-info">
      <p class="stat-value"><%= stats.cancelled || 0 %></p>
      <p class="stat-label">Cancelled</p>
    </div>
  </div>
</div>

<!-- View Toggle & Filter Tabs -->
<div class="flex flex-col gap-md mb-lg"
     x-data="{ view: 'list' }">

  <!-- Filter Tabs -->
  <div class="flex items-center justify-between flex-wrap gap-md">
    <div class="tabs" style="margin-bottom:0">
      <% tabs.forEach(function(tab) { %>
        <a href="/schedules<%= buildQuery({ status: tab.key, page: 1 }) %>"
           class="tab <%= currentStatus === tab.key ? 'active' : '' %>">
          <%= tab.label %>
        </a>
      <% }); %>
    </div>

    <!-- View Toggle -->
    <div class="flex items-center gap-sm" style="background:var(--bg-tertiary);border-radius:var(--radius-md);padding:4px">
      <button @click="view = 'list'"
              :class="view === 'list' ? 'btn btn-sm' : 'btn btn-ghost btn-sm'"
              :style="view === 'list' ? 'background:var(--bg-secondary);box-shadow:var(--shadow-sm)' : ''"
              class="flex items-center gap-sm">
        <i data-lucide="list" style="width:16px;height:16px"></i>
        List
      </button>
      <button @click="view = 'card'"
              :class="view === 'card' ? 'btn btn-sm' : 'btn btn-ghost btn-sm'"
              :style="view === 'card' ? 'background:var(--bg-secondary);box-shadow:var(--shadow-sm)' : ''"
              class="flex items-center gap-sm">
        <i data-lucide="layout-grid" style="width:16px;height:16px"></i>
        Cards
      </button>
    </div>
  </div>

  <% if (schedules.length > 0) { %>

  <!-- List View -->
  <template x-if="view === 'list'">
    <div class="card overflow-hidden w-full">
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Candidate Name</th>
              <th>Job Role</th>
              <th>Date & Time</th>
              <th>Mode</th>
              <th>Location / Link</th>
              <th>Panel Members</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% schedules.forEach(function(sch) { %>
              <%
                const candidateName = sch.candidate_name || (sch.candidate ? (sch.candidate.first_name + ' ' + (sch.candidate.last_name || '')) : 'Unknown');
                const jobTitle = sch.job_title || (sch.job ? sch.job.title : 'N/A');
                const mode = sch.mode || 'offline';
                const modeBadge = mode === 'online' ? 'badge badge-info' : 'badge badge-muted';
                const schStatus = sch.status || 'scheduled';
                const schStatusBadge = schStatus === 'scheduled' ? 'badge badge-scheduled'
                  : schStatus === 'completed' ? 'badge badge-success'
                  : schStatus === 'cancelled' ? 'badge badge-danger'
                  : schStatus === 'rescheduled' ? 'badge badge-warning'
                  : 'badge badge-muted';
                const panelMembers = sch.panel_members || sch.panelMembers || [];
                const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);
              %>
              <tr>
                <!-- Candidate Name -->
                <td>
                  <div class="flex items-center gap-sm">
                    <div class="avatar avatar-sm avatar-gradient shrink-0">
                      <span><%= candidateName.charAt(0).toUpperCase() %></span>
                    </div>
                    <span class="font-medium"><%= candidateName %></span>
                  </div>
                </td>

                <!-- Job Role -->
                <td class="text-secondary"><%= jobTitle %></td>

                <!-- Date & Time -->
                <td>
                  <div class="text-sm">
                    <% if (sch.scheduled_date || sch.date) { %>
                      <p class="font-medium">
                        <%= new Date(sch.scheduled_date || sch.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                      </p>
                      <p class="text-xs text-muted">
                        <% if (sch.scheduled_time || sch.time) { %>
                          <%= sch.scheduled_time || sch.time %>
                        <% } %>
                      </p>
                    <% } else { %>
                      &mdash;
                    <% } %>
                  </div>
                </td>

                <!-- Mode -->
                <td>
                  <span class="<%= modeBadge %>">
                    <% if (mode === 'online') { %>
                      <i data-lucide="video" style="width:12px;height:12px"></i>
                    <% } else { %>
                      <i data-lucide="map-pin" style="width:12px;height:12px"></i>
                    <% } %>
                    <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
                  </span>
                </td>

                <!-- Location / Link -->
                <td class="text-sm text-secondary truncate" style="max-width:200px">
                  <% if (mode === 'online' && (sch.meeting_link || sch.meetingLink)) { %>
                    <a href="<%= sch.meeting_link || sch.meetingLink %>" target="_blank" class="text-accent">
                      <i data-lucide="external-link" style="width:12px;height:12px;display:inline-block;margin-right:4px"></i>
                      Join Meeting
                    </a>
                  <% } else if (sch.location) { %>
                    <span><i data-lucide="map-pin" style="width:12px;height:12px;display:inline-block;margin-right:4px"></i><%= sch.location %></span>
                  <% } else { %>
                    &mdash;
                  <% } %>
                </td>

                <!-- Panel Members -->
                <td>
                  <% if (panelList.length > 0) { %>
                    <div class="flex flex-wrap gap-sm">
                      <% panelList.slice(0, 2).forEach(function(member) { %>
                        <span class="badge badge-muted">
                          <%= typeof member === 'string' ? member : (member.name || member) %>
                        </span>
                      <% }); %>
                      <% if (panelList.length > 2) { %>
                        <span class="badge badge-muted">
                          +<%= panelList.length - 2 %> more
                        </span>
                      <% } %>
                    </div>
                  <% } else { %>
                    <span class="text-xs text-muted">&mdash;</span>
                  <% } %>
                </td>

                <!-- Status -->
                <td>
                  <span class="<%= schStatusBadge %>">
                    <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
                  </span>
                </td>

                <!-- Actions -->
                <td>
                  <div class="flex items-center gap-sm">
                    <a href="/schedules/<%= sch.id %>" class="btn btn-ghost btn-sm text-accent" title="View Details">
                      <i data-lucide="eye" style="width:16px;height:16px"></i>
                    </a>
                    <% if (schStatus === 'scheduled') { %>
                      <a href="/schedules/<%= sch.id %>/edit" class="btn btn-ghost btn-sm text-warning" title="Reschedule">
                        <i data-lucide="calendar-clock" style="width:16px;height:16px"></i>
                      </a>
                      <form action="/schedules/<%= sch.id %>/cancel" method="POST" class="inline"
                            onsubmit="return confirm('Cancel this interview?')">
                        <button type="submit" class="btn btn-ghost btn-sm text-danger" title="Cancel">
                          <i data-lucide="x" style="width:16px;height:16px"></i>
                        </button>
                      </form>
                      <form action="/schedules/<%= sch.id %>/complete" method="POST" class="inline">
                        <button type="submit" class="btn btn-ghost btn-sm text-success" title="Mark Complete">
                          <i data-lucide="check-circle" style="width:16px;height:16px"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (pagination.totalPages > 1) { %>
        <div class="flex items-center justify-between p-md border-t">
          <p class="text-sm text-secondary">
            Showing <span class="font-medium"><%= ((pagination.page - 1) * pagination.limit) + 1 %></span>
            to <span class="font-medium"><%= Math.min(pagination.page * pagination.limit, pagination.total) %></span>
            of <span class="font-medium"><%= pagination.total %></span> results
          </p>
          <div class="pagination">
            <% if (pagination.page > 1) { %>
              <a href="/schedules<%= buildQuery({ page: pagination.page - 1 }) %>">
                <i data-lucide="chevron-left" style="width:16px;height:16px"></i> Prev
              </a>
            <% } %>

            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <% if (i === pagination.page) { %>
                <span class="active"><%= i %></span>
              <% } else if (Math.abs(i - pagination.page) <= 2 || i === 1 || i === pagination.totalPages) { %>
                <a href="/schedules<%= buildQuery({ page: i }) %>"><%= i %></a>
              <% } else if (Math.abs(i - pagination.page) === 3) { %>
                <span class="text-muted">&hellip;</span>
              <% } %>
            <% } %>

            <% if (pagination.page < pagination.totalPages) { %>
              <a href="/schedules<%= buildQuery({ page: pagination.page + 1 }) %>">
                Next <i data-lucide="chevron-right" style="width:16px;height:16px"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </template>

  <!-- Card View -->
  <template x-if="view === 'card'">
    <div class="grid-auto w-full">
      <% schedules.forEach(function(sch) { %>
        <%
          const candidateName = sch.candidate_name || (sch.candidate ? (sch.candidate.first_name + ' ' + (sch.candidate.last_name || '')) : 'Unknown');
          const initials = candidateName.split(' ').map(n => n.charAt(0).toUpperCase()).slice(0, 2).join('');
          const jobTitle = sch.job_title || (sch.job ? sch.job.title : 'N/A');
          const mode = sch.mode || 'offline';
          const modeBadge = mode === 'online' ? 'badge badge-info' : 'badge badge-muted';
          const schStatus = sch.status || 'scheduled';
          const schStatusBadge = schStatus === 'scheduled' ? 'badge badge-scheduled'
            : schStatus === 'completed' ? 'badge badge-success'
            : schStatus === 'cancelled' ? 'badge badge-danger'
            : schStatus === 'rescheduled' ? 'badge badge-warning'
            : 'badge badge-muted';
          const panelMembers = sch.panel_members || sch.panelMembers || [];
          const panelList = Array.isArray(panelMembers) ? panelMembers : (typeof panelMembers === 'string' ? panelMembers.split(',').map(p => p.trim()) : []);
        %>
        <div class="card p-lg" style="transition:box-shadow var(--transition-fast)">
          <!-- Card Header -->
          <div class="flex items-start justify-between mb-md">
            <div class="flex items-center gap-sm">
              <div class="avatar avatar-md avatar-gradient shrink-0">
                <span><%= initials %></span>
              </div>
              <div>
                <p class="font-medium"><%= candidateName %></p>
                <p class="text-xs text-muted"><%= jobTitle %></p>
              </div>
            </div>
            <span class="<%= schStatusBadge %>">
              <%= schStatus.charAt(0).toUpperCase() + schStatus.slice(1) %>
            </span>
          </div>

          <!-- Card Details -->
          <div class="flex flex-col gap-sm mb-md">
            <!-- Date & Time -->
            <div class="flex items-center gap-sm text-sm">
              <i data-lucide="calendar" style="width:16px;height:16px;color:var(--text-muted);flex-shrink:0"></i>
              <% if (sch.scheduled_date || sch.date) { %>
                <span>
                  <%= new Date(sch.scheduled_date || sch.date).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
                </span>
                <% if (sch.scheduled_time || sch.time) { %>
                  <span class="text-muted">at <%= sch.scheduled_time || sch.time %></span>
                <% } %>
              <% } else { %>
                <span class="text-muted">Not set</span>
              <% } %>
            </div>

            <!-- Mode -->
            <div class="flex items-center gap-sm text-sm">
              <% if (mode === 'online') { %>
                <i data-lucide="video" style="width:16px;height:16px;color:var(--text-muted);flex-shrink:0"></i>
              <% } else { %>
                <i data-lucide="map-pin" style="width:16px;height:16px;color:var(--text-muted);flex-shrink:0"></i>
              <% } %>
              <span class="<%= modeBadge %>">
                <%= mode.charAt(0).toUpperCase() + mode.slice(1) %>
              </span>
              <% if (mode === 'online' && (sch.meeting_link || sch.meetingLink)) { %>
                <a href="<%= sch.meeting_link || sch.meetingLink %>" target="_blank" class="text-accent text-xs">
                  Join Link
                </a>
              <% } else if (sch.location) { %>
                <span class="text-muted truncate"><%= sch.location %></span>
              <% } %>
            </div>

            <!-- Panel Members -->
            <% if (panelList.length > 0) { %>
              <div class="flex items-start gap-sm text-sm">
                <i data-lucide="users" style="width:16px;height:16px;color:var(--text-muted);flex-shrink:0;margin-top:2px"></i>
                <div class="flex flex-wrap gap-sm">
                  <% panelList.forEach(function(member) { %>
                    <span class="badge badge-muted">
                      <%= typeof member === 'string' ? member : (member.name || member) %>
                    </span>
                  <% }); %>
                </div>
              </div>
            <% } %>
          </div>

          <!-- Card Actions -->
          <div class="flex items-center gap-sm border-t" style="padding-top:12px">
            <a href="/schedules/<%= sch.id %>" class="btn btn-outline btn-sm flex-1 justify-center">
              <i data-lucide="eye" style="width:16px;height:16px"></i>
              View
            </a>
            <% if (schStatus === 'scheduled') { %>
              <a href="/schedules/<%= sch.id %>/edit" class="btn btn-outline btn-sm flex-1 justify-center">
                <i data-lucide="calendar-clock" style="width:16px;height:16px"></i>
                Reschedule
              </a>
              <form action="/schedules/<%= sch.id %>/complete" method="POST" class="flex-1">
                <button type="submit" class="btn btn-primary btn-sm w-full justify-center">
                  <i data-lucide="check" style="width:16px;height:16px"></i>
                  Complete
                </button>
              </form>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
  </template>

  <% } else { %>
    <!-- Empty State -->
    <div class="card w-full">
      <div class="empty-state" style="padding:80px 24px">
        <i data-lucide="calendar"></i>
        <h3 class="text-lg font-semibold mb-sm">No Interview Schedules</h3>
        <p class="text-sm text-muted mb-lg" style="max-width:24rem;margin-left:auto;margin-right:auto">
          No interview schedules found. Schedules will appear here once interviews are scheduled.
        </p>
        <a href="/schedules/create" class="btn btn-primary">
          <i data-lucide="calendar-plus" style="width:16px;height:16px"></i>
          Schedule Interview
        </a>
      </div>
    </div>
  <% } %>
</div>
