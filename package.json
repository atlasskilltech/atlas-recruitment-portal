{
  "name": "atlas-hr-recruitment",
  "version": "1.0.0",
  "description": "Atlas University HR Recruitment Portal - AI-Powered ATS & Screening System",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "css:build": "npx tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --minify",
    "css:watch": "npx tailwindcss -i ./src/public/css/input.css -o ./src/public/css/output.css --watch",
    "db:migrate": "node database/migrations/run.js",
    "db:seed": "node database/seeds/run.js",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "csurf": "^1.11.0",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.1.4",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.13.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
